    <!-- Add Activity -->
<activity>
        <title>The Line-Up Challenge</title>
        <statement>
            <p>
                Suppose you have 4 different colored books (Red, Blue, Green, Yellow) to arrange on a shelf.
                <ol>
                    <li>How many choices do you have for the first position?</li>
                    <li>Once the first book is placed, how many choices remain for the second position?</li>
                    <li>Continue this logic until all books are placed. Multiply the number of choices together. What is the result?</li>
                    <li>How would this change if you had 5 books? 6 books?</li>
                </ol>
            </p>
        </statement>
    </activity>
