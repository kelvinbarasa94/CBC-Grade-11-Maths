    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

   <exercises>
        <exercise>
            <statement>
                <p>Calculate the value of <m>6! - 5!</m>.</p>
            </statement>
            <solution>
                <p>
                    Evaluate each factorial first:
                    <m>6! = 720</m>
                    <m>5! = 120</m>
                    Subtract the values: <m>720 - 120 = 600</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>Simplify the expression <me>\frac{100!}{98!}</me> without using a calculator.</p>
            </statement>
            <solution>
                <p>
                    Expand the numerator until it matches the denominator:
                    <me>\frac{100 \times 99 \times 98!}{98!}</me>
                    Cancel <m>98!</m>:
                    <me>100 \times 99 = 9,900</me>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>Express the following product in factorial notation: <me>20 \times 19 \times 18 \times 17</me></p>
            </statement>
            <solution>
                <p>
                    This is a partial product of <m>20!</m>. To remove the unwanted part (<m>16 \times 15 \times \dots \times 1</m>), we divide by <m>16!</m>:
                    <me>\frac{20!}{16!}</me>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>Solve for <m>n</m> if <m>\frac{n!}{(n-1)!} = 12</m>.</p>
            </statement>
            <solution>
                <p>
                    Expand <m>n!</m> as <m>n \times (n-1)!</m>:
                    <me>\frac{n \times (n-1)!}{(n-1)!} = 12</me>
                    After canceling <m>(n-1)!</m>, we are left with:
                    <me>n = 12</me>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>True or False: <m>3! + 2! = 5!</m>. Justify your answer.</p>
            </statement>
            <solution>
                <p>
                    <strong>False.</strong> 
                    Calculate each side:
                    Left side: <m>3! + 2! = 6 + 2 = 8</m>.
                    Right side: <m>5! = 120</m>.
                    Since <m>8 \neq 120</m>, the statement is false. Factorials cannot be added like regular integers.
                </p>
            </solution>
        </exercise>
    </exercises>

