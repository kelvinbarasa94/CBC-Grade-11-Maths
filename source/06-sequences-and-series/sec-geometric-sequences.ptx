    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <p>
            A geometric sequence is a sequence in which each term is obtained by multiplying the previous term by a constant value called the common ratio.
        </p>
        <p>
            In repeated splitting patterns, the number of parts grows multiplicatively. This leads to sequences such as:
        </p>
        <p>
            <m>1, 4, 16, 64, \dots</m>
        </p>
        <p>
            If the first term is <m>a</m> and the common ratio is <m>r</m>, then the <m>n^{th}</m> term is given by:
        </p>
        <p>
            <m>n^{th} = ar^{n-1}</m>
        </p>
        <p>
            This formula allows us to determine any term in the sequence without listing all previous terms.
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->
    <example>
        <statement>
            <p>
                Given the geometric sequence <m>4,12,36,...</m>, find the <m>4^{th}, 5^{th},</m> and <m>n^{th} </m> terms.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{The first term,}\; a =  \amp \; 4 </mrow>
                    <mrow> \text {The common ratio,}\; r \amp = \; 3 </mrow>
                    <mrow> \therefore \;\text{the}\; 4^{th}\; \text{term}\; \amp = \; 4\times 3^{4-1} </mrow>
                    <mrow> \amp = \; 4 \times 3^3 </mrow>
                    <mrow> \amp = \; 108 </mrow>
                    <mrow> \text{The}\; 5^{th} \; \text{term}\; \amp = \; 4 \times 3^{5-1} </mrow>
                    <mrow> \amp = \; 4 \times 3^4 </mrow>
                    <mrow> \amp = \; 324 </mrow>
                    <mrow> \text{The}\; n^{th} \; \text{term}\; \amp = \; 4 \times 3^{n-1} </mrow>
                </md>
                
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                The <m>4^{th}</m> term of a geometric sequence is <m>16</m>. If the first term is <m>2</m>, find:
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The common ratio.
                        </p>
                    </li>
                    <li>
                        <p>
                            The seventh term.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <ol marker="(a)">
                    <li>
                    <p>
                        The common ratio <m>r</m>.
                    </p>
                        <p>
                            <md>
                                <mrow> \text{The first term,} \; a \amp = \; 2 </mrow>
                                <mrow> \text{The}4^{th}\; \text{ term is}\; 2\times r^{4-1} \amp = \; 16 </mrow>
                                <mrow>\text{Thus,} \; 2r^3 \amp = \; 16 </mrow>
                                <mrow> r^3 \amp = \; 8 </mrow>
                                <mrow> \therefore \;\text{\the common ratio} \; \amp = \; 2 </mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                    <p>
                        The <m>7^{th}</m> term.
                    </p>
                        <p>
                            <md>
                                <mrow>\text{The}\; 7^{th}\; \text{term} \; \amp = \; 2 \times 2^6 </mrow>
                                <mrow> \amp = \; 128 </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                The fourth term of a geometric sequence is <m>8</m> and the sixth term is <m>32</m>. Find the two possible common ratios.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow>\text{The}\; 4^{th} \;\text{term is} \; ar^3 \amp = \; 8 </mrow>
                    <mrow>\text{The}\; 6^{th} \;\text{term is} \; ar^5 \amp = \; 32 </mrow>
                    <mrow>\therefore \frac{ar^5}{ar^3} \amp = \; \frac{32}{8} </mrow>
                    <mrow> r^2 \amp = \; 4</mrow>
                    <mrow> r \amp = \; \pm 2 </mrow>
                </md>
            </p>
            <p>
                The possible common ratios are <m>r = 2</m> and <m>r = -2</m>.
            </p>
        </solution>
    </example>

