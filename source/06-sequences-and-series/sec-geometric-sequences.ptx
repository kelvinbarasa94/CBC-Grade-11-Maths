    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
    <exercises>
        <exercise>
            <statement>
                <p>
                    The ratio of the <m>10^{th}</m> to the <m>8^{th}</m> terms of a geometric sequence is <m>9</m>. Find the two possible common ratios.
                </p>
            </statement>
            <answer>
                <p>
                    <m>\pm3</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The third term of a geometric sequence is <m>1</m>. If the sixth term of the same sequence is <m>\frac{1}{27}</m>, write down the first four terms of the sequence.
                </p>
            </statement>
            <answer>
                <p>
                    <m>9,3,1,\frac{1}{3}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The ratio of the forth to the first term of a geometric sequence is <m>\frac{1}{8}</m>. If the first term exceeds the second term by <m>5</m>, find the first and the <m>8^{th}</m> terms of the sequence.
                </p>
            </statement>
            <answer>
                <p>
                    <m>10, \frac{5}{64}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The first, third, and fifth terms of a geometric sequence form arithmetic sequence. If the first term of the sequence is <m>3</m>, find the tenth term of the geometric sequence.
                </p>
            </statement>
            <answer>
                <p>
                    <m>\pm3</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The first term of a geometric sequence is <m>x+1</m>. if the third term of the same sequence is <m>(x+1)(x^2 - 2x +1)</m>, show that the second term is <m>x^2 -1</m>.
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow> \frac{\text{Third term}}{\text{first term}}  =\amp \; \frac{(x+1)(x^2-2x+1)}{x+1} </mrow>
                        <mrow>\frac{ar^2}{a} \amp = \; \frac{(x+1)(x^2-2x+1)}{x+1} </mrow>
                        <mrow> r^2 \amp = \; x^2-2x+1 </mrow>
                        <mrow> r \amp = \; x-1 </mrow>
                        <mrow> \text{The second term} \; \amp = \; ar </mrow>
                        <mrow>2^{nd} \;\text{term}\; \amp = \; (x+1)(x-1) </mrow>
                        <mrow>2^{nd} \;\text{term}\; \amp = \; (x^2-1) </mrow>
                    </md>
                    
                </p>
                <p>
                    The second term of the geometric sequence is <m>x^2 - 1</m>.
                </p>
            </answer>
        </exercise>
    </exercises>

