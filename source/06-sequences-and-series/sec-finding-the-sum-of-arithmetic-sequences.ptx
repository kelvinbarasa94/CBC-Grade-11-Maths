    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    The sum of the <m>10</m> terms of an arithmatic series is <m>400</m>. If the sum of the first <m>6</m> terms of the same series is <m>120</m>, find the <m>15^{th} </m> term.
                </p>
            </statement>
            <answer>
                <p>
                    <m>975</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The sum of the first <m>20</m> terms of an arithmatic series is <m>7\frac{1}{2} </m>. If the third term of the series is <m>2</m>, find the sum of the first <m>13</m> terms.
                </p>
            </statement>
            <answer>
                <p>
                    <m>2.869</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    An arithmatic series has a common difference as <m>-\frac{1}{4} </m> and the first term as <m>3</m>. Find the number of terms of the series which would give a sum of zero.
                </p>
            </statement>
            <answer>
                <p>
                    <m>25</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Two arithmatic series are such that their common differences are <m>9</m> and <m>3</m> respectively. If their first terms are <m>2</m> and <m>5</m> respectively, find the number of terms of each series that would give a common sum.
                </p>
            </statement>
            <answer>
                <p>
                    <m>2</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A man buys premium bond every year. In the first year, he buys sh. <m>2,000</m> worth of bonds. If every year he increases his annual investment in bonds by sh. <m>600</m>, how long will he take for his total investment in bonds to be sh. <m>37,000</m>.
                </p>
            </statement>
            <answer>
                <p>
                    <m>16.28</m>
                </p>
            </answer>
        </exercise>
     </exercises>

