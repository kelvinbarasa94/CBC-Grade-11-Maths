    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    The fourth term of a geometric sequence is <m>192</m>. If the first term of the sequence is <m>3</m>, find:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                The common ratio#.
                            </p>
                        </li>
                        <li>
                            <p>
                                The number of terms that will give a sum of <m>255</m>.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m> r = 4</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> n = 4</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A geometric series has the first term as <m>2</m>. Find the two common ratios if the sum of the first three terms is <m>26</m>.
                </p>
            </statement>
            <answer>
                <p>
                    <m> r = 3 \; \text{or} \; -4 </m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    In a geometric progression, the sum of the <m>2^{nd} </m> and <m>3^{rd} </m> terms is <m>4</m> and the sum of <m>3^{rd} </m> and <m>4^{th} </m> terms is <m>2</m>. Find the first term and the common ratio.
                </p>
            </statement>
            <answer>
                <p>
                    <m> a = -16, r = -\frac{1}{2} </m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The <m>2^{nd}, 4^{th}, ;\text{and}\; 7^{th} </m> terms of an arithmetic progression are the first three consecutive terms of a geometric progression. Find:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                The common ratio.
                            </p>
                        </li>
                        <li>
                            <p>
                                The sum of the first eight terms of the geometric progression. If the common difference of the arithmetic progression is <m>2</m>.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m> r = 1\frac{1}{2} </m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>S_8 = 394.06</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The sum of the first three terms of a geometric sequence is <m>14</m>. If the common ratio is <m>-3</m>, find the sum of the first five terms. 
                </p>
            </statement>
            <answer>
                <p>
                    <m> 122</m>
                </p>
            </answer>
        </exercise>
     </exercises>

