    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <p>
            Any sequence of numbers which have a common difference is called an <term>arithmetic sequence</term>. In an arithmetic sequence, the first term is <m>a</m> and the common difference is <m>d</m>.
        </p>
        <p>
            Can you explore how to find the second, third, forth, ... terms given the first term?
        </p>
        <p>
            <term>Notice that:</term> The general form of an arithmetic sequence is <m>a, a+d, a+2d, a+3d ...</m>. 
        </p>
        <p>
            In the general form, 
        </p>
        <p>
            <md>
                <mrow> 1^{st} term \amp =\; a </mrow>
                <mrow>2^{nd} term \amp =\; a+d </mrow>
                <mrow>3^{rd} term \amp =\; a+2d </mrow>
                <mrow>4^{th} term \amp =\; a+3d </mrow>
            </md>
        </p>
        <p>
            What is the <m>10^{th}</m> term?
        </p>
        <p>
            How do we find the <m>n^{th}</m> term of an arithmetic sequence?
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->
     <example>
        <statement>
            <p>
                Given the arithmetic sequence <m>4,11,18, ... find:</m>
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The common difference.
                        </p>
                    </li>
                    <li>
                        <p>
                            The <m>6^{th}</m> term.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                           The common difference 
                        </p>
                        <p>
                            <md>
                                <mrow> d \amp =\; 11-4 = 18-11 </mrow>
                                <mrow> \amp =\; 7 </mrow>
                            </md>
                            
                        </p>
                    </li>
                    <li>
                        <p>
                            The <m>n^{th} \;\text{term}\; = a + (n-1)d </m>
                        </p>
                        <p>
                            <md>
                                <mrow> 6^{th} \;\text{term}\; \amp =\; 4+(6-1)7 </mrow>
                                <mrow> \amp =\; 39 </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                The <m>20^{th}</m> term of an arithmetic sequence is <m>60</m> and <m>16^{th}</m> term is <m>20</m>. Find the first term and the common difference.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{The} \; 20^{th}\;\text{term}\; \amp =\; a+(20-1)d =\amp\; 60 </mrow>
                    <mrow>\therefore a+19d \amp =\; 60 ......(i) </mrow>
                    <mrow> \text{The} \; 16^{th}\;\text{term}\; \amp =\; a+(16-1)d =\amp\; 20 </mrow>
                    <mrow>\therefore a+15d \amp =\; 20 ......(ii) </mrow>
                </md>
                
            </p>
            <p>
                <m>(i) - (ii) </m> gives;
            </p>
            <p>
                <md>
                    <mrow> 4d \amp =\; 40 </mrow>
                    <mrow> \amp =\; 10 </mrow>
                </md>
                
            </p>
            <p>
                <md>
                    <mrow> \text{But}\; a+15d \amp =\; 20 </mrow>
                    <mrow>\therefore a+15\times10 \amp =\; 20 </mrow>
                    <mrow> a + 150 \amp =\; 20 </mrow>
                    <mrow> a =\amp\; -130 </mrow>
                </md>
                
            </p>
            <p>
                Hence, the first term is <m>-130</m> and the common difference is <m>10</m>.
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                Find the number of terms in the sequence <m>-3,0,3,...,54</m>
            </p>
        </statement>
        <solution>
            <p>
                The <m>n^{th}</m> term is <m>a+(n-1)d </m>
            </p>
            <p>
                <md>
                    <mrow> a \amp =\; -3, d = 3 </mrow>
                    <mrow> n^{th} \;\text{term}\; \amp =\; 54 </mrow>
                    <mrow>\therefore -3+(n-1)3 \amp =\; 54 </mrow>
                    <mrow> 3(n-1)\amp =\; 57 </mrow>
                    <mrow> n-1 \amp =\; 19 </mrow>
                    <mrow> n \amp =\; 20 </mrow>
                </md>
                
            </p>
        </solution>
     </example>

