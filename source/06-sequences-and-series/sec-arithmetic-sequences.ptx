    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    The second term of an arithmetic sequence is <m>7</m> and the ninth term is <m>28</m>. Find the common difference and the first term of the sequence.
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow> a \amp =\; 4 </mrow>
                        <mrow> d \amp =\; 3 </mrow>
                    </md>
                    
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The <m>10^{th}</m> term of an arithmetic sequence is <m>42</m> more than the <m>7^{th}</m> term. If the first term is <m>-14</m>, find the second term of the sequance.
                </p>
            </statement>
            <answer>
                <p>
                    <m>2^{nd} term = 0</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    In an arithmetic sequemce, the <m>15^{th}</m> term is <m>52</m>, and the common difference is <m>3</m>.Find:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                The first term.
                            </p>
                        </li>
                        <li>
                            <p>
                                The <m>20^{th}</m> term.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>1^{st} term = a = 10 </m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>20^{th} term = 67 </m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The product of the third and fourth terms of an arithmetic sequence is <m>3,000</m>. Find the first term if the common difference is <m>10</m>.
                </p>
            </statement>
            <answer>
                <p>
                    <m>1^{st} term = -80 \;\text{or}\; 30 </m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The first term of an arithmetic sequence is <m>4</m> and the last term is <m>64</m>. If the common difference is <m>5</m>, find the number of terms. 
                </p>
            </statement>
            <answer>
                <p>
                    <m>n = 13</m>
                </p>
            </answer>
        </exercise>
     </exercises>
