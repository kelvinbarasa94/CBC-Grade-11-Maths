<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-graphing-inequalities-in-one-unknown" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Graphing Inequalities in One Unknown</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.3 Linear Inequalities
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Represent linear inequalities in two unknowns graphically
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        <m>15</m> minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To help learners transition from one-dimensional number lines to a two-dimensional Cartesian plane, discovering how to represent constraints like <m>x \le k</m> or <m>y \gt k</m> as vertical or horizontal region blocks.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Guide learners to see that an inequality missing a variable still exists on a coordinate grid, reinforce the distinction between vertical and horizontal boundary orientations, and assist them in shading the infinite region paths cleanly.
                    </p>
                </li>
            </dl>
        </axiom>

    <!-- [LP] Add guidance on structured lesson plan-->

