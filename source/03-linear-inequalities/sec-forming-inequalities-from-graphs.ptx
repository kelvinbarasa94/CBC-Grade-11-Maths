<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-forming-inequalities-from-graphs" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Forming Inequalities From Graphs</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.3 Linear Inequalities
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Form simple linear inequalities from inequality graphs
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        <m>15</m> minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To engage learners in the reverse process of graphing inequalities—moving from a visual representation to the algebraic inequality expression.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Guide learners to identify the boundary line, determine whether the line is included or excluded, and interpret which side of the line represents the solution set.
                    </p>
                </li>
            </dl>
        </axiom>

    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                <term>Work in groups:</term> Form groups of <m>3</m> or <m>4</m> learners.
            </p>
            <p>
                <term>Materials needed:</term>
            </p>
            <p>
                <ul>
                    <li>
                        <p>
                            Pre-drawn graphs showing shaded inequalities (provided by the teacher or students' sketch).
                        </p>
                    </li>
                    <li>
                        <p>
                            A notebook and a pen or pencil.
                        </p>
                    </li>
                </ul>
            </p>
            <p>
                <term>Instructions:</term>
            </p>
            <p>
                In your groups:
                <ol>
                    <li>
                        <p>
                            Examine the first graph showing a shaded region on a coordinate plane.
                        </p>
                    </li>
                    <li>
                        <p>
                            Identify the <term>boundary line</term>. Find its equation by identifying its intercepts or calculating its slope and y-intercept.
                        </p>
                    </li>
                    <li>
                        <p>
                            Look at the boundary line structure. Is it solid (included, using <m>\le</m> or <m>\ge</m>) or dashed (excluded, using <m>\lt</m> or <m>\gt</m>)?
                        </p>
                    </li>
                    <li>
                        <p>
                            Determine whether the shaded region lies <term>above</term> or <term>below</term> the boundary line.
                        </p>
                    </li>
                    <li>
                        <p>
                            Pick a test point inside the shaded zone (such as <m>(0,0)</m> if eligible) and verify your proposed inequality.
                        </p>
                    </li>
                    <li>
                        <p>
                            Write out the final inequality in standard form and share your findings with the class.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <hint>
            <p>
                Remember:
            </p>
            <p>
                A <term>solid boundary line</term> means the line is part of the solution set, so use <m>\le</m> or <m>\ge</m>. A <term>dashed boundary line</term> means the line is not part of the solution set, so use <m>\lt</m> or <m>\gt</m>.
            </p>
            <p>
                If the shaded region is <term>above</term> a non-vertical line with positive slope, think about the <m>y</m>-values in that region being larger. If the shaded region is <term>below</term> the line, think about the <m>y</m>-values being smaller.
            </p>
            <p>
                Always test a point from the shaded region to verify your inequality is correct.
            </p>
        </hint>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

