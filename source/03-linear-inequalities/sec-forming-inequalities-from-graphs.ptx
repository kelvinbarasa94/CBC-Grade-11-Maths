    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Determine the algebraic inequality represented by the shaded region bounded by the solid boundary line below:
                </p>
                <p>
                    <image>
                        <latex-image>
                            \begin{tikzpicture}
                                \draw[gray!20, thin] (-1,-1) grid (6,6);
                                \fill[fill=blue!15, opacity=0.6] (0,0) -- (5,0) -- (0,5) -- cycle;
                                \draw[black, thick, &lt;-&gt;] (-1,0) -- (6,0) node[right=4pt] {$x$};
                                \draw[black, thick, &lt;-&gt;] (0,-1) -- (0,6) node[above=4pt] {$y$};
                                \draw[solid, thick, black] (-1,6) -- (6,-1);
                                \fill[black] (0,5) circle (2.5pt);
                                \fill[black] (5,0) circle (2.5pt);
                                \node at (-0.3,-0.3) [font=\small] {0};
                                \foreach \x in {1, 2, 3, 4, 5} {
                                    \draw (\x, 0.1) -- (\x, -0.1) node[below=3pt, font=\small] {$\x$};
                                }
                                \foreach \y in {1, 2, 3, 4, 5} {
                                    \draw (0.1, \y) -- (-0.1, \y) node[left=3pt, font=\small] {$\y$};
                                }
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </p>
            </statement>
            <solution>
                <p>
                    The boundary line passes through intercepts <m>(0,5)</m> and <m>(5,0)</m>. Finding the slope:
                    <md>
                        <mrow>m = \frac{0 - 5}{5 - 0} = -1</mrow>
                    </md>
                </p>
                <p>
                    This gives a line equation of <m>y = -x + 5</m>, or <m>x + y = 5</m>. 
                </p>
                <p>
                    Since the boundary is solid and the shaded region falls below it within the positive first quadrant, the resulting inequality is:
                </p>
                <p>
                    <md>
                        <mrow>x + y \le 5, \amp x \ge 0, \amp y \ge 0</mrow>
                    </md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Identify the linear inequality shown in the graph below
                </p>
                <p>
                    <image>
                        <latex-image>
                            \begin{tikzpicture}
                                % 1. GRID: Expanded x-bounds to 7 so the x-intercept at 6 sits cleanly inside
                                \draw[gray!20, thin] (-3,-2) grid (7,5);
                                
                                % 2. Safe purple shaded region tracking up to the new grid limit
                                \fill[fill=purple!15, opacity=0.6] (-3,4.5) -- (7,-0.5) -- (7,5) -- (-3,5) -- cycle;
                                
                                % 3. Extended axes past the grid margins to prevent arrowhead clipping
                                \draw[black, thick, &lt;-&gt;] (-3,0) -- (7,0) node[right=4pt] {$x$};
                                \draw[black, thick, &lt;-&gt;] (0,-2) -- (0,5) node[above=4pt] {$y$};
                                
                                % 4. Dashed boundary line matching the slope perfectly
                                \draw[dashed, thick, black] (-3,4.5) -- (7,-0.5);
                                
                                % 5. Intercept point markers
                                \fill[black] (0,3) circle (2.5pt);
                                \fill[black] (6,0) circle (2.5pt);
                                
                                % 6. IMPROVEMENT: White-backed labels clear of grid lines
                                \node at (0,3) [above right=2pt, font=\small, fill=white, inner sep=1pt] {$(0,3)$};
                                \node at (6,0) [above right=4pt, font=\small, fill=white, inner sep=1pt] {$(6,0)$};
                                
                                % 7. Ticks and grid numbering
                                \foreach \x in {-2, -1, 1, 2, 3, 4, 5, 6} {
                                    \draw (\x, 0.1) -- (\x, -0.1) node[below=3pt, font=\small] {$\x$};
                                }
                                \foreach \y in {-1, 1, 2, 3, 4} {
                                    \draw (0.1, \y) -- (-0.1, \y) node[left=3pt, font=\small] {$\y$};
                                }
                                \node at (-0.4,-0.4) [font=\small] {0};
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </p>
            </statement>
            <solution>
                <p>
                    The line crosses the vertical axis at <m>(0,3)</m> and the horizontal axis at <m>(6,0)</m>. 
                </p>
                <p>
                    Calculating the slope (<m>m</m>) of the boundary line:
                </p>
                <p>
                    <md>
                        <mrow>m = \frac{0 - 3}{6 - 0} = -\frac{1}{2}</mrow>
                    </md>
                </p>
                <p>
                    Using the y-intercept <m>b = 3</m>, the boundary equation is <m>y = -\frac{1}{2}x + 3</m>.
                </p>
                <p>
                    Because the boundary line is <em>dashed</em> and the shaded region extends <em>above</em> it, we use the strict greater-than inequality symbol (<m>\gt</m>):
                </p>
                <p>
                    <md>
                        <mrow>y \gt -\frac{1}{2}x + 3</mrow>
                    </md>
                </p>
                <p>
                    Multiplying all terms by <m>2</m> gives <m>2y \gt -x + 6</m>. Rearranging terms to standard form yields the final linear expression: <m>x + 2y \gt 6</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    <em>Mtawala</em> cooperative farming group in Eldoret charts out their resource limitation boundary line for purchasing fertilizer bags (<m>x</m>) and organic manure trucks (<m>y</m>). The boundary line and shaded permissible funding layout are displayed below. Formulate the explicit cost constraint inequality representing their budget restriction.
                </p>
                <p>
                    <image>
                        <latex-image>
                            \begin{tikzpicture}[scale=0.6]
                                \draw[gray!20, thin, step=2] (-2,-2) grid (12,12);
                                \fill[fill=green!15, opacity=0.6] (0,0) -- (10,0) -- (0,5) -- cycle;
                                \draw[black, thick, -&gt;] (-1,0) -- (13,0) node[right=4pt] {$x$ (Fertilizer)};
                                \draw[black, thick, -&gt;] (0,-1) -- (0,13) node[above=4pt] {$y$ (Manure)};
                                \draw[solid, thick, black] (-2,6) -- (12,-1);
                                \fill[black] (0,5) circle (3pt) node[above right, font=\small, fill=white] {$(0,5)$};
                                \fill[black] (10,0) circle (3pt) node[above right, font=\small, fill=white] {$(10,0)$};
                                \node at (-0.4,-0.4) [font=\small] {0};
                                \foreach \x in {2, 4, 6, 8, 10, 12} {
                                    \draw (\x, 0.1) -- (\x, -0.1) node[below=3pt, font=\small] {$\x$};
                                }
                                \foreach \y in {2, 4, 6, 8, 10, 12} {
                                    \draw (0.1, \y) -- (-0.1, \y) node[left=3pt, font=\small] {$\y$};
                                }
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </p>
            </statement>
            <solution>
                <p>
                    The boundary equation has a y-intercept at <m>(0,5)</m> and an x-intercept at <m>(10,0)</m>. 
                </p>
                <p>
                    The geometric slope is:
                </p>
                <p>
                    <md>
                        <mrow>m = \frac{0 - 5}{10 - 0} = -\frac{1}{2}</mrow>
                    </md>
                </p>
                <p>
                    This sets the boundary line formula to <m>y = -\frac{1}{2}x + 5</m>.
                </p>
                <p>
                    The solid line combined with shading below it inside the non-negative quadrant fields creates the final constraint configuration:
                </p>
                <p>
                    <md>
                        <mrow>x + 2y \le 10, \amp x \ge 0, \amp y \ge 0</mrow>
                    </md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A computer laboratory space at <em>Mtwapa Technical school</em> in Mombasa restricts its layout based on two simple physical boundaries shown below:
                </p>
                <p>
                    <image>
                        <latex-image>
                            \begin{tikzpicture}
                                % 1. Balanced background grid
                                \draw[gray!20, thin] (-1,-1) grid (6,6);
                                
                                % 2. Shaded region bounded by horizontal and vertical limits
                                \fill[fill=blue!15, opacity=0.6] (3,2) -- (6,2) -- (6,6) -- (3,6) -- cycle;
                                
                                % 3. Clean single-direction axes past grid edges
                                \draw[black, thick, -&gt;] (-1,0) -- (6,0) node[right=4pt] {$x$};
                                \draw[black, thick, -&gt;] (0,-1) -- (0,6) node[above=4pt] {$y$};
                                
                                % 4. Boundary lines: x=3 (dashed) and y=2 (solid)
                                \draw[dashed, thick, black] (3,-1) -- (3,6);
                                \draw[solid, thick, black] (-1,2) -- (6,2);
                                
                                % 5. Identification text elements with white background padding
                                \node at (3,4.5) [right=4pt, font=\small, fill=white, inner sep=1pt] {$x = 3$};
                                \node at (1.5,2) [above=4pt, font=\small, fill=white, inner sep=1pt] {$y = 2$};
                                
                                % 6. Grid Ticks and numbering
                                \foreach \x in {1, 2, 3, 4, 5} {
                                    \draw (\x, 0.1) -- (\x, -0.1) node[below=3pt, font=\small] {$\x$};
                                }
                                \foreach \y in {1, 2, 3, 4, 5} {
                                    \draw (0.1, \y) -- (-0.1, \y) node[left=3pt, font=\small] {$\y$};
                                }
                                \node at (-0.3,-0.3) [font=\small] {0};
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </p>
                <p>
                    Write the linear inequalities that perfectly models the shaded permissible zone for computer placement in this lab space.
                </p>
            </statement>
            <solution>
                <p>
                    By analyzing the geometric boundaries independently:
                    <ol>
                        <li>
                            <p>
                                The vertical boundary is a <term>dashed line</term> passing through <m>x = 3</m>. The shading lies to the right side of this boundary line, indicating values strictly greater than 3:
                                <md>
                                    <mrow>x \gt 3</mrow>
                                </md>
                            </p>
                        </li>
                        <li>
                            <p>
                                The horizontal boundary is a <term>solid line</term> passing through <m>y = 2</m>. The shaded area lies above this boundary line, indicating values greater than or equal to 2:
                                <md>
                                    <mrow>y \ge 2</mrow>
                                </md>
                            </p>
                        </li>
                    </ol>
                </p>
                <p>
                    Therefore, the combined system of linear inequalities defining the region is:
                    <md>
                        <mrow>x \gt 3, \amp\quad y \ge 2</mrow>
                    </md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Examine the graph below, then formulate correct algebraic inequality represented by the shaded region.
                </p>
                <p>
                    <image>
                        <latex-image>
                            \begin{tikzpicture}
                                % 1. Balanced background grid
                                \draw[gray!20, thin] (-1,-1) grid (5,6);
                                
                                % 2. Shaded area below/right of the positive sloped boundary
                                \fill[fill=purple!15, opacity=0.6] (0,0) -- (2,4) -- (3,6) -- (5,6) -- (5,0) -- cycle;
                                
                                % 3. Standard clean axes layout
                                \draw[black, thick, -&gt;] (-1,0) -- (5,0) node[right=4pt] {$x$};
                                \draw[black, thick, -&gt;] (0,-1) -- (0,6) node[above=4pt] {$y$};
                                
                                % 4. Solid boundary line with positive slope
                                \draw[solid, thick, black] (-0.5,-1) -- (3,6);
                                
                                % 5. Clear reference point coordinates with white backing
                                \fill[black] (0,0) circle (2.5pt);
                                \fill[black] (2,4) circle (2.5pt);
                                
                                % 6. Axis numbering loops
                                \foreach \x in {1, 2, 3, 4} {
                                    \draw (\x, 0.1) -- (\x, -0.1) node[below=3pt, font=\small] {$\x$};
                                }
                                \foreach \y in {1, 2, 3, 4, 5} {
                                    \draw (0.1, \y) -- (-0.1, \y) node[left=3pt, font=\small] {$\y$};
                                }
                                \node at (-0.3,-0.3) [font=\small] {0};
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </p>
            </statement>
            <solution>
                <p>
                    <ol>
                        <li>
                            <p>
                                Since the boundary line passes through <m>(0,0)</m>, its y-intercept is <m>b = 0</m>. Using the second clear point <m>(2,4)</m>, we calculate the slope:
                                <md>
                                    <mrow>m = \frac{4 - 0}{2 - 0} = 2</mrow>
                                </md>
                                This yields the boundary line equation <m>y = 2x</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                The boundary line is <term>solid</term>, meaning the constraint will involve either <m>\le</m> or <m>\ge</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                The shaded region lies below the line on the right side. Choosing a clear test point inside the shaded region, such as <m>(3,1)</m>:
                                <md>
                                    <mrow>1 \le 2(3) \implies 1 \le 6 \quad \text{(True)}</mrow>
                                </md>
                            </p>
                        </li>
                    </ol>
                </p>
                <p>
                    Hence, the inequality is <m>y \le 2x</m>, which can be expressed in standard form as:
                    <md>
                        <mrow>2x - y \ge 0</mrow>
                    </md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A poultry farmer in Lokichar designs a local coordinate model to balance feed storage spaces. The horizontal axis (<m>x</m>) represents bags of grower mash, and the vertical axis (<m>y</m>) represents bags of layers chick mash. 
                </p>
                <p>
                    Determine the linear inequality that governs this critical farm feed capacity limit from the graph below:
                </p>
                <p>
                    <image>
                        <latex-image>
                            \begin{tikzpicture}
                                % 1. Grid
                                \draw[gray!20, thin] (-1,-1) grid (7,5);
                                
                                % 2. Shaded area below the dashed capacity line
                                \fill[fill=green!15, opacity=0.6] (0,0) -- (6,0) -- (0,4) -- cycle;
                                
                                % 3. Production axes limits
                                \draw[black, thick, -&gt;] (-1,0) -- (7.5,0) node[right=4pt] {$x$ (Grower Mash)};
                                \draw[black, thick, -&gt;] (0,-1) -- (0,5.5) node[above=4pt] {$y$ (Layers Mash)};
                                
                                % 4. Dashed boundary line showing strict structural limit
                                \draw[dashed, thick, black] (-0.75,4.5) -- (6.75,-0.5);
                                
                                % 5. Clear intercept markers
                                \fill[black] (0,4) circle (2.5pt);
                                \fill[black] (6,0) circle (2.5pt);
                                \node at (0,4) [above right=2pt, font=\small, fill=white, inner sep=1pt] {$(0,4)$};
                                \node at (6,0) [above right=4pt, font=\small, fill=white, inner sep=1pt] {$(6,0)$};
                                
                                % 6. Number line loops
                                \foreach \x in {1, 2, 3, 4, 5, 6, 7} {
                                    \draw (\x, 0.1) -- (\x, -0.1) node[below=3pt, font=\small] {$\x$};
                                }
                                \foreach \y in {1, 2, 3, 4, 5} {
                                    \draw (0.1, \y) -- (-0.1, \y) node[left=3pt, font=\small] {$\y$};
                                }
                                \node at (-0.3,-0.3) [font=\small] {0};
                                
                                % 7. Non-negativity constraint indicators
                                \node at (3.5, 0) [below=12pt, font=\small] {$y = 0$};
                                \node at (0, 2.2) [left=12pt, font=\small] {$x = 0$};
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </p>
            </statement>
            <solution>
                <p>
                    <ol>
                        <li>
                            <p>
                                Identify the boundary intercepts from the storage layout: <m>(0,4)</m> and <m>(6,0)</m>. Calculating the slope:
                                <md>
                                    <mrow>m = \frac{0 - 4}{6 - 0} = -\frac{4}{6} = -\frac{2}{3}</mrow>
                                </md>
                                With a y-intercept of <m>b = 4</m>, the line equation is <m>y = -\frac{2}{3}x + 4</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                The line is <term>dashed</term>, indicating a strict capacity barrier (<m>\lt</m> or <m>\gt</m>).
                            </p>
                        </li>
                        <li>
                            <p>
                                Since the shaded zone represents affordable storage combinations beneath the feed limit line, we choose <m>\lt</m>:
                                <md>
                                    <mrow>y \lt -\frac{2}{3}x + 4</mrow>
                                </md>
                            </p>
                        </li>
                    </ol>
                </p>
                <p>
                    Multiplying all terms by 3 gives <m>3y \lt -2x + 12</m>. Rearranging to standard form gives the final agribusiness resource constraint model:
                    <md>
                        <mrow>2x + 3y \lt 12, \quad \text{where } x \ge 0 \text{ and } y \ge 0</mrow>
                    </md>
                </p>
            </solution>
        </exercise>
    </exercises>

