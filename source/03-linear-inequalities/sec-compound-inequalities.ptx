    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Solve the compound inequality <m>3x - 2 \le 10 \text{ OR } x + 4 \gt 15</m>.
                </p>
            </statement>
            <answer>
                <p>
                    <m>x \le 4 \text{ OR } x \gt 11</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The speed limit on a section of the <em>Thika Superhighway</em> states that a driver's speed, <m>S</m>, must be a minimum of <m>50</m> km/h and a maximum of <m>80</m> km/h. Write a single inequality to represent the legal driving speeds for this section of the highway.
                </p>
            </statement>
            <answer>
                <p>
                    <m>50 \le S \le 80</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Solve, <m>2x - 5 \lt 3x + 1 \le 2x + 7</m>. Show all your steps.
                </p>
            </statement>
            <answer>
                <p>
                    <m>-6 \lt x \le 8</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    In an end-of-term mathematics exam, a learner must score at least <m>40\%</m> to pass. To be awarded a grade 'A', a learner must score <m>90 \%</m> or above. If Nanjala's score is represented by <m>N</m>, write a compound inequality to represent the range of possible scores if he passed the exam but did not manage to get a grade 'A'.
                </p>
            </statement>
            <answer>
                <p>
                    <m>40 \le N \lt 90</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A farmer in <em>Molo</em> needs to keep the temperature (<m>T</m>) of a greenhouse such that it is higher than <m>15^\circ \text{C}</m> but strictly lower than <m>28^\circ \text{C}</m>.
                </p>
                <p>
                    <ol marker="a)">
                        <li>
                            <p>
                                Write this as a single compound inequality to represent the temperature range.
                            </p>
                        </li>
                        <li>
                            <p>
                                If a new automatic heater always adds exactly <m>10^\circ \text{C}</m> to the current outdoor temperature (<m>t</m>), by substituting <m>T</m>, find the range of outdoor temperatures that will keep the greenhouse in the ideal condition.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="a)">
                        <li>
                            <p>
                                <m>15 \lt T \lt 28</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>5 \lt t \lt 18</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
    </exercises>

