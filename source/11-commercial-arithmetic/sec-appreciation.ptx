    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    An investor purchases a plot of land in a growing urban center for <m>3,500,000</m> Shillings. If the land value appreciates at a steady rate of <m>12\%</m> per annum, what will be the value of the land after <m>8</m> years?
                </p>
            </statement>
            <answer>
                <p>
                    <m>8,665,860</m> shillings
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A first edition textbook is currently valued at <m>85,000</m> Shillings. It has been appreciating at a rate of <m>6\%</m> per year for the last <m>10 </m> years. How much did the collector originally pay for it?
                </p>
            </statement>
            <answer>
                <p>
                    <m>4746.50</m> shillings
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A small tech startup was valued at <m>1,200,000</m> Shillings when it launched. Exactly <m>4</m> years later, it was valued at <m>2,500,000</m> Shillings. Calculate the annual appreciation rate.
                </p>
            </statement>
            <answer>
                <p>
                    <m>20.1\%\;\text{per annum}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A gold bar bought for <m>600,000</m> Shillings appreciates at a rate of <m>9 \%</m> per annum. How many years will it take for the value of the gold bar to reach <m>1,000,000</m> Shillings?
                </p>
            </statement>
            <answer>
                <p>
                    <m>5.93 \;\text{years}</m>
                </p>
            </answer>
        </exercise>
    </exercises>

