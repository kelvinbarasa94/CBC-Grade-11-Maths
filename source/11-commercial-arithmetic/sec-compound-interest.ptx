    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Murunga want to buy a laptop worth <m>150,000</m> Shillings in <m>3</m> years. A fund offers <m>8</m> % interest per annum compounded semi-annually. How much must Murunga invest to reach his goal?
                </p>
            </statement>
            <answer>
                <p>
                    <m>118,547.18 \;\text{Shillings}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Armstrong invested a sum of <m>200,000</m> Shillings, he later received an amount of <m>293,865</m> Shillings. If the interest rate was <m>10</m> % compounded quarterly. How many years was the money invested?
                </p>
            </statement>
            <answer>
                <p>
                    <m>3.89 \;\text{years}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A business loan of <m>500,000</m> Shillings accumulated to <m>714,610</m> Shillings after <m>5</m> years with interest compounded annually. What was the annual interest rate?
                </p>
            </statement>
            <answer>
                <p>
                    <m>7.4 \%</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Monica invests <m>50,000</m> Shillings for <m>2</m> years at <m>12 \%</m> p.a in three banks. The interests are calculated Annual, Semi-Annual, and Quarterly for Banks A, B, and C respectively. Calculate the interest Monica will receive from each bank?
                </p>
            </statement>
            <answer>
                <p>
                    A <m> = 12,720 \;\text{shillings}</m>
                </p>
                <p>
                    B <m> = 13,123.85 \;\text{shillings}</m>
                </p>
                <p>
                    C <m> = 13,338.50 \;\text{shillings}</m>
                </p>
            </answer>
        </exercise>
    </exercises>

