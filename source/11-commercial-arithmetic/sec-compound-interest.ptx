    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Murunga want to buy a laptop worth <m>150,000</m> Shillings in <m>3</m> years. A fund offers <m>8</m> % interest per annum compounded semi-annually. How much must Murunga invest to reach his goal?
                </p>
            </statement>
            <answer>
                <p>
                    <m>118,547.18 \;\text{Shillings}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Armstrong invested a sum of <m>200,000</m> Shillings, he later received an amount of <m>293,865</m> Shillings. If the interest rate was <m>10</m> % compounded quarterly. How many years was the money invested?
                </p>
            </statement>
            <answer>
                <p>
                    <m>3.89 \;\text{years}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A business loan of <m>500,000</m> Shillings accumulated to <m>714,610</m> Shillings after <m>5</m> years with interest compounded annually. What was the annual interest rate?
                </p>
            </statement>
            <answer>
                <p>
                    <m>7.4 \%</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Monica invests <m>50,000</m> Shillings for <m>2</m> years at <m>12 \%</m> p.a in three banks. The interests are calculated Annual, Semi-Annual, and Quarterly for Banks A, B, and C respectively. Calculate the interest Monica will receive from each bank?
                </p>
            </statement>
            <answer>
                <p>
                    A <m> = 12,720 \;\text{shillings}</m>
                </p>
                <p>
                    B <m> = 13,123.85 \;\text{shillings}</m>
                </p>
                <p>
                    C <m> = 13,338.50 \;\text{shillings}</m>
                </p>
            </answer>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>
        <table>
            <title>Differentiation Strategies for Compound Interest</title>
            <tabular halign="left" top="medium" bottom="medium" left="medium" right="medium">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row bottom="minor">
                    <cell><alert>Support (Struggling)</alert></cell>
                    <cell>
                        Avoid starting directly with fractions or variables inside exponents. Have learners compute the total account balances manually year-by-year using simple interest methods on an updating ledger. Allow learners to calculate the amount year by year before introducing the compound interest formula.
                    </cell>
                </row>
                <row bottom="minor">
                    <cell><alert>Core (On-Level)</alert></cell>
                    <cell>
                        Guide learners to map calculations directly into the algebraic structure <m>A = P\left(1 + \frac{R}{100}\right)^T</m>. Ensure they can comfortably adjust variables when compounding frequencies shift from annual to semi-annual or quarterly cycles.
                    </cell>
                </row>
                <row>
                    <cell><alert>Challenge (Advanced)</alert></cell>
                    <cell>
                        Ask learners to investigate how increasing the frequency of compounding affects the final amount accumulated. For example, compare the amounts obtained from annual, semi-annual, quarterly, and monthly compounding for the same principal, rate, and time period. Encourage them to derive the formula for continuous compounding and explore its implications.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

