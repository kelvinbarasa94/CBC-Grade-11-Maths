    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    A school van was bought for K£ <m>75,000</m>. Each year, its value decreases by <m>10\%</m>. Find its value after the second and the third year?
                </p>
            </statement>
            <answer>
                <p>
                    K£ <m> 60,750 </m>, K£ <m> 54,675 </m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A coffee hullery depreciates in value at the rate of <m>8\%</m> p.a. If the original cost of the hullery was sh. <m>98,000</m>, find its value after <m>5</m> years?
                </p>
            </statement>
            <answer>
                <p>
                    <m>64,590</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A car which costs sh. <m>2,000,000</m> depreciates in value at a rate of <m>5\%</m> every <m>6</m> months. Find its value after <m>4</m> years.
                </p>
            </statement>
            <answer>
                <p>
                    <m> \text{sh.}\; 1,326,840 </m>
                </p>
            </answer>
        </exercise>
     </exercises>


