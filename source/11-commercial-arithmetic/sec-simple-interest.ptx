<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-simple-interest" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Simple Interest</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.4 Commercial Arithmetic
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Compute simple interest using the simple interest formula
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        10 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To introduce learners to the different aspects of simple interest (principals, rates, yearly interest).
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Help learners to work through the questions, paying particular attention to question (f) which requires finding the total amount of interest.
                    </p>
                </li>
            </dl>
        </axiom>

    <!-- Add Activity -->
     <activity>
        <statement>
            <paragraphs>
                <title>Work in Groups</title>
            </paragraphs>
            <p>
                A group of students received Ksh 1,000,000 from a school innovation competition. They decide to invest the money in a bank so that it can earn interest and help fund future school projects. The students visit three banks and collect the following information:
            </p>
            <sidebyside widths="30% 30% 30%">
                <p>
                    <alert>Bank of Sheila:</alert> Deposit Ksh <m>200,000</m> with us for 5 years, and we'll give you Ksh <m>20,000</m> in interest each year!
                </p>
                <p>
                    <alert>Bank of Mike:</alert> Invest Ksh <m>500,000</m> for 10 years and earn <m>5\%</m> simple interest per year!
                </p>
                <p>
                    <alert>Bank of Esther:</alert> We offer <m>3\%</m> (simple) interest each year if you deposit Ksh <m>800,000</m> for 12 years!
                </p>
            </sidebyside>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            Discuss with your group the advantages and disadvantages of each bank.
                        </p>
                        <note component="lesson-plan">
                            <p>
                                Encourage learners to discuss different features of the banks: how big the initial deposit must be (a smaller initial deposit might be better), how long the deposit must be invested for (12 years is a long time!), what the rate of interest is, etc. 
                            </p>
                            <p>
                                There is no <q>correct</q> answer here, so make sure learners are justifying their choice of bank.
                            </p>
                        </note>
                    </li>
                    <li>
                        <p>
                            Which bank would your group choose? Explain your reasons.
                        </p>
                    </li>
                    <li>
                        <p>
                            The Bank of Sheila does not provide a percentage amount for their interest. Calculate what percentage of the deposit is given as interest each year.
                        </p>
                        <answer component="lesson-plan">
                            <p>
                                <m>\frac{20,000}{200,000} = 0.1 = 10\%</m> (simple) interest each year.
                            </p>
                        </answer>
                    </li>
                    <li>
                        <p>
                            How many Kenyan shillings would be given in interest each year at:
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Bank of Mike
                                    </p>
                                    <answer component="lesson-plan">
                                        <p>
                                            <m>5\% \times 500,000 = 25,000</m>
                                        </p>
                                    </answer>
                                </li>
                                <li>
                                    <p>
                                        Bank of Esther
                                    </p>
                                    <answer component="lesson-plan">
                                        <p>
                                            <m>3\% \times 800,000 = 24,000</m>
                                        </p>
                                    </answer>
                                </li>
                            </ol>
                        </p>
                    </li>
                    <li>
                        <p>
                            Which bank offers the highest interest rate (the percentage of deposit given as interest)? Explain your answer.
                        </p>
                        <answer component="lesson-plan">
                            <p>
                                Bank of Sheila (<m>10\%</m>) gives a better rate than Bank of Mike (<m>5\%</m>) and Bank of Esther (<m>3\%</m>)
                            </p>
                        </answer>
                    </li>
                    <li>
                        <p>
                            Which bank offers the greatest <alert>amount</alert> of interest (not percentage) each year? Explain your answer.
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Bank of Mike gives the most (Ksh <m>25,000</m> per year), followed by Bank of Esther (Ksh <m>24,000</m> per year) and then Bank of Sheila (Ksh <m>20,000</m>).
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            With which bank would you earn the greatest amount of interest over the time period? Remember than each bank has a different time period!
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Bank of Esther gives <m>24,000 \times 12 = 288,000</m> Kenyan shillings, which is greater than Bank of Mike (<m>25,000 \times 10 = 250,000</m>) and Bank of Sheila (<m>20,000 \times 5 = 100,000</m>).
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            If you added your initial deposit (the <term>principal</term>) and the total interest over the time period, with which bank would give you the greatest result?
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Bank of Esther gives <m>288,000 + 800,000 = 1,188,000</m> Kenyan shillings, which is more than Bank of Mike (<m>250,000 + 500,000 = 750,000</m>) and Bank of Sheila (<m>100,000 + 200,000 = 300,000</m>).
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Could you create a formula for the total interest (<m>I</m>) earnt, if the bank offers an interest rate of <m>R\%</m> over <m>T</m> years, from a deposit/principal of <m>P</m> Kenyan shillings?
                        </p>
                        <note component="lesson-plan">
                            <p>
                                Try lead learners towards <m>I = P \times \frac{R}{100} \times T</m>. Emphasise why we need to divide <m>R</m> by 100 to get a decimal. 
                            </p>
                        </note>
                    </li>
                </ol>
            </p>
        </statement>
     </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    5 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To connect the learner experience to the formula <m>I = P \times \frac{R}{100} \times T</m>
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                        If learners have not created a formula yet, try to encourage them to generalise their results from the experience. What would happen if Bank of Sheila offered their interest for <m>T</m> years, rather than just 5?
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->
     <insight>
        <p>
            When you deposit money in a bank, you earn <term>interest</term>: a percentage of your deposite paid back to you. Three factors are important in determining interest:
        </p>
        <dl>
            <li>
                <title><m>P</m></title>
                <p>
                    The Principal / Deposit. This is how much money you give to the bank. The more money you give, the greater the interest 
                </p>
            </li>
            <li>
                <title><m>R</m></title>    
                <p>
                    The Interest Rate. This is the percentage of your deposit that the Bank offers you each year. 
                </p>
            </li>
            <li>
                <title><m>T</m></title>                
                <p>
                    The Time. This is how many years you invest for.
                </p>
            </li>
        </dl>
        <p>
            To calculate the total simple interest, we can use the formula: 
            <md>
                I = P \times \frac{R}{100} \times T
            </md> 
        </p>
     </insight>

     <warning>
        <p>
            In this formula, we need to divide <m>R</m> by <m>100</m> to convert it from a percentage to a decimal. If a Bank offers an interest rate of <m>5\%</m>, we multiply by <m>\frac{R}{100} = \frac{5}{100} = 0.05</m> in the formula. 
        </p>
     </warning>

    <!-- <insight>
    </insight> -->

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Esther deposited Ksh <m>12,500</m> in her bank account where it will earn <m>4 </m> % interest. How much interest will Esther earn in <m>5</m> years?
            </p>
        </statement>
        <solution>
            <p>
                We are asked to find the Interest, <m>I.</m>
            </p>
            <p>
                <md>
                    <mrow> I \amp = \;?</mrow>
                    <mrow> P \amp = \;\text{Ksh}\; 12,500</mrow>
                    <mrow> R \amp = \;4 \;\%</mrow>
                    <mrow> T \amp = \;5 \;\text{years}</mrow>
                </md>
                
            </p>
            <p>
                We now apply the formula to calculate the interest earned by Esther,
            </p>
            <p>
                <md>
                    <mrow> I \amp = \;\frac{P\times R \times T}{100}</mrow>
                    <mrow> \amp = \;\frac{12,500 \times 4 \times 5}{100}</mrow>
                    <mrow> \amp =\; \text{Ksh}\; 2,500</mrow>
                </md>
                
            </p>
            <p>
                In <m>5</m> years, Esther will earn an interest of Ksh <m>2,500</m>.
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
               Kelvin got Ksh <m>900,000</m> as graduation gifts and invested it in a <m>10</m> month certificate of deposit that earned <m> 2.1</m> % interest. How much interest did this investment earn? 
            </p>
        </statement>
        <solution>
            <p>
                We are asked to calculate the interest, <m>I</m>.
            </p>
            <p>
                <md>
                    <mrow> I \amp = \; ?</mrow>
                    <mrow> P \amp = \; \text{Ksh}\;900,000</mrow>
                    <mrow> R \amp = \; 2.1 \; \%</mrow>
                    <mrow> T \amp = \; 10 \; \text{months}</mrow>
                </md>
                
            </p>
            <p>
                Apply the formula to calculate the interest Kelvin earned,
            </p>
            <p>
                <md>
                    <mrow> I \amp =\; \frac{P \times R \times T}{100} </mrow>
                    <mrow> \amp = \; \frac{900,000 \times 2.1 \times 10} {100 \times 12}</mrow>
                    <mrow> \amp = \; \text{Ksh}\; 15,750</mrow>
                </md>
                
            </p>
            <p>
                Kelvin's interest after <m>10</m> months is Ksh <m>15,750</m>.
            </p>
            <p>
                Notice that the time is given as <m>10</m> months hence we convert it into years by dividing it by <m>12</m> months.
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                Loren lent his brother <m>\text{Ksh} \;300,000</m> to help him buy a car. In <m>4 \text{years }</m> his brother paid him back the <m>\text{Ksh}\;366,000 </m>. What was the rate of interest?
            </p>
        </statement>
        <solution>
            <p>
                Apply the Interest formula to calculate the interest rate
            </p>
            <p>
                <md>
                    <mrow> P \amp = \; \text{Ksh}\;300,000</mrow>
                    <mrow> R \amp = \; ?</mrow>
                    <mrow> T \amp = \; 4 \; \text{years}</mrow>
                    <mrow> \text{Amount} \amp = \; \text{Ksh}\;366,000 </mrow>
                </md>
                
            </p>
            <p>
                We calculate the interest paid by Loren, <m>I = \text{Amount} - P = \text{Ksh} \; 66,000</m>
            </p>
            <p>
                <m>I = \frac{P \times R \times T}{100}</m>
            </p>
            <p>
                <md>
                    <mrow> R =  \amp \; \frac{100 \times I}{P \times T}</mrow>
                    <mrow> \amp = \; \frac{100 \times 66,000}{300,000 \times 4}</mrow>
                    <mrow> \amp = \; 5.5\; \%</mrow>
                </md>
            </p>
            <p>
                The rate of interest is <m>5.5\; \%</m>
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    Find the simple interest earned after <m>4</m> years on <m>\text{Ksh} \; 8,000</m> at an interest rate of <m> 5 \;\%</m>.
                </p>
            </statement>
            <answer>
                <p> Ksh <m>1,600</m></p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Find the simple interest earned after <m>2</m> years on <m>\text{Ksh} \; 70,000 </m> at an interest rate of <m> 4 \;\%</m>.
                </p>
            </statement>
            <answer>
                <p>Ksh <m>5600</m></p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Find the principal invested if <m>\text{Ksh}\; 4950 </m> interest was earned in <m>3</m> years at an interest rate of <m> 6 \;\%</m>.
                </p>
            </statement>
            <answer>
                <p> Ksh <m>27,500</m></p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Sean's new car loan statement said he would pay <m>\text{Ksh} \; 486,625</m> in interest from an interest rate of <m>8.5 \;\%</m>.  If sean borrowed <m>1,145,000</m> from the bank to but the car. After how long should the loan be payed back?
                </p>
            </statement>
            <answer>
                <p>
                    <m>5</m> years
                </p>
            </answer>
        </exercise>
     </exercises>


