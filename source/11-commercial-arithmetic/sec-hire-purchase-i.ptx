    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    A laptop has a cash price of ksh <m>60,000</m>. Under hire purchase, the deposit is Ksh <m>15,000</m> followed by <m>10</m> installments of Ksh <m>5,200</m>. Calculate the carrying charge.
                </p>
            </statement>
            <answer>
                <p>
                    <m>\text{Ksh} \; 7,000</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The Hire purchase price of a sofa is Ksh <m>48,000</m>. The deposit is Ksh <m>12,000</m> and the rest is paid in <m>1.5</m> years. Find the monthly installment.
                </p>
            </statement>
            <answer>
                <p>
                    Ksh <m>2,000</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A water pump's Hire purchase price is <m>30,000</m>. This price is composed of a deposit and <m>12</m> installments of Ksh <m>1,800</m>. What percentage of the Hire purchase was the deposit?
                </p>
            </statement>
            <answer>
                <p>
                    <m>28 \%</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A shopkeeper marks a cooker at Ksh <m>24,000</m> cash. For hire purchase, he requires a <m>20\%</m> deposit of the cash price and <m>8</m> installments of Ksh <m>2,800</m>. Find the difference between the Hire purchase and the Cash Price.
                </p>
            </statement>
            <answer>
                <p>
                    <m>\text{Ksh} \; 3,200</m>
                </p>
            </answer>
        </exercise>
    </exercises>

