    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                A television has a cash price of Ksh <m>36,000</m>. A customer buys it on hire purchase by paying a deposit of Ksh <m>8,000</m> and <m>15</m> monthly installments of Ksh <m>2,500</m> each. Calculate the Hire Purchase Price.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{Deposit} = \amp \;\text{Ksh} \;8,000</mrow>
                    <mrow> \text{Total Installments} = \amp\; \text{Ksh}\; 2,500 \times 15 = \;\text{Ksh} \;37,500 </mrow>
                    <mrow> \text{Hire Purchase Price} = \amp \;8,000 + 37,500 = \;\text{Ksh}\; 45,500 </mrow>
                </md>
                
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                The hire purchase price of a motorcycle is Ksh <m>120,000</m>. A buyer pays a <m>25\%</m> deposit and the remainder in <m>24</m> equal monthly installments. Find the value of each installment.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{Calculate Deposit} = \amp \; \frac{25}{100} \times 120,000 = \;\text{Ksh}\; 30,000</mrow>
                    <mrow> \text{Calculate Remaining Balance} = \amp \; 120,000 - 30,000 = \;\text{Ksh}\; 90,000 </mrow>
                    <mrow> \text{Calculate Installment} = \amp \; \frac{90,000}{24} = \;\text{Ksh} \; 3,750 </mrow>
                </md>
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                A refrigerator has a cash price of Ksh <m>50,000</m>. The hire purchase price is <m>15\%</m> higher than the cash price. If the monthly installment is Ksh <m>3,500</m> for <m>12</m> months, find the deposit paid.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{Calculate Hire Purchase} = \amp \;50,000 + \frac{15}{100} \times 50,000 = \;\text{Ksh} \; 57,500 </mrow>
                    <mrow> \text{Calculate Total Installments} = \amp \; 3,500 \times 12 = \text{Ksh} \; 42,000 </mrow>
                    <mrow> \text{Deposit} = \amp \; \text{Hire Purchase} - \text{Total Instalments} </mrow>
                    <mrow> = \amp \; 57,500 - 42,000 = \;\text{ksh} \; 15,500 </mrow>
                </md>
                
            </p>
        </solution>
    </example>


