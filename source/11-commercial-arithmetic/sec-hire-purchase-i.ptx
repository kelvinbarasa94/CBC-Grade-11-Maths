    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation Strategies for Hire Purchase</title>
            <tabular halign="left" top="medium" bottom="medium" left="medium" right="medium">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>

                <row bottom="minor">
                    <cell><alert>Support (Struggling)</alert></cell>
                    <cell>
                        Help learners identify the deposit, installment amount, and number of payments. Use simple substitution into the formula <m>H = D + (x \times n)</m> and solve step by step.
                    </cell>
                </row>

                <row bottom="minor">
                    <cell><alert>Core (On-Level)</alert></cell>
                    <cell>
                        Learners calculate total hire purchase cost from given deposit and installment values. Use examples from household items such as phones, TVs, and furniture.
                    </cell>
                </row>

                <row>
                    <cell><alert>Advanced (Challenge)</alert></cell>
                    <cell>
                        Give problems where one value is missing (deposit, installment, or time). Learners solve for the unknown and explain their steps.
                    </cell>
                </row>

            </tabular>
        </table>
    </axiom>

