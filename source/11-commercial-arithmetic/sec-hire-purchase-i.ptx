<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-hire-purchase-i" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Hire Purchase I</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.4 Commercial Arithmetic
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Determine the cost of goods in purchase
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>

        <ol>

            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>

            <li>
                <title>Objective</title>
                <p>
                    To understand how hire purchase works, calculate the total amount paid over time, and identify the extra cost paid.
                </p>
            </li>

            <li>
                <title>Teacher's Role</title>
                <p>
                    Put learners in groups of <m>3</m> or <m>4</m>. Let them use familiar examples such as motorcycles, solar kits, and smartphones. In the television example, guide them to see that the total cost is made up of the deposit plus all monthly payments. Help them avoid confusing the cash price with the hire purchase total.
                </p>
            </li>

        </ol>
    </axiom>

    <activity>
        <statement>

            <p>
                <term>Work in Groups to:</term>
            </p>

            <p>
                Identify and record items in your environment that are commonly bought through hire purchase. Discuss why people prefer hire purchase instead of paying cash.
            </p>

            <tabular top="medium" bottom="medium" right="medium" left="medium">
                <row header="yes">
                    <cell>Item</cell>
                    <cell>Reason for Hire Purchase</cell>
                </row>
                <row>
                    <cell>Television</cell>
                    <cell>High cost makes full payment difficult</cell>
                </row>
                <row>
                    <cell>?</cell>
                    <cell>?</cell>
                </row>
                <row>
                    <cell>?</cell>
                    <cell>?</cell>
                </row>
            </tabular>

            <p>
                <alert>In your groups explore the situation below:</alert>
            </p>

            <p>
                A shop sells a television on hire purchase under the following terms:
            </p>

            <p>
                Cash price = Ksh <m>40,000</m>, Deposit = Ksh <m>10,000</m>, Monthly instalment = Ksh <m>2,500</m> for <m>14</m> months.
            </p>

            <p>
                <alert>In your groups you are required to:</alert>
            </p>

            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            Calculate the total amount paid through hire purchase.
                        </p>
                    </li>
                    <li>
                        <p>
                            Determine the extra cost paid compared to the cash price.
                        </p>
                    </li>
                    <li>
                        <p>
                            Express the extra cost as a fraction of the cash price.
                        </p>
                    </li>
                    <li>
                        <p>
                            Convert the fraction into a percentage.
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                <alert>Further Exploration:</alert> Compare the total cost of buying an item using cash and hire purchase. Discuss the advantages and disadvantages of each method.
            </p>

            <p>
                Explore what happens if the repayment period increases or decreases.
            </p>
        </statement>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>

        <p>
            <ol>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>

            <li>
                <title>Objective</title>
                <p>
                    To use algebra to compare cash price and hire purchase price and determine the extra cost paid.
                </p>
            </li>
            </ol>
        </p>

        <paragraphs>
            <title>Discussion of Learner Findings</title>
            <ol>

                <li>
                    <p>
                        <alert>Discussion:</alert> Use the television example to guide discussion. Show that the cash price is Ksh <m>40,000</m>, while the hire purchase cost is Ksh <m>10,000 + (2,500 \times 14) = 45,000</m>. The difference of Ksh <m>5,000</m> is the extra cost of buying on credit.
                    </p>
                </li>

                <li>
                    <p>
                        <alert>Developing the Formula:</alert> Help learners express the relationship as <m>H = D + xn</m>. Explain that the extra cost is the difference between the total paid and the cash price (<m>I = H - P</m>).
                    </p>
                </li>

                <li>
                    <p>
                        <alert>Discussion:</alert> Discuss how paying in installments makes goods more expensive overall. Relate this to everyday buying decisions.
                    </p>
                </li>

            </ol>
        </paragraphs>
    </axiom>

    <insight>
        <p>
            Hire purchase is a method of buying goods where a buyer pays a deposit and the remaining amount in instalments while using the item.
        </p>

        <p>
            Although it makes expensive goods more affordable in the short term, the total amount paid is usually higher than the cash price due to added costs spread over time.
        </p>

        <p>
            Let:
        </p>

        <p>
            <md>
                <mrow> P = \amp \;\text{Cash price} </mrow>
                <mrow> D = \amp \; \text{Deposit} </mrow>
                <mrow> x =  \amp \;\text{Instalment amount} </mrow>
                <mrow> n = \amp \; \text{Number of instalments} </mrow>
                <mrow> H = \amp \;\text{Hire purchase price} </mrow>
            </md>
        </p>

        <p>
            Then:
        </p>

        <p>
            <md>
                <mrow> H = \amp \;D + xn </mrow>
                <mrow> I = \amp \;H - P </mrow>
                <mrow> R = \amp \;\frac{H - P}{P} \times 100\% </mrow>
            </md>
        </p>

        <p>
            The key idea is that hire purchase increases accessibility to goods, but it also increases the total cost of ownership. Therefore, careful financial decision-making is necessary before choosing this method of payment.
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                A television has a cash price of Ksh <m>36,000</m>. A customer buys it on hire purchase by paying a deposit of Ksh <m>8,000</m> and <m>15</m> monthly installments of Ksh <m>2,500</m> each. Calculate the Hire Purchase Price.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{Deposit} \amp = \;\text{Ksh} \;8,000</mrow>
                    <mrow> \text{Total Installments} \amp =\; \text{Ksh}\; 2,500 \times 15 = \;\text{Ksh} \;37,500 </mrow>
                    <mrow> \text{Hire Purchase Price} \amp = \;8,000 + 37,500 = \;\text{Ksh}\; 45,500 </mrow>
                </md>
                
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                The hire purchase price of a motorcycle is Ksh <m>120,000</m>. A buyer pays a <m>25\%</m> deposit and the remainder in <m>24</m> equal monthly installments. Find the value of each installment.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{Calculate Deposit} \amp = \; \frac{25}{100} \times 120,000 = \;\text{Ksh}\; 30,000</mrow>
                    <mrow> \text{Calculate Remaining Balance} \amp = \; 120,000 - 30,000 = \;\text{Ksh}\; 90,000 </mrow>
                    <mrow> \text{Calculate Installment} \amp = \; \frac{90,000}{24} = \;\text{Ksh} \; 3,750 </mrow>
                </md>
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                A refrigerator has a cash price of Ksh <m>50,000</m>. The hire purchase price is <m>15\%</m> higher than the cash price. If the monthly installment is Ksh <m>3,500</m> for <m>12</m> months, find the deposit paid.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{Calculate Hire Purchase} \amp = \;50,000 + \frac{15}{100} \times 50,000 = \;\text{Ksh} \; 57,500 </mrow>
                    <mrow> \text{Calculate Total Installments} \amp = \; 3,500 \times 12 = \text{Ksh} \; 42,000 </mrow>
                    <mrow> \text{Deposit} \amp = \; \text{Hire Purchase} - \text{Total Instalments} </mrow>
                    <mrow> \amp = \; 57,500 - 42,000 = \;\text{ksh} \; 15,500 </mrow>
                </md>
                
            </p>
        </solution>
    </example>


    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    A laptop has a cash price of ksh <m>60,000</m>. Under hire purchase, the deposit is Ksh <m>15,000</m> followed by <m>10</m> installments of Ksh <m>5,200</m>. Calculate the carrying charge.
                </p>
            </statement>
            <answer>
                <p>
                    <m>\text{Ksh} \; 7,000</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The Hire purchase price of a sofa is Ksh <m>48,000</m>. The deposit is Ksh <m>12,000</m> and the rest is paid in <m>1.5</m> years. Find the monthly installment.
                </p>
            </statement>
            <answer>
                <p>
                    Ksh <m>2,000</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A water pump's Hire purchase price is <m>30,000</m>. This price is composed of a deposit and <m>12</m> installments of Ksh <m>1,800</m>. What percentage of the Hire purchase was the deposit?
                </p>
            </statement>
            <answer>
                <p>
                    <m>28 \%</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A shopkeeper marks a cooker at Ksh <m>24,000</m> cash. For hire purchase, he requires a <m>20\%</m> deposit of the cash price and <m>8</m> installments of Ksh <m>2,800</m>. Find the difference between the Hire purchase and the Cash Price.
                </p>
            </statement>
            <answer>
                <p>
                    <m>\text{Ksh} \; 3,200</m>
                </p>
            </answer>
        </exercise>
    </exercises>

