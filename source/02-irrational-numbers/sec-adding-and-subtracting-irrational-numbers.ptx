    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
      <statement>Simplify: <m>8\sqrt{3} + 5\sqrt{3} - 2\sqrt{3}</m></statement>
      <solution>
        <p>All terms are <q>like surds.</q> We perform the operations on the coefficients: <m>(8 + 5 - 2)\sqrt{3} = 11\sqrt{3}</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Simplify: <m>4\sqrt{2} + 7\sqrt{5} + 3\sqrt{2} - 2\sqrt{5}</m></statement>
      <solution>
        <p>Group like surds: <m>(4\sqrt{2} + 3\sqrt{2}) + (7\sqrt{5} - 2\sqrt{5}) = 7\sqrt{2} + 5\sqrt{5}</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Simplify: <m>\sqrt{18} + \sqrt{50}</m></statement>
      <solution>
        <p>First, simplify each surd: <m>\sqrt{18} = 3\sqrt{2}</m> and <m>\sqrt{50} = 5\sqrt{2}</m>. Now add: <m>3\sqrt{2} + 5\sqrt{2} = 8\sqrt{2}</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Simplify: <m>2\sqrt{27} - \sqrt{12}</m></statement>
      <solution>
        <p>Simplify: <m>2(3\sqrt{3}) = 6\sqrt{3}</m> and <m>\sqrt{12} = 2\sqrt{3}</m>. Result: <m>6\sqrt{3} - 2\sqrt{3} = 4\sqrt{3}</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Find the perimeter of a rectangle with length <m>\sqrt{20}</m> cm and width <m>\sqrt{5}</m> cm.</statement>
      <solution>
        <p>Perimeter <m>= 2(2\sqrt{5} + \sqrt{5}) = 2(3\sqrt{5}) = 6\sqrt{5}</m> cm.</p>
      </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
<exercises>
      <exercise>
        <statement><p>Simplify <m>12\sqrt{7} - 9\sqrt{7}</m>.</p></statement>
        <solution><p><m>3\sqrt{7}</m></p></solution>
      </exercise>
      <exercise>
        <statement><p>Simplify <m>\sqrt{8} + \sqrt{32}</m>.</p></statement>
        <solution><p><m>2\sqrt{2} + 4\sqrt{2} = 6\sqrt{2}</m></p></solution>
      </exercise>
      <exercise>
        <statement><p>Simplify <m>5\sqrt{3} + 2\sqrt{12} - \sqrt{27}</m>.</p></statement>
        <solution><p><m>5\sqrt{3} + 4\sqrt{3} - 3\sqrt{3} = 6\sqrt{3}</m></p></solution>
      </exercise>
      <exercise>
        <statement><p>A triangle has sides of <m>\sqrt{24}</m> units, <m>\sqrt{54}</m> units, and <m>\sqrt{6}</m> units. Calculate its perimeter.</p></statement>
        <solution><p><m>2\sqrt{6} + 3\sqrt{6} + \sqrt{6} = 6\sqrt{6}</m> units.</p></solution>
      </exercise>
      <exercise>
        <statement><p>Show that <m>\sqrt{45} - \sqrt{20}</m> is equal to <m>\sqrt{5}</m>.</p></statement>
        <solution><p><m>3\sqrt{5} - 2\sqrt{5} = \sqrt{5}</m>.</p></solution>
      </exercise>
    </exercises>
