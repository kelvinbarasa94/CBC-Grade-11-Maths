    <!-- Add Activity -->
     <axiom component="lesson-plan">
      <title>Problem-Solving and Discovery</title>
      <dl>
        <li>
          <title>Suggested Time</title>
          <p>15 minutes</p>
        </li>
        <li>
          <title>Objective</title>
          <p>To realize that fractions are easier to compare and compute when the denominator is a rational number.</p>
        </li>
        <li>
          <title>Teacher's Role</title>
          <p>Write <m>\frac{1}{\sqrt{2}}</m> on the board. Ask learners to estimate its value using a calculator. Then ask them to multiply both the numerator and denominator by <m>\sqrt{2}</m> and estimate again. Lead a discussion on why <m>\frac{\sqrt{2}}{2}</m> might be more <q>useful</q> than <m>\frac{1}{\sqrt{2}}</m>.</p>
        </li>
      </dl>
    </axiom>

    <activity>
      <statement>
        <p>Investigate the effect of multiplying a fraction by a specialized form of 1:</p>
        <ol>
          <li>Consider the fraction <m>\frac{3}{\sqrt{5}}</m>. If you multiply it by <m>\frac{\sqrt{5}}{\sqrt{5}}</m>, what happens to the radical in the denominator?</li>
          <li>Does the actual value of the number change when you multiply it by <m>\frac{\sqrt{n}}{\sqrt{n}}</m>? Explain why.</li>
          <li>Try to find a way to remove the radical from the denominator of <m>\frac{1}{2 + \sqrt{3}}</m>. (Hint: Remember the difference of two squares from your previous algebra lessons).</li>
        </ol>
      </statement>
    </activity>

