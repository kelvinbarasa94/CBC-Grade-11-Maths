                    <p>
                        1.2 Irrational Numbers
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Rationalise irrational numbers in different situations
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
