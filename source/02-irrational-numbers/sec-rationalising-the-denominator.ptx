    <!-- Add insight / key takeaway directly related to activity / learner experience --><axiom component="lesson-plan">
      <title>Structured Instruction</title>
      <p>
        <dl>
          <li>
            <title>Suggested Time</title>
            <p>10 minutes</p>
          </li>
          <li>
            <title>Objective</title>
            <p>To formalize the process of rationalising denominators for both monomial and binomial surds.</p>
          </li>
        </dl>
      </p>
      <paragraphs>
        <title>Key Takeaways &amp; Teacher Connection</title>
        <ol>
          <li>
            <p>
              <alert>Connecting to Learner Work:</alert> Explain that rationalising is like <q>cleaning up</q> a fraction. For binomial denominators, introduce the concept of the <term>conjugate</term>.
            </p>
          </li>
        </ol>
      </paragraphs>
    </axiom>

    <insight>
      <p>
        Rationalising the denominator is the process of removing a radical from the bottom of a fraction. 
      </p>
      <ul>
        <li>For a single surd <m>\sqrt{a}</m>, multiply the top and bottom by <m>\sqrt{a}</m>.</li>
        <li>For a binomial <m>a + \sqrt{b}</m>, multiply by its conjugate <m>a - \sqrt{b}</m>. The product of a surd and its conjugate is always a rational number.</li>
      </ul>
    </insight>

    <!-- <insight>
    </insight> -->

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

   <example>
      <statement>Rationalise the denominator of <m>\frac{5}{\sqrt{3}}</m></statement>
      <solution>
        <p>Multiply the numerator and denominator by <m>\sqrt{3}</m>: <m>\frac{5 \times \sqrt{3}}{\sqrt{3} \times \sqrt{3}} = \frac{5\sqrt{3}}{3}</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Simplify by rationalising: <m>\frac{\sqrt{2}}{\sqrt{6}}</m></statement>
      <solution>
        <p>First, simplify the fraction: <m>\sqrt{\frac{2}{6}} = \sqrt{\frac{1}{3}} = \frac{1}{\sqrt{3}}</m>. Now rationalise: <m>\frac{1 \times \sqrt{3}}{\sqrt{3} \times \sqrt{3}} = \frac{\sqrt{3}}{3}</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Rationalise the denominator of <m>\frac{2}{3 - \sqrt{5}}</m></statement>
      <solution>
        <p>Multiply by the conjugate <m>3 + \sqrt{5}</m>: <m>\frac{2(3 + \sqrt{5})}{(3 - \sqrt{5})(3 + \sqrt{5})}</m>.</p>
        <p>Denominator: <m>3^2 - (\sqrt{5})^2 = 9 - 5 = 4</m>.</p>
        <p>Result: <m>\frac{2(3 + \sqrt{5})}{4} = \frac{3 + \sqrt{5}}{2}</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Rationalise: <m>\frac{1}{\sqrt{2} + 1}</m></statement>
      <solution>
        <p>Multiply by the conjugate <m>\sqrt{2} - 1</m>: <m>\frac{1(\sqrt{2} - 1)}{(\sqrt{2} + 1)(\sqrt{2} - 1)} = \frac{\sqrt{2} - 1}{2 - 1} = \sqrt{2} - 1</m>.</p>
      </solution>
    </example>

    <example>
      <statement>Simplify <m>\frac{\sqrt{3} + \sqrt{2}}{\sqrt{3} - \sqrt{2}}</m> by rationalising the denominator.</statement>
      <solution>
        <p>Multiply by the conjugate <m>\sqrt{3} + \sqrt{2}</m>: <m>\frac{(\sqrt{3} + \sqrt{2})^2}{(\sqrt{3} - \sqrt{2})(\sqrt{3} + \sqrt{2})}</m>.</p>
        <p>Numerator: <m>3 + 2\sqrt{6} + 2 = 5 + 2\sqrt{6}</m>.</p>
        <p>Denominator: <m>3 - 2 = 1</m>. Result: <m>5 + 2\sqrt{6}</m>.</p>
      </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
      <exercise>
        <statement><p>Rationalise the denominator of <m>\frac{7}{\sqrt{11}}</m>.</p></statement>
        <solution><p><m>\frac{7\sqrt{11}}{11}</m></p></solution>
      </exercise>
      <exercise>
        <statement><p>Simplify <m>\frac{4}{2\sqrt{2}}</m> by rationalising.</p></statement>
        <solution><p><m>\frac{2}{\sqrt{2}} = \frac{2\sqrt{2}}{2} = \sqrt{2}</m></p></solution>
      </exercise>
      <exercise>
        <statement><p>Rationalise the denominator of <m>\frac{1}{4 + \sqrt{7}}</m>.</p></statement>
        <solution><p><m>\frac{4 - \sqrt{7}}{16 - 7} = \frac{4 - \sqrt{7}}{9}</m></p></solution>
      </exercise>
      <exercise>
        <statement><p>A triangle has an area of 10 square units and a base of <m>\sqrt{5}</m> units. Find its height and write the answer with a rationalised denominator.</p></statement>
        <solution><p>Area = <m>\frac{1}{2}bh \implies 10 = \frac{1}{2}(\sqrt{5})h \implies h = \frac{20}{\sqrt{5}} = \frac{20\sqrt{5}}{5} = 4\sqrt{5}</m> units.</p></solution>
      </exercise>
      <exercise>
        <statement><p>In a technical drawing, a length is given by <m>\frac{\sqrt{3}}{2 + \sqrt{3}}</m>. Express this length in a form without a radical in the denominator.</p></statement>
        <solution><p><m>\frac{\sqrt{3}(2 - \sqrt{3})}{(2 + \sqrt{3})(2 - \sqrt{3})} = \frac{2\sqrt{3} - 3}{4 - 3} = 2\sqrt{3} - 3</m>.</p></solution>
      </exercise>
      <exercise>
        <statement><p>Simplify <m>\frac{2}{\sqrt{10} - \sqrt{8}}</m>.</p></statement>
        <solution><p><m>\frac{2(\sqrt{10} + \sqrt{8})}{10 - 8} = \frac{2(\sqrt{10} + 2\sqrt{2})}{2} = \sqrt{10} + 2\sqrt{2}</m>.</p></solution>
      </exercise>
      <exercise>
        <statement><p>Two numbers are in the ratio <m>1 : (2 + \sqrt{3})</m>. Express this ratio in its simplest rationalised form <m>(a - \sqrt{b}) : 1</m>.</p></statement>
        <solution><p>Divide 1 by <m>2 + \sqrt{3}</m> and rationalise: <m>\frac{1(2 - \sqrt{3})}{(2 + \sqrt{3})(2 - \sqrt{3})} = 2 - \sqrt{3}</m>. Ratio is <m>(2 - \sqrt{3}) : 1</m>.</p></solution>
      </exercise>
    </exercises>
