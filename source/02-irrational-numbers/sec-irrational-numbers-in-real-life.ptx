<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-irrational-numbers-in-real-life" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Irrational Numbers in Real Life</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.2 Irrational Numbers
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                            <ul>
                              <li>Apply irrational numbers in different situations</li>
                              <li>Reflect on the use of irrational numbers in mathematical computations</li>
                            </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->
<axiom component="lesson-plan">
    <title>Problem-Solving and Discovery</title>
    <dl>
        <li>
            <title>Suggested Time</title>
            <p>20 minutes</p>
        </li>
        <li>
            <title>Objective</title>
            <p>To identify and calculate irrational numbers within physical structures and functional design.</p>
        </li>
        <li>
            <title>Teacher's Role</title>
            <p>
                Organize learners into groups of five. Provide each group with a measuring tape and a standard A4 sheet of paper. Guide them to explore the school compound to find rectangular features (like window frames or floor tiles) where they can apply the Pythagorean theorem.
            </p>
        </li>
    </dl>
</axiom>

<activity>
    <title>Engineering Discovery Task</title>
    <statement>
        <p> Work in groups and complete the following interactive tasks:</p>
        <ol>
            <li>
                <p><strong>The Diagonal Truth:</strong> Measure the length and width of a rectangular window in your classroom. Use the Pythagorean theorem to calculate the <em>exact</em> diagonal length. Is the result a whole number? Express it as a surd.</p>
            </li>
            <li>
                <p><strong>The A4 Secret:</strong> Measure the long side and the short side of an A4 paper in millimeters. Divide the long side by the short side. How close is your answer to <m>\sqrt{2}</m> (approximately 1.414)? Discuss why paper is designed this way.</p>
            </li>
            <li>
                <p><strong>The Garden Plot:</strong> Imagine the school is building a square garden with an area of exactly 12 <m>\text{m}^2</m>. Determine the exact length of one side in its simplest surd form.</p>
            </li>
        </ol>
    </statement>
</activity>
