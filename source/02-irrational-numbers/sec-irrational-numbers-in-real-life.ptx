    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
    <statement>
        <p>A carpenter is reinforcing a square gate with an area of 18 <m>\text{m}^2</m>. Find the exact length of one side.</p>
    </statement>
    <solution>
        <p><m>s = \sqrt{18} = \sqrt{9 \times 2} = 3\sqrt{2}</m> meters.</p>
    </solution>
</example>

<example>
    <statement>
        <p>Find the exact diagonal of a football pitch goalpost that is 2m high and 6m wide.</p>
    </statement>
    <solution>
        <p><m>d = \sqrt{2^2 + 6^2} = \sqrt{4 + 36} = \sqrt{40} = 2\sqrt{10}</m> meters.</p>
    </solution>
</example>
<!-- Additional Examples -->

<example>
    <statement>
        <p>A square classroom floor has an area of 32 <m>\text{m}^2</m>. Find the exact length of one side.</p>
    </statement>
    <solution>
        <p><m>s = \sqrt{32} = \sqrt{16 \times 2} = 4\sqrt{2}</m> meters.</p>
    </solution>
</example>

<example>
    <statement>
        <p>A ladder is placed against a wall. The base is 3 m from the wall and the height reached is 5 m. Find the exact length of the ladder.</p>
    </statement>
    <solution>
        <p><m>d = \sqrt{3^2 + 5^2} = \sqrt{9 + 25} = \sqrt{34}</m> meters.</p>
    </solution>
</example>

<example>
    <statement>
        <p>A square school field has a side length of <m>\sqrt{50}</m> meters. Express this length in simplest surd form.</p>
    </statement>
    <solution>
        <p><m>\sqrt{50} = \sqrt{25 \times 2} = 5\sqrt{2}</m> meters.</p>
    </solution>
</example>

<!-- Expanded Exercises -->

<exercises>
    <exercise>
        <statement>
            <p>A square notice board has an area of 72 <m>\text{cm}^2</m>. Find the exact side length.</p>
        </statement>
        <solution>
            <p><m>\sqrt{72} = \sqrt{36 \times 2} = 6\sqrt{2}</m> cm.</p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>The diagonal of a rectangular classroom is formed by sides of 6 m and 8 m. Find the exact diagonal length.</p>
        </statement>
        <solution>
            <p><m>\sqrt{6^2 + 8^2} = \sqrt{36 + 64} = \sqrt{100} = 10</m> m.</p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>A square garden has an area of 98 <m>\text{m}^2</m>. Find the exact side length in simplest form.</p>
        </statement>
        <solution>
            <p><m>\sqrt{98} = \sqrt{49 \times 2} = 7\sqrt{2}</m> m.</p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>Simplify the length of a rope measuring <m>\sqrt{180}</m> cm.</p>
        </statement>
        <solution>
            <p><m>\sqrt{180} = \sqrt{36 \times 5} = 6\sqrt{5}</m> cm.</p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>A square tile has a side length of <m>\sqrt{27}</m> cm. If two tiles are placed side by side, find the total length.</p>
        </statement>
        <solution>
            <p><m>\sqrt{27} = 3\sqrt{3}</m></p>
            <p><m>2 \times 3\sqrt{3} = 6\sqrt{3}</m> cm.</p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>A rectangular field has length 7 m and width 9 m. Find the exact diagonal length.</p>
        </statement>
        <solution>
            <p><m>\sqrt{7^2 + 9^2} = \sqrt{49 + 81} = \sqrt{130}</m> m.</p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>A square has a side length of <m>\sqrt{20}</m> cm. Express it in simplest surd form.</p>
        </statement>
        <solution>
            <p><m>\sqrt{20} = \sqrt{4 \times 5} = 2\sqrt{5}</m> cm.</p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>If a wire of length <m>\sqrt{200}</m> cm is cut into 2 equal parts, find the length of each part in simplest form.</p>
        </statement>
        <solution>
            <p><m>\sqrt{200} = 10\sqrt{2}</m></p>
            <p><m>\frac{10\sqrt{2}}{2} = 5\sqrt{2}</m> cm.</p>
        </solution>
    </exercise>
    <exercise>
        <statement>
            <p>A decorative triangular window has a base of 4m and a height of 4m. Calculate the exact length of the slanted side (hypotenuse).</p>
        </statement>
        <solution>
            <p><m>\sqrt{4^2 + 4^2} = \sqrt{32} = 4\sqrt{2}</m> meters.</p>
        </solution>
    </exercise>
    <exercise>
        <statement>
            <p>If a wire of length <m>\sqrt{108}</m> cm is cut into 3 equal pieces, find the exact length of each piece in simplest form.</p>
        </statement>
        <solution>
            <p><m>\frac{\sqrt{108}}{3} = \frac{6\sqrt{3}}{3} = 2\sqrt{3}</m> cm.</p>
        </solution>
    </exercise>
</exercises>

