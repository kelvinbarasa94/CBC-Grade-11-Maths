<section xml:id="sec-simplifying-irrational-numbers" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Simplifying Irrational Numbers</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.2 Irrational Numbers
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Simplify irrational numbers in different situations
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>
<activity>
    <alert>Discovering Side Lengths of Squares</alert>
        <statement>
            <p>
                <term>Work in Groups</term>
            </p>
            <p>
                <term>What you need</term>
            </p>
            <p>
                <ol>
                    <li><p>Ruler (with cm markings)</p></li>
                    <li><p>Masking tape or chalk </p></li>
                    <li><p> Paper and pen</p></li>
                    <li><p>Square tile or a drawn square</p></li>
                </ol>
            </p>
            <p>
                    <term>What to do</term>     
            </p>
            <task>
                <statement>
                    <p>
                        Create or choose a square and decide on its area (for example: <m>16 cm², 20 cm², 25 cm², 18 cm²,36 cm²</m>).
                    </p>
                
                        <!-- Writes each number in square root form <m>(e.g., √50, √64).</m> -->
                    
                    <!-- <image>
                        <latex-image>
                            \begin{tikzpicture}[scale=0.6]

                                \foreach \n in {1,2,3,4,5} {
                                    \begin{scope}[shift={(\n*5,0)}]
                                        \draw[step=1cm] (0,0) grid (\n,\n);
                                        \draw[thick] (0,0) rectangle (\n,\n);
                                        \node at (\n/2,-0.7) {$\n$};
                                    \end{scope}
                                }

                            \end{tikzpicture}
                        </latex-image>
                    </image> -->
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                          Work together to find the side length of your square using: <m> s=\sqrt{Area}</m>
                    </p>
            
                    <!-- <tabular left="medium" right="medium" top="medium" bottom="medium">
                        <row>
                            <cell right="medium">Side Length (<m>n</m>)</cell>
                            <cell>Number of Unit Squares (<m>n^2</m>)</cell>
                        </row>
