<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-graphing-circles" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Graphing Circles</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.6 Graphical Methods
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                            <ul>
                              <li>Determine the centre, radius and equation of a circle in different situations</li>
                              <li>Draw graphs of circles and parabolas in different situations</li>
                            </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        15 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To discover the relationship between the coordinates of points on a circle and its center and radius using the distance formula.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Guide learners to use a compass or a piece of string to maintain a constant distance from a fixed point. Encourage them to apply the Pythagorean theorem or distance formula to generalize their findings.
                    </p>
                </li>
            </dl>
        </axiom>

    <activity>
        <statement>
            <p>
                <alert>Work in Groups</alert>
            </p>
            <p>
                <alert>What you need</alert>
            </p>
            <p>
                <ul>
                    <li>
                        <p>
                            Graph paper
                        </p>
                    </li>
                    <li>
                        <p>
                            A compass or a piece of string and a pencil
                        </p>
                    </li>
                    <li>
                        <p>
                            A ruler
                        </p>
                    </li>
                </ul>
            </p>
            <p>
                Imagine you have a fixed point <m>C(2, 3)</m> on a coordinate plane. You want to find all points <m>P(x, y)</m> that are exactly 5 units away from <m>C</m>.
            </p>
            <p>
                <alert>What to do</alert>
            </p>
            <p>
                <ol>
                    <li>
                        <p>
                            Plot the point <m>C(2, 3)</m> on a grid.
                        </p>
                        <solution component="lesson-plan">
                            <image width="95%">
                            <latex-image label="fig-activity-center">
                                \begin{tikzpicture}[scale=0.7]
                                    \draw[color=gray!50, step=1] (-5,-4) grid (9,10);
                                    \draw[-&gt;] (-5,0) -- (9,0) node[right] {$x$};
                                    \draw[-&gt;] (0,-4) -- (0,10) node[above] {$y$};
                                    \foreach \x in {-4,-2,2,4,6,8} \draw (\x,2pt) -- (\x,-2pt) node[below] {$\x$};
                                    \foreach \y in {-2,2,4,6,8} \draw (2pt,\y) -- (-2pt,\y) node[left] {$\y$};
                                    \filldraw (2,3) circle (2pt) node[above right] {$C(2,3)$};
                                \end{tikzpicture}
                            </latex-image>      
                        </image>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Mark at least <m>8</m> points that are exactly <m>5</m> units away from <m>C</m>. (Hint: Think of points directly above, below, left, and right, and some in between using Pythagorean triples like 3, 4, 5).
                        </p>
                        <solution component="lesson-plan">
                        <image width="95%">
                            <latex-image label="fig-activity-points">
                                \begin{tikzpicture}[scale=0.7]
                                    \draw[color=gray!50, step=1] (-5,-4) grid (9,10);
                                    \draw[-&gt;] (-5,0) -- (9,0) node[right] {$x$};
                                    \draw[-&gt;] (0,-4) -- (0,10) node[above] {$y$};
                                    \foreach \x in {-4,-2,2,4,6,8} \draw (\x,2pt) -- (\x,-2pt) node[below] {$\x$};
                                    \foreach \y in {-2,2,4,6,8} \draw (2pt,\y) -- (-2pt,\y) node[left] {$\y$};
                                    \filldraw (2,3) circle (3pt) node[above right] {$C(2,3)$};
                                    \foreach \p in {(7,3), (-3,3), (2,8), (2,-2), (5,7), (-1,7), (5,-1), (-1,-1)}
                                        \filldraw \p circle (2.5pt);
                                \end{tikzpicture}
                            </latex-image>   
                        </image>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Connect these points smoothly. What shape do you get?
                        </p>
                        <solution component="lesson-plan">
                        <image width="95%">
                            <latex-image label="fig-activity-circle">
                                \begin{tikzpicture}[scale=0.7]
                                    \draw[color=gray!50, step=1] (-5,-4) grid (9,10);
                                    \draw[-&gt;] (-5,0) -- (9,0) node[right] {$x$};
                                    \draw[-&gt;] (0,-4) -- (0,10) node[above] {$y$};
                                    \foreach \x in {-4,-2,2,4,6,8} \draw (\x,2pt) -- (\x,-2pt) node[below] {$\x$};
                                    \foreach \y in {-2,2,4,6,8} \draw (2pt,\y) -- (-2pt,\y) node[left] {$\y$};
                                    \filldraw (2,3) circle (3pt) node[above right] {$C(2,3)$};
                                    \draw[blue, thick] (2,3) circle (5);
                                    \foreach \p in {(7,3), (-3,3), (2,8), (2,-2), (5,7), (-1,7), (5,-1), (-1,-1)}
                                        \filldraw \p circle (2.5pt);
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Use the distance formula to write an expression for the distance between <m>C(2, 3)</m> and any point <m>P(x, y)</m> on this shape.
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                The distance <m>d</m> from <m>C(2, 3)</m> to <m>P(x, y)</m> is given by the distance formula:
                                <md>d = \sqrt{(x - 2)^2 + (y - 3)^2}</md>
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Set this distance expression equal to <m>5</m> and square both sides. What equation do you get?
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Squaring both sides of <m>d = 5</m> gives:
                                <md>(x - 2)^2 + (y - 3)^2 = 25</md>
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            What do you notice about the equation you derived? How does it relate to the points you plotted?
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                The equation <m>(x - 2)^2 + (y - 3)^2 = 25</m> represents all points <m>(x, y)</m> that are exactly 5 units away from the center <m>(2, 3)</m>. This is the standard form of a circle's equation, where the center is at <m>(h, k) = (2, 3)</m> and the radius is <m>r = 5</m>.
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Share your work with the class.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the definition of a circle and derive its standard equation.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ul>
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Show how the general equations apply to the specific case of <m>r = 5</m>, <m>h = 2</m>, and <m>k = 3</m> that the learners just explored. Emphasize that the equation they derived is a specific instance of a more general formula for circles.
                    </p>
                </li>
            </ul>
        </paragraphs>
    </axiom>

    <insight>
        <p>
            A <term>circle</term> is the set of all points in a plane that are at a constant distance, called the <term>radius</term> (<m>r</m>), from a fixed point called the <term>center</term> (<m>h, k</m>).
        </p>
        <p>
            The <term>standard equation</term> of a circle with center <m>(h, k)</m> and radius <m>r</m> is:
            <md>(x - h)^2 + (y - k)^2 = r^2</md>
        </p>
        <p>
            If the center is at the origin <m>(0, 0)</m>, the equation simplifies to:
            <md>x^2 + y^2 = r^2</md>
        </p>
        <p>
        <alert> How to Graph a Circle </alert>
        </p>
        <p>
            To graph a circle from its standard equation <m>(x - h)^2 + (y - k)^2 = r^2</m>, follow these steps:
        </p>
        <ol>
            <li>
                <p>
                    <alert>Identify the Center:</alert> The center is the point <m>(h, k)</m>. Note that the signs in the equation are negative, so if you see <m>(x + 2)</m>, then <m>h = -2</m>.
                </p>
            </li>
            <li>
                <p>
                    <alert>Identify the Radius:</alert> The constant term on the right is <m>r^2</m>. Take the square root to find the radius <m>r</m>.
                </p>
            </li>
            <li>
                <p>
                    <alert>Plot the Center:</alert> Mark the point <m>(h, k)</m> on the coordinate plane.
                </p>
            </li>
            <li>
                <p>
                    <alert>Plot Four Key Points:</alert> From the center, move <m>r</m> units in four directions:
                    <ul>
                        <li><p>Up: <m>(h, k + r)</m></p></li>
                        <li><p>Down: <m>(h, k - r)</m></p></li>
                        <li><p>Left: <m>(h - r, k)</m></p></li>
                        <li><p>Right: <m>(h + r, k)</m></p></li>
                    </ul>
                </p>
            </li>
            <li>
                <p>
                    <alert>Draw the Circle:</alert> Connect these four points with a smooth, round curve.
                </p>
            </li>
        </ol>
    </insight> 

    <warning>
        <p>
            Remember the minus signs in the equation indicate the center's coordinates. If we have the equation:
            <md>
                (x+3)^2 + (y+2)^2 = 5^2
            </md>
            Then the center is at <m>(-3, -2)</m>, <em>not</em> <m>(3, 2)</m>.
        </p>
    </warning>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <example>
        <statement>
            <p>
                Find the equation of a circle with center <m>(0, 0)</m> and radius <m>4</m> units. Sketch its graph.
            </p>
        </statement>
        <solution>
            <p>
                Since the center is at the origin <m>(0, 0)</m>, we use the simplified equation <md>x^2 + y^2 = r^2</md>.
            </p>
            <p>
                Given <m>r = 4</m>, we have:
                <md>x^2 + y^2 = 4^2</md>
                <md>x^2 + y^2 = 16</md>
            </p>
            <p>
                Sketching the graph:
            </p>
                <image xml:id="img-example-origin" width="95%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[color=gray!30, step=1] (-5,-5) grid (5,5);
                            \draw[-&gt;] (-5,0) -- (5,0) node[right] {$x$};
                            \draw[-&gt;] (0,-5) -- (0,5) node[above] {$y$};
                            \filldraw (0,0) circle (2pt) node[above right] {$(0,0)$};
                            \draw[blue, thick] (0,0) circle (4);
                            \filldraw (4,0) circle (1.5pt) node[below right] {$(4,0)$};
                            \filldraw (-4,0) circle (1.5pt) node[below left] {$(-4,0)$};
                            \filldraw (0,4) circle (1.5pt) node[above left] {$(0,4)$};
                            \filldraw (0,-4) circle (1.5pt) node[below left] {$(0,-4)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Find the equation of a circle with center <m>(-2, 5)</m> and radius <m>3</m> units.
            </p>
        </statement>
        <solution>
            <p>
                We use the standard equation <m>(x - h)^2 + (y - k)^2 = r^2</m>.
            </p>
            <p>
                Here, <m>h = -2</m>, <m>k = 5</m>, and <m>r = 3</m>.
            </p>
            <p>
                Substituting these values:
                <md>(x - (-2))^2 + (y - 5)^2 = 3^2</md>
                <md>(x + 2)^2 + (y - 5)^2 = 9</md>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Identify the center and radius of the circle with equation <md>(x - 3)^2 + (y + 4)^2 = 25</md> Sketch its graph.
            </p>
        </statement>
        <solution>
            <p>
                Comparing <m>(x - 3)^2 + (y + 4)^2 = 25</m> with <m>(x - h)^2 + (y - k)^2 = r^2</m>:
                <ul>
                    <li>
                        <p>
                            <m>h = 3</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>k = -4</m> (since <m>y + 4 = y - (-4)</m>)
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>r^2 = 25 \Rightarrow r = \sqrt{25} = 5</m>
                        </p>
                    </li>
                </ul>
            </p>
            <p>
                The center is <m>(3, -4)</m> and the radius is <m>5</m>.
            </p>
                <image xml:id="img-example-h-k" width="95%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (-3,-10) grid (9,2);
                            \draw[-&gt;] (-3,0) -- (9,0) node[right] {$x$};
                            \draw[-&gt;] (0,-10) -- (0,2) node[above] {$y$};
                            \filldraw (3,-4) circle (2pt) node[above right] {$(3,-4)$};
                            \draw[blue, thick] (3,-4) circle (5);
                            \filldraw (8,-4) circle (1.5pt);
                            \filldraw (-2,-4) circle (1.5pt);
                            \filldraw (3,1) circle (1.5pt);
                            \filldraw (3,-9) circle (1.5pt);
                        \end{tikzpicture}
                    </latex-image>
                </image>
            <p>
                To sketch the graph:
                <ol>
                    <li>
                        <p>
                            Plot the center <m>(3, -4)</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Move 5 units up, down, left, and right from the center to find four points on the circle: <m>(3, 1), (3, -9), (-2, -4), (8, -4)</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Draw a smooth circle passing through these points.
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                Identify the correct equation for the graph below:
            </p>
            <image width="95%">
                <latex-image label="fig-example-multiple-choice">
                    \begin{tikzpicture}[scale=0.7]
                        \draw[help lines, color=gray!30, step=1] (-5,-10) grid (7,4);
                        \draw[-&gt;] (-5,0) -- (7,0) node[right] {$x$};
                        \draw[-&gt;] (0,-10) -- (0,4) node[above] {$y$};
                        \filldraw (1,-2) circle (2pt) node[above right] {$(1,-2)$};
                        \draw[blue, thick] (1,-2) circle (6);
                        \filldraw (7,-2) circle (1.5pt);
                        \filldraw (-5,-2) circle (1.5pt);
                        \filldraw (1,4) circle (1.5pt);
                        \filldraw (1,-8) circle (1.5pt);
                    \end{tikzpicture}
                </latex-image>
                
            </image>
            <p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p>
                            <m> y^2 = x^2 + 6^2 </m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>(x - 1)^2 + (y + 2)^2 = 36</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>(x + 1)^2 + (y - 2)^2 = 36</m>
                        </p>        
                    </li>
                    <li>
                        <p>
                            <m>(x - 1)^2 + (y - 2)^2 = 36</m>
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                Identify an <m>x^2</m> term and <m>y^2</m> term.
            </p>
            <p>
                The equation must be in the form <m>(x - h)^2 + (y - k)^2 = r^2</m>.
            </p>
            <p>
                The center is <m>(1, -2)</m>, so <m>h = 1</m> and <m>k = -2</m>.
            </p>
            <p>
                The radius is 6, so <m>r^2 = 36</m>.
            </p>
            <p>
                Substituting these values gives:
                <md>(x - 1)^2 + (y - (-2))^2 = 36</md>
                <md>(x - 1)^2 + (y + 2)^2 = 36</md>
            </p>
            <p>
                Therefore, the correct equation is <m>(x - 1)^2 + (y + 2)^2 = 36</m>.
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <exercises>
        <exercise>
            <statement>   
                <p>
                    Write the equation of a circle with the following properties:
                </p>
                <ol>
                    <li>
                        <p>
                            Center <m>(0, 0)</m>, radius <m>7</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            Center <m>(1, -2)</m>, radius <m>6</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            Center <m>(-3, -5)</m>, radius <m>\sqrt{10}</m>
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol>
                    <li><p><m>x^2 + y^2 = 49</m></p></li>
                    <li><p><m>(x - 1)^2 + (y + 2)^2 = 36</m></p></li>
                    <li><p><m>(x + 3)^2 + (y + 5)^2 = 10</m></p></li>
                </ol>
            </answer>
            <solution>
                <ol>
                    <li>
                        <p>
                            <m>x^2 + y^2 = 7^2 \Rightarrow x^2 + y^2 = 49</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>(x - 1)^2 + (y - (-2))^2 = 6^2 \Rightarrow (x - 1)^2 + (y + 2)^2 = 36</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>(x - (-3))^2 + (y - (-5))^2 = (\sqrt{10})^2 \Rightarrow (x + 3)^2 + (y + 5)^2 = 10</m>
                        </p>
                    </li>
                </ol>
            </solution>             
        </exercise>        

        <exercise>
            <statement>
                <p>
                    Identify the center and radius of the following circles:
                </p>
                <ol>
                    <li>
                        <p>
                            <m>x^2 + y^2 = 100</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>(x + 1)^2 + (y - 9)^2 = 81</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>(x - 4.5)^2 + (y + 2.5)^2 = 16</m>
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol>
                    <li><p>Center <m>(0, 0)</m>, radius <m>10</m></p></li>
                    <li><p>Center <m>(-1, 9)</m>, radius <m>9</m></p></li>
                    <li><p>Center <m>(4.5, -2.5)</m>, radius <m>4</m></p></li>
                </ol>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A circle has center <m>(2, 3)</m> and passes through the point <m>(5, 7)</m>. Find its equation.
                </p>
            </statement>
            <answer>
                <p><m>(x - 2)^2 + (y - 3)^2 = 25</m></p>
            </answer>
            <solution>
                <p>
                    First, find the radius using the distance formula between the center <m>(2, 3)</m> and point <m>(5, 7)</m>:
                    <md>r = \sqrt{(5 - 2)^2 + (7 - 3)^2}</md>
                    <md>r = \sqrt{3^2 + 4^2} = \sqrt{9 + 16} = \sqrt{25} = 5</md>
                </p>
                <p>
                    The equation is:
                    <md>
                        <mrow>(x - 2)^2 + (y - 3)^2 \amp = 5^2</mrow>
                        <mrow>(x - 2)^2 + (y - 3)^2 \amp = 25</mrow>
                    </md>
                    

                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Sketch the graph of <m>(x + 2)^2 + y^2 = 4</m>.
                </p>
            </statement>
            <answer>
                <p>
                    Center: <m>(-2, 0)</m>, Radius: <m>2</m>.
                </p>
                <p>
                    Key points: <m>(-2, 2), (-2, -2), (0, 0), (-4, 0)</m>.
                </p>
                    <image xml:id="img-exercise-sketch" width="95%">
                        <latex-image>
                            \begin{tikzpicture}[scale=0.7]
                                \draw[color=gray!30, step=1] (-6,-3) grid (2,3);
                                \draw[-&gt;] (-6,0) -- (2,0) node[right] {$x$};
                                \draw[-&gt;] (0,-3) -- (0,3) node[above] {$y$};
                                \filldraw (-2,0) circle (2pt) node[below] {$(-2,0)$};
                                \draw[blue, thick] (-2,0) circle (2);
                                \filldraw (0,0) circle (1.5pt);
                                \filldraw (-4,0) circle (1.5pt);
                                \filldraw (-2,2) circle (1.5pt);
                                \filldraw (-2,-2) circle (1.5pt);
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Determine if the point <m>(1, 2)</m> lies on, inside, or outside the circle <m>x^2 + y^2 = 9</m>.
                </p>
            </statement>
            <answer>
                <p>Inside</p>
            </answer>
            <solution>
                <p>
                    Since the circle is centered at the origin with radius 3, we can find the distance from the point <m>(1, 2)</m> to the center:
                    <md>d = \sqrt{(1 - 0)^2 + (2 - 0)^2} = \sqrt{1 + 4} = \sqrt{5}</md>
                </p>
                <p>
                    Since <m>\sqrt{5} &lt; 3</m>, the point lies <alert>inside</alert> the circle.
                </p>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Consider the equation <m>x^2 + y^2 - 4x + 6y - 3 = 0</m>.
                </p>
                <ol marker="(a)">
                    <li>
                        <p>
                            Find at least four points <m>(x, y)</m> that satisfy the equation and plot them on a coordinate plane.
                            What shape do they seem to lie on?
                        </p>
                        <hint>
                            <p>
                                Try <m>x = 2</m> and solve for <m>y</m>. Then try <m>y = -3</m> and solve for <m>x</m>. Look for integer solutions to make it easier.
                            </p>
                        </hint>
                    </li>
                    <li>
                        <p>
                            Complete the square in both <m>x</m> and <m>y</m> to rewrite the equation in standard form.
                            Identify the center and radius of the circle.
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)">
                    <li>
                        <p>
                            Four points on the curve: <m>(2, 1)</m>, <m>(2, -7)</m>, <m>(6, -3)</m>, <m>(-2, -3)</m>.
                            They lie on a circle.
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>(x - 2)^2 + (y + 3)^2 = 16</m>; center <m>(2, -3)</m>, radius <m>4</m>.
                        </p>
                    </li>
                </ol>
            </answer>
            <solution>
                <ol marker="(a)">
                    <li>
                    <p>
                        We look for integer solutions by trying values of <m>x</m> and solving for <m>y</m>, or by
                        noting that the equation must be satisfied exactly.  Four convenient points are found by
                        checking directly:
                    </p>
                    <tabular halign="center" top="minor" bottom="minor" left="minor" right="minor">
                        <row header="yes">
                            <cell><m>x</m></cell><cell><m>y</m></cell><cell>Check: <m>x^2+y^2-4x+6y-3</m></cell>
                        </row>
                        <row><cell><m>2</m></cell><cell><m>1</m></cell><cell><m>4+1-8+6-3=0\checkmark</m></cell></row>
                        <row><cell><m>2</m></cell><cell><m>-7</m></cell><cell><m>4+49-8-42-3=0\checkmark</m></cell></row>
                        <row><cell><m>6</m></cell><cell><m>-3</m></cell><cell><m>36+9-24-18-3=0\checkmark</m></cell></row>
                        <row><cell><m>-2</m></cell><cell><m>-3</m></cell><cell><m>4+9+8-18-3=0\checkmark</m></cell></row>
                    </tabular>
                    <p>
                        Plotting these four points, they appear to lie on a circle centred somewhere around
                        <m>(2, -3)</m>.
                    </p>
                    <image width="65%">
                        <latex-image>
                            \begin{tikzpicture}[scale=0.6]
                                \draw[color=gray!30, step=1] (-4,-9) grid (8,3);
                                \draw[-&gt;, thick] (-4,0) -- (8,0) node[right] {$x$};
                                \draw[-&gt;, thick] (0,-9) -- (0,3) node[above] {$y$};
                                \foreach \x in {-3,-2,-1,1,2,3,4,5,6,7}
                                    \draw (\x,0.08)--(\x,-0.08) node[below,font=\tiny] {$\x$};
                                \foreach \y in {-8,-7,-6,-5,-4,-3,-2,-1,1,2}
                                    \draw (0.08,\y)--(-0.08,\y) node[left,font=\tiny] {$\y$};
                                \draw[blue, thick] (2,-3) circle (4);
                                \filldraw[red] (2,1)   circle (3pt) node[above right] {$(2,1)$};
                                \filldraw[red] (2,-7)  circle (3pt) node[below right] {$(2,-7)$};
                                \filldraw[red] (6,-3)  circle (3pt) node[right]       {$(6,-3)$};
                                \filldraw[red] (-2,-3) circle (3pt) node[left]        {$(-2,-3)$};
                                \filldraw (2,-3) circle (2pt) node[below right, font=\small] {$(2,-3)$};
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                        </li>
                <li>
                <p>
                    Group the <m>x</m>-terms and <m>y</m>-terms and move the constant to the right:
                </p>
                <p>
                    <md>
                        <mrow>(x^2 - 4x) + (y^2 + 6y) \amp= 3</mrow>
                    </md>
                </p>
                <p>
                    Complete the square for each group.  For <m>x</m>: half of <m>-4</m> is <m>-2</m>,
                    and <m>(-2)^2 = 4</m>.  For <m>y</m>: half of <m>6</m> is <m>3</m>,
                    and <m>3^2 = 9</m>.  Add the same amounts to the right-hand side to keep the equation balanced:
                    <md>
                        <mrow>(x^2 - 4x + 4) + (y^2 + 6y + 9) \amp= 3 + 4 + 9</mrow>
                        <mrow>(x - 2)^2 + (y + 3)^2 \amp= 16</mrow>
                    </md>
                </p>
                <p>
                    This is the standard form of a circle with center <m>(2, -3)</m> and radius <m>r = \sqrt{16} = 4</m>.
                </p>
            </li>
                </ol>
            </solution>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        Provide a physical compass and pre-drawn grids. Focus on circles centered at the origin before moving to <m>(h, k)</m>.
                    </cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above, including derivation of the formula.</line>
                    </cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        Ask learners to find the equation of a circle given its diameter endpoints or to complete the square to find the center and radius from general form <m>x^2 + y^2 + Dx + Ey + F = 0</m>.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

