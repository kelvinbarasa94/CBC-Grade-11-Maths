<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-graphical-methods-in-real-life" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Graphical Methods in Real Life</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.6 Graphical Methods
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Apply graphical methods (circles, quadratics, simultaneous equations, rates of change, and linearization) to solve real-world problems in various fields.
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        20 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To apply graphical models (circles and simultaneous solutions) to solve spatial coverage and resource optimization problems.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Facilitate the group work by ensuring learners understand how to translate real-world locations into coordinates and how to represent constraints as mathematical boundaries.
                    </p>
                </li>
            </dl>
        </axiom>

    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                <alert>Work in groups</alert>
            </p>
            <p>
                You are network engineers for "GlobalLink Telecom". Your task is to provide signal coverage for your rural community.
            </p>
            <p>
                <alert>What you need</alert>
            </p>
                <p>
                    <ul>
                        <li>
                           <p> 
                             Graph paper (representing a <m>10 \times 10</m> km map)
                            </p>
                        </li>
                        <li>
                            <p>
                                Compass and Ruler
                            </p>
                        </li>
                        <li>
                            <p>
                                Colored pencils
                            </p>
                        </li>
                    </ul>
                </p>
            <p>
                <alert>What to do</alert>
            </p>
            <p>
                <ol>
                    <li>
                        <p>
                            On your graph paper, set the town center at the origin <m>(0,0)</m>.
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Students should draw a Cartesian plane with the horizontal axis labeled <m>x</m> (km) and the vertical axis labeled <m>y</m> (km), intersecting at <m>(0,0)</m>.
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            The community has three key zones that MUST have signal:
                            <ul>
                                <li>Zone A (School): located at <m>(3, 4)</m></li>
                                <li>Zone B (Hospital): located at <m>(-4, -3)</m></li>
                                <li>Zone C (Market): located at <m>(0, -5)</m></li>
                            </ul>
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Students should plot the points <m>A(3,4)</m>, <m>B(-4,-3)</m>, and <m>C(0,-5)</m> on their grids as shown in the initial diagram.
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            You have two cell towers. Each tower has a circular coverage range of <m>5</m> km.
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Each tower covers a circular area defined by the inequality <m>(x-h)^2 + (y-k)^2 \le 25</m>, where <m>(h,k)</m> is the tower's location.
                            </p>
                        </solution>
                        <image width="65%">
                            <latex-image label="Graphical-representation-of-the-telecom-problem">
                                \begin{tikzpicture}
                                \begin{axis}[
                                    axis lines=center,
                                    xlabel={$x$ (km)},
                                    ylabel={$y$ (km)},
                                    xmin=-6, xmax=6,
                                    ymin=-6, ymax=6,
                                    xtick={-4,-2,2,4},
                                    ytick={-4,-2,2,4},
                                    tick label style={font=\footnotesize},
                                    grid=both,
                                    grid style={line width=0.3pt, draw=gray!30},
                                    axis equal image,
                                ]
                                    \addplot[only marks, mark=*, mark size=2pt, red] coordinates {(3,4)};
                                    \node[above right, font=\footnotesize, red] at (axis cs:3,4) {Zone A};
                                    \addplot[only marks, mark=*, mark size=2pt, blue] coordinates {(-4,-3)};
                                    \node[below left, font=\footnotesize, blue] at (axis cs:-4,-3) {Zone B};
                                    \addplot[only marks, mark=*, mark size=2pt, green!60!black] coordinates {(0,-5)};
                                    \node[below, font=\footnotesize, green!60!black] at (axis cs:0,-5) {Zone C};
                                \end{axis}
                                \end{tikzpicture}
                            </latex-image>
                            
                        </image>
                    </li>
                    <li>
                        <p>
                            Decide on the best coordinates to place your two towers so that all three zones receive a signal. Hint: Use the equations of circles <m>(x-h)^2 + (y-k)^2 = r^2</m>.
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                By inspecting the coordinates, students may notice that <m>A(3,4)</m>, <m>B(-4,-3)</m>, and <m>C(0,-5)</m> are all exactly <m>5</m> units from the origin. While a single tower at <m>(0,0)</m> would cover all three on its boundary, using two towers allows for more robust coverage. For example, placing Tower 1 at <m>(1,1)</m> and Tower 2 at <m>(-1,-3)</m> ensures all zones are well within the signal circles.
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Draw the circles representing the coverage area for each tower.
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Students should use a compass set to a radius of <m>5</m> units (km) to draw circles centered at their chosen tower coordinates. The resulting map should show all three zones inside or on the boundary of the circles.
                            </p>
                        </solution>
                        <image width="40%">
                            <latex-image label="Graphical-representation-of-the-telecom-problem-with-coverage-circles">
                                \begin{tikzpicture}
                                \begin{axis}[
                                    axis lines=center,
                                    xlabel={$x$ (km)},
                                    ylabel={$y$ (km)},
                                    xmin=-8, xmax=8,
                                    ymin=-8, ymax=8,
                                    xtick={-6,-4,-2,2,4,6},
                                    ytick={-6,-4,-2,2,4,6},
                                    tick label style={font=\footnotesize},
                                    grid=both,
                                    grid style={line width=0.3pt, draw=gray!30},
                                    axis equal image,
                                ]
                                    \addplot[thick, dashed, domain=0:360, samples=100, smooth]
                                        ({1 + 5*cos(\x)}, {1 + 5*sin(\x)});
                                    \addplot[thick, dashed, domain=0:360, samples=100, smooth]
                                        ({-2 + 5*cos(\x)}, {-2 + 5*sin(\x)});
                                    \addplot[only marks, mark=*, mark size=2pt, red] coordinates {(3,4)};
                                    \node[above right, font=\footnotesize, red] at (axis cs:3,4) {Zone A};
                                    \addplot[only marks, mark=*, mark size=2pt, blue] coordinates {(-4,-3)};
                                    \node[below left, font=\footnotesize, blue] at (axis cs:-4,-3) {Zone B};
                                    \addplot[only marks, mark=*, mark size=2pt, green!60!black] coordinates {(0,-5)};
                                    \node[below, font=\footnotesize, green!60!black] at (axis cs:0,-5) {Zone C};
                                \end{axis}
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li>
                        <p>
                            Identify the area where the signals overlap. Discuss: Is overlap good for the users (e.g., seamless handoff)? Is it efficient for the company (e.g., redundant equipment)?
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                Overlap is beneficial for users because it ensures a "seamless handoff" when moving between zones and provides redundancy if one tower fails. For the company, it can be seen as less efficient due to the cost of overlapping equipment, but it improves service reliability.
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                             Instead of placing towers yourself, consider a scenario where three towers are already fixed at <m>(0,0)</m>, <m>(6,0)</m>, and <m>(3,6)</m>, each with a coverage radius of <m>5</m> km. The school board wants to know if their school at <m>(3,4)</m> is in a "dead zone" or a "power zone".
                            <ul>
                                <li>
                                    <p>
                                        Write the mathematical equations for the three circular coverage areas to formalize the model.
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Plot these circles on your graph. Identify the intersection points of the towers at <m>(0,0)</m> and <m>(6,0)</m> graphically. Does the school lie exactly on this boundary?
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        By looking at your graph, determine if the school is covered by the third tower as well. If the tower at <m>(0,0)</m> were to fail, would the school still have signal?
                                    </p>
                                </li>
                            </ul>
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                <ol marker="i.">
                                    <li>
                                        <p>
                                            The model equations are: <m>x^2 + y^2 = 25</m>, <m>(x-6)^2 + y^2 = 25</m>, and <m>(x-3)^2 + (y-6)^2 = 25</m>.
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            By plotting the first two circles, students will observe that they intersect exactly at <m>(3, 4)</m> and <m>(3, -4)</m>. The school at <m>(3, 4)</m> lies directly on the intersection point of these two signal boundaries.
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            Visually, the school is well within the third circle. Since it lies on the boundary of two towers and inside a third, it is in a "triple-coverage" zone. Even if any one tower fails, the school remains connected—demonstrating the "impact" of redundant graphical design!
                                        </p>
                                    </li>
                                </ol>
                            </p>
                        </solution>
                    </li>
                </ol>
            </p>
        </statement>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize how graphical methods (simultaneous equations, rates of change, and linearization) are used across professional fields.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                        <alert>Visualization:</alert> Graphs transform abstract data into visual patterns, revealing critical points like intersections (solutions), vertices (maximums/minimums), and gradients (rates of change).
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Optimization:</alert> Finding the "sweet spot" in business or engineering often requires locating the vertex of a quadratic or the intersection of constraints.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Prediction:</alert> Linearization allows us to take complex, non-linear real-world trends and simplify them into predictable straight-line models.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <p>
            Graphical methods are used in countless real-world applications to make informed decisions, optimize outcomes, and predict future trends. Here are just a few examples:
            <ul>
                <li>
                    <p>
                        <alert>Economics:</alert> Analysts use "Break-Even" graphs to find the point where costs and revenue meet, determining the minimum sales needed for profit.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Medicine:</alert> Doctors use growth charts and dosage-response curves to monitor patient health and determine the safe rate of drug metabolism.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Environmental Science:</alert> Scientists use lines of best fit on historical temperature data to predict future climate trends and guide policy.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Sports Science:</alert> Coaches use velocity-time graphs to analyze acceleration, helping athletes find the exact moment to shift their effort for peak performance.
                    </p>
                </li>
            </ul>
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                A small business produces eco-friendly bags. The total monthly cost <m>C</m> (in KSh) is given by <m>C = 200x + 10000</m>, where <m>x</m> is the number of bags produced. The revenue <m>R</m> from selling the bags is <m>R = 450x</m>.
            </p>
            <ol marker="(a)">
                <li><p>Plot both graphs on the same axes for <m>0 \le x \le 100</m>.</p></li>
                <li><p>Use the graph to find the "Break-Even Point" (where <m>R = C</m>).</p></li>
            </ol>
        </statement>
        <solution>
            <ol marker="(a)">
                <li>
                    <image width="70%">
                        <latex-image label="Cost-and-Revenue-Functions">
                    \begin{tikzpicture}
                    \begin{axis}[
                        axis x line=bottom, axis y line=left,
                        xlabel={Number of bags $x$},
                        ylabel={Cost / Revenue (KSh '000)},
                        xmin=0, xmax=120,
                        ymin=0, ymax=60,
                        xtick={0,20,40,60,80,100,120},
                        ytick={10,20,30,40,50,60},
                        tick label style={font=\footnotesize},
                        grid=both,
                        grid style={line width=0.3pt, draw=gray!30},
                    ]
                        \addplot[blue, thick, dashed, domain=0:120, samples=2] {0.2*x + 10};
                        \node[blue, font=\footnotesize] at (axis cs:30,55) {$C = 200x + 10\,000$};
                        \addplot[red, thick, domain=0:120, samples=2] {0.45*x};
                        \node[red, right, font=\footnotesize] at (axis cs:90,42) {$R = 450x$};
                        \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(40,18)};
                        \node[right, font=\footnotesize] at (axis cs:40,18) {$(40,\ 18\,000)$};
                    \end{axis}
                    \end{tikzpicture}
                        </latex-image>
                    </image>
                </li>
                <li>
                    <p>
                        The intersection point is where <m>450x = 200x + 10000 \implies 250x = 10000 \implies x = 40</m>.
                    </p>
                    <p>
                        The break-even point is <m>40</m> bags. Selling more than <m>40</m> bags results in profit.
                    </p>
                </li>
            </ol>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                The concentration <m>K</m> (mg/L) of a certain medicine in a patient's blood over time <m>t</m> (hours) follows the curve <m>K = -t^2 + 6t + 2</m> for <m>0 \le t \le 6</m>. 
            </p>
            <p>
                Use a graph to estimate the instantaneous rate of change of the concentration at <m>t = 2</m> hours.
            </p>
        </statement>
        <solution>
            
                <image width="65%">
                    <latex-image label="Graphical-representation-of-the-drug-concentration-over-time">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis x line=bottom, axis y line=left,
                            xlabel={Time $t$ (hours)},
                            ylabel={Concentration $K$ (mg/L)},
                            xmin=0, xmax=7,
                            ymin=0, ymax=12,
                            xtick={0,1,2,3,4,5,6},
                            ytick={0,2,4,6,8,10,12},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=0:6, samples=80, smooth] {-x^2 + 6*x + 2};
                            \addplot[red, thick, domain=0:2.5, samples=2] {2*x + 6};
                            \node[red, right, font=\footnotesize] at (axis cs:0.2,7) {tangent at $(2,10)$};
                            \addplot[only marks, mark=*, mark size=2pt, blue] coordinates {(2,10)};
                            \node[above left, font=\footnotesize] at (axis cs:2,10) {$(2,10)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            <p>
                From the graph, we estimate the gradient of the tangent by choosing two points on the tangent, say <m>(1, 8)</m> and <m>(3, 12)</m>:
                <me>m = \frac{12 - 8}{3 - 1} = \frac{4}{2} = 2\text{ mg/L per hour}</me>
            </p>
            <p>
                At 2 hours, the drug concentration is increasing at a rate of 2 mg/L per hour.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                A circular support pillar has a cross-section modeled by the equation <m>x^2 + y^2 = 9</m> (units in cm). An engineer needs to install a brace along the line <m>y = x + 3</m>. 
            </p>
            <p>
                Determine graphically where the brace will touch the edge of the pillar.
            </p>
        </statement>
        <solution>
            <p>
                To find the intersection points, we can substitute <m>y = x + 3</m> into the circle equation:
                <md>
                    <mrow> x^2 + (x + 3)^2 \amp = 9  </mrow>
                    <mrow> x^2 + x^2 + 6x + 9 \amp = 9  </mrow>
                    <mrow> 2x^2 + 6x \amp = 0  </mrow>
                    <mrow> 2x(x + 3) \amp = 0 </mrow>
                </md>
                This gives us two solutions: <m>x = 0</m> and <m>x = -3</m>.
            </p>
            <p>
                Corresponding <m>y</m> values are:
                <md>
                    <mrow> y = 0 + 3 = 3 </mrow>
                    <mrow> y = -3 + 3 = 0 </mrow>
                </md>
            </p>
            
            <image width="65%">
                <latex-image label="Graphical-representation-of-the-pillar-and-brace">
                    \begin{tikzpicture}
                    \begin{axis}[
                        axis lines=center,
                        xlabel={$x$ (cm)},
                        ylabel={$y$ (cm)},
                        xmin=-4, xmax=4,
                        ymin=-4, ymax=4,
                        xtick={-3,-2,-1,1,2,3},
                        ytick={-3,-2,-1,1,2,3,4},
                        tick label style={font=\footnotesize},
                        grid=both,
                        grid style={line width=0.3pt, draw=gray!30},
                        axis equal image,
                    ]
                        \addplot[thick, red, domain=0:360, samples=100, smooth]
                            ({3*cos(\x)}, {3*sin(\x)});
                        \addplot[thick, blue, domain=-4:1, samples=2] {x + 3};
                        \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(0,3) (-3,0)};
                    \end{axis}
                    \end{tikzpicture}
                </latex-image>
            </image>
            
            <p>
                1. Draw the circle with center <m>(0,0)</m> and radius <m>3</m>.
            </p>
            <p>
                2. Draw the line <m>y = x + 3</m> (intercepts at <m>(0, 3)</m> and <m>(-3, 0)</m>).
            </p>
            <p>
                3. The intersection points on the graph are <m>(0, 3)</m> and <m>(-3, 0)</m>.
            </p>
            <p>
                The brace touches the pillar at these two points.
            </p>
        </solution>
    </example>

