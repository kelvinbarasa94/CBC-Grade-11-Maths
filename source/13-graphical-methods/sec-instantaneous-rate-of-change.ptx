<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-instantaneous-rate-of-change" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Instantaneous Rate of Change</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.6 Graphical Methods
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Determine average rate of change and average rate of change at an instant from a graph
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        15 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To discover how to estimate the rate of change at a specific point on a curve by drawing a tangent line.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Provide learners with curved graphs. Guide them in the technique of placing a ruler so it just touches the curve at a single point without crossing it.
                    </p>
                </li>
            </dl>
        </axiom>

    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                <alert> Work in groups </alert>
            </p>
            <p>
                You are helping design a modern, energy-efficient greenhouse.
                The roof of the greenhouse follows a perfect parabolic curve defined by the equation <m>y = x^2</m>, where <m>y</m> is the height and <m>x</m> is the horizontal distance from the center.
            </p>
            <p>
                A support beam needs to be attached to the roof exactly at the point where <m>x = 2</m>.
                To ensure the joint is secure, the lead engineer needs to know the gradient (slope) of the roof at that specific point. 
                This gradient tells us "how fast <m>y</m> is changing" compared to <m>x</m>.
            </p>
            <p>
                <alert>What you need</alert>
            </p>
            <p>
                <ul>
                    <li>
                        <p>
                            Graph paper
                        </p>
                    </li>
                    <li>
                        <p>
                            A transparent ruler
                        </p>
                    </li>
                    <li>
                        <p>
                            A pencil or pen
                        </p>
                    </li>
                </ul>
            </p>
            <p>
                <alert>What to do</alert>
            </p>
            <p>
                <ol>
                    <li>
                        <p>
                            Carefully plot the graph of <m>y = x^2</m> for <m>x</m> from <m>0</m> to <m>4</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Identify the point <m>(2, 4)</m> on your graph.
                        </p>
                    </li>
                    <li>
                        <p>
                            Using a transparent ruler, draw a line that <alert>just touches</alert> the curve at <m>(2, 4)</m>. This is the tangent line.
                        </p>
                    </li>
                    <li>
                        <p>
                            Pick two points on this tangent line that are easy to read from the grid.
                        </p>
                    </li>
                    <li>
                        <p>
                            Calculate the gradient of the tangent line. What does this value tell you about the curve at <m>x = 2</m>?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the concept of instantaneous rate of change as the gradient of the tangent at a point.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                        <alert>The Tangent Line:</alert> A tangent to a curve at a point is a straight line that touches the curve at that point and has the same gradient as the curve at that point.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Instantaneous Rate:</alert> The gradient of the tangent gives the <alert>instantaneous rate of change</alert> (the rate of change at that specific instant).
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <p>
            <ul>
                <li>
                    <p>
                        The <alert>instantaneous rate of change</alert> at a single point on a curve is the gradient of the <alert>tangent line</alert> at that point.
                    </p>
                    <p>
                        <term>Tangent line:</term> is a straight line that touches a curve at only one point.
                    </p>
                </li>
                <li>
                    <p>
                        To find the gradient at an instant from a graph:
                        <ol>
                            <li>
                                <p>
                                    Identify the point on the curve.
                                </p>
                            </li>
                            <li>
                                <p>
                                    Draw a tangent line at that point using a ruler.
                                </p>
                            </li>
                            <li>
                                <p>
                                    Pick two points on the tangent line and calculate its gradient using <m>m = \frac{\Delta y}{\Delta x}</m>.
                                </p>
                            </li>
                        </ol>
                    </p>
                </li>
            </ul>
        </p>
        <image xml:id="img-tangent-illustration" width="65%">
            <latex-image label="Tangent-Line-Illustration">
                \begin{tikzpicture}
                \begin{axis}[
                    axis lines=center,
                    xlabel={$x$},
                    ylabel={$y$},
                    xmin=0, xmax=6,
                    ymin=0, ymax=5,
                    tick label style={font=\footnotesize},
                    grid=both,
                    grid style={line width=0.3pt, draw=gray!30},
                ]
                    \addplot[blue, thick, samples=60, smooth] {0.2*x^2 + 1};
                    \addplot[green!60!black, thick, domain=0.5:3.5, samples=2] {0.8*x + 0.2};
                    \node[right, font=\footnotesize] at (axis cs:3.5,3) {Tangent line};
                    \addplot[only marks, mark=*, mark size=1.5pt, black] coordinates {(2,1.8)};
                    \node[below right, font=\footnotesize] at (axis cs:2,1.8) {Point of tangency};
                \end{axis}
                \end{tikzpicture}
            </latex-image>
        </image>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Using a graph of <m>y = x^2</m>, estimate the gradient of the curve at the point <m>(2, 4)</m>.
            </p>
        </statement>
        <solution>
            <p>
                <ol>
                    <li>
                        <p>
                            Plot the graph of <m>y = x^2</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Draw a tangent line to the curve at the point <m>(2, 4)</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Choose two points on the tangent line, for example <m>(1, 0)</m> and <m>(3, 8)</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Calculate the gradient of the tangent:
                            <me>\text{Gradient} = \frac{8 - 0}{3 - 1} = \frac{8}{2} = 4</me>
                        </p>
                    </li>
                </ol>
            </p>
            <image xml:id="img-example-tangent-inst" width="65%">
                <latex-image>
                    \begin{tikzpicture}
                    \begin{axis}[
                        axis lines=center,
                        xlabel={$x$},
                        ylabel={$y$},
                        xmin=-1, xmax=5,
                        ymin=0, ymax=10,
                        xtick={-1,1,2,3,4},
                        ytick={2,4,6,8,10},
                        tick label style={font=\footnotesize},
                        grid=both,
                        grid style={line width=0.3pt, draw=gray!30},
                    ]
                        \addplot[blue, thick, domain=0:3.1, samples=60, smooth] {x^2};
                        \addplot[green!60!black, thick, domain=1:3, samples=2] {4*x - 4};
                        \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(2,4) (1,0) (3,8)};
                        \node[above left, font=\footnotesize] at (axis cs:2,4) {$(2,4)$};
                        \node[below left, font=\footnotesize] at (axis cs:1,0) {$(1,0)$};
                        \node[right, font=\footnotesize] at (axis cs:3,8) {$(3,8)$};
                        \draw[dashed, black, thick] (axis cs:1,0) -- (axis cs:3,0)
                            node[midway, below, font=\footnotesize] {$\Delta x = 2$};
                        \draw[dashed, black, thick] (axis cs:3,0) -- (axis cs:3,8)
                            node[midway, right, font=\footnotesize] {$\Delta y = 8$};
                    \end{axis}
                    \end{tikzpicture}
                </latex-image>
            </image>
            <p>
                The estimated instantaneous rate of change at <m>x = 2</m> is <m>4</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                The volume of water <m>V</m> (litres) in a leaking tank over time <m>t</m> (minutes) is given by <m>V = 100 - t^2</m>. Find the rate at which water is leaking exactly at <m>t = 5</m> minutes by drawing a tangent.
            </p>
        </statement>
        <solution>
            <p>
                <ol>
                    <li>
                        <p>
                            Plot the graph of <m>V = 100 - t^2</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Draw a tangent at the point <m>(5, 75)</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Pick points on the tangent like <m>(4, 85)</m> and <m>(6, 65)</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Gradient = <m>\frac{65 - 85}{6 - 4} = \frac{-20}{2} = -10</m> litres/minute.
                        </p>
                    </li>
                </ol>
            </p>
            <image xml:id="img-example-volume-inst" width="85%">
                <description>Graph of V = 100 - t^2 with a tangent line and gradient triangle at t=5.</description>
                <latex-image>
                    \begin{tikzpicture}
                    \begin{axis}[
                        axis x line=bottom, axis y line=left,
                        xlabel={$t$},
                        ylabel={$V$},
                        xmin=0, xmax=12,
                        ymin=0, ymax=105,
                        xtick={0,2,4,6,8,10},
                        ytick={0,20,40,60,80,100},
                        tick label style={font=\footnotesize},
                        grid=both,
                        grid style={line width=0.3pt, draw=gray!30},
                    ]
                        \addplot[blue, thick, domain=0:10, samples=80, smooth] {100 - x^2};
                        \addplot[green!60!black, thick, domain=3:7, samples=2] {-10*x + 125};
                        \node[right, font=\footnotesize] at (axis cs:7,55) {Tangent at $t=5$};
                        \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(5,75) (4,85) (6,65)};
                        \node[below left, font=\footnotesize] at (axis cs:5,75) {$(5,75)$};
                        \draw[dashed, black, thick] (axis cs:4,85) -- (axis cs:6,85);
                        \draw[dashed, black, thick] (axis cs:6,85) -- (axis cs:6,65)
                            node[midway, right, font=\footnotesize] {$\Delta V = -20$};
                    \end{axis}
                    \end{tikzpicture}
                </latex-image>
            </image>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Estimate the instantaneous rate of change of <m>y = x^3</m> at <m>x = 1</m> from a graph.
            </p>
        </statement>
        <solution>
            <p>
                <ol>
                    <li>
                        <p>
                            Plot <m>y = x^3</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Draw the tangent at <m>(1, 1)</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Picking points on the tangent such as <m>(0, -2)</m> and <m>(2, 4)</m>:
                            <me>\text{Gradient} = \frac{4 - (-2)}{2 - 0} = \frac{6}{2} = 3</me>
                        </p>
                    </li>
                </ol>
            </p>
            <image xml:id="img-example-cubic-tangent-inst" width="65%">
                <description>Graph of y = x^3 with a tangent line and gradient triangle at x=1.</description>
                <latex-image>
                    \begin{tikzpicture}
                    \begin{axis}[
                        axis lines=center,
                        xlabel={$x$},
                        ylabel={$y$},
                        xmin=-3.5, xmax=3.5,
                        ymin=-8, ymax=8,
                        xtick={-2,-1,1,2},
                        ytick={-6,-4,-2,2,4,6},
                        tick label style={font=\footnotesize},
                        grid=both,
                        grid style={line width=0.3pt, draw=gray!30},
                    ]
                        \addplot[blue, thick, domain=-2.04:2.04, samples=60, smooth] {x^3};
                        \addplot[green!60!black, thick, domain=-1:2.5, samples=2] {3*x - 2};
                        \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(1,1) (0,-2) (2,4)};
                        \node[right, font=\footnotesize] at (axis cs:1,1) {$(1,1)$};
                        \draw[dashed, black, thick] (axis cs:0,-2) -- (axis cs:2,-2)
                            node[midway, below, font=\footnotesize] {$\Delta x = 2$};
                        \draw[dashed, black, thick] (axis cs:2,-2) -- (axis cs:2,4)
                            node[midway, right, font=\footnotesize] {$\Delta y = 6$};
                    \end{axis}
                    \end{tikzpicture}
                </latex-image>
            </image>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Sketch the graph of <m>y = 2x^2 + 1</m>. Estimate the gradient of the curve at <m>x = 1</m> by drawing a tangent.
                </p>
            </statement>
            <answer>
                <image width="65%">
                    <latex-image label="Graph of y = 2x^2 + 1 with Tangent Line">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-1, xmax=3,
                            ymin=-2, ymax=8,
                            xtick={-1,0,1,2,3},
                            ytick={-2,0,2,4,6,8},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]

                            % Curve
                            \addplot[
                                blue,
                                thick,
                                domain=-0.5:2.5,
                                samples=200
                            ]
                            {2*x^2 + 1};

                            % Tangent
                            \addplot[
                                green!60!black,
                                very thick,
                                domain=0:2.3
                            ]
                            {4*x - 1};

                            % Points used
                            \addplot[
                                only marks,
                                mark=*,
                                mark size=2.5pt,
                                black
                            ]
                            coordinates {
                                (1,3)
                                (0,-1)
                                (2,7)
                            };

                            % Labels
                            \node[right,font=\footnotesize]
                                at (axis cs:1,3)
                                {$(1,3)$};

                            \node[below left,font=\footnotesize]
                                at (axis cs:0,-1)
                                {$(0,-1)$};

                            \node[above right,font=\footnotesize]
                                at (axis cs:2,7)
                                {$(2,7)$};

                            % Slope triangle
                            \draw[dashed,black,thick]
                                (axis cs:0,-1) --
                                (axis cs:2,-1);

                            \draw[dashed,black,thick]
                                (axis cs:2,-1) --
                                (axis cs:2,7);

                            \node[below,font=\footnotesize]
                                at (axis cs:1,-1)
                                {$\Delta x = 2$};

                            \node[right,font=\footnotesize]
                                at (axis cs:2,3)
                                {$\Delta y = 8$};

                            % Tangent label
                            \node[
                                font=\footnotesize,
                                green!60!black
                            ]
                            at (axis cs:2.4,6)
                            {$y=8x-5$};

                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    (The learner should draw the curve and a tangent at <m>(1, 3)</m>).
                    Picking points on the tangent such as <m>(0, -1)</m> and <m>(2, 7)</m>:
                    <me>\text{Gradient} = \frac{7 - (-1)}{2 - 0} = \frac{8}{2} = 4</me>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A ball is thrown upwards such that its height <m>h</m> at time <m>t</m> is <m>h = 20t - 5t^2</m>. Use a graph to estimate the velocity of the ball at <m>t = 1</m> second.
                </p>
            </statement>
            <answer>
                <p>
                    The velocity at an instant is the gradient of the tangent at that time.
                    Plotting <m>h = 20t - 5t^2</m> and drawing a tangent at <m>(1, 15)</m>:
                    The gradient of the tangent is <m>10</m> m/s which represents the velocity.
                </p>
                <image xml:id="img-ex-velocity-inst" width="65%">
                    <latex-image label="Projectile-Motion-with-Tangent-Line">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis x line=bottom, axis y line=left,
                            xlabel={$t$},
                            ylabel={$h$},
                            xmin=0, xmax=4,
                            ymin=0, ymax=30,
                            xtick={0,1,2,3,4},
                            ytick={0,5,10,15,20,25, 30},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=0:4, samples=80, smooth] {20*x - 5*x^2};
                            \addplot[green!60!black, thick, domain=0:2, samples=2] {10*x + 5};
                            \node[right, font=\footnotesize] at (axis cs:2,25) {Tangent at $t=1$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(1,15) (0,5) (2,25)};
                            \draw[dashed, black, thick] (axis cs:0,5) -- (axis cs:2,5);
                            \draw[dashed, black, thick] (axis cs:2,5) -- (axis cs:2,25)
                                node[midway, right, font=\footnotesize] {$\Delta h = 20$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Sketch the graph of <m>y = 4 - x^2</m>. Estimate the gradient of the curve at <m>x = 1</m>.
                </p>
            </statement>
            <answer>
                <p>
                    Plot <m>y = 4 - x^2</m> and draw a tangent at <m>(1, 3)</m>.
                    Picking points on the tangent like <m>(0, 5)</m> and <m>(2, 1)</m>:
                    <me>\text{Gradient} = \frac{1 - 5}{2 - 0} = \frac{-4}{2} = -2</me>
                </p>
                <image xml:id="img-ex-quad-neg-inst" width="85%">
                    <latex-image label="Graph-estimation-of-gradient-at-x=1">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-3, xmax=4,
                            ymin=-5, ymax=6,
                            xtick={-2,-1,1,2},
                            ytick={-4,-2,2,4,6},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=-2.5:2.5, samples=60, smooth] {4 - x^2};
                            \addplot[green!60!black, thick, domain=-0.5:2.5, samples=2] {-2*x + 5};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(1,3) (0,5) (2,1)};
                            \node[right, font=\footnotesize] at (axis cs:1,3) {$(1,3)$};
                            \draw[dashed, black, thick] (axis cs:0,5) -- (axis cs:2,5);
                            \draw[dashed, black, thick] (axis cs:2,5) -- (axis cs:2,1)
                                node[midway, right, font=\footnotesize] {$\Delta y = -4$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The number of bacteria <m>N</m> in a culture after <m>t</m> hours is given by <md>N = 2t^2 + 10</md> Estimate the rate of growth of the bacteria at <m>t = 3</m> hours.
                </p>
            </statement>
            <answer>
                <p>
                    At <m>t = 3</m>, <m>N = 2(3)^2 + 10 = 28</m>.
                    Draw a tangent at <m>(3, 28)</m> and pick points like <m>(2, 16)</m> and <m>(4, 40)</m>.
                    <me>\text{Rate} = \frac{40 - 16}{4 - 2} = \frac{24}{2} = 12 \text{ bacteria/hour}</me>
                </p>
                <image xml:id="img-ex-bacteria-inst" width="65%">
                    <latex-image label="Bacterial-Growth-with-Tangent-Line">
                        \begin{tikzpicture}
                        \begin{axis}[
                                axis x line=bottom, axis y line=left,
                                xlabel={$t$ (hours)},
                                ylabel={$N$ (bacteria)},
                                xmin=0, xmax=5,
                                ymin=0, ymax=50,
                                xtick={0,1,2,3,4},
                                ytick={0,10,20,30,40,50},
                                tick label style={font=\footnotesize},
                                grid=both,
                                grid style={line width=0.3pt, draw=gray!30},
                            ]
                            \addplot[blue, thick, domain=0:4.2, samples=60, smooth] {2*x^2 + 10};
                            \addplot[green!60!black, thick, domain=1.8:4.2, samples=2] {12*x - 8};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(3,28) (2,16) (4,40)};
                            \node[below left, font=\footnotesize] at (axis cs:3,28) {$(3,28)$};
                            \draw[dashed, black, thick] (axis cs:2,16) -- (axis cs:4,16)
                                node[midway, below, font=\footnotesize] {$\Delta t = 2$};
                            \draw[dashed, black, thick] (axis cs:4,16) -- (axis cs:4,40)
                                node[midway, right, font=\footnotesize] {$\Delta N = 24$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Sketch the graph of <m>y = \frac{1}{2}x^2</m>. Estimate the instantaneous rate of change at <m>x = -2</m>.
                </p>
            </statement>
            <answer>
                <p>
                    At <m>x = -2</m>, <m>y = 2</m>. Draw a tangent at <m>(-2, 2)</m>.
                    Pick points on the tangent such as <m>(0, -2)</m> and <m>(-3, 4)</m>.
                    <me>\text{Gradient} = \frac{4 - (-2)}{-3 - 0} = \frac{6}{-3} = -2</me>
                </p>
                <image xml:id="img-ex-quad-neg-x-inst" width="65%">
                    <latex-image label="Quadratic_Function_representation">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-4, xmax=2,
                            ymin=-3, ymax=6,
                            xtick={-3,-2,-1,1},
                            ytick={-2,2,4,6},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=-3.4:2, samples=60, smooth] {0.5*x^2};
                            \addplot[green!60!black, thick, domain=-3.5:0.5, samples=2] {-2*x - 2};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(-2,2) (0,-2) (-3,4)};
                            \draw[dashed, black, thick] (axis cs:0,-2) -- (axis cs:-3,-2)
                                node[midway, below, font=\footnotesize] {$\Delta x = -3$};
                            \draw[dashed, black, thick] (axis cs:-3,-2) -- (axis cs:-3,4)
                                node[midway, left, font=\footnotesize] {$\Delta y = 6$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>
                    For <m>f(x) = x^2</m>, estimate the instantaneous rate of change at <m>x = 3</m> by computing the average rate of change over <m>[3,\ 3+h]</m> for decreasing values of <m>h</m>.
                </p>
                <p>
                    <tabular top="minor" bottom="minor" left="minor" right="minor" halign="center">
                        <row header="yes">
                            <cell><m>h</m></cell>
                            <cell><m>f(3+h)</m></cell>
                            <cell>AROC <m>= \dfrac{f(3+h)-f(3)}{h}</m></cell>
                        </row>
                        <row><cell><m>1</m></cell><cell></cell><cell></cell></row>
                        <row><cell><m>0.5</m></cell><cell></cell><cell></cell></row>
                        <row><cell><m>0.1</m></cell><cell></cell><cell></cell></row>
                        <row><cell><m>0.01</m></cell><cell></cell><cell></cell></row>
                    </tabular>
                </p>
                <p>What value does the AROC appear to approach? This is the instantaneous rate of change at <m>x = 3</m>.</p>
            </statement>
            <answer>
                <p>
                    <tabular top="minor" bottom="minor" left="minor" right="minor" halign="center">
                        <row header="yes">
                            <cell><m>h</m></cell><cell><m>f(3+h)</m></cell><cell>AROC <m>= 6+h</m></cell>
                        </row>
                        <row><cell>1</cell><cell>16</cell><cell>7</cell></row>
                        <row><cell>0.5</cell><cell>12.25</cell><cell>6.5</cell></row>
                        <row><cell>0.1</cell><cell>9.61</cell><cell>6.1</cell></row>
                        <row><cell>0.01</cell><cell>9.0601</cell><cell>6.01</cell></row>
                    </tabular>
                </p>
                <p>The AROC approaches <m>6</m> as <m>h \to 0</m>. The instantaneous rate of change at <m>x = 3</m> is <m>6</m>.</p>

                <image width="70%">
                    <latex-image label="Instantaneous-Rate-of-Change-at-3">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=left,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=2, xmax=4.5,
                            ymin=3, ymax=18,
                            xtick={2,2.5,3,3.5,4},
                            ytick={4,8,12,16},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.2pt, draw=gray!30},
                            width=11cm,
                            height=8cm
                        ]

                            % Parabola
                            \addplot[
                                blue,
                                thick,
                                domain=2:4.5,
                                samples=200
                            ] {x^2};

                            % Secant h = 1
                            \addplot[
                                red,
                                dashed,
                                thick,
                                domain=2.4:4.3
                            ] {7*x - 12};

                            % Secant h = 0.5
                            \addplot[
                                orange,
                                dashed,
                                thick,
                                domain=2.5:4
                            ] {6.5*x - 10.5};

                            % Tangent line at x=3
                            \addplot[
                                green!60!black,
                                very thick,
                                domain=2.3:4.2
                            ] {6*x - 9};

                            % Key points
                            \addplot[
                                only marks,
                                mark=*,
                                mark size=2.5pt,
                                black
                            ]
                            coordinates {
                                (3,9)
                                (3.5,12.25)
                                (4,16)
                            };

                            % Point labels
                            \node[above left,font=\footnotesize]
                                at (axis cs:3,9)
                                {$(3,9)$};

                            \node[above,font=\footnotesize]
                                at (axis cs:3.5,12.25)
                                {$h=0.5$};

                            \node[above,font=\footnotesize]
                                at (axis cs:4,16)
                                {$h=1$};


                            % Slope triangle on tangent
                            \draw[green!60!black, thick]
                                (axis cs:3,9) --
                                (axis cs:4,9);

                            \draw[green!60!black, thick]
                                (axis cs:4,9) --
                                (axis cs:4,15);

                            \node[below,font=\footnotesize]
                                at (axis cs:3.5,9)
                                {$1$};

                            \node[right,font=\footnotesize]
                                at (axis cs:4,12)
                                {$6$};

                            % Gradient explanation box
                            \node[
                                draw,
                                rounded corners,
                                fill=white,
                                font=\small,
                                align=center
                            ]
                            at (axis cs:2.65,16.5)
                            {
                                
                                Gradient $=\dfrac{6}{1}=6$\\
                                Instantaneous ROC $=6$
                            };

                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>
                    The position of a matatu along Ngong Road (in km from Nairobi) is given by <m>d(t) = 5t^2 + t</m>, where <m>t</m> is time in hours. The table below shows recorded positions near <m>t = 2</m>.
                </p>
                <p>
                    <tabular top="minor" bottom="minor" left="minor" right="minor" halign="center">
                        <row header="yes">
                            <cell><m>t</m> (h)</cell>
                            <cell>1.9</cell><cell>1.95</cell><cell>2.0</cell><cell>2.05</cell><cell>2.1</cell>
                        </row>
                        <row>
                            <cell><m>d(t)</m> (km)</cell>
                            <cell>19.95</cell><cell>20.9625</cell><cell>22</cell><cell>23.0625</cell><cell>24.15</cell>
                        </row>
                    </tabular>
                </p>
                <ol marker="(a)">
                    <li><p>Compute the average speed over <m>[1.9,\ 2.1]</m> and over <m>[1.95,\ 2.05]</m>.</p></li>
                    <li><p>What is your estimate for the instantaneous speed at exactly <m>t = 2</m>?</p></li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)">
                    <li><p>Both equal 21 km/h.</p></li>
                    <li><p>21 km/h.</p></li>
                </ol>
            </answer>
            <solution>
                <ol marker="(a)">
                    <li>
                        <p>
                            <md>
                                <mrow>\frac{d(2.1)-d(1.9)}{2.1-1.9} \amp= \frac{24.15-19.95}{0.2} = \frac{4.2}{0.2} = 21 \text{ km/h}</mrow>
                                <mrow>\frac{d(2.05)-d(1.95)}{2.05-1.95} \amp= \frac{23.0625-20.9625}{0.1} = \frac{2.1}{0.1} = 21 \text{ km/h}</mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>Both symmetric intervals give 21 km/h, so the instantaneous speed at <m>t=2</m> is <m>21</m> km/h.</p>
                    </li>
                </ol>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    The graph of <m>f(x) = x^3 - 3x</m> is shown below.
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-3, xmax=3,
                            ymin=-5, ymax=5,
                            xtick={-2,-1,1,2},
                            ytick={-4,-2,2,4},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=-2.2:2.2, samples=60, smooth] {x^3 - 3*x};
                            \node[blue, font=\footnotesize] at (axis cs:2.4,4) {$f(x)$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(-1,2) (1,-2)};
                            \node[above left, font=\footnotesize] at (axis cs:-1,2) {$(-1,2)$};
                            \node[below right, font=\footnotesize] at (axis cs:1,-2) {$(1,-2)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <ol marker="(a)">
                    <li><p>At <m>x = -1</m> and <m>x = 1</m>, the tangent to the curve is horizontal. What is the instantaneous rate of change at these points?</p></li>
                    <li><p>State whether the curve is rising or falling on each of the intervals <m>x &lt; -1</m>, <m>-1 &lt; x &lt; 1</m>, and <m>x &gt; 1</m>.</p></li>
                    <li><p>Estimate the instantaneous rate of change at <m>x = 2</m> by drawing a tangent and reading its gradient.</p></li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)">
                    <li><p>Zero at both points (horizontal tangent).</p></li>
                    <li><p>Rising on <m>x &lt; -1</m> and <m>x &gt; 1</m>; falling on <m>-1 &lt; x &lt; 1</m>.</p></li>
                    <li><p>Approximately <m>9</m>.</p></li>
                </ol>
            </answer>
            <solution>
                <ol marker="(a)">
                    <li>
                        <p>A horizontal tangent has slope zero, so the instantaneous rate of change is <m>0</m> at both <m>x=-1</m> and <m>x=1</m>.</p>
                    </li>
                    <li>
                        <p>
                            <ul>
                                <li><p>On <m>x &lt; -1</m>: the curve is <em>rising</em>.</p></li>
                                <li><p>On <m>-1 &lt; x &lt; 1</m>: the curve is <em>falling</em>.</p></li>
                                <li><p>On <m>x &gt; 1</m>: the curve is <em>rising</em> again.</p></li>
                            </ul>
                        </p>
                    </li>
                    <li>
                        <p>
                            Draw a tangent at <m>(2, 2)</m> and pick points on the tangent such as <m>(2.5, 6.5)</m> and <m>(2, 2)</m>.
                            The gradient is approximately:
                            <me>\text{Gradient} = \frac{6.5 - 2}{2.5 - 2} = \frac{4.5}{0.5} = 9</me>
                        </p>                        
                        <image width="65%">
                            <latex-image label="Estimating the gradient at x=2">
                                \begin{tikzpicture}
                                \begin{axis}[
                                    axis lines=center,
                                    xlabel={$x$},
                                    ylabel={$y$},
                                    xmin=-3, xmax=4,
                                    ymin=-5, ymax=8,
                                    xtick={-2,-1,0,1,2,3},
                                    ytick={-4,-2,0,2,4,6},
                                    tick label style={font=\footnotesize},
                                    grid=both,
                                    grid style={line width=0.3pt, draw=gray!30},
                                ]

                                    % Original curve
                                    \addplot[
                                        blue,
                                        thick,
                                        domain=-2.2:2.2,
                                        samples=200,
                                        smooth
                                    ]
                                    {x^3 - 3*x};

                                    % Original labelled points
                                    \addplot[
                                        only marks,
                                        mark=*,
                                        mark size=2pt,
                                        black
                                    ]
                                    coordinates {
                                        (-1,2)
                                        (1,-2)
                                    };

                                    \node[above left,font=\footnotesize]
                                        at (axis cs:-1,2)
                                        {$(-1,2)$};

                                    \node[below right,font=\footnotesize]
                                        at (axis cs:1,-2)
                                        {$(1,-2)$};

                                    % Point where gradient is required
                                    \addplot[
                                        only marks,
                                        mark=*,
                                        mark size=2.5pt,
                                        red
                                    ]
                                    coordinates {(2,2)};

                                    \node[above right,font=\footnotesize]
                                        at (axis cs:2,2)
                                        {$(2,2)$};

                                    % Tangent at x=2
                                    \addplot[
                                        green!60!black,
                                        thick,
                                        domain=1.5:2.8
                                    ]
                                    {9*x - 16};

                                    % Gradient triangle
                                    \addplot[
                                        dashed,
                                        black,
                                        thick
                                    ]
                                    coordinates {(2,2) (2.5,2)};

                                    \addplot[
                                        dashed,
                                        black,
                                        thick
                                    ]
                                    coordinates {(2.5,2) (2.5,6.5)};

                                    \node[below,font=\footnotesize]
                                        at (axis cs:2.25,2)
                                        {$\Delta x=0.5$};

                                    \node[right,font=\footnotesize]
                                        at (axis cs:2.5,4.25)
                                        {$\Delta y\approx4.5$};

                                    % Gradient label
                                    \node[
                                        draw,
                                        fill=white,
                                        font=\footnotesize
                                    ]
                                    at (axis cs:-1.8,-4)
                                    {$\text{Gradient}\approx\frac{4.5}{0.5}=9$};

                                \end{axis}
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                </ol>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A cyclist's distance from home (in km) is <m>s(t) = 3t^2</m>, where <m>t</m> is time in hours.
                </p>
                <ol marker="(a)">
                    <li><p>Plot the graph of <m>s(t)</m> for <m>0 \le t \le 3</m> and draw the tangent at <m>t = 2</m>.</p></li>
                    <li><p>Estimate the cyclist's instantaneous speed at <m>t = 2</m> hours from your tangent.</p></li>
                    <li><p>Is the cyclist speeding up or slowing down as time increases? How does the graph show this?</p></li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)">
                    <li><p>Upward-opening parabola passing through <m>(0,0)</m>, <m>(1,3)</m>, <m>(2,12)</m>, <m>(3,27)</m>.</p></li>
                    <li><p>Approximately <m>12</m> km/h.</p></li>
                    <li><p>Speeding up; the tangent becomes steeper as <m>t</m> increases.</p></li>
                </ol>
            </answer>
            <solution>
                <ol marker="(a)">
                    <li>
                        <p></p>
                        <image width="65%">
                            <latex-image label="Cyclist-Graph">
                                \begin{tikzpicture}
                                \begin{axis}[
                                    axis x line=bottom, axis y line=left,
                                    xlabel={$t$ (h)},
                                    ylabel={$s$ (km)},
                                    xmin=0, xmax=3.5,
                                    ymin=0, ymax=30,
                                    xtick={0,1,2,3},
                                    ytick={0,5,10,15,20,25,30},
                                    tick label style={font=\footnotesize},
                                    grid=both,
                                    grid style={line width=0.2pt, draw=gray!30},
                                ]
                                    \addplot[blue, thick, domain=0:3.2, samples=100, smooth] {3*x^2};
                                    \addplot[green!60!black, thick, domain=1:3] {12*x - 12};
                                    \addplot[only marks, mark=*, mark size=1.5pt, black] coordinates {(0,0) (1,3) (2,12) (3,27)};
                                    \node[below right, font=\footnotesize] at (axis cs:2,12) {$(2,12)$};
                                \end{axis}
                                \end{tikzpicture}
                            </latex-image>
                            
                        </image>
                    </li>
                    <li>
                        <p>Drawing a tangent at <m>(2, 12)</m> and reading two points — for example <m>(1, 0)</m> and <m>(3, 24)</m> — gives gradient <m>\dfrac{24-0}{3-1} = 12</m> km/h.</p>
                        <image width="65%">
                            <latex-image label="Cyclist-Tangent">
                                \begin{tikzpicture}
                                \begin{axis}[
                                    axis x line=bottom, axis y line=left,
                                    xlabel={$t$ (h)},
                                    ylabel={$s$ (km)},
                                    xmin=0, xmax=4,
                                    ymin=0, ymax=30,
                                    xtick={0,1,2,3,4},
                                    ytick={0,5,10,15,20,25,30},
                                    tick label style={font=\footnotesize},
                                    grid=both,
                                    grid style={line width=0.2pt, draw=gray!30},
                                ]
                                    \addplot[blue, thick, domain=0:3.2, samples=100, smooth] {3*x^2};
                                    \addplot[green!60!black, thick, domain=1:3] {12*x - 12}; % Tangent at t=2
                                    \addplot[only marks, mark=*, mark size=1.5pt, black] coordinates {(2,12) (1,0) (3,24)};
                                    \node[below right, font=\footnotesize] at (axis cs:2,12) {$(2,12)$};
                                    \draw[dashed, black, thick] (axis cs:1,0) -- (axis cs:3,0);
                                    \draw[dashed, black, thick] (axis cs:3,0) -- (axis cs:3,24) node[midway, right, font=\footnotesize] {$\Delta s = 24$};
                                \end{axis}
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li>
                        <p>The cyclist is speeding up. The tangent lines get steeper as <m>t</m> increases, meaning the instantaneous rate of change is growing.</p>
                    </li>
                </ol>
                
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A population of bacteria in a petri dish (in thousands) grows according to <m>P(t) = t^2 + 2t</m>, where <m>t</m> is time in hours.
                </p>
                <ol marker="(a)">
                    <li><p>Estimate the instantaneous rate of growth at <m>t = 1</m> by drawing a tangent to the graph of <m>P</m>.</p></li>
                    <li><p>Estimate the instantaneous rate of growth at <m>t = 3</m> in the same way.</p></li>
                    <li><p>At which time is the population growing faster? By how much?</p></li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)">
                    <li><p>At <m>t=1</m>, <m>P(1)=3</m>. A tangent drawn at <m>(1,3)</m> passes through approximately <m>(0,-1)</m> and <m>(2,7)</m>, giving gradient <m>\dfrac{7-(-1)}{2-0}=4</m>.</p>
                    <image width="65%">
                        <latex-image label="Bacteria-Population-Graph">
                            \begin{tikzpicture}
                            \begin{axis}[
                                axis x line=bottom, axis y line=left,
                                xlabel={$t$ (h)},
                                ylabel={$P$ (000s)},
                                xmin=0, xmax=5,
                                ymin=0, ymax=30,
                                xtick={0,1,2,3,4},
                                ytick={0,5,10,15,20,25},
                                tick label style={font=\footnotesize},
                                grid=both,
                                grid style={line width=0.2pt, draw=gray!30},
                            ]
                                \addplot[blue, thick, domain=0:4.5, samples=100, smooth] {x^2 + 2*x};
                                \addplot[green!60!black, thick, domain=0:2.5] {4*x - 1};
                                \addplot[only marks, mark=*, mark size=1.5pt, black] coordinates {(1,3) (0,-1) (2,7)};
                                \node[below left, font=\footnotesize] at (axis cs:1,3) {$(1,3)$};
                                \draw[dashed, black, thick] (axis cs:0,-1) -- (axis cs:2,-1)
                                    node[midway, below, font=\footnotesize] {$\Delta t = 2$};
                                \draw[dashed, black, thick] (axis cs:2,-1) -- (axis cs:2,7)
                                    node[midway, right, font=\footnotesize] {$\Delta P = 8$};
                            \end{axis}
                            \end{tikzpicture}
                        </latex-image>
                    </image></li>
                    <li><p>. A tangent at <m>(3,15)</m> passes through approximately <m>(2,7)</m> and <m>(4,23)</m>, giving gradient <m>\dfrac{23-7}{4-2}=8</m>.</p></li>
                    <li><p>Faster at <m>t = 3</m>, by about <m>4</m> thousand bacteria per hour.</p></li>
                </ol>
            </answer>
            <solution>
                <ol marker="(a)">
                    <li>
                        <p>At <m>t=1</m>, <m>P(1)=3</m>. A tangent drawn at <m>(1,3)</m> passes through approximately <m>(0,-1)</m> and <m>(2,7)</m>, giving gradient <m>\dfrac{7-(-1)}{2-0}=4</m>.</p>
                    </li>
                    <li>
                        <p>At <m>t=3</m>, <m>P(3)=15</m>. A tangent at <m>(3,15)</m> passes through approximately <m>(2,7)</m> and <m>(4,23)</m>, giving gradient <m>\dfrac{23-7}{4-2}=8</m>.</p>
                    </li>
                    <li>
                        <p>The population is growing faster at <m>t=3</m> (approximately 8 vs. 4 thousand bacteria per hour), by about 4 thousand bacteria per hour.</p>
                    </li>
                </ol>
                <image width="65%">
                    <latex-image label="Bacteria-Tangents">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis x line=bottom, axis y line=left,
                            xlabel={$t$ (h)},
                            ylabel={$P$ (000s)},
                            xmin=0, xmax=5,
                            ymin=0, ymax=30,
                            xtick={0,1,2,3,4},
                            ytick={0,5,10,15,20,25},
                            tick label style={font=\footnotesize},
                            grid=both,
                            grid style={line width=0.2pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=0:4.5, samples=100, smooth] {x^2 + 2*x};
                            \addplot[green!60!black, thick, domain=0:2.5] {4*x - 1}; % Tangent at t=1
                            \addplot[red, thick, domain=1.5:4.5] {8*x - 9}; % Tangent at t=3
                            \addplot[only marks, mark=*, mark size=1.5pt, black] coordinates {(1,3) (3,15) (0,-1) (2,7) (2,7) (4,23)};
                            \draw[dashed, green!60!black, thick] (axis cs:0,-1) -- (axis cs:2,-1)
                                node[midway, below, font=\footnotesize] {$\Delta t = 2$};
                            \draw[dashed, green!60!black, thick] (axis cs:2,-1) -- (axis cs:2,7)
                                node[midway, left, font=\footnotesize] {$\Delta P = 8$};
                            \draw[dashed, red, thick] (axis cs:2,7) -- (axis cs:4,7)
                                node[midway, below, font=\footnotesize] {$\Delta t = 2$};
                            \draw[dashed, red, thick] (axis cs:4,7) -- (axis cs:4,23)
                                node[midway, right, font=\footnotesize] {$\Delta P = 16$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </solution>
        </exercise>
    </exercises>

