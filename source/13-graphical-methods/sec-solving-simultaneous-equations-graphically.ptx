<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-solving-simultaneous-equations-graphically" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Solving Simultaneous Equations Graphically</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.6 Graphical Methods
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Solve simultaneous equations of a linear and a quadratic and cubic equations graphically
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        15 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To discover that the solutions to simultaneous equations are the coordinates of the points where their graphs intersect.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Provide learners with graph paper. Guide them to plot both a linear and a quadratic equation on the same grid. Encourage them to identify and read the coordinates of the intersection points accurately.
                    </p>
                </li>
            </dl>
        </axiom>

    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                <alert>Work in pairs</alert>
            </p>
            <p>
                Imagine a straight road and a curved railway track. The road follows the path <m>y = x + 2</m>, and the railway track follows the path <m>y = x^2</m>.
            </p>
            <p>
                <alert>What to do</alert>
            </p>
            <p>
                <ol>
                    <li>
                        <p>
                            Create a table of values for both <m>y = x + 2</m> and <m>y = x^2</m> for <m>x</m> values from <m>-2</m> to <m>3</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            On the same Cartesian plane, plot the graph of the straight line and the curve.
                        </p>
                    </li>
                    <li>
                        <p>
                            Identify the points where the road and the railway track cross each other.
                        </p>
                    </li>
                    <li>
                        <p>
                            What are the coordinates <m>(x, y)</m> of these intersection points? How do these values relate to the two equations?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the method of solving simultaneous linear and non-linear equations graphically.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Use the activity to show that the points <m>(-1, 1)</m> and <m>(2, 4)</m> satisfy both equations simultaneously.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Generalizing the Concept:</alert> Explain that for any two equations, their common solutions are found at the intersection points of their graphs.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <p>
            <ul>
                <li>
                    <p>
                       Solving simultaneous equations graphically involves finding the points where the graphs of the given equations intersect.
                    </p>
                </li>
                <li>
                    <p>
                        The coordinates <m>(x, y)</m> of the intersection points are the solutions to the simultaneous equations.
                    </p>
                </li>
                <li>
                    <p>
                        A linear equation and a quadratic equation can have 0, 1, or 2 solutions.
                    </p>
                </li>
                <li>
                    <p>
                        A linear equation and a cubic equation can have 1, 2, or 3 solutions.
                    </p>
                </li>
            </ul>
        </p>
        <p>
            <alert>How to solve simultaneous equations of a linear and a quadratic and cubic equations graphically</alert>
        </p>
        <p>
            <ol>
                <li>
                    <p>
                        <alert>Linear and Quadratic Equations</alert>:
                    </p>
                    <p>
                        Given the <m>2</m> equations:
                    </p>
                    <p>
                        <me> y = x^2 - 4x + 3</me>
                        <me>y = x - 1 </me>
                    </p>
                    <p>
                        <ul>
                            <li>
                                <p>
                                    Create value tables for both equations.
                                </p>
                            </li>
                            <li>
                                <p>
                                    Plot the linear equation (straight line) and the quadratic equation (parabola) on the same graph.
                                </p>
                            </li>
                            <li>
                                <p>
                                    Identify the points of intersection. These points represent the solutions to the simultaneous equations.
                                </p>
                            </li>
                        </ul>
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Linear and Cubic Equations</alert>:
                    </p>
                    <p>
                        Given the <m>2</m> equations:
                    </p>
                    <p>
                        <me> y = x^2(x - 2)</me>
                        <me>y = 2x + 5 </me>
                    </p>
                    <p>
                        <ul>
                            <li>
                                <p>
                                    Create a table of values for both equations to determine key points for plotting.
                                </p>
                            </li>
                            <li>
                                <p>
                                    Plot the linear equation (straight line) and the cubic equation (curve) on the same graph.
                                </p>
                            </li>
                            <li>
                                <p>
                                    Identify the points of intersection. These points represent the solutions to the simultaneous equations.
                                </p>
                            </li>
                        </ul>
                    </p>
                </li>
            </ol>
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Solve the following simultaneous equations graphically for the interval <m>-2 \le x \le 5</m>:
                <me>y = x^2 - 4x + 3</me>
                <me>y = x - 1</me>
            </p>
        </statement>
        <solution>
            <p>
                1. Create a table of values for both equations:
            </p>
            <p>
                For <m>y = x^2 - 4x + 3</m>:
                <tabular bottom="minor" top="minor" left="minor" right="minor">
                    <row>
                        <cell><m>x</m></cell>
                        <cell>-1</cell>
                        <cell>0</cell>
                        <cell>1</cell>
                        <cell>2</cell>
                        <cell>3</cell>
                        <cell>4</cell>
                        <cell>5</cell>
                    </row>
                    <row>
                        <cell><m>y</m></cell>
                        <cell>8</cell>
                        <cell>3</cell>
                        <cell>0</cell>
                        <cell>-1</cell>
                        <cell>0</cell>
                        <cell>3</cell>
                        <cell>8</cell>
                    </row>
                </tabular>
            </p>
            <p>
                For <m>y = x - 1</m>:
                <tabular bottom="minor" top="minor" left="minor" right="minor">
                    <row>
                        <cell><m>x</m></cell>
                        <cell>0</cell>
                        <cell>1</cell>
                        <cell>4</cell>
                    </row>
                    <row>
                        <cell><m>y</m></cell>
                        <cell>-1</cell>
                        <cell>0</cell>
                        <cell>3</cell>
                    </row>
                </tabular>
            </p>
            <p>
                2. Plot both graphs on the same grid:
            </p>
            <image width="65%">
                <latex-image>
                    \begin{tikzpicture}[scale=0.7]
                        \draw[help lines, color=gray!30, step=1] (-2,-2) grid (6,9);
                        \draw[-&gt;] (-2,0) -- (6,0) node[right] {$x$};
                        \draw[-&gt;] (0,-2) -- (0,9) node[above] {$y$};
                        \draw[blue, thick, domain=-0.8:4.8, smooth] plot (\x, {\x*\x - 4*\x + 3});
                        \node[blue] at (5, 6) {$y=x^2-4x+3$};
                        \draw[red, thick, domain=-1:5.5] plot (\x, {\x - 1});
                        \node[red] at (5, 3.5) {$y=x-1$};
                        \filldraw[black] (1,0) circle (2pt) node[below right] {$(1, 0)$};
                        \filldraw[black] (4,3) circle (2pt) node[below right] {$(4, 3)$};
                    \end{tikzpicture}
                </latex-image>
            </image>
            <p>
                3. The points of intersection are <m>(1, 0)</m> and <m>(4, 3)</m>.
            </p>
            <p>
                Therefore, the solutions are <m>x = 1, y = 0</m> and <m>x = 4, y = 3</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Determine the intersection points of the curve <m>y = x^2 - 2</m> and the line <m>y = x</m> graphically.
            </p>
        </statement>
        <solution>
            <p>
                By plotting <m>y = x^2 - 2</m> (a parabola) and <m>y = x</m> (a straight line), we observe that they cross at two points.
            </p>
            <image width="65%">
                <latex-image label="Graph of y = x^2 - 2 and y = x">
                    \begin{tikzpicture}[scale=0.7]
                        \draw[help lines, color=gray!30, step=1] (-2,-3) grid (3,3);
                        \draw[-&gt;] (-2,0) -- (3,0) node[right] {$x$};
                        \draw[-&gt;] (0,-3) -- (0,3) node[above] {$y$};
                        \draw[blue, thick, domain=-1.5:2.5, smooth] plot (\x, {\x*\x - 2});
                        \node[blue] at (2.5, 2) {$y=x^2-2$};
                        \draw[red, thick, domain=-1.5:2.5] plot (\x, {\x});
                        \node[red] at (2.5, 1.5) {$y=x$};
                        \filldraw[black] (-1,-1) circle (2pt) node[below right] {$(-1, -1)$};
                        \filldraw[black] (2,2) circle (2pt) node[below right] {$(2, 2)$};
                    \end{tikzpicture}
                </latex-image>
                
            </image>
            <p>
                Reading from the graph, the intersection points are <m>(-1, -1)</m> and <m>(2, 2)</m>.
            </p>
            <p>
                These points satisfy both equations:
                <ul>
                    <li>For <m>(-1, -1)</m>: <m>-1 = (-1)^2 - 2 \Rightarrow -1 = 1 - 2</m> (True)</li>
                    <li>For <m>(2, 2)</m>: <m>2 = (2)^2 - 2 \Rightarrow 2 = 4 - 2</m> (True)</li>
                </ul>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Solve the simultaneous equations <m>y = x^3 - x</m> and <m>y = 0</m> graphically.
            </p>
        </statement>
        <solution>
            <p>
                The equation <m>y = 0</m> represents the <m>x</m>-axis. We need to find where the cubic curve <m>y = x^3 - x</m> crosses the <m>x</m>-axis.
            </p>
            <p>
                Plotting the cubic function:
                <ul>
                    <li>When <m>x = -2, y = (-2)^3 - (-2) = -8 + 2 = -6</m></li>
                    <li>When <m>x = -1, y = (-1)^3 - (-1) = -1 + 1 = 0</m></li>
                    <li>When <m>x = 0, y = 0</m></li>
                    <li>When <m>x = 1, y = (1)^3 - 1 = 0</m></li>
                    <li>When <m>x = 2, y = (2)^3 - 2 = 6</m></li>
                </ul>
            </p>
            <image width="65%">
                <latex-image label="Graph of y = x^3 - x">
                    \begin{tikzpicture}[scale=0.7]
                        \draw[help lines, color=gray!30, step=1] (-2.5,-7) grid (2.5,7);
                        \draw[-&gt;] (-2.5,0) -- (2.5,0) node[right] {$x$};
                        \draw[-&gt;] (0,-7) -- (0,7) node[above] {$y$};
                        \draw[blue, thick, domain=-2:2, smooth] plot (\x, {\x*\x*\x - \x});
                        \node[blue] at (2.5, 6) {$y=x^3-x$};
                        \filldraw[black] (-1,0) circle (2pt) node[below right] {$(-1, 0)$};
                        \filldraw[black] (0,0) circle (2pt) node[below right] {$(0, 0)$};
                        \filldraw[black] (1,0) circle (2pt) node[below right] {$(1, 0)$};
                    \end{tikzpicture}
                </latex-image>
            </image>
            <p>
                The curve intersects the <m>x</m>-axis at three points: <m>(-1, 0)</m>, <m>(0, 0)</m>, and <m>(1, 0)</m>.
            </p>
            <p>
                The solutions are <m>x = -1, 0, 1</m> (all with <m>y = 0</m>).
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Solve the equations <m>y = x^2 - x - 6</m> and <m>y = 0</m> graphically for <m>-4 \le x \le 4</m>.
                </p>
            </statement>
            <solution>
                <p>
                    Plot <m>y = x^2 - x - 6</m> and read off where it crosses the <m>x</m>-axis.
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (-4,-8) grid (4,4);
                            \draw[-&gt;] (-4,0) -- (4,0) node[right] {$x$};
                            \draw[-&gt;] (0,-8) -- (0,4) node[above] {$y$};
                            \draw[blue, thick, &lt;-&gt;, domain=-2.7:3.7, smooth] plot (\x, {\x*\x - \x - 6});
                            \node[blue, font=\small] at (3.5, 3) {$y=x^2-x-6$};
                            \filldraw[black] (-2,0) circle (2pt) node[above left] {$(-2,0)$};
                            \filldraw[black] (3,0) circle (2pt) node[above right] {$(3,0)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The parabola crosses the <m>x</m>-axis at <m>(-2, 0)</m> and <m>(3, 0)</m>.
                    The solutions are <m>x = -2</m> and <m>x = 3</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    On the same grid, plot the graphs of <m>y = x^2 - 2x + 1</m> and <m>y = x + 1</m>. Use your graph to find the coordinates of the intersection points.
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (-1,-1) grid (5,6);
                            \draw[-&gt;] (-1,0) -- (5,0) node[right] {$x$};
                            \draw[-&gt;] (0,-1) -- (0,6) node[above] {$y$};
                            \draw[blue, thick, &lt;-&gt;, domain=-0.3:3.3, smooth] plot (\x, {(\x-1)*(\x-1)});
                            \node[blue, font=\small] at (4, 5.5) {$y=(x{-}1)^2$};
                            \draw[red, thick, domain=-1:5] plot (\x, {\x + 1});
                            \node[red, font=\small] at (4, 3.5) {$y=x+1$};
                            \filldraw[black] (0,1) circle (2pt) node[left] {$(0,1)$};
                            \filldraw[black] (3,4) circle (2pt) node[above left] {$(3,4)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The intersection points are <m>(0, 1)</m> and <m>(3, 4)</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A cubic function is given by <m>y = x^3 - 4x</m>. Find its intersection points with the line <m>y = -3x</m> by plotting both graphs.
                </p>
            </statement>
            <solution>
                <p>
                    Setting <m>x^3 - 4x = -3x \Rightarrow x^3 - x = 0 \Rightarrow x(x-1)(x+1) = 0</m>.
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (-3,-7) grid (3,7);
                            \draw[-&gt;] (-3,0) -- (3,0) node[right] {$x$};
                            \draw[-&gt;] (0,-7) -- (0,7) node[above] {$y$};
                            \draw[blue, thick, domain=-2.2:2.2, smooth] plot (\x, {\x*\x*\x - 4*\x});
                            \node[blue, font=\small] at (2.5, 4.5) {$y=x^3-4x$};
                            \draw[red, thick, domain=-2.2:2.2] plot (\x, {-3*\x});
                            \node[red, font=\small] at (-2, 5.5) {$y=-3x$};
                            \filldraw[black] (-1,3) circle (2pt) node[above right] {$(-1,3)$};
                            \filldraw[black] (0,0) circle (2pt) node[below right] {$(0,0)$};
                            \filldraw[black] (1,-3) circle (2pt) node[below left] {$(1,-3)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The intersection points are <m>(-1, 3)</m>, <m>(0, 0)</m>, and <m>(1, -3)</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve the simultaneous equations <m>y = x^2</m> and <m>y = -x^2 + 8</m> graphically.
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (-3,-1) grid (3,9);
                            \draw[-&gt;] (-3,0) -- (3,0) node[right] {$x$};
                            \draw[-&gt;] (0,-1) -- (0,9) node[above] {$y$};
                            \draw[blue, thick, &lt;-&gt;, domain=-3:3, smooth] plot (\x, {\x*\x});
                            \node[blue, font=\small] at (2.5, 7.5) {$y=x^2$};
                            \draw[red, thick, &lt;-&gt;, domain=-2.9:2.9, smooth] plot (\x, {-\x*\x + 8});
                            \node[red, font=\small] at (-2.5, 7.5) {$y=-x^2+8$};
                            \filldraw[black] (-2,4) circle (2pt) node[left] {$(-2,4)$};
                            \filldraw[black] (2,4) circle (2pt) node[right] {$(2,4)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs intersect at <m>(-2, 4)</m> and <m>(2, 4)</m>.
                    The solutions are <m>x = -2, y = 4</m> and <m>x = 2, y = 4</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Plot the graphs of <m>y = x^2 - 4x + 5</m> and <m>y = 2x - 4</m> on the same axes. How many intersection points are there? State the solution(s).
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (-1,-5) grid (5,7);
                            \draw[-&gt;] (-1,0) -- (5,0) node[right] {$x$};
                            \draw[-&gt;] (0,-5) -- (0,7) node[above] {$y$};
                            \draw[blue, thick, &lt;-&gt;, domain=-0.5:4.5, smooth] plot (\x, {\x*\x - 4*\x + 5});
                            \node[blue, font=\small] at (4.5, 6) {$y=x^2-4x+5$};
                            \draw[red, thick, domain=-1:5.5] plot (\x, {2*\x - 4});
                            \node[red, font=\small] at (4.5, 4) {$y=2x-4$};
                            \filldraw[black] (3,2) circle (2pt) node[above left] {$(3,2)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The line touches the parabola at exactly <em>one</em> point: <m>(3, 2)</m>.
                    The line is a <term>tangent</term> to the parabola.
                </p>
                <p>
                    Algebraically: <m>x^2 - 4x + 5 = 2x - 4 \Rightarrow x^2 - 6x + 9 = 0 \Rightarrow (x - 3)^2 = 0</m>,
                    confirming the single solution <m>x = 3</m>, <m>y = 2</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    The graph of <m>y = x^3 - 4x^2</m> is drawn on the grid below.
                    Draw the line <m>y = x - 4</m> on the same axes and use your graph to solve <m>x^3 - 4x^2 = x - 4</m>.
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.55]
                            \draw[help lines, color=gray!30, step=1] (-2,-10) grid (6,8);
                            \draw[-&gt;] (-2,0) -- (6,0) node[right] {$x$};
                            \draw[-&gt;] (0,-10) -- (0,8) node[above] {$y$};
                            \begin{scope}
                                \clip (-2,-10) rectangle (6,8);
                                \draw[blue, thick, domain=-1.3:5.3, smooth] plot (\x, {\x*\x*\x - 4*\x*\x});
                            \end{scope}
                            \node[blue, font=\small] at (5.5, 6) {$y=x^3-4x^2$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </statement>
            <solution>
                <p>
                    The line <m>y = x - 4</m> passes through <m>(0, -4)</m> and <m>(4, 0)</m>. Adding it to the grid:
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.55]
                            \draw[help lines, color=gray!30, step=1] (-2,-10) grid (6,8);
                            \draw[-&gt;] (-2,0) -- (6,0) node[right] {$x$};
                            \draw[-&gt;] (0,-10) -- (0,8) node[above] {$y$};
                            \begin{scope}
                                \clip (-2,-10) rectangle (6,8);
                                \draw[blue, thick, domain=-1.3:5.3, smooth] plot (\x, {\x*\x*\x - 4*\x*\x});
                                \draw[red, thick, domain=-2:6] plot (\x, {\x - 4});
                            \end{scope}
                            \node[blue, font=\small] at (5.5, 6) {$y=x^3-4x^2$};
                            \node[red, font=\small] at (5.5, 0.5) {$y=x-4$};
                            \filldraw[black] (-1,-5) circle (2.5pt) node[left] {$(-1,-5)$};
                            \filldraw[black] (1,-3) circle (2.5pt) node[right] {$(1,-3)$};
                            \filldraw[black] (4,0) circle (2.5pt) node[above right] {$(4,0)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs intersect at <m>(-1, -5)</m>, <m>(1, -3)</m>, and <m>(4, 0)</m>.
                    The solutions to <m>x^3 - 4x^2 = x - 4</m> are <m>x = -1</m>, <m>x = 1</m>, and <m>x = 4</m>.
                </p>
                <p>
                    (Check: <m>x^3 - 4x^2 - x + 4 = x^2(x-4) - (x-4) = (x-4)(x^2-1) = (x-4)(x-1)(x+1) = 0</m>.)
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A stone is thrown upward from the ground. Its height above the ground is modelled by
                    <m>h = -5t^2 + 25t</m> metres, where <m>t</m> is time in seconds.
                    A window ledge is at a constant height of <m>30</m> metres.
                </p>
                <p>
                    By drawing the graphs of <m>h = -5t^2 + 25t</m> and <m>h = 30</m> on the same axes,
                    find the times at which the stone passes the level of the ledge.
                </p>
            </statement>
            <solution>
                <p>
                    The <m>h</m>-axis below is scaled so that each grid unit represents <m>5</m> m (i.e. the grid
                    value <m>6</m> corresponds to <m>h = 30</m> m).
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (0,0) grid (6,7);
                            \draw[-&gt;] (-0.3,0) -- (6,0) node[right] {$t$ (s)};
                            \draw[-&gt;] (0,-0.3) -- (0,7) node[above] {$h$ (m)};
                            \foreach \t in {1,2,3,4,5}
                                \draw (\t, 0.08) -- (\t,-0.08) node[below] {\small $\t$};
                            \foreach \h/\lab in {2/10, 4/20, 6/30}
                                \draw (0.08,\h) -- (-0.08,\h) node[left] {\small $\lab$};
                            \draw[blue, thick, domain=0:5, smooth] plot (\x, {-\x*\x + 5*\x});
                            \node[blue, font=\small] at (5.5, 4) {$h=-5t^2+25t$};
                            \draw[red, thick, domain=0:6] plot (\x, {6});
                            \node[red, font=\small] at (5.5, 6.4) {$h=30$};
                            \filldraw[black] (2,6) circle (2.5pt) node[above left] {\small $(2,\,30)$};
                            \filldraw[black] (3,6) circle (2.5pt) node[above right] {\small $(3,\,30)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs meet at <m>t = 2</m> s and <m>t = 3</m> s (both at <m>h = 30</m> m).
                    The stone passes the window ledge at <m>t = 2</m> seconds on the way up,
                    and again at <m>t = 3</m> seconds on the way down.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A trader sells a product for several days after launch. Her daily revenue is modelled by
                    <m>S = -x^2 + 6x</m> thousand shillings (revenue rises then falls as the product loses popularity),
                    where <m>x</m> is the number of days after launch.
                    A competitor's revenue grows steadily, modelled by <m>S = 2x</m> thousand shillings.
                </p>
                <p>
                    Draw both graphs and find the day(s) on which the two traders have equal daily revenue.
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.7]
                            \draw[help lines, color=gray!30, step=1] (0,0) grid (7,12);
                            \draw[-&gt;] (-0.3,0) -- (7,0) node[right] {$x$ (days)};
                            \draw[-&gt;] (0,-0.3) -- (0,12) node[above] {$S$ (Ksh 000s)};
                            \foreach \x in {1,2,3,4,5,6}
                                \draw (\x, 0.08) -- (\x,-0.08) node[below] {\small $\x$};
                            \foreach \y in {2,4,6,8,10}
                                \draw (0.08,\y) -- (-0.08,\y) node[left] {\small $\y$};
                            \draw[blue, thick, domain=0:6, smooth] plot (\x, {-\x*\x + 6*\x});
                            \node[blue, font=\small] at (4.5, 10.5) {$S=-x^2+6x$};
                            \draw[red, thick, domain=0:6] plot (\x, {2*\x});
                            \node[red, font=\small] at (5.7, 9.5) {$S=2x$};
                            \filldraw[black] (0,0) circle (2.5pt) node[above right] {\small $(0,0)$};
                            \filldraw[black] (4,8) circle (2.5pt) node[above left] {\small $(4,8)$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs meet at <m>(0, 0)</m> and <m>(4, 8)</m>.
                    The revenues are equal on <alert>day 0</alert> (launch day, both at zero) and on
                    <alert>day 4</alert> (both at 8 thousand shillings).
                </p>
            </solution>
        </exercise>

    </exercises>

    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation Strategies</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        Provide pre-drawn grids with scales already marked. Use simpler equations like <m>y = x^2</m> and <m>y = 4</m> to build confidence.
                    </cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        The core lesson activities as described above, focusing on accurate plotting and reading intersection points.
                    </cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        Challenge them to find the equation of a line that would intersect a given parabola at exactly one point (tangent line) or no points at all.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

