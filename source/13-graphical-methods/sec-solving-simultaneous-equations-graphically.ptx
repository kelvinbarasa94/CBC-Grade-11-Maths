<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-solving-simultaneous-equations-graphically" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Solving Simultaneous Equations Graphically</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.6 Graphical Methods
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Solve simultaneous equations of a linear and a quadratic and cubic equations graphically
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        15 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To discover that the solutions to simultaneous equations are the coordinates of the points where their graphs intersect.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Provide learners with graph paper. Guide them to plot both a linear and a quadratic equation on the same grid. Encourage them to identify and read the coordinates of the intersection points accurately.
                    </p>
                </li>
            </dl>
        </axiom>

    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                <alert>Work in pairs</alert>
            </p>
            <p>
                Imagine a straight road and a curved railway track. The road follows the path <m>y = x + 2</m>, and the railway track follows the path <m>y = x^2</m>.
            </p>
            <p>
                <alert>What to do</alert>
            </p>
            <p>
                <ol>
                    <li>
                        <p>
                            Create a table of values for both <m>y = x + 2</m> and <m>y = x^2</m> for <m>x</m> values from <m>-2</m> to <m>3</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            On the same Cartesian plane, plot the graph of the straight line and the curve.
                        </p>
                    </li>
                    <li>
                        <p>
                            Identify the points where the road and the railway track cross each other.
                        </p>
                    </li>
                    <li>
                        <p>
                            What are the coordinates <m>(x, y)</m> of these intersection points? How do these values relate to the two equations?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <alert>Step 1: Table of values</alert>
            </p>
            <p>
                For <m>y = x + 2</m> and <m>y = x^2</m>, with <m>x</m> from <m>-2</m> to <m>3</m>:
            </p>
            <tabular bottom="minor" top="minor" left="minor" right="minor" halign="center">
                <row header="yes" bottom="medium">
                    <cell><m>x</m></cell>
                    <cell><m>-2</m></cell>
                    <cell><m>-1</m></cell>
                    <cell><m>0</m></cell>
                    <cell><m>1</m></cell>
                    <cell><m>2</m></cell>
                    <cell><m>3</m></cell>
                </row>
                <row>
                    <cell><m>y = x + 2</m></cell>
                    <cell><m>0</m></cell>
                    <cell><m>1</m></cell>
                    <cell><m>2</m></cell>
                    <cell><m>3</m></cell>
                    <cell><m>4</m></cell>
                    <cell><m>5</m></cell>
                </row>
                <row>
                    <cell><m>y = x^2</m></cell>
                    <cell><m>4</m></cell>
                    <cell><m>1</m></cell>
                    <cell><m>0</m></cell>
                    <cell><m>1</m></cell>
                    <cell><m>4</m></cell>
                    <cell><m>9</m></cell>
                </row>
            </tabular>
            <p>
                <alert>Step 2: Plot both graphs on the same axes</alert>
            </p>
            <image width="65%">
                <latex-image>
                    \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-6, xmax=6,
                            ymin=-1, ymax=10,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                            legend style={at={(0.05,0.95)}, anchor=north west, font=\small},
                        ]
                            \addplot[red, thick, domain=-4:6, samples=2] {x + 2};
                            \addlegendentry{$y = x+2$}
                            \addplot[blue, thick, domain=-4:6, samples=80] {x^2};
                            \addlegendentry{$y = x^2$}
                            \addplot[only marks, mark=*, mark size=1.5pt, black]
                                coordinates {(-1,1) (2,4)};
                            \node[left, font=\small] at (axis cs:-1,1) {$(-1,\,1)$};
                            \node[above left, font=\small] at (axis cs:2,4) {$(2,\,4)$};
                        \end{axis}
                    \end{tikzpicture}
                </latex-image>
            </image>
            <p>
                <alert>Step 3 and 4: Intersection points and verification</alert>
            </p>
            <p>
                The road <m>y = x + 2</m> and the railway track <m>y = x^2</m> cross at two points:
                <m>(-1,\, 1)</m> and <m>(2,\, 4)</m>.
            </p>
            <p>
                These coordinates satisfy <em>both</em> equations at the same time:
            </p>
            <p>
                <ul>
                    <li>
                        <p>
                            At <m>(-1,\, 1)</m>: <m>y = (-1) + 2 = 1</m> <m>\checkmark</m> and <m>y = (-1)^2 = 1</m> <m>\checkmark</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            At <m>(2,\, 4)</m>: <m>y = 2 + 2 = 4</m> <m>\checkmark</m> and <m>y = 2^2 = 4</m> <m>\checkmark</m>
                        </p>
                    </li>
                </ul>
            </p>
            <p>
                The intersection points give the values of <m>x</m> and <m>y</m> that satisfy both equations
                simultaneously. These are the solutions to the simultaneous equations
                <m>y = x + 2</m> and <m>y = x^2</m>.
            </p>
        </solution>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the method of solving simultaneous linear and non-linear equations graphically.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Use the activity to show that the points <m>(-1, 1)</m> and <m>(2, 4)</m> satisfy both equations simultaneously.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Generalizing the Concept:</alert> Explain that for any two equations, their common solutions are found at the intersection points of their graphs.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <p>
            <ul>
                <li>
                    <p>
                       Solving simultaneous equations graphically involves finding the points where the graphs of the given equations intersect.
                    </p>
                </li>
                <li>
                    <p>
                        The coordinates <m>(x, y)</m> of the intersection points are the solutions to the simultaneous equations.
                    </p>
                </li>
                <li>
                    <p>
                        A linear equation and a quadratic equation can have 0, 1, or 2 solutions.
                    </p>
                </li>
                <li>
                    <p>
                        A linear equation and a cubic equation can have 1, 2, or 3 solutions.
                    </p>
                </li>
            </ul>
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <!-- TODO: Convert all examples and exercises which solve simultaneous with y = 0 into something more interesting (e.g. y = 1, something with nice answers)-->

    <example>
        <statement>
            <p>
                Solve the following simultaneous equations graphically:
                <me>y = x^2 - 4x + 3</me>
                <me>y = x - 1</me>
            </p>
        </statement>
        <solution>
            <p>
                1. Create a table of values for both equations:
            </p>
            <p>
                For <m>y = x^2 - 4x + 3</m>:
                <tabular bottom="minor" top="minor" left="minor" right="minor">
                    <row>
                        <cell><m>x</m></cell>
                        <cell><m>-1</m></cell>
                        <cell><m>0</m></cell>
                        <cell><m>1</m></cell>
                        <cell><m>2</m></cell>
                        <cell><m>3</m></cell>
                        <cell><m>4</m></cell>
                        <cell><m>5</m></cell>
                    </row>
                    <row>
                        <cell><m>y</m></cell>
                        <cell><m>8</m></cell>
                        <cell><m>3</m></cell>
                        <cell><m>0</m></cell>
                        <cell><m>-1</m></cell>
                        <cell><m>0</m></cell>
                        <cell><m>3</m></cell>
                        <cell><m>8</m></cell>
                    </row>
                </tabular>
            </p>
            <p>
                For <m>y = x - 1</m>:
                <tabular bottom="minor" top="minor" left="minor" right="minor">
                    <row>
                        <cell><m>x</m></cell>
                        <cell><m>0</m></cell>
                        <cell><m>1</m></cell>
                        <cell><m>4</m></cell>
                    </row>
                    <row>
                        <cell><m>y</m></cell>
                        <cell><m>-1</m></cell>
                        <cell><m>0</m></cell>
                        <cell><m>3</m></cell>
                    </row>
                </tabular>
            </p>
            <p>
                2. Plot both graphs on the same grid:
            </p>
            <image width="65%">
                <latex-image>
                    \begin{tikzpicture}
                    \begin{axis}[
                        axis lines=center,
                        xlabel={$x$},
                        ylabel={$y$},
                        xmin=-2, xmax=6,
                        ymin=-2, ymax=9,
                        tick label style={font=\small},
                        grid=both,
                        grid style={line width=0.3pt, draw=gray!30},
                        axis equal image,
                    ]
                        \addplot[blue, thick, domain=-0.8:4.8, samples=80, smooth] {x^2 - 4*x + 3};
                        \node[blue, font=\small] at (axis cs:1.5,6) {$y=x^2-4x+3$};
                        \addplot[red, thick, domain=-1:5.5, samples=2] {x - 1};
                        \node[red, font=\small] at (axis cs:3,3.5) {$y=x-1$};
                        \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(1,0) (4,3)};
                        \node[below right, font=\small] at (axis cs:1,0) {$(1,0)$};
                        \node[below right, font=\small] at (axis cs:4,3) {$(4,3)$};
                    \end{axis}
                    \end{tikzpicture}
                </latex-image>
            </image>
            <p>
                3. The points of intersection are <m>(1, 0)</m> and <m>(4, 3)</m>.
            </p>
            <p>
                Therefore, the solutions are <m>x = 1, y = 0</m> and <m>x = 4, y = 3</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Determine the intersection points of the curve <m>y = x^2 - 2</m> and the line <m>y = x</m> graphically.
            </p>
        </statement>
        <solution>
            <p>
                By plotting <m>y = x^2 - 2</m> (a parabola) and <m>y = x</m> (a straight line), we observe that they cross at two points.
            </p>
            <image width="65%">
                <latex-image label="Graph of y = x^2 - 2 and y = x">
                    \begin{tikzpicture}
                    \begin{axis}[
                        axis lines=center,
                        xlabel={$x$},
                        ylabel={$y$},
                        xmin=-2, xmax=3,
                        ymin=-3, ymax=3,
                        tick label style={font=\small},
                        grid=both,
                        grid style={line width=0.3pt, draw=gray!30},
                        axis equal image,
                    ]
                        \addplot[blue, thick, domain=-1.5:2.5, samples=80, smooth] {x^2 - 2};
                        \node[blue, font=\small] at (axis cs:2.3,2) {$y=x^2-2$};
                        \addplot[red, thick, domain=-1.5:2.5, samples=2] {x};
                        \node[red, font=\small] at (axis cs:2.3,1.5) {$y=x$};
                        \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(-1,-1) (2,2)};
                        \node[below right, font=\small] at (axis cs:-1,-1) {$(-1,-1)$};
                        \node[below right, font=\small] at (axis cs:2,2) {$(2,2)$};
                    \end{axis}
                    \end{tikzpicture}
                </latex-image>
            </image>
            <p>
                Reading from the graph, the intersection points are <m>(-1, -1)</m> and <m>(2, 2)</m>.
            </p>
            <p>
                These points satisfy both equations:
                <ul>
                    <li>For <m>(-1, -1)</m>: <m>-1 = (-1)^2 - 2 \Rightarrow -1 = 1 - 2</m> (True)</li>
                    <li>For <m>(2, 2)</m>: <m>2 = (2)^2 - 2 \Rightarrow 2 = 4 - 2</m> (True)</li>
                </ul>
            </p>
        </solution>
    </example>

    <example>
            <statement>
                <p>
                    Plot the graphs of <m>y = x^2 - 4x + 5</m> and <m>y = 2x - 4</m> on the same axes. How many intersection points are there? State the solution(s).
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-1, xmax=5,
                            ymin=-5, ymax=7,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-0.5:4.5, samples=80, smooth] {x^2 - 4*x + 5};
                            \node[blue, font=\small] at (axis cs:4,6) {$y=x^2-4x+5$};
                            \addplot[red, thick, domain=-0.5:5, samples=2] {2*x - 4};
                            \node[red, font=\small] at (axis cs:4.5,4.5) {$y=2x-4$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(3,2)};
                            \node[above left, font=\small] at (axis cs:3,2) {$(3,2)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The line touches the parabola at exactly <em>one</em> point: <m>(3, 2)</m>.
                    The line is a <term>tangent</term> to the parabola.
                </p>
                <p>
                    Algebraically: <m>x^2 - 4x + 5 = 2x - 4 \Rightarrow x^2 - 6x + 9 = 0 \Rightarrow (x - 3)^2 = 0</m>,
                    confirming the single solution <m>x = 3</m>, <m>y = 2</m>.
                </p>
            </solution>
        </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Solve the equations <m>y = x^2 - x - 6</m> and <m>y = 0</m> graphically for <m>-4 \le x \le 4</m>.
                </p>
            </statement>
            <solution>
                <p>
                    Plot <m>y = x^2 - x - 6</m> and read off where it crosses the <m>x</m>-axis.
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-4, xmax=4,
                            ymin=-8, ymax=4,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-2.7:3.7, samples=80, smooth] {x^2 - x - 6};
                            \node[blue, font=\small] at (axis cs:3,3) {$y=x^2-x-6$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(-2,0) (3,0)};
                            \node[above left, font=\small] at (axis cs:-2,0) {$(-2,0)$};
                            \node[above right, font=\small] at (axis cs:3,0) {$(3,0)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The parabola crosses the <m>x</m>-axis at <m>(-2, 0)</m> and <m>(3, 0)</m>.
                    The solutions are <m>x = -2</m> and <m>x = 3</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    On the same grid, plot the graphs of <m>y = x^2 - 2x + 1</m> and <m>y = x + 1</m>. Use your graph to find the coordinates of the intersection points.
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-1, xmax=5,
                            ymin=-1, ymax=6,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-0.3:3.3, samples=80, smooth] {(x-1)^2};
                            \node[blue, font=\small] at (axis cs:4,5.5) {$y=(x{-}1)^2$};
                            \addplot[red, thick, domain=-0.5:4.5, samples=2] {x + 1};
                            \node[red, font=\small] at (axis cs:4,3.5) {$y=x+1$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(0,1) (3,4)};
                            \node[left, font=\small] at (axis cs:0,1) {$(0,1)$};
                            \node[above left, font=\small] at (axis cs:3,4) {$(3,4)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The intersection points are <m>(0, 1)</m> and <m>(3, 4)</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A cubic function is given by <m>y = x^3 - 4x</m>. Find its intersection points with the line <m>y = -3x</m> by plotting both graphs.
                </p>
            </statement>
            <solution>
                <p>
                    Setting <m>x^3 - 4x = -3x \Rightarrow x^3 - x = 0 \Rightarrow x(x-1)(x+1) = 0</m>.
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-3, xmax=3,
                            ymin=-7, ymax=7,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-2.2:2.2, samples=80, smooth] {x^3 - 4*x};
                            \node[blue, font=\small] at (axis cs:2.5,4.5) {$y=x^3-4x$};
                            \addplot[red, thick, domain=-2.2:2.2, samples=2] {-3*x};
                            \node[red, font=\small] at (axis cs:-2,5.5) {$y=-3x$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(-1,3) (0,0) (1,-3)};
                            \node[above right, font=\small] at (axis cs:-1,3) {$(-1,3)$};
                            \node[below right, font=\small] at (axis cs:0,0) {$(0,0)$};
                            \node[below left, font=\small] at (axis cs:1,-3) {$(1,-3)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The intersection points are <m>(-1, 3)</m>, <m>(0, 0)</m>, and <m>(1, -3)</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve the simultaneous equations <m>y = x^3 - x</m> and <m>y = 0</m> graphically.
                </p>
            </statement>
            <solution>
                <p>
                    The equation <m>y = 0</m> represents the <m>x</m>-axis. We need to find where the cubic curve <m>y = x^3 - x</m> crosses the <m>x</m>-axis.
                </p>
                <p>
                    Plotting the cubic function:
                    <ul>
                        <li>When <m>x = -2, y = (-2)^3 - (-2) = -8 + 2 = -6</m></li>
                        <li>When <m>x = -1, y = (-1)^3 - (-1) = -1 + 1 = 0</m></li>
                        <li>When <m>x = 0, y = 0</m></li>
                        <li>When <m>x = 1, y = (1)^3 - 1 = 0</m></li>
                        <li>When <m>x = 2, y = (2)^3 - 2 = 6</m></li>
                    </ul>
                </p>
                <image width="65%">
                    <latex-image label="Graph of y = x^3 - x">
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-2.5, xmax=2.5,
                            ymin=-7, ymax=7,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-2:2, samples=80, smooth] {x^3 - x};
                            \node[blue, font=\small] at (axis cs:2.2,6) {$y=x^3-x$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(-1,0) (0,0) (1,0)};
                            \node[below right, font=\small] at (axis cs:-1,0) {$(-1,0)$};
                            \node[below right, font=\small] at (axis cs:0,0) {$(0,0)$};
                            \node[below right, font=\small] at (axis cs:1,0) {$(1,0)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The curve intersects the <m>x</m>-axis at three points: <m>(-1, 0)</m>, <m>(0, 0)</m>, and <m>(1, 0)</m>.
                </p>
                <p>
                    The solutions are <m>x = -1, 0, 1</m> (all with <m>y = 0</m>).
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve the simultaneous equations <m>y = x^2</m> and <m>y = -x^2 + 8</m> graphically.
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-3, xmax=3,
                            ymin=-1, ymax=9,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-3:3, samples=80, smooth] {x^2};
                            \node[blue, font=\small] at (axis cs:2.5,7.5) {$y=x^2$};
                            \addplot[red, thick, domain=-2.9:2.9, samples=80, smooth] {-x^2 + 8};
                            \node[red, font=\small] at (axis cs:-2.5,7.5) {$y=-x^2+8$};
                            \addplot[only marks, mark=*, mark size=2pt, black] coordinates {(-2,4) (2,4)};
                            \node[left, font=\small] at (axis cs:-2,4) {$(-2,4)$};
                            \node[right, font=\small] at (axis cs:2,4) {$(2,4)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs intersect at <m>(-2, 4)</m> and <m>(2, 4)</m>.
                    The solutions are <m>x = -2, y = 4</m> and <m>x = 2, y = 4</m>.
                </p>
            </solution>
        </exercise>

        

        <exercise>
            <statement>
                <p>
                    The graph of <m>y = x^3 - 4x^2</m> is drawn on the grid below.
                    Draw the line <m>y = x - 4</m> on the same axes and use your graph to solve <m>x^3 - 4x^2 = x - 4</m>.
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-2, xmax=6,
                            ymin=-10, ymax=8,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-1.3:5.3, samples=80, smooth] {x^3 - 4*x^2};
                            \node[blue, font=\small] at (axis cs:5,6) {$y=x^3-4x^2$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </statement>
            <solution>
                <p>
                    The line <m>y = x - 4</m> passes through <m>(0, -4)</m> and <m>(4, 0)</m>. Adding it to the grid:
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$},
                            ylabel={$y$},
                            xmin=-2, xmax=6,
                            ymin=-10, ymax=8,
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                            axis equal image,
                        ]
                            \addplot[blue, thick, domain=-1.3:5.3, samples=80, smooth] {x^3 - 4*x^2};
                            \addplot[red, thick, domain=-2:6, samples=2] {x - 4};
                            \node[blue, font=\small] at (axis cs:5,6) {$y=x^3-4x^2$};
                            \node[red, font=\small] at (axis cs:5.5,0.5) {$y=x-4$};
                            \addplot[only marks, mark=*, mark size=2.5pt, black] coordinates {(-1,-5) (1,-3) (4,0)};
                            \node[left, font=\small] at (axis cs:-1,-5) {$(-1,-5)$};
                            \node[right, font=\small] at (axis cs:1,-3) {$(1,-3)$};
                            \node[above right, font=\small] at (axis cs:4,0) {$(4,0)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs intersect at <m>(-1, -5)</m>, <m>(1, -3)</m>, and <m>(4, 0)</m>.
                    The solutions to <m>x^3 - 4x^2 = x - 4</m> are <m>x = -1</m>, <m>x = 1</m>, and <m>x = 4</m>.
                </p>
                <p>
                    (Check: <m>x^3 - 4x^2 - x + 4 = x^2(x-4) - (x-4) = (x-4)(x^2-1) = (x-4)(x-1)(x+1) = 0</m>.)
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A stone is thrown upward from the ground. Its height above the ground is modelled by
                    <m>h = -5t^2 + 25t</m> metres, where <m>t</m> is time in seconds.
                    A window ledge is at a constant height of <m>30</m> metres.
                </p>
                <p>
                    By drawing the graphs of <m>h = -5t^2 + 25t</m> and <m>h = 30</m> on the same axes,
                    find the times at which the stone passes the level of the ledge.
                </p>
            </statement>
            <solution>
                <p>
                    The <m>h</m>-axis below is scaled so that each grid unit represents <m>5</m> m (i.e. the grid
                    value <m>6</m> corresponds to <m>h = 30</m> m).
                </p>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$t$ (s)},
                            ylabel={$h$ (m)},
                            xmin=0, xmax=6,
                            ymin=0, ymax=35,
                            xtick={1,2,3,4,5},
                            ytick={0,5,10,15,20,25,30,35},
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=0:5, samples=80, smooth] {-5*x^2 + 25*x};
                            \node[blue, font=\small] at (axis cs:5,20) {$h=-5t^2+25t$};
                            \addplot[red, thick, domain=0:5.5, samples=2] {30};
                            \node[red, font=\small] at (axis cs:5,32) {$h=30$};
                            \addplot[only marks, mark=*, mark size=2.5pt, black] coordinates {(2,30) (3,30)};
                            \node[above left, font=\small] at (axis cs:2,30) {$(2,30)$};
                            \node[above right, font=\small] at (axis cs:3,30) {$(3,30)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs meet at <m>t = 2</m> s and <m>t = 3</m> s (both at <m>h = 30</m> m).
                    The stone passes the window ledge at <m>t = 2</m> seconds on the way up,
                    and again at <m>t = 3</m> seconds on the way down.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A trader sells a product for several days after launch. Her daily revenue is modelled by
                    <m>S = -x^2 + 6x</m> thousand shillings (revenue rises then falls as the product loses popularity),
                    where <m>x</m> is the number of days after launch.
                    A competitor's revenue grows steadily, modelled by <m>S = 2x</m> thousand shillings.
                </p>
                <p>
                    Draw both graphs and find the day(s) on which the two traders have equal daily revenue.
                </p>
            </statement>
            <solution>
                <image width="65%">
                    <latex-image>
                        \begin{tikzpicture}
                        \begin{axis}[
                            axis lines=center,
                            xlabel={$x$ (days)},
                            ylabel={$S$ (Ksh 000s)},
                            xmin=0, xmax=7,
                            ymin=0, ymax=12,
                            xtick={1,2,3,4,5,6},
                            ytick={2,4,6,8,10,12},
                            tick label style={font=\small},
                            grid=both,
                            grid style={line width=0.3pt, draw=gray!30},
                        ]
                            \addplot[blue, thick, domain=0:6, samples=80, smooth] {-x^2 + 6*x};
                            \node[blue, font=\small] at (axis cs:4.5,10.5) {$S=-x^2+6x$};
                            \addplot[red, thick, domain=0:6, samples=2] {2*x};
                            \node[red, font=\small] at (axis cs:5.5,9.5) {$S=2x$};
                            \addplot[only marks, mark=*, mark size=2.5pt, black] coordinates {(0,0) (4,8)};
                            \node[above right, font=\small] at (axis cs:0,0) {$(0,0)$};
                            \node[above left, font=\small] at (axis cs:4,8) {$(4,8)$};
                        \end{axis}
                        \end{tikzpicture}
                    </latex-image>
                </image>
                <p>
                    The graphs meet at <m>(0, 0)</m> and <m>(4, 8)</m>.
                    The revenues are equal on <alert>day 0</alert> (launch day, both at zero) and on
                    <alert>day 4</alert> (both at 8 thousand shillings).
                </p>
            </solution>
        </exercise>

    </exercises>

    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation Strategies</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        Provide pre-drawn grids with scales already marked. Use simpler equations like <m>y = x^2</m> and <m>y = 4</m> to build confidence.
                    </cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        The core lesson activities as described above, focusing on accurate plotting and reading intersection points.
                    </cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        Challenge them to find the equation of a line that would intersect a given parabola at exactly one point (tangent line) or no points at all.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

