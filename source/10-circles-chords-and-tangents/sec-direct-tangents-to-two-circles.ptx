<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-direct-tangents-to-two-circles" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Direct Tangents to Two Circles</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.3 Circles, Chords and Tangents
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title>
                    <p>
                        Construct direct and transverse common tangents to two circles
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    12 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To guide learners to discover that exactly two direct common tangents exist for two separate circles, and that these tangents meet at a single point on the line through the two centres.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Prepare a sheet with two pre-drawn circles of clearly different sizes for learners who struggle to draw their own. 
                </p>
                <p>
                    If learners find the tangents easily, challenge them to find a formula for the distance between the two tangent points in terms of the radii and distance between the centres.
                </p>
            </li>
        </dl>
    </axiom>

    <activity>
        <statement>
            <paragraphs>
                <title>Discovering Direct Common Tangents</title>
                <p>
                    In this activity you will draw pairs of circles and look for straight lines that are tangent to both circles on the same side.
                    <ol marker="(a)">
                        <li>
                            <p>
                                Using a compass (or by tracing two circular objects of different sizes), draw two circles that do not overlap and are not inside each other. Label the centres <m>A</m> and <m>B</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Try to draw a straight line that touches circle <m>A</m> at exactly one point and circle <m>B</m> at exactly one point, with both circles on the same side of the line. How many such lines can you draw? Record your answer in the table below.
                            </p>
                        </li>
                        <li>
                            <p>
                                Extend both lines you found until they meet. Where does the meeting point lie in relation to the line <m>AB</m>?
                            </p>
                            <solution component="lesson-plan">
                                <p>
                                    The meeting point should lie on line <m>AB</m> extended, beyond the smaller circle. This is the external centre of similitude.
                                </p>
                            </solution>
                        </li>
                        <li>
                            <p>
                                Repeat parts (a)–(c) with two more pairs of circles, choosing different sizes and distances each time.
                            </p>
                        </li>
                        <li>
                            <p>
                                Write a conjecture: how many direct common tangents do two separate, non-overlapping circles always have?
                            </p>
                            <solution component="lesson-plan">
                                <p>
                                    Exactly two. Learners should state that two separate circles always have exactly two direct common tangents, and that both tangents pass through the same point on line <m>AB</m> extended.
                                </p>
                            </solution>
                        </li>
                    </ol>
                </p>
                <table>
                    <title>Direct common tangent observations</title>
                    <tabular halign="center" top="minor" bottom="minor" left="minor" right="minor">
                        <row header="yes" bottom="medium">
                            <cell>Pair</cell>
                            <cell>Radius of circle <m>A</m></cell>
                            <cell>Radius of circle <m>B</m></cell>
                            <cell>Number of direct tangents found</cell>
                            <cell>Do the tangents meet when extended?</cell>
                        </row>
                        <row>
                            <cell>1</cell>
                            <cell></cell><cell></cell><cell></cell><cell></cell>
                        </row>
                        <row>
                            <cell>2</cell>
                            <cell></cell><cell></cell><cell></cell><cell></cell>
                        </row>
                        <row>
                            <cell>3</cell>
                            <cell></cell><cell></cell><cell></cell><cell></cell>
                        </row>
                    </tabular>
                </table>
            </paragraphs>
        </statement>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalise the concept of a direct common tangent and teach the compass-and-straightedge construction step by step.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ul>
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Confirm that everyone found exactly two tangents on the same side. Ask a learner to describe where the two lines met — establish together that this point always lies on line <m>AB</m> extended beyond the smaller circle.
                    </p>
                </li>
                <li>
                    <p>
                        Work through the construction steps in the Key Ideas box below. Demonstrate each step on the board before asking learners to follow along at their desks.
                    </p>
                </li>
            </ul>
        </paragraphs>
    </axiom>

    <paragraphs>
        <title>Constructing a Direct Common Tangent</title>
        
         <ol marker="1.">
            <li>
                <p>
                    Draw the two circles with centres <m>A</m> (radius <m>r</m>) and <m>B</m> (radius <m>R</m>), and draw a line through the centres (that continues beyond them).
                </p>
                <figure xml:id="fig-direct-tangents-construction-1">
                <caption>
                    Two circles with centres A and B, and line AB extended.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawPoints(A,B)
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzLabelPoints(A,B)
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
            <li>
                <p>
                    Draw an <term>auxiliary circle</term> centred at <m>B</m> with radius <m>R - r</m>.
                </p>
                <figure xml:id="fig-direct-tangents-construction-3">
                <caption>
                    The auxiliary circle (red) with radius <m>R-r</m>.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDefShiftPoint[c](-2*\rt, 0){c1}
                            \tkzDrawCircles[red](B,c1)
                            \tkzDrawSegment[red](B,c1)
                            \tkzLabelSegment[above, sloped](B,c1){$R - r$}
                            \tkzDrawPoints(A,B)
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzLabelPoints(A,B)
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
            <li>
                <p>
                    Find the midpoint <m>I</m> of segment <m>AB</m>.
                </p>
                <figure xml:id="fig-direct-tangents-construction-4">
                <caption>
                    Point I is the midpoint of AB.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzInterCC(A,B)(B,A) \tkzGetPoints{i}{j}
                            \tkzCompass(A,i)\tkzCompass(A,j)
                            \tkzCompass(B,i)\tkzCompass(B,j)
                            \tkzDrawLine[very thin, add=0.1 and 0.1](i,j)
                            \tkzDrawPoints(A,B,I)
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzLabelPoints(A,B,I)
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
            <li>
                <p>
                    Draw the <term>connecting circle</term> centred at <m>I</m> with radius <m>IA</m>. Use a dashed line.
                </p>
                <figure xml:id="fig-direct-tangents-construction-5">
                <caption>
                    The auxiliary circle (red) and the connecting circle (dashed orange).
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzDrawCircle[orange, thick, dashed](I,B)
                            \tkzDrawPoints(A,B,I)
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzLabelPoints(A,B,I)
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
            <li>
                <p>
                    Label <m>Q</m> as one of the intersection points of the connecting circle and the auxiliary circle.
                </p>
                <figure xml:id="fig-direct-tangents-construction-6">
                <caption>
                    Point Q is the intersection of the connecting circle and the auxiliary circle.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzDrawCircle[orange, thick, dashed](I,B)
                            \tkzDrawPoints(A,B,Q, I)
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzLabelPoints(A,B,Q,I)
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
            <li>
                <p>
                    Draw the ray from <m>B</m> through <m>Q</m> and extend it to meet circle <m>B</m> at the point <m>T'_1</m>.
                </p>
                <figure xml:id="fig-direct-tangents-construction-7">
                <caption>
                    Ray from B through Q meets circle B at <m>T'_1</m>
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzDrawCircle[orange, thick, dashed](I,B)
                            \tkzDrawPoints(A,B,T',Q, I)
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzDrawLines(B,T')
                            \tkzLabelPoints(A,B,Q,I)
                            \tkzLabelPoint[left, xshift=-5pt](T'){$T'_1$}
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
            <li>
                <p>
                    At <m>T'_1</m>, construct the tangent to circle <m>B</m>. Continue this line until it intersects with the extended line <m>AB</m>, and label this point <m>O</m>. Mark the point <m>T_1</m> where the tangent meets <m>AB</m>. The line <m>T_1T'_1</m> is one direct common tangent.
                </p>
                <figure xml:id="fig-direct-tangents-construction-8">
                <caption>
                    First direct tangent drawn.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzDrawCircle[orange, thick, dashed](I,B)
                            \tkzDrawPoints(O,A,B,T',T,Q, I)
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzDrawLines(T',O B,T' A,T)
                            \tkzLabelPoints(O,A,B,Q,I)
                            \tkzLabelPoint[left](T){$T_1$}
                            \tkzLabelPoint[left, xshift=-5pt](T'){$T'_1$}
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
            <li>
                <p>
                    Label <m>Q'</m> as the other intersection point from Step 5. Repeat Steps 6 and 7 using <m>Q'</m> in place of <m>Q</m> to obtain the second direct common tangent, <m>T_2T'_2</m>
                </p>
                <figure xml:id="fig-direct-tangents-construction-9">
                <caption>
                    Second direct tangent drawn.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8]
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoints{0/0/A,4/2/B,2/3/K}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzInterLC[R](B,Q')(B,\R) \tkzGetPoints{X2'}{T2'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzInterLC[R](O,T2')(A,\r) \tkzGetPoints{T2}{T2}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzDrawCircle[orange, thick, dashed](I,B)
                            \tkzDrawPoints(O,A,B,T',T,T2,Q,Q',I,T2')
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzDrawLines(B,T' A,T B,T2' A,T2)
                            \tkzDrawLines(T',O T2',O)
                            \tkzLabelPoints(O,B,Q,I)
                            \tkzLabelPoints[right](A)
                            \tkzLabelPoints[below right](Q')
                            \tkzLabelPoint[left](T){$T_1$}
                            \tkzLabelPoint[left, xshift=-5pt](T'){$T'_1$}
                            \tkzLabelPoint[below](T2){$T_2$}
                            \tkzLabelPoint[below right](T2'){$T'_2$}
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
            </li>
        </ol>
    </paragraphs>

    <exploration>
        <title>Interactive Construction of Direct Tangents</title>
        <interactive xml:id="interactive-direct-tangents" platform="jsxgraph" aspect="4:3" source="jsxgraph/direct-common-tangent-construction.js" width="65%">
            <slate xml:id="jsx-direct-common-tangent-construction" surface="jsxboard" aspect="4:3"/>
            <instructions>
                <p>
                    Use the <c>Back</c> and <c>Next</c> buttons to step through the tangent construction process. At each step, try to replicate the construction on your own paper with a compass and straightedge.
                </p>
                <p>
                    Feel free to drag around the circles and change their radii.
                </p>
            </instructions>
        </interactive>
    </exploration>

    <insight>
        <p>
            <ul>
                <li>
                    <p>
                        A <term>direct common tangent</term> to two circles is a straight line that is tangent to both circles and leaves both circles on the same side of the line.
                    </p>
                </li>
                <li>
                    <p>
                        Two circles that do not overlap and are not inside each other have exactly <em>two</em> direct common tangents.
                    </p>
                </li>
                <li>
                    <p>
                        Both direct common tangents pass through a single point <m>O</m> on the line through the centres.
                    </p>
                </li>
            </ul>
        </p>
    </insight>

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <example xml:id="ex-2-9-5-construction">
        <statement>
            <p>
                Two circles have centres <m>A</m> and <m>B</m> with radii 2 cm and 5 cm respectively. The distance <m>AB = 9</m> cm. Using a compass and ruler, construct the direct common tangents to the two circles.
            </p>
            <figure xml:id="fig-2-5-9-construction">
                <caption>
                    Two circles with centres A and B, and line AB extended.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.5]
                            \pgfmathsetmacro{\r}{2}%
                            \pgfmathsetmacro{\R}{5}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoint(0,0){A}
                            \tkzDefPoint(-30:9){B}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDefShiftPoint[a](-2*\r, 0){a1}
                            \tkzDefShiftPoint[b](-2*\R, 0){b1}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawPoints(A,B)
                            \tkzDrawSegment(A,B)
                            \tkzLabelSegment[above, sloped, fill=white, opacity=0.5](A,B){$9$ cm}
                            \tkzDrawSegment[blue](A,a)
                            \tkzDrawSegment[red](B,b1)
                            \tkzLabelSegment[above, sloped](A,a){$2$ cm}
                            \tkzLabelSegment[above, sloped](B,b1){$5$ cm}
                            \tkzLabelPoints(A,B)
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
        </statement>
        <solution>
            <p>
                Follow the construction steps as discussed above:
                <ol>
                    <li>
                        <p>
                            Draw circle <m>A</m> with radius 2 cm and circle <m>B</m> with radius 5 cm, with <m>AB = 9</m> cm.
                        </p>
                    </li>
                    <li>
                        <p>
                            Set your compass to <m>R - r = 5 - 2 = 3</m> cm. Draw an auxiliary circle centred at <m>B</m> with radius 3 cm (dashed).
                        </p>
                    </li>
                    <li>
                        <p>
                            Bisect <m>AB</m> to find the midpoint <m>I</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Set your compass to <m>IA = IB = 4.5</m> cm. Draw the connecting circle on diameter <m>AB</m> (dashed).
                        </p>
                    </li>
                    <li>
                        <p>
                            Mark the two intersection points <m>Q</m> and <m>Q'</m> of the semicircle and the auxiliary circle.
                        </p>
                    </li>
                    <li>
                        <p>
                            Draw the ray <m>BQ</m> extended to meet circle <m>B</m> at <m>T_1'</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Construct the tangent to circle <m>B</m> at <m>T_1'</m>; extend it to meet line <m>AB</m> extended at <m>O</m>, and mark the point <m>T_1</m> where the tangent meets <m>AB</m>. The line <m>T_1T_1'</m> is one direct common tangent.
                        </p>
                    </li>
                    <li>
                        <p>
                            Repeat the previous two steps using <m>Q'</m> to find the second direct common tangent <m>T_2T_2'</m>.
                        </p>
                    </li>
                </ol>
            </p>
            <figure xml:id="fig-2-5-9-soln">
                <caption>
                    Second direct tangent drawn.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.5]
                            \pgfmathsetmacro{\r}{2}%
                            \pgfmathsetmacro{\R}{5}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoint(0,0){A}
                            \tkzDefPoint(-30:9){B}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzInterLC[R](B,Q')(B,\R) \tkzGetPoints{X2'}{T2'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzInterLC[R](O,T2')(A,\r) \tkzGetPoints{T2}{T2}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzDrawCircle[orange, thick, dashed](I,B)
                            \tkzDrawPoints(O,A,B,T',T,T2,Q,Q',I,T2')
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzDrawLines(B,T' A,T B,T2' A,T2)
                            \tkzDrawLines(T',O T2',O)
                            \tkzLabelPoints(O,B,I)
                            \tkzLabelPoints[right](A, Q)
                            \tkzLabelPoints[above](Q')
                            \tkzLabelPoint[above](T){$T_1$}
                            \tkzLabelPoint[above left](T'){$T'_1$}
                            \tkzLabelPoint[below](T2){$T_2$}
                            \tkzLabelPoint[below](T2'){$T'_2$}
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
        </solution>
    </example>

    <example xml:id="ex-direct-tangent-length">
        <statement>
            <p>
                Two circles have their centres 13 cm apart. Their radii are 2 cm and 7 cm. Calculate the length of a direct common tangent.
            </p>
        </statement>
        <solution>
            <p>
                Let the centres be <m>A</m> (radius <m>r = 2</m> cm) and <m>B</m> (radius <m>R = 7</m> cm), with <m>AB = d = 13</m> cm.
            </p>
            <p>
                Draw a line through <m>A</m> parallel to the tangent <m>TT'</m>, meeting the perpendicular <m>BT'</m> at the point <m>M</m>. This creates a right triangle with:
                <ul>
                    <li><p>hypotenuse <m>AB = 13</m> cm,</p></li>
                    <li><p>one leg <m>BM = R - r = 7 - 2 = 5</m> cm,</p></li>
                    <li><p>other leg <m>AM = TT'</m> (the length we want).</p></li>
                </ul>
            </p>
            <figure xml:id="fig-direct-tangent-formula">
                <caption>
                    The right triangle <m>ABM</m> used to derive the tangent length formula.
                    Here <m>r = 2</m> cm, <m>R = 7</m> cm, <m>d = 13</m> cm.
                </caption>
                <image width="75%">
                    <shortdescription>
                        Circles at A and B with a direct common tangent TT-prime. A dashed line
                        from A parallel to the tangent meets the radius BT-prime at M, forming
                        right triangle ABM with the right angle at M.
                    </shortdescription>
                    <latex-image>
                        \begin{tikzpicture}[scale=0.85]
                        % Scaled by 0.5: r=1 (=2cm), R=3.5 (=7cm), d=6.5 (=13cm).
                        % Tangent points and M computed analytically.
                        \tkzDefPoints{0/0/A, 6.5/0/B}
                        \tkzDefPoint(-0.385,0.923){T}
                        \tkzDefPoint(5.154,3.231){Tp}
                        \tkzDefPoint(5.538,2.308){M}
                        % Circles (drawn thin for context)
                        \tkzDefCircle[R](A,1) \tkzGetPoint{cA}
                        \tkzDefCircle[R](B,3.5) \tkzGetPoint{cB}
                        \tkzDrawCircle[thin,gray](A,cA)
                        \tkzDrawCircle[thin,gray](B,cB)
                        % Centre line (dashed)
                        \tkzDrawSegment[dashed, gray](A,B)
                        % Radii to tangent points
                        \tkzDrawSegments[thin](A,T B,Tp)
                        % Tangent segment TT' (prominent)
                        \tkzDrawSegment[very thick](T,Tp)
                        % Auxiliary dashed line AM parallel to TT'
                        \tkzDrawSegment[dashed](A,M)
                        % Right angle marks
                        \tkzMarkRightAngle[size=0.18](A,M,B)
                        \tkzMarkRightAngle[size=0.14](Tp,T,A)
                        \tkzMarkRightAngle[size=0.14](T,Tp,B)
                        % Points
                        \tkzDrawPoints(A,B,T,Tp,M)
                        \tkzLabelPoint[below](A){$A$}
                        \tkzLabelPoint[below right](B){$B$}
                        \tkzLabelPoint[above left](T){$T$}
                        \tkzLabelPoint[above right](Tp){$T'$}
                        \tkzLabelPoint[right](M){$M$}
                        % Length labels
                        \tkzLabelSegment[below,font=\small](A,B){$d = 13$ cm}
                        \tkzLabelSegment[left,font=\small](A,T){$r{=}2$}
                        \tkzLabelSegment[above,sloped,font=\small](T,Tp){$L = 12$ cm}
                        \tkzLabelSegment[right,font=\small](B,M){$R{-}r{=}5$}
                        \tkzLabelSegment[right,font=\small](M,Tp){$r{=}2$}
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                By Pythagoras:
                <md>
                    <mrow> (TT')^2 \amp= AB^2 - BM^2 </mrow>
                    <mrow>       \amp= 13^2 - 5^2 </mrow>
                    <mrow>       \amp= 169 - 25 </mrow>
                    <mrow>       \amp= 144 </mrow>
                    <mrow> TT'  \amp= 12 \text{ cm} </mrow>
                </md>
            </p>
            <p>
                The length of the direct common tangent is <m>12</m> cm.
            </p>
        </solution>
    </example>

    <theorem xml:id="length-of-direct-tangent">
        <title>Length of the Direct Tangent</title>
        <p>
            Generalising the previous example, if we have two circles with radii <m>r</m> and <m>R</m> and the distance between their centres is <m>d</m>, then the length of the direct common tangent <m>L</m> is given by:
            <md>
                <mrow> L \amp= \sqrt{d^2 - (R - r)^2} </mrow>
            </md>
        </p>
        <p>
            You'll prove this in <xref ref="ex-direct-tangent-length-proof"/>.
        </p>
    </theorem>

    <example xml:id="ex-direct-tangent-find-d">
        <statement>
            <p>
                Two circles have radii 3 cm and 9 cm. The length of their direct common tangent is 8 cm. Find the distance between the centres.
            </p>
        </statement>
        <solution>
            <p>
                Let the distance between the centres be <m>d</m> cm. Using the direct common tangent length formula:
                <md>
                    <mrow> L^2 \amp= d^2 - (R - r)^2 </mrow>
                    <mrow> 8^2 \amp= d^2 - (9 - 3)^2 </mrow>
                    <mrow>  64 \amp= d^2 - 36 </mrow>
                    <mrow> d^2 \amp= 100 </mrow>
                    <mrow>   d \amp= 10 \text{ cm} </mrow>
                </md>
            </p>
            <p>
                The distance between the centres is <m>10</m> cm.
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <exercises>
        <exercise>
            <statement>
                <p>
                    In each part, two circles are given. Using a compass and ruler, construct both direct common tangents. Mark the external centre of similitude <m>O</m> in each case.
                </p>
                <ol marker="(a)">
                    <li>
                        <p>
                            Circle <m>A</m> with radius 1 cm, circle <m>B</m> with radius 3 cm, centres 6 cm apart.
                        </p>
                    </li>
                    <li>
                        <p>
                            Circle <m>A</m> with radius 2 cm, circle <m>B</m> with radius 4 cm, centres 8 cm apart.
                        </p>
                    </li>
                    <li>
                        <p>
                            Circle <m>A</m> with radius 1.5 cm, circle <m>B</m> with radius 3.5 cm, centres 7 cm apart.
                        </p>
                    </li>
                </ol>
            </statement>
        <solution>
            <ol marker="(a)">
                <li>
                    <p>
                    Drawing the tangents:
                </p>
                    <p>
                        <figure xml:id="fig-exer1a-direct">
                    <caption>Part (a): <m>r = 1</m>, <m>R = 3</m>, <m>d = 6</m> cm.</caption>
                    <image>
                        <shortdescription>
                            Two circles at A and B with two direct common tangents.
                        </shortdescription>
                        <latex-image>
                            \begin{tikzpicture}
                            % r=1, R=3, d=6, scaled by 0.5: rA=0.5, rB=1.5, A=(0,0), B=(3,0)
                            % O = -r*d/(R-r) = -3, scaled: O=(-1.5,0)
                            \pgfmathsetmacro{\rA}{0.5}
                            \pgfmathsetmacro{\rB}{1.5}
                            \tkzDefPoints{0/0/A, 3/0/B, -1.5/0/O}
                            \tkzDefCircle[R](A,\rA) \tkzGetPoint{cA}
                            \tkzDefCircle[R](B,\rB) \tkzGetPoint{cB}
                            % Tangent points via circle-on-diameter method
                            \tkzDefMidPoint(O,A) \tkzGetPoint{MA}
                            \tkzDefMidPoint(O,B) \tkzGetPoint{MB}
                            \tkzInterCC(MA,A)(A,cA) \tkzGetPoints{T1}{T2}
                            \tkzInterCC(MB,B)(B,cB) \tkzGetPoints{T1p}{T2p}
                            \useasboundingbox (-0.7,-2.05) rectangle (4.8,2.05);
                            \clip (-0.7,-2.05) rectangle (4.8,2.05);
                            \tkzDrawCircle[thick](A,cA)
                            \tkzDrawCircle[thick](B,cB)
                            \tkzDrawLine[add=0.5 and 0.5](T1,T1p)
                            \tkzDrawLine[add=0.5 and 0.5](T2,T2p)
                            \tkzDrawPoint(O)
                            \tkzDrawPoints(A,B)
                            \tkzLabelPoint[below](O){$O$}
                            \tkzLabelPoint[above right](A){$A$}
                            \tkzLabelPoint[above right](B){$B$}
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                </p>
            </li>
            <li>
                <p>
                    Drawing the tangents:
                </p>
            <p>
                <figure xml:id="fig-exer1b-direct">
                    <caption>Part (b): <m>r = 2</m>, <m>R = 4</m>, <m>d = 8</m> cm.</caption>
                    <image>
                        <shortdescription>
                            Two circles at A and B with two direct common tangents.
                        </shortdescription>
                        <latex-image>
                            \begin{tikzpicture}
                            % r=2, R=4, d=8, scaled by 0.35: rA=0.7, rB=1.4, A=(0,0), B=(2.8,0)
                            % O = -r*d/(R-r) = -8, scaled: O=(-2.8,0)
                            \pgfmathsetmacro{\rA}{0.7}
                            \pgfmathsetmacro{\rB}{1.4}
                            \tkzDefPoints{0/0/A, 2.8/0/B, -2.8/0/O}
                            \tkzDefCircle[R](A,\rA) \tkzGetPoint{cA}
                            \tkzDefCircle[R](B,\rB) \tkzGetPoint{cB}
                            \tkzDefMidPoint(O,A) \tkzGetPoint{MA}
                            \tkzDefMidPoint(O,B) \tkzGetPoint{MB}
                            \tkzInterCC(MA,A)(A,cA) \tkzGetPoints{T1}{T2}
                            \tkzInterCC(MB,B)(B,cB) \tkzGetPoints{T1p}{T2p}
                            \useasboundingbox (-0.9,-1.8) rectangle (4.4,1.8);
                            \clip (-0.9,-1.8) rectangle (4.4,1.8);
                            \tkzDrawCircle[thick](A,cA)
                            \tkzDrawCircle[thick](B,cB)
                            \tkzDrawLine[add=0.5 and 0.5](T1,T1p)
                            \tkzDrawLine[add=0.5 and 0.5](T2,T2p)
                            \tkzDrawPoints(A,B)
                            \tkzLabelPoint[above right](A){$A$}
                            \tkzLabelPoint[above right](B){$B$}
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                </p>
            </li>
            <li>
                <p>
                    Drawing the tangents:
                </p>
            <p>
                <figure xml:id="fig-exer1c-direct">
                    <caption>Part (c): <m>r = 1.5</m>, <m>R = 3.5</m>, <m>d = 7</m> cm.</caption>
                    <image>
                        <shortdescription>
                            Two circles at A and B with two direct common tangents.
                        </shortdescription>
                        <latex-image>
                            \begin{tikzpicture}
                            % r=1.5, R=3.5, d=7, scaled by 0.5: rA=0.75, rB=1.75, A=(0,0), B=(3.5,0)
                            % O = -r*d/(R-r) = -5.25, scaled: O=(-2.625,0)
                            \pgfmathsetmacro{\rA}{0.75}
                            \pgfmathsetmacro{\rB}{1.75}
                            \tkzDefPoints{0/0/A, 3.5/0/B, -2.625/0/O}
                            \tkzDefCircle[R](A,\rA) \tkzGetPoint{cA}
                            \tkzDefCircle[R](B,\rB) \tkzGetPoint{cB}
                            \tkzDefMidPoint(O,A) \tkzGetPoint{MA}
                            \tkzDefMidPoint(O,B) \tkzGetPoint{MB}
                            \tkzInterCC(MA,A)(A,cA) \tkzGetPoints{T1}{T2}
                            \tkzInterCC(MB,B)(B,cB) \tkzGetPoints{T1p}{T2p}
                            \useasboundingbox (-0.95,-2.15) rectangle (5.4,2.15);
                            \clip (-0.95,-2.15) rectangle (5.4,2.15);
                            \tkzDrawCircle[thick](A,cA)
                            \tkzDrawCircle[thick](B,cB)
                            \tkzDrawLine[add=0.5 and 0.5](T1,T1p)
                            \tkzDrawLine[add=0.5 and 0.5](T2,T2p)
                            \tkzDrawPoints(A,B)
                            \tkzLabelPoint[above right](A){$A$}
                            \tkzLabelPoint[above right](B){$B$}
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                </p>
                </li>
            </ol>
        </solution>
        </exercise>

        <exercise xml:id="ex-direct-construction-why">
            <statement>
                <p>
                    This exercise explains <em>why</em> the construction in the Key Ideas box always produces a direct common tangent. Recall the construction for two circles with centres <m>A</m> (radius <m>r</m>) and <m>B</m> (radius <m>R</m>, with <m>R \gt r</m>):
                </p>
                <ul>
                    <li><p>the <term>connecting circle</term> has <m>AB</m> as a diameter (centre <m>I</m>, the midpoint of <m>AB</m>);</p></li>
                    <li><p>the <term>auxiliary circle</term> has centre <m>B</m> and radius <m>R - r</m>;</p></li>
                    <li><p><m>Q</m> is a point where these two circles meet;</p></li>
                    <li><p><m>T_1'</m> is the point where the ray from <m>B</m> through <m>Q</m>, extended, meets circle <m>B</m> (so that <m>Q</m> lies between <m>B</m> and <m>T_1'</m>), and the tangent line is drawn through <m>T_1'</m> at right angles to the radius <m>BT_1'</m>.</p></li>
                </ul>
                <figure xml:id="fig-direct-why">
                    <caption>
                        The points behind the construction. <m>Q</m> lies on the connecting circle (orange, on diameter <m>AB</m>) and on the auxiliary circle (light red, radius <m>R-r</m>); the tangent drawn at <m>T_1'</m> meets line <m>AB</m> at <m>O</m>, outside both circles.
                    </caption>
                    <image width="90%">
                        <shortdescription>
                            Two circles centred at A and B. A dashed connecting circle on diameter AB and a dashed auxiliary circle of radius R minus r meet at Q, where angle AQB is a right angle. The ray from B through Q, extended, meets circle B at T-one-prime, where a line is drawn tangent to circle B; this same line is tangent to circle A at T-one, with both circles on the same side, and crosses line AB at O beyond the smaller circle A.
                        </shortdescription>
                        <latex-image>
                            \begin{tikzpicture}[scale=0.85]
                            %% --- SET ---
                            \pgfmathsetmacro{\r}{1}%
                            \pgfmathsetmacro{\R}{3}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoint(0,0){A}
                            \tkzDefPoint(6,0){B}
                            %% --- CALCULATE ---
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterCC(I,B)(B,c) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[near](Q,B)(B,b) \tkzGetFirstPoint{T1p}
                            \tkzDefLine[tangent at=T1p](B) \tkzGetPoint{h1}
                            \tkzDefPointBy[projection=onto h1--T1p](A) \tkzGetPoint{T1}
                            \tkzInterLL(T1,T1p)(A,B) \tkzGetPoint{O}
                            %% --- DRAW ---
                            \tkzDrawCircle[blue, thick](A,a)
                            \tkzDrawCircle[red, thick](B,b)
                            \tkzDrawCircle[red!40, dashed](B,c)
                            \tkzDrawCircle[orange, dashed](I,B)
                            \tkzDrawLine[add=0.1 and 0.7](B,A)
                            \tkzDrawSegment(A,Q)
                            \tkzDrawSegment(B,T1p)
                            \tkzDrawLine[add=0.15 and 0.5, thick](O,T1p)
                            \tkzDrawSegment[blue](A,T1)
                            \tkzDrawPoints(A,B,I,Q,T1p,T1,O)
                            %% --- MARK ---
                            \tkzMarkRightAngle[size=0.32](A,Q,B)
                            \tkzMarkRightAngle[size=0.28](B,T1p,O)
                            \tkzMarkRightAngle[size=0.28](T1p,T1,A)
                            %% --- LABEL ---
                            \tkzLabelPoint[above right](A){$A$}
                            \tkzLabelPoint[below right](B){$B$}
                            \tkzLabelPoint[below](I){$I$}
                            \tkzLabelPoint[above right](Q){$Q$}
                            \tkzLabelPoint[above right](T1p){$T_1'$}
                            \tkzLabelPoint[below left](T1){$T_1$}
                            \tkzLabelPoint[below left](O){$O$}
                            \tkzLabelSegment[below right, pos=0.5](B,Q){$R-r$}
                            \tkzLabelSegment[above left, pos=0.5](Q,T1p){$r$}
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                <ol marker="(a)">
                    <li>
                        <p>
                            Explain why <m>\angle AQB = 90^\circ</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Write down the length <m>BQ</m>, and hence show that <m>QT_1' = r</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            The tangent line is perpendicular to the radius <m>BT_1'</m>. Explain why this tangent line is <em>parallel</em> to <m>AQ</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Using parts (b) and (c), show that the perpendicular distance from <m>A</m> to the tangent line is exactly <m>r</m>. Why does this prove that the line is tangent to circle <m>A</m>?
                        </p>
                    </li>
                    <li>
                        <p>
                            Explain why <m>A</m> and <m>B</m> lie on the <em>same</em> side of the tangent line, so that it is a <em>direct</em> (and not a transverse) common tangent.
                        </p>
                    </li>
                    <li>
                        <p>
                            The second meeting point <m>Q'</m> of the connecting and auxiliary circles gives the second direct tangent in exactly the same way. Explain briefly why the two tangents are reflections of each other in the line <m>AB</m>, and hence why they meet at a single point <m>O</m> on line <m>AB</m>. Why does <m>O</m> lie <em>outside</em> both circles?
                        </p>
                    </li>
                </ol>
            </statement>
            <solution>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>Q</m> lies on the connecting circle, which has <m>AB</m> as a diameter. An angle subtended by a diameter at a point on the circle is a right angle (the angle in a semicircle), so <m>\angle AQB = 90^\circ</m>. In particular, <m>AQ \perp QB</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>Q</m> lies on the auxiliary circle, centred at <m>B</m> with radius <m>R - r</m>, so <m>BQ = R - r</m>. The point <m>T_1'</m> lies on circle <m>B</m>, so <m>BT_1' = R</m>, and <m>Q</m> lies between <m>B</m> and <m>T_1'</m>. Therefore
                            <me>QT_1' = BT_1' - BQ = R - (R - r) = r.</me>
                        </p>
                    </li>
                    <li>
                        <p>
                            The tangent line is perpendicular to <m>BT_1'</m>. Since <m>T_1'</m> lies on line <m>QB</m>, the radius <m>BT_1'</m> lies along <m>QB</m>, so the tangent line is perpendicular to <m>QB</m>. From part (a), <m>AQ</m> is also perpendicular to <m>QB</m>. Two lines that are perpendicular to the same line are parallel, so the tangent line is parallel to <m>AQ</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            The tangent line and <m>AQ</m> are parallel, and both are perpendicular to <m>QB</m>. The perpendicular distance between them is therefore the distance measured along <m>QB</m> from <m>Q</m> to <m>T_1'</m>, which is <m>QT_1' = r</m> by part (b). As <m>A</m> lies on the line <m>AQ</m>, the perpendicular distance from <m>A</m> to the tangent line is exactly <m>r</m>. A straight line whose distance from the centre of a circle equals that circle's radius touches the circle at exactly one point, so the line is tangent to circle <m>A</m> (radius <m>r</m>). It is tangent to circle <m>B</m> by construction, so it is a common tangent.
                        </p>
                    </li>
                    <li>
                        <p>
                            Because <m>Q</m> lies <em>between</em> <m>B</m> and <m>T_1'</m>, both <m>B</m> and <m>Q</m> lie on the same side of the tangent line (the side of <m>T_1'</m> towards <m>B</m>). Since <m>AQ \perp QB</m> at <m>Q</m>, the centre <m>A</m> is level with <m>Q</m> and so lies on that same side. Hence <m>A</m> and <m>B</m> are on the <em>same</em> side of the line, which is exactly what makes it a <em>direct</em> common tangent rather than a transverse one.
                        </p>
                    </li>
                    <li>
                        <p>
                            The whole construction is symmetric about the line <m>AB</m>: the points <m>Q</m> and <m>Q'</m> are the two intersections of the connecting and auxiliary circles, and these are mirror images of each other in <m>AB</m>. Reflecting the first tangent in <m>AB</m> therefore produces the second tangent, and two lines that are mirror images in <m>AB</m> must meet on the mirror line itself — so both tangents pass through a single point <m>O</m> on line <m>AB</m>. Comparing the similar right triangles <m>AT_1O</m> and <m>BT_1'O</m> gives <m>AO : OB = AT_1 : BT_1' = r : R</m>. Since <m>r \lt R</m>, the point <m>O</m> cannot lie between <m>A</m> and <m>B</m>; it lies on <m>AB</m> extended beyond the smaller circle <m>A</m>, outside both circles.
                        </p>
                    </li>
                </ol>
            </solution>
        </exercise>

        <exercise xml:id="ex-direct-tangent-length-proof">
            <statement>
                <p>
                    A direct common tangent <m>TT'</m> touches circle <m>A</m> (radius <m>r</m>) at <m>T</m> and circle <m>B</m> (radius <m>R</m>, <m>R \gt r</m>) at <m>T'</m>. The distance between the centres is <m>d = AB</m>.
                </p>
                <figure xml:id="fig-exer2-proof-setup">
                    <caption>
                        Direct common tangent <m>TT'</m> and the auxiliary right triangle <m>ABM</m>,
                        where <m>AM \parallel TT'</m>.
                    </caption>
                    <image width="65%">
                        <shortdescription>
                            Two circles at A and B. A tangent line touches circle A at T and circle B
                            at T-prime. A dashed line from A parallel to TT-prime meets the line BT-prime
                            at M, forming right triangle ABM with the right angle at M.
                        </shortdescription>
                        <latex-image>
                            \begin{tikzpicture}[scale=0.85]
                            % Generic diagram: r=1, R=3.5, d=6.5 (symbolic labels only).
                            % O = -r*d/(R-r) = -2.6; tangent points computed analytically.
                            \tkzDefPoints{0/0/A, 6.5/0/B, -2.6/0/O}
                            \tkzDefCircle[R](A,1) \tkzGetPoint{cA}
                            \tkzDefCircle[R](B,3.5) \tkzGetPoint{cB}
                            % Tangent points via circle-on-diameter
                            \tkzDefMidPoint(O,A) \tkzGetPoint{MA}
                            \tkzDefMidPoint(O,B) \tkzGetPoint{MB}
                            \tkzInterCC(MA,A)(A,cA) \tkzGetPoints{T}{Tx}
                            \tkzInterCC(MB,B)(B,cB) \tkzGetPoints{Tp}{Tpx}
                            % M: intersection of line through A parallel to TT', and line BT'
                            % M is on segment BT' at distance R-r from B.
                            % Direction B->Tp (unit vector): compute M = B + (R-r)/R * (Tp - B)
                            \tkzDefPointWith[linear,K={2.5/3.5}](B,Tp) \tkzGetPoint{M}
                            % Circles (thin)
                            \tkzDrawCircle[thin,gray](A,cA)
                            \tkzDrawCircle[thin,gray](B,cB)
                            % Centre line
                            \tkzDrawSegment[dashed,gray](A,B)
                            % Radii
                            \tkzDrawSegments[thin](A,T B,Tp)
                            % Tangent TT' (prominent)
                            \tkzDrawSegment[very thick](T,Tp)
                            % Auxiliary AM (dashed)
                            \tkzDrawSegment[dashed](A,M)
                            % Right angle at M
                            \tkzMarkRightAngle[size=0.22](A,M,B)
                            \tkzMarkRightAngle[size=0.16](Tp,T,A)
                            \tkzMarkRightAngle[size=0.16](T,Tp,B)
                            % Points
                            \tkzDrawPoints(A,B,T,Tp,M)
                            \tkzLabelPoint[below](A){$A$}
                            \tkzLabelPoint[below right](B){$B$}
                            \tkzLabelPoint[above left](T){$T$}
                            \tkzLabelPoint[above right](Tp){$T'$}
                            \tkzLabelPoint[right](M){$M$}
                            % Symbolic length labels
                            \tkzLabelSegment[below,font=\small](A,B){$d$}
                            \tkzLabelSegment[left,font=\small](A,T){$r$}
                            \tkzLabelSegment[above,sloped,font=\small](T,Tp){$L = TT'$}
                            \tkzLabelSegment[right,font=\small](B,M){$R{-}r$}
                            \tkzLabelSegment[right,font=\small](M,Tp){$r$}
                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                <ol marker="(a)">
                    <li>
                        <p>
                            From <m>A</m>, draw a line parallel to <m>TT'</m> meeting the line <m>BT'</m> at a point <m>M</m>. Explain why <m>BM = R - r</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Explain why triangle <m>ABM</m> is right-angled at <m>M</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Show that <m>AM = TT'</m>, and hence use Pythagoras' theorem to prove that
                            <md>
                                TT' = \sqrt{d^2 - (R - r)^2}.
                            </md>
                        </p>
                    </li>
                </ol>
            </statement>
            <solution>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                Since <m>AT \perp TT'</m>, <m>BT' \perp TT'</m>, and <m>AM \parallel TT'</m>, the quadrilateral <m>ATT'M</m> is a rectangle. Therefore <m>MT' = AT = r</m>, and so <m>BM = BT' - MT' = R - r</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Since <m>AM \parallel TT'</m> and <m>BT'</m> is perpendicular to <m>TT'</m>, the line <m>BM</m> is also perpendicular to <m>AM</m>. Therefore <m>\angle AMB = 90°</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Since <m>AMT'T</m> is a rectangle, <m>AM = TT'</m>. Applying Pythagoras to triangle <m>ABM</m>:
                                <md>
                                    <mrow> AB^2 \amp= AM^2 + BM^2 </mrow>
                                    <mrow> d^2  \amp= TT'^2 + (R-r)^2 </mrow>
                                    <mrow> TT'  \amp= \sqrt{d^2 - (R-r)^2}. </mrow>
                                </md>
                            </p>
                        </li>
                    </ol>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    So far we've only look at two circles with no overlap. Below are two circles with radius 2 cm and 6 cm, and the distance between their centres is 6 cm. 
                </p>
                 <figure xml:id="fig-overlap-setup">
                <caption>
                    Overlapping circles
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.5]
                            \pgfmathsetmacro{\r}{2}%
                            \pgfmathsetmacro{\R}{6}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoint(0,0){A}
                            \tkzDefPoint(-30:6){B}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawPoints(A,B)
                            \tkzLabelPoints(B)
                            \tkzLabelPoints[right](A)
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
                <p>
                    Can you draw a direct common tangent to these circles using our previous methods? Explain why or why not.
                </p>
            </statement>
            <solution>
                <p>
                    Yes, the same method works:
                </p>
                <p>
                    <figure xml:id="fig-overlap-soln">
                <caption>
                    Second direct tangent drawn.
                </caption>
                <image width="90%">
                    <!-- Image adapted from https://altermundus.fr/files/tkz-euclide/tkz-euclide.pdf p. 232 -->
                    <latex-image>
                        \begin{tikzpicture}[scale=0.5]
                            \pgfmathsetmacro{\r}{2}%
                            \pgfmathsetmacro{\R}{6}%
                            \pgfmathsetmacro{\rt}{\R-\r}%
                            \tkzDefPoint(0,0){A}
                            \tkzDefPoint(-30:6){B}
                            \tkzDefMidPoint(A,B) \tkzGetPoint{I}
                            \tkzInterLC[R](A,B)(B,\rt) \tkzGetPoints{E}{F}
                            \tkzInterCC(I,B)(B,F) \tkzGetPoints{Q}{Q'}
                            \tkzInterLC[R](B,Q)(B,\R) \tkzGetPoints{X'}{T'}
                            \tkzInterLC[R](B,Q')(B,\R) \tkzGetPoints{X2'}{T2'}
                            \tkzDefLine[tangent at=T'](B) \tkzGetPoint{h}
                            \tkzInterLL(T',h)(A,B) \tkzGetPoint{O}
                            \tkzInterLC[R](O,T')(A,\r) \tkzGetPoints{T}{T}
                            \tkzInterLC[R](O,T2')(A,\r) \tkzGetPoints{T2}{T2}
                            \tkzDefCircle[R](A,\r) \tkzGetPoint{a}
                            \tkzDefCircle[R](B,\R) \tkzGetPoint{b}
                            \tkzDefCircle[R](B,\rt) \tkzGetPoint{c}
                            \tkzDrawCircles[blue, thick](A,a)
                            \tkzDrawCircles[red, thick](B,b)
                            \tkzDrawCircles[red](B,c)
                            \tkzDrawCircle[orange, thick, dashed](I,B)
                            \tkzDrawPoints(O,A,B,T',T,T2,Q,Q',I,T2')
                            \tkzDrawLines[add=0.2 and 0.5](O,B)
                            \tkzDrawLines(B,T' A,T B,T2' A,T2)
                            \tkzDrawLines(T',O T2',O)
                            \tkzLabelPoints(O,B,I)
                            \tkzLabelPoints[right](A, Q)
                            \tkzLabelPoints[above](Q')
                            \tkzLabelPoint[above](T){$T_1$}
                            \tkzLabelPoint[above left](T'){$T'_1$}
                            \tkzLabelPoint[below](T2){$T_2$}
                            \tkzLabelPoint[below](T2'){$T'_2$}
                            \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    In each part, find the length of the direct common tangent to the two circles.
                </p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p>
                            Radii 2 cm and 8 cm, centres 10 cm apart.
                        </p>
                    </li>
                    <li>
                        <p>
                            Radii 2 cm and 10 cm, centres 17 cm apart.
                        </p>
                    </li>
                    <li>
                        <p>
                            Radii 1 cm and 4 cm, centres 5 cm apart.
                        </p>
                    </li>
                    <li>
                        <p>
                            Radii 3 cm and 13 cm, centres 26 cm apart.
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)" cols="2">
                    <li><p>8 cm</p></li>
                    <li><p>15 cm</p></li>
                    <li><p>4 cm</p></li>
                    <li><p>24 cm</p></li>
                </ol>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>
                    In each part, find the distance between the centres of the two circles.
                </p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p>
                            Radii 1 cm and 9 cm, direct common tangent length 15 cm.
                        </p>
                    </li>
                    <li>
                        <p>
                            Radii 3 cm and 5 cm, direct common tangent length 4 cm.
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)" cols="2">
                    <li><p>17 cm</p></li>
                    <li><p><m>2\sqrt{5}</m> cm</p></li>
                </ol>
            </answer>
        </exercise>

