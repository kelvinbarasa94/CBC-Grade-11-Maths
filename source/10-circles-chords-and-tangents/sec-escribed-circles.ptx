<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-escribed-circles" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Escribed Circles</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.3 Circles, Chords and Tangents
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title>
                    <p>
                            <ul>
                              <li>Construct an inscribed, circumscribed and escribed circles on a triangle</li>
                              <li>Determine the centroid and orthocentre of a triangle</li>
                            </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    8 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To explore circles tangent to a triangle from outside, and to struggle productively with the construction of an excircle.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    You don't need to provide the correct construction to learners, as this will be covered after the Learner Experience.
                </p>
            </li>
        </dl>
    </axiom>

    <activity>
        <statement>
            <paragraphs>
                <title>Circles Outside the Triangle</title>
                <p>
                    You have seen how a circle can fit perfectly <em>inside</em> a triangle, tangent to all three sides. Now we'll focus on circles 
                    <ol marker="(a)">
                        <li>
                            <p>
                                Draw a triangle <m>ABC</m> of your choice, and extend each side as a dashed ray beyond the triangle in both directions.
                            </p>
                            <figure xml:id="fig-extended-triangle">
                                <caption>Triangle <m>ABC</m> with sides extended</caption>
                                <image width="75%">
                                    <latex-image>
                                    \begin{tikzpicture}[scale=0.5]
                                        %% --- SET: a=BC=5, b=CA=6, c=AB=7 ---
                                        \tkzDefPoints{0/0/B, 5/0/C}
                                        \tkzDefPoint(7,0){bR}
                                        \tkzDefPoint(11,0){cR}
                                        %% --- CALCULATE ---
                                        \tkzInterCC(B,bR)(C,cR) \tkzGetPoints{A}{Ap}

                                        \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext1}
                                        \tkzDefPointBy[homothety=center A ratio 2.1](B) \tkzGetPoint{ABext2}

                                        \tkzDefPointBy[homothety=center C ratio 2.1](A) \tkzGetPoint{ACext1}
                                        \tkzDefPointBy[homothety=center A ratio 2.1](C) \tkzGetPoint{ACext2}

                                        \tkzDefPointBy[homothety=center C ratio 2.1](B) \tkzGetPoint{BCext1}
                                        \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{BCext2}


                                        %% --- DRAW ---
                                        \tkzDrawPolygon[thick](A,B,C)
                                        \tkzDrawPoints(A,B,C)
                                        \tkzDrawSegments[dashed,thick](B,ABext1 B,ABext2 C,ACext1 C,ACext2 B,BCext1 C,BCext2)
                                        %% --- MARK ---
                                        %% --- LABEL ---
                                        \tkzLabelPoint[below](B){$A$}
                                        \tkzLabelPoints[below right](C)
                                        \tkzLabelPoint[above, yshift=5pt](A){$B$}
                                    \end{tikzpicture}
                                    </latex-image>
                                </image>
                            </figure>
                        </li>
                        <li>
                            <p>
                                This creates 6 regions, 3 of which have one of the triangle's edges as a border. For each of those 3 regions, can you construct a circle which is tangent to the triangle edge and both dashed edges?
                            </p>
                        </li>
                    </ol>
                </p>
            </paragraphs>
        </statement>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To introduce the concept of an excircle, and to show how to construct it using angle bisectors and perpendiculars.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <insight>
        <ul>
            <li>
                <p>
                    A circle tangent to one side of a triangle and to the extensions of the other two sides is called an <term>excircle</term>.
                </p>
            </li>
            <li>
                <p>
                    Every triangle has three excircles, one opposite each vertex. The excircle opposite vertex <m>A</m> is tangent to side <m>BC</m> and to the extensions of sides <m>AB</m> and <m>AC</m>.
                </p>
            </li>
            <li>
                <p>
                    We denote the centre of the excircle (the <term>excenter</term>) opposite <m>A</m> as <m>J_a</m>, and its radius (the <term>exradius</term>) as <m>r_a</m>.
                </p>
            </li>
        </ul>
    </insight>

    
    <!-- \begin{tikzpicture}[scale=1]
        \tkzDefPoints{0/0/A,4/0/B,1/2.5/C}
        \tkzDrawPolygon(A,B,C)
        \tkzDefCircle[ex](B,C,A)
        \tkzGetPoint{J_c} \tkzGetSecondPoint{T_c}
        \tkzDrawCircle(J_c,T_c)
        \tkzDrawLines[add=0 and 1](C,A C,B)
        \tkzDrawSegment(J_c,T_c)
        \tkzMarkRightAngle(J_c,T_c,B)
        \tkzDrawPoints(A,B,C,J_c,T_c)
        \end{tikzpicture} -->

    <paragraphs>
        <title>Constructing the Excircle Opposite <m>A</m></title>
        <p>
            Follow these steps to construct the excircle opposite vertex <m>A</m>. Each step is shown in the diagrams below.
        </p>
        <ol marker="1.">
            <li>
        <p>
            Draw triangle <m>ABC</m>. Extend side <m>AB</m> beyond <m>B</m> as a dashed ray, and extend side <m>AC</m> beyond <m>C</m> as a dashed ray.
        </p>
        <figure xml:id="fig-excircle-step1">
            <caption>Step 1: Triangle <m>ABC</m> with dashed extensions.</caption>
            <image width="80%">
                <latex-image>
                \begin{tikzpicture}[scale=0.8]
                  %% --- SET ---
                  \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.5/A}
                  %% --- CALCULATE ---
                  \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext}
                  \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{ACext}
                  %% --- DRAW ---
                  \tkzDrawPolygon[thick](A,B,C)
                  \tkzDrawSegments[dashed,thick](B,ABext C,ACext)
                  \tkzDrawPoints(A,B,C)
                  %% --- MARK ---
                  %% --- LABEL ---
                  \tkzLabelPoint[below](B){$A$}
                  \tkzLabelPoint[below](C){$C$}
                  \tkzLabelPoint[above left](A){$B$}
                \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
        </li>
        <li>
        <p>
            Bisect the angle at <m>B</m> and draw the bisector as a ray from <m>B</m>.
        </p>
        <figure xml:id="fig-excircle-step2">
            <caption>Step 2: Angle bisector at <m>B</m>.</caption>
            <image width="80%">
                <latex-image>
                \begin{tikzpicture}[scale=0.8]
                  %% --- SET ---
                  \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.5/A}
                  %% --- CALCULATE ---
                  \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext}
                  \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{ACext}
                  \tkzDefCircle[ex](A,B,C) \tkzGetPoints{Ia}{Xa}
                  %% --- DRAW ---
                  \tkzDrawPolygon[thick](A,B,C)
                  \tkzDrawSegments[dashed,thick](B,ABext C,ACext)
                  \tkzDrawLine[add=0 and 0.3, blue](B,Ia)
                  \tkzDrawPoints(A,B,C)
                  %% --- MARK ---
                  %% --- LABEL ---
                  \tkzLabelPoint[below](B){$A$}
                  \tkzLabelPoint[below](C){$C$}
                  \tkzLabelPoint[above left](A){$B$}
                \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
        </li>
        <li>
        <p>
            Bisect the exterior angle at <m>C</m>: this is the angle between side <m>BC</m> and the extension of <m>AC</m> beyond <m>C</m>. Draw the bisector as a ray from <m>C</m>. Label the intersection of the two bisectors <m>J_a</m>.
        </p>
        <figure xml:id="fig-excircle-step3">
            <caption>Step 3: External bisectors at <m>B</m> and <m>C</m> meet at <m>J_a</m>.</caption>
            <image width="80%">
                <latex-image>
                \begin{tikzpicture}[scale=0.8]
                  %% --- SET ---
                  \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.5/A}
                  %% --- CALCULATE ---
                  \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext}
                  \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{ACext}
                  \tkzDefCircle[ex](A,B,C) \tkzGetPoints{Ia}{Xa}
                  %% --- DRAW ---
                  \tkzDrawPolygon[thick](A,B,C)
                  \tkzDrawSegments[dashed,thick](B,ABext C,ACext)
                  \tkzDrawLine[add=0 and 0.1, blue](B,Ia)
                  \tkzDrawLine[add=0 and 0.1, blue](C,Ia)
                  \tkzDrawPoints(A,B,C,Ia)
                  %% --- MARK ---
                  %% --- LABEL ---
                  \tkzLabelPoint[below](B){$A$}
                  \tkzLabelPoint[below](C){$C$}
                  \tkzLabelPoint[above left](A){$B$}
                  \tkzLabelPoint[right](Ia){$J_a$}
                \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
        </li>
        <li>
        <p>
            From <m>J_a</m>, drop a perpendicular to side <m>BC</m>. Label the foot of the perpendicular <m>X</m>. The distance <m>J_aX</m> is the excircle radius <m>r_a</m>.
        </p>
        <figure xml:id="fig-excircle-step4">
            <caption>Step 4: Perpendicular from <m>J_a</m> to <m>BC</m> gives radius <m>r_a = J_aX</m>.</caption>
            <image width="80%">
                <latex-image>
                \begin{tikzpicture}[scale=0.8]
                  %% --- SET ---
                  \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.5/A}
                  %% --- CALCULATE ---
                  \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext}
                  \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{ACext}
                  \tkzDefCircle[ex](A,B,C) \tkzGetPoints{Ia}{Xa}
                  \tkzDefPointBy[projection=onto B--C](Ia) \tkzGetPoint{X}
                  %% --- DRAW ---
                  \tkzDrawPolygon[thick](A,B,C)
                  \tkzDrawSegments[dashed,thick](B,ABext C,ACext)
                  \tkzDrawLine[add=0 and 0.1, blue](B,Ia)
                  \tkzDrawLine[add=0 and 0.1, blue](C,Ia)
                  \tkzDrawSegment[red,thick](Ia,X)
                  \tkzDrawPoints(A,B,C,Ia,X)
                  %% --- MARK ---
                  \tkzMarkRightAngle[size=0.18](Ia,X,B)
                  %% --- LABEL ---
                  \tkzLabelPoints[below](B,C,X)
                  \tkzLabelPoint[above left](A){$B$}
                  \tkzLabelPoint[right](Ia){$J_a$}
                  \tkzLabelSegment[right](Ia,X){$r_a$}
                \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
        </li>
        <li>
        <p>
            Draw the circle with centre <m>J_a</m> and radius <m>J_aX</m>. It should be tangent to side <m>BC</m> and to the extensions of <m>AB</m> and <m>AC</m>.
        </p>
        <figure xml:id="fig-excircle-step5">
            <caption>Step 5: The completed excircle opposite <m>A</m>.</caption>
            <image width="80%">
                <latex-image>
                \begin{tikzpicture}[scale=0.8]
                  %% --- SET ---
                  \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.5/A}
                  %% --- CALCULATE ---
                  \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext}
                  \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{ACext}
                  \tkzDefCircle[ex](A,B,C) \tkzGetPoints{Ia}{Xa}
                  \tkzDefPointBy[projection=onto B--C](Ia) \tkzGetPoint{X}
                  %% --- DRAW ---
                  \tkzDrawPolygon[thick](A,B,C)
                  \tkzDrawSegments[dashed,thick](B,ABext C,ACext)
                  \tkzDrawLine[add=0 and 0.1, blue!60](B,Ia)
                  \tkzDrawLine[add=0 and 0.1, blue!60](C,Ia)
                  \tkzDrawSegment[red,thick](Ia,X)
                  \tkzDrawCircle[blue,thick](Ia,X)
                  \tkzDrawPoints(A,B,C,Ia,X)
                  %% --- MARK ---
                  \tkzMarkRightAngle[size=0.18](Ia,X,B)
                  %% --- LABEL ---
                  \tkzLabelPoint[below](B){$A$}
                  \tkzLabelPoint[below](C){$C$}
                  \tkzLabelPoint[above left](A){$B$}
                  \tkzLabelPoint[right](Ia){$J_a$}
                  \tkzLabelPoint[below](X){$X$}
                  \tkzLabelSegment[right](Ia,X){$r_a$}
                \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
    </li>
    </ol>
    </paragraphs>

    <theorem xml:id="thm-exradius">
        <title>The Excircle and its Radius</title>
        <statement>
            <p>
                For any triangle <m>ABC</m> with side lengths <m>a = BC</m>, <m>b = CA</m>, <m>c = AB</m>, semi-perimeter <m>s</m>, and area <m>\Delta</m>, the <term>excircle opposite <m>A</m></term> has centre <m>J_a</m> and radius
                <md>
                    r_a = \frac{\Delta}{s - a}
                </md>
                Similarly, <m>r_b = \frac{\Delta}{s - b}</m> and <m>r_c = \frac{\Delta}{s - c}</m>
            </p>
            <figure xml:id="fig-excircle-theorem">
                <caption>The excircle opposite <m>A</m>: centre <m>J_a</m>, tangent to <m>BC</m> at <m>X</m> and to the extensions at <m>Y</m> and <m>Z</m>.</caption>
                <image width="85%">
                    <latex-image>
                    \begin{tikzpicture}[scale=0.7]
                      %% --- SET ---
                      \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.5/A}
                      %% --- CALCULATE ---
                      \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext}
                        \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{ACext}
                      \tkzDefCircle[ex](A,B,C) \tkzGetPoints{Ia}{Xa}
                      \tkzDefPointBy[projection=onto B--C](Ia) \tkzGetPoint{X}
                      \tkzDefPointBy[projection=onto B--ABext](Ia) \tkzGetPoint{Y}
                      \tkzDefPointBy[projection=onto C--A](Ia) \tkzGetPoint{Z}
                      %% --- DRAW ---
                      \tkzDrawPolygon[thick](A,B,C)
                      \tkzDrawSegments[dashed,thick](B,ABext C,ACext)
                      \tkzDrawSegments[red,thin](Ia,X Ia,Y Ia,Z)
                      \tkzDrawCircle[blue,thick](Ia,X)
                      \tkzDrawPoints(A,B,C,Ia,X,Y,Z)
                      %% --- MARK ---
                      \tkzMarkRightAngle[size=0.15](Ia,X,C)
                      \tkzMarkRightAngle[size=0.15](Ia,Y,B)
                      \tkzMarkRightAngle[size=0.15](Ia,Z,C)
                      %% --- LABEL ---
                      \tkzLabelPoint[below](B){$A$}
                      \tkzLabelPoint[below](C){$C$}
                      \tkzLabelPoint[above left](A){$B$}
                      \tkzLabelPoint[right](Ia){$J_a$}
                      \tkzLabelPoint[below](X){$X$}
                      \tkzLabelPoint[left](Y){$Y$}
                      \tkzLabelSegment[right](X,Ia){$r_a = \frac{\Delta}{s-a}$}
                      \tkzLabelSegment[left](A,B){$c$}
                      \tkzLabelSegment[below](A,C){$a$}
                      \tkzLabelSegment[below left](B,C){$b$}
                    \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>

            <p> You will prove this in <xref ref="ex-exradius-proof"/>.</p>
        </statement>
    </theorem>

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <example>
        <statement>
            <p>
                Draw a triangle <m>ABC</m> with <m>AB = 7</m> cm, <m>BC = 5</m> cm, and <m>CA = 6</m> cm. Construct the excircle opposite <m>A</m>.
            </p>
            <figure xml:id="fig-excircle-ex1">
                <caption><m>\triangle ABC</m> with <m>AB=7</m>, <m>BC=5</m>, <m>CA=6</m>.</caption>
                <image width="65%">
                    <latex-image>
                    \begin{tikzpicture}[scale=1]
                      %% --- SET: place B and C; find A by intersection of circles of radii AB=7 and CA=6 ---
                      \tkzDefPoints{0/0/B, 5/0/C}
                      \tkzDefPoint(7,0){bR}
                      \tkzDefPoint(11,0){cR}
                      %% --- CALCULATE ---
                      \tkzInterCC(B,bR)(C,cR) \tkzGetPoints{A}{Ap}
                      %% --- DRAW ---
                      \tkzDrawPolygon[thick](A,B,C)
                      %% --- LABEL ---
                      \tkzLabelPoint[below](B){$A$}
                      \tkzLabelPoint[below](C){$C$}
                      \tkzLabelPoint[above left](A){$B$}
                    \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
        </statement>
        <solution>
            <p>
                <ol marker="1.">
                    <li>
                        <p>Draw <m>BC = 5</m> cm as a base. Use compasses to mark <m>AB = 7</m> cm from <m>B</m> and <m>CA = 6</m> cm from <m>C</m>; label the intersection <m>A</m>.</p>
                    </li>
                    <li>
                        <p>Extend side <m>AB</m> beyond <m>B</m> as a dashed ray. Extend side <m>AC</m> beyond <m>C</m> as a dashed ray.</p>
                    </li>
                    <li>
                        <p>Bisect the exterior angle at <m>B</m> (between side <m>BC</m> and the extension of <m>AB</m> beyond <m>B</m>): open the compasses and draw equal arcs from <m>B</m> on both lines, then bisect between their intersection points. Draw the bisector as a ray from <m>B</m>.</p>
                    </li>
                    <li>
                        <p>Bisect the exterior angle at <m>C</m> in the same way. Label the intersection of the two bisector rays <m>J_a</m>.</p>
                    </li>
                    <li>
                        <p>From <m>J_a</m>, drop a perpendicular to line <m>BC</m> (foot <m>X</m>). Set the compasses to <m>J_aX</m> and draw the excircle. It should touch <m>BC</m> and both extensions.</p>
                    </li>
                </ol>
            </p>
            <figure xml:id="fig-excircle-ex1-soln">
                <caption>Excircle opposite <m>A</m> for triangle with <m>AB=7</m>, <m>BC=5</m>, <m>CA=6</m>.</caption>
                <image width="85%">
                    <latex-image>
                    \begin{tikzpicture}[scale=0.8]
                      %% --- SET: place B and C; find A by intersection of circles of radii AB=7 and CA=6 ---
                      \tkzDefPoints{0/0/B, 5/0/C}
                      \tkzDefPoint(7,0){bR}
                      \tkzDefPoint(11,0){cR}
                      %% --- CALCULATE ---
                      \tkzInterCC(B,bR)(C,cR) \tkzGetPoints{A}{Ap}
                      \tkzDefPointBy[homothety=center B ratio 2.1](A) \tkzGetPoint{ABext}
                      \tkzDefPointBy[homothety=center B ratio 2.1](C) \tkzGetPoint{ACext}
                      \tkzDefCircle[ex](A,B,C) \tkzGetPoints{Ia}{Xa}
                      \tkzDefPointBy[projection=onto B--C](Ia) \tkzGetPoint{X}
                      %% --- DRAW ---
                      \tkzDrawPolygon[thick](A,B,C)
                      \tkzDrawSegments[dashed,thick](B,ABext C,ACext)
                      \tkzDrawSegment[red,thin](Ia,X)
                      \tkzDrawCircle[blue,thick](Ia,X)
                      \tkzDrawPoints(A,B,C,Ia,X)
                      %% --- MARK ---
                      \tkzMarkRightAngle[size=0.18](Ia,X,C)
                      %% --- LABEL ---
                      \tkzLabelPoint[below](B){$A$}
                      \tkzLabelPoint[below](C){$C$}
                      \tkzLabelPoint[above left](A){$B$}
                      \tkzLabelPoint[right](Ia){$J_a$}
                      \tkzLabelPoint[below](X){$X$}
                    \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                A triangle has sides <m>3</m> cm, <m>4</m> cm, and <m>5</m> cm. Find all three excircle radii.
            </p>
            <figure xml:id="fig-excircle-ex2">
                <caption>All three excircles of the 3-4-5 right triangle.</caption>
                <image width="75%">
                    <latex-image>
                    \begin{tikzpicture}[scale=0.4]
                      %% --- SET: right angle at C; a=BC=3, b=CA=4, c=AB=5 ---
                      \tkzDefPoints{0/0/C, 3/0/B, 0/4/A}
                      %% --- CALCULATE ---
                      \tkzDefCircle[ex](A,B,C) \tkzGetPoints{Ia}{Xa}
                      \tkzDefCircle[ex](B,C,A) \tkzGetPoints{Ib}{Xb}
                      \tkzDefCircle[ex](C,A,B) \tkzGetPoints{Ic}{Xc}
                      \tkzDefPointBy[projection=onto B--C](Ia) \tkzGetPoint{FootA}
                      \tkzDefPointBy[projection=onto C--A](Ib) \tkzGetPoint{FootB}
                      \tkzDefPointBy[projection=onto A--B](Ic) \tkzGetPoint{FootC}
                      %% --- DRAW ---
                      \tkzDrawLine[add=2 and 2, dashed](B,C)
                      \tkzDrawLine[add=2 and 2, dashed](A,B)
                      \tkzDrawLine[add=2 and 2, dashed](A,C)
                      \tkzDrawPolygon[thick](A,B,C)
                      \tkzDrawCircle[blue](Ia,FootA)
                      \tkzDrawCircle[blue](Ib,FootB)
                      \tkzDrawCircle[blue](Ic,FootC)
                      \tkzDrawPoints(A,B,C,Ia,Ib,Ic)
                      %% --- MARK ---
                      \tkzMarkRightAngle[size=0.2](A,C,B)
                      %% --- LABEL ---
                      \tkzLabelPoints[below right](B)
                      \tkzLabelPoints[below left](C)
                      \tkzLabelPoints[left](A)
                      \tkzLabelPoint[left](Ia){$J_b$}
                      \tkzLabelPoint[below](Ib){$J_c$}
                      \tkzLabelPoint[below](Ic){$J_a$}
                      \tkzLabelSegment[left](A,C){$4$}
                      \tkzLabelSegment[below](B,C){$3$}
                      \tkzLabelSegment[above right](A,B){$5$}
                    \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
        </statement>
        <solution>
            <p>
                Label the sides <m>a = 3</m>, <m>b = 4</m>, <m>c = 5</m>. The semi-perimeter is <md>s = \frac{3+4+5}{2} = 6</md> and the area is <md>\Delta = \frac{1}{2}\times 4 \times 3 = 6</md> Then by <xref ref="thm-exradius"/>:
                <md>
                    <mrow>r_a \amp= \frac{6}{6 - 3} = 2 \text{ cm}</mrow>
                    <mrow>r_b \amp= \frac{6}{6 - 4} = 3 \text{ cm}</mrow>
                    <mrow>r_c \amp= \frac{6}{6 - 5} = 6 \text{ cm.}</mrow>
                </md>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                A right triangle has legs <m>8</m> cm and <m>15</m> cm. Construct the excircle tangent to the longer leg and find its radius.
            </p>
            <figure xml:id="fig-excircle-ex5">
                <caption>Excircle opposite the right angle <m>C</m> in the 8-15-17 triangle.</caption>
                <image width="70%">
                    <latex-image>
                    \begin{tikzpicture}[scale=0.4]
                      %% --- SET: right angle at C; CA=8, CB=15, AB=17 ---
                      \tkzDefPoints{0/0/C, 15/0/B, 0/8/A}
                      %% --- CALCULATE ---
                      \tkzDefCircle[ex](C,A,B) \tkzGetPoints{Ic}{Xc}
                      \tkzDefPointBy[projection=onto A--B](Ic) \tkzGetPoint{FootC}
                      %% --- DRAW ---
                      \tkzDrawPolygon[thick](A,B,C)
                      %% --- MARK ---
                      \tkzMarkRightAngle[size=0.5](A,C,B)
                      %% --- LABEL ---
                      \tkzLabelPoints[below](C,B)
                      \tkzLabelPoints[above left](A)
                      \tkzLabelSegment[below,pos=0.5](C,B){$15$}
                      \tkzLabelSegment[left,pos=0.5](C,A){$8$}
                    \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
        </statement>
        <solution>
            <p>
                Constructing the excircle should give:
                <figure xml:id="fig-excircle-ex5-soln">
                <caption>Excircle opposite the right angle <m>C</m> in the 8-15-17 triangle.</caption>
                <image width="70%">
                    <latex-image>
                    \begin{tikzpicture}[scale=0.2]
                      %% --- SET: right angle at C; CA=8, CB=15, AB=17 ---
                      \tkzDefPoints{0/0/C, 15/0/B, 0/8/A}
                      %% --- CALCULATE ---
                      \tkzDefCircle[ex](A,C,B) \tkzGetPoints{Ic}{Xc}
                      \tkzDefPointBy[projection=onto C--B](Ic) \tkzGetPoint{FootC}
                      %% --- DRAW ---
                      \tkzDrawLines[add=0 and 1, dashed, thick](C,B)
                      \tkzDrawLines[add=2 and 0, dashed, thick](A,C)
                      \tkzDrawPolygon(A,B,C)
                      \tkzDrawSegment[red,thin](Ic,FootC)
                      \tkzDrawCircle[blue,thick](Ic,FootC)
                      \tkzDrawPoints(A,B,C,Ic,FootC)
                      %% --- MARK ---
                      \tkzMarkRightAngle[size=0.5](A,C,B)
                      \tkzMarkRightAngle[size=0.4](Ic,FootC,C)
                      %% --- LABEL ---
                      \tkzLabelPoints[below left](C)
                      \tkzLabelPoints[below](B)
                      \tkzLabelPoints[above left](A)
                      \tkzLabelPoint[right](Ic){$J_C$}
                      \tkzLabelSegment[below,pos=0.5](C,B){$15$}
                      \tkzLabelSegment[left,pos=0.5](C,A){$8$}
                    \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            </p>
            <p>
                The hypotenuse is <m>c = 17</m> cm and the semi-perimeter is <md>s = \frac{8+15+17}{2} = 20</md>. The area is <m>\Delta = \frac{1}{2} \times 8 \times 15 = 60</m>, so:
                <md>
                    r_B = \frac{\Delta}{s-b} = \frac{60}{20-17} = 20 \text{ cm.}
                </md>
                It is no conincidence that <m>r_B = s</m>, this is in fact true for all excircles opposite a right angle.
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <exercises>
        <exercise>
            <statement>
                <p>
                    For each triangle below, use a pair of compasses and a straightedge to construct the exercircle opposite <m>A</m>. In your solution, show your construction.
                </p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p>Acute scalene triangle.</p>
                            <image width="90%">
                                <latex-image>
                                    \begin{tikzpicture}[scale=0.6]
                                        \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.6/A}
                                        \tkzDrawPolygon[thick](A,B,C)
                                        \tkzDrawLine[add=0 and 0.7, dashed, gray](A,B)
                                        \tkzDrawLine[add=0 and 0.7, dashed, gray](A,C)
                                        \tkzDrawPoints(A,B,C)
                                        \tkzLabelPoints[above](A)
                                        \tkzLabelPoints[below left](B)
                                        \tkzLabelPoints[below right](C)
                                    \end{tikzpicture}
                                </latex-image>
                            </image>
                    </li>
                    <li>
                        <p>Right triangle</p>
                        <image width="90%">
                            <latex-image>
                                \begin{tikzpicture}[scale=0.6]
                                    \tkzDefPoints{0/0/B, 4/0/C, 0/3/A}
                                    \tkzDrawPolygon[thick](A,B,C)
                                    \tkzMarkRightAngle[size=0.2](A,B,C)
                                    \tkzDrawLine[add=0 and 0.7, dashed, gray](A,B)
                                    \tkzDrawLine[add=0 and 0.7, dashed, gray](A,C)
                                    \tkzDrawPoints(A,B,C)
                                    \tkzLabelPoints[above left](A)
                                    \tkzLabelPoints[below left](B)
                                    \tkzLabelPoints[below right](C)
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li>
                        <p>Obtuse triangle.</p>
                        <image width="90%">
                            <latex-image>
                                \begin{tikzpicture}[scale=0.6]
                                    \tkzDefPoints{0/0/B, 4/0/C, -0.5/2.5/A}
                                    \tkzDrawPolygon[thick](A,B,C)
                                    \tkzDrawLine[add=0 and 0.7, dashed, gray](A,B)
                                    \tkzDrawLine[add=0 and 0.7, dashed, gray](A,C)
                                    \tkzDrawPoints(A,B,C)
                                    \tkzLabelPoints[above left](A)
                                    \tkzLabelPoints[below left](B)
                                    \tkzLabelPoints[below right](C)
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li>
                        <p>Equilateral triangle.</p>
                        <image width="90%">
                            <latex-image>
                                \begin{tikzpicture}[scale=0.6]
                                    \tkzDefPoints{0/0/B, 5/0/C, 2.5/4.33/A}
                                    \tkzDrawPolygon[thick](A,B,C)
                                    \tkzDrawLine[add=0 and 0.7, dashed, gray](A,B)
                                    \tkzDrawLine[add=0 and 0.7, dashed, gray](A,C)
                                    \tkzDrawPoints(A,B,C)
                                    \tkzLabelPoints[above](A)
                                    \tkzLabelPoints[above left](B)
                                    \tkzLabelPoints[above right](C)
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                </ol>
            </statement>
            <solution>
                <p>
                    In each case the external bisectors at <m>B</m> and <m>C</m> (dashed) meet at the excentre <m>J_a</m>; the internal bisector from <m>A</m> passes through the same point. The perpendicular from <m>J_a</m> to side <m>BC</m> is the radius <m>r_a</m>, and the excircle touches <m>BC</m> and both extensions.
                </p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p>
                            Drawing the excircle:
                        </p>
                        <image width="90%">
                            <latex-image>
                                \begin{tikzpicture}[scale=0.6]
                                    \tkzDefPoints{0/0/B, 5/0/C, 1.5/3.6/A}
                                    \tkzDefLine[bisector out](A,B,C)\tkzGetPoint{eB}
                                    \tkzDefLine[bisector out](A,C,B)\tkzGetPoint{eC}
                                    \tkzInterLL(B,eB)(C,eC)\tkzGetPoint{Ia}
                                    \tkzDefPointBy[projection=onto B--C](Ia)\tkzGetPoint{X}
                                    \tkzDrawPolygon[thick](A,B,C)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,B)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,C)
                                    \tkzDrawSegments[dashed,gray](A,Ia B,Ia C,Ia)
                                    \tkzDrawSegment[orange!80!black](Ia,X)
                                    \tkzDrawCircle[orange!80!black,thick](Ia,X)
                                    \tkzMarkRightAngle[size=0.18](Ia,X,C)
                                    \tkzDrawPoints(A,B,C,Ia,X)
                                    \tkzLabelPoints[above](A)
                                    \tkzLabelPoint[below left](B){$B$}
                                    \tkzLabelPoint[below right](C){$C$}
                                    \tkzLabelPoint[below](Ia){$J_a$}
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li>
                        <p>
                            Drawing the excircle:
                        </p>
                        <image width="90%">
                            <latex-image>
                                \begin{tikzpicture}[scale=0.6]
                                    \tkzDefPoints{0/0/B, 4/0/C, 0/3/A}
                                    \tkzDefLine[bisector out](A,B,C)\tkzGetPoint{eB}
                                    \tkzDefLine[bisector out](A,C,B)\tkzGetPoint{eC}
                                    \tkzInterLL(B,eB)(C,eC)\tkzGetPoint{Ia}
                                    \tkzDefPointBy[projection=onto B--C](Ia)\tkzGetPoint{X}
                                    \tkzDrawPolygon[thick](A,B,C)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,B)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,C)
                                    \tkzDrawSegments[dashed,gray](A,Ia B,Ia C,Ia)
                                    \tkzDrawSegment[orange!80!black](Ia,X)
                                    \tkzDrawCircle[orange!80!black,thick](Ia,X)
                                    \tkzMarkRightAngle[size=0.18](Ia,X,C)
                                    \tkzDrawPoints(A,B,C,Ia,X)
                                    \tkzLabelPoints[above left](A)
                                    \tkzLabelPoint[below left](B){$B$}
                                    \tkzLabelPoint[below right](C){$C$}
                                    \tkzLabelPoint[below](Ia){$J_a$}
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li>
                        <p>
                            Drawing the excircle:
                        </p>
                        <image width="90%">
                            <latex-image>
                                \begin{tikzpicture}[scale=0.6]
                                    \tkzDefPoints{0/0/B, 4/0/C, -0.5/2.5/A}
                                    \tkzDefLine[bisector out](A,B,C)\tkzGetPoint{eB}
                                    \tkzDefLine[bisector out](A,C,B)\tkzGetPoint{eC}
                                    \tkzInterLL(B,eB)(C,eC)\tkzGetPoint{Ia}
                                    \tkzDefPointBy[projection=onto B--C](Ia)\tkzGetPoint{X}
                                    \tkzDrawPolygon[thick](A,B,C)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,B)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,C)
                                    \tkzDrawSegments[dashed,gray](A,Ia B,Ia C,Ia)
                                    \tkzDrawSegment[orange!80!black](Ia,X)
                                    \tkzDrawCircle[orange!80!black,thick](Ia,X)
                                    \tkzMarkRightAngle[size=0.18](Ia,X,C)
                                    \tkzDrawPoints(A,B,C,Ia,X)
                                    \tkzLabelPoints[above left](A)
                                    \tkzLabelPoint[below left](B){$B$}
                                    \tkzLabelPoint[below right](C){$C$}
                                    \tkzLabelPoint[below](Ia){$J_a$}
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li>
                        <p>
                            Drawing the excircle:
                        </p>
                        <image width="90%">
                            <latex-image>
                                \begin{tikzpicture}[scale=0.6]
                                    \tkzDefPoints{0/0/B, 5/0/C, 2.5/4.33/A}
                                    \tkzDefLine[bisector out](A,B,C)\tkzGetPoint{eB}
                                    \tkzDefLine[bisector out](A,C,B)\tkzGetPoint{eC}
                                    \tkzInterLL(B,eB)(C,eC)\tkzGetPoint{Ia}
                                    \tkzDefPointBy[projection=onto B--C](Ia)\tkzGetPoint{X}
                                    \tkzDrawPolygon[thick](A,B,C)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,B)
                                    \tkzDrawLine[add=0 and 0.9, dashed, gray](A,C)
                                    \tkzDrawSegments[dashed,gray](A,Ia B,Ia C,Ia)
                                    \tkzDrawSegment[orange!80!black](Ia,X)
                                    \tkzDrawCircle[orange!80!black,thick](Ia,X)
                                    \tkzMarkRightAngle[size=0.18](Ia,X,C)
                                    \tkzDrawPoints(A,B,C,Ia,X)
                                    \tkzLabelPoints[above](A)
                                    \tkzLabelPoint[below left](B){$B$}
                                    \tkzLabelPoint[below right](C){$C$}
                                    \tkzLabelPoint[below](Ia){$J_a$}
