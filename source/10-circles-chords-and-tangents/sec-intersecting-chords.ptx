    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->
     <example>
        <statement>
            <p>
                AB and XY are two chords that intersect in a circle at R. Given that AR <m> = 4</m> cm, XR <m> = 5</m> cm, and RY <m> = 3</m> cm, find AB.
            </p>
        </statement>
        <solution>
            <figure>
                <caption>Chords intersecting inside a circle.</caption>
                <image>
                    <shortdescription>A circle with two intersecting chords AB and XY meeting at point R.</shortdescription>
                    <latex-image>
                        \begin{tikzpicture}
                            \draw[thick] (0,0) circle (3);

                            \coordinate (A) at (-2.8, 0.5);
                            \coordinate (B) at (2.8, 1.1);
                            \coordinate (X) at (-2.1, -2.1);
                            \coordinate (Y) at (1.9, 2.3);

                            \coordinate (R) at (0.42, 0.83);

                            \draw[blue, thick] (A) -- (B);
                            \draw[red, thick] (X) -- (Y);

                            \node[left] at (A) {A};
                            \node[right] at (B) {B};
                            \node[below left] at (X) {X};
                            \node[below right] at (Y) {Y};
                            \node[below] at (R) {R};

                            \node[above] at (-1.2, 0.65) {4 cm};
                            \node[above] at (1.6, 0.95) {x cm};
                            \node[left] at (-0.8, -0.6) {5 cm};
                            \node[left] at (1.2, 1.6) {3 cm};


                        \end{tikzpicture}
                    </latex-image>
                    
                </image>
            </figure>
            <p>
                Let RB <m> = x</m> cm
            </p>
            <p>
                <m>4 \times x = 5 \times 3</m>
            </p>
            <p>
                <m> 4x = 15</m>
            </p>
            <p>
                <m> x = 3.75</m> cm
            </p>
            <p>
                <md>
                    <mrow> \text{since AB}\; \amp = \; \text{AR}\; + \;\text{RB} </mrow>
                    <mrow> \text{Therefore} \; \amp = \; 4 + 3.75 </mrow>
                    <mrow> \amp = \; 7.75 \text{cm} </mrow>
                </md>
                
            </p>
        </solution>
     </example>
