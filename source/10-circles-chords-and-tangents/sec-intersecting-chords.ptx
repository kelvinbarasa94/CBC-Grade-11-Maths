        </exercise>

        <exercise>
            <statement>
                <p>
                    In each part, two chords intersect inside a circle at point <m>T</m>. Find <m>x</m> and then find the length of chord <m>RS</m>.
                </p>
                <figure>
                    <caption>Chords <m>PQ</m> and <m>RS</m> intersecting at <m>T</m>.</caption>
                    <image width="50%">
                        <shortdescription>A circle with two intersecting chords PQ (blue) and RS (red) meeting at T. The four segments PT, TQ, RT, TS are labelled.</shortdescription>
                        <latex-image>
                            \begin{tikzpicture}[scale=1.0]

                              %% --- SET ---
                              \tkzDefPoint(0,0){O}
                              \tkzDefPoint(3,0){cR}
                              \tkzDefPointBy[rotation=center O angle 188](cR) \tkzGetPoint{P}
                              \tkzDefPointBy[rotation=center O angle 12](cR)  \tkzGetPoint{Q}
                              \tkzDefPointBy[rotation=center O angle 100](cR) \tkzGetPoint{R}
                              \tkzDefPointBy[rotation=center O angle 292](cR) \tkzGetPoint{S}

                              %% --- CALCULATE ---
                              \tkzInterLL(P,Q)(R,S) \tkzGetPoint{T}

                              %% --- DRAW ---
                              \tkzDrawCircle[thick](O,cR)
                              \tkzDrawSegment[blue, thick](P,Q)
                              \tkzDrawSegment[red, thick](R,S)
                              \tkzDrawPoints(P,Q,R,S,T)

                              %% --- MARK ---

                              %% --- LABEL ---
                              \tkzLabelPoints[left](P)
                              \tkzLabelPoints[right](Q)
                              \tkzLabelPoints[above](R)
                              \tkzLabelPoints[below right](S)
                              \tkzLabelPoints[above right](T)
                              \tkzLabelSegment[above, sloped, font=\small](P,T){$PT$}
                              \tkzLabelSegment[above, sloped, font=\small](T,Q){$TQ$}
                              \tkzLabelSegment[right, font=\small](R,T){$RT$}
                              \tkzLabelSegment[right, font=\small](T,S){$TS$}

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>PT = x</m>, <m>TQ = 6</m>, <m>RT = 4</m>, <m>TS = x + 2</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>PT = x + 1</m>, <m>TQ = 4</m>, <m>RT = x</m>, <m>TS = 5</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>PT = 2x</m>, <m>TQ = 3</m>, <m>RT = x + 1</m>, <m>TS = 4</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>PT = 3</m>, <m>TQ = 2x + 1</m>, <m>RT = x + 2</m>, <m>TS = 3</m>.
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)">
                    <li><p><m>x = 4</m>; <m>RS = 10</m> cm</p></li>
                    <li><p><m>x = 4</m>; <m>RS = 9</m> cm</p></li>
                    <li><p><m>x = 2</m>; <m>RS = 7</m> cm</p></li>
                    <li><p><m>x = 1</m>; <m>RS = 6</m> cm</p></li>
                </ol>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>
                    In each part, two chords of a circle meet at right angles at point <m>P</m>.
                </p>
                <figure>
                    <caption>Perpendicular chords <m>AB</m> and <m>CD</m> meeting at <m>P</m>.</caption>
                    <image width="50%">
                        <shortdescription>A circle with a horizontal chord AB (blue) and a vertical chord CD (red) crossing at right angles at P. The four segments AP, PB, CP, PD are labelled.</shortdescription>
                        <latex-image>
                            \begin{tikzpicture}[scale=0.85]

                              %% --- SET ---
                              \tkzDefPoint(0,0){P}
                              \tkzDefPoint(-2,0){A}
                              \tkzDefPoint(4.5,0){B}
                              \tkzDefPoint(0,3){C}
                              \tkzDefPoint(0,-3){D}

                              %% --- CALCULATE ---
                              \tkzDefCircle[circum](A,B,C) \tkzGetPoint{O}

                              %% --- DRAW ---
                              \tkzDrawCircle[thick](O,A)
                              \tkzDrawSegment[blue, thick](A,B)
                              \tkzDrawSegment[red, thick](C,D)
                              \tkzDrawPoints(A,B,C,D,P)

                              %% --- MARK ---
                              \tkzMarkRightAngle[size=0.20](A,P,C)

                              %% --- LABEL ---
                              \tkzLabelPoints[left](A)
                              \tkzLabelPoints[right](B)
                              \tkzLabelPoints[above](C)
                              \tkzLabelPoints[below](D)
                              \tkzLabelPoints[below left](P)
                              \tkzLabelSegment[above, font=\small](A,P){$AP$}
                              \tkzLabelSegment[above, font=\small](P,B){$PB$}
                              \tkzLabelSegment[right, font=\small](C,P){$CP$}
                              \tkzLabelSegment[right, font=\small](P,D){$PD$}

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                <ol marker="(a)">
                    <li>
                        <p>
                            Chords <m>AB</m> and <m>CD</m> meet at right angles at <m>P</m>. <m>AP = 4</m> cm, <m>PB = 9</m> cm, and <m>P</m> is the midpoint of <m>CD</m>. Find <m>CP</m> and the length of <m>CD</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Two perpendicular chords intersect at <m>P</m>. The segments of the first chord are <m>AP = 2</m> cm and <m>PB = 8</m> cm. Without finding <m>CP</m> and <m>PD</m> individually, state the value of <m>CP \times PD</m>.
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)">
                    <li><p><m>CP = 6</m> cm; <m>CD = 12</m> cm</p></li>
                    <li><p><m>CP \times PD = 16</m> cm<m>^2</m></p></li>
                </ol>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Two chords <m>AB</m> and <m>CD</m> of a circle intersect at a point <m>P</m> inside the circle such that <m>AP = CP</m>. Prove that <m>PB = PD</m>.
                </p>
                <figure>
                    <caption>Chords <m>AB</m> and <m>CD</m> intersecting at <m>P</m>, with <m>AP = CP</m>.</caption>
                    <image width="50%">
                        <shortdescription>A circle with two intersecting chords AB (blue) and CD (red) meeting at P. Single tick marks on AP and CP show that they are equal.</shortdescription>
                        <latex-image>
                            \begin{tikzpicture}[scale=1.0]

                              %% --- SET ---
                              \tkzDefPoint(0,0){O}
                              \tkzDefPoint(3,0){cR}
                              \tkzDefPointBy[rotation=center O angle 175](cR) \tkzGetPoint{A}
                              \tkzDefPointBy[rotation=center O angle 40](cR)  \tkzGetPoint{B}
                              \tkzDefPointBy[rotation=center O angle 215](cR) \tkzGetPoint{C}
                              \tkzDefPointBy[rotation=center O angle 80](cR)  \tkzGetPoint{D}

                              %% --- CALCULATE ---
                              \tkzInterLL(A,B)(C,D) \tkzGetPoint{P}

                              %% --- DRAW ---
                              \tkzDrawCircle[thick](O,cR)
                              \tkzDrawSegment[blue, thick](A,B)
                              \tkzDrawSegment[red, thick](C,D)
                              \tkzDrawPoints(A,B,C,D,P)

                              %% --- MARK ---
                              \tkzMarkSegments[mark=|](A,P C,P)

                              %% --- LABEL ---
                              \tkzLabelPoints[left](A)
                              \tkzLabelPoints[right](B)
                              \tkzLabelPoints[below left](C)
                              \tkzLabelPoints[above](D)
                              \tkzLabelPoints[above right](P)

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
            </statement>
            <solution>
                <p>
                    By the Intersecting Chords Theorem:
                    <md>
                        AP \times PB = CP \times PD.
                    </md>
                    Since <m>AP = CP</m>, we may divide both sides by <m>AP</m> (which is non-zero):
                    <md>
                        PB = PD.
                    </md>
                </p>
            </solution>
        </exercise>
    </exercises>

