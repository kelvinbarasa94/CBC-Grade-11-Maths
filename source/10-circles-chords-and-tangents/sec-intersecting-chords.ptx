<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-intersecting-chords" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Intersecting Chords</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.3 Circles, Chords and Tangents
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title>
                    <p>
                        Determine the length of intersecting chords in a circle
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    12 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To guide learners to discover the Intersecting Chords Theorem through measurement and pattern recognition.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Prepare a pre-drawn circle with two intersecting chords for learners who struggle to draw their own. Circulate as learners fill in the table, and prompt with questions such as: <q>Look at your two products — what do you notice? Does this hold for your classmates' circles too?</q>
                </p>
            </li>
        </dl>
    </axiom>

    <activity>
        <statement>
            <paragraphs>
                <title>Discovering a Pattern</title>
                <p>
                    In this activity you will draw circles, construct intersecting chords, and measure their segments.
                    <ol marker="(a)">
                        <li>
                            <p>
                                Draw a circle using a compass (or trace a circular object). Draw two chords <m>AB</m> and <m>CD</m> that cross each other <em>inside</em> the circle. Label their intersection point <m>P</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Measure <m>AP</m>, <m>PB</m>, <m>CP</m>, and <m>PD</m> to the nearest millimetre. Record your results in the table below, and calculate the two products <m>AP \times PB</m> and <m>CP \times PD</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Repeat parts (a) and (b) with two more circles, choosing a different size circle and a different position for the intersection point each time.
                            </p>
                        </li>
                        <li>
                            <p>
                                What do you notice about <m>AP \times PB</m> and <m>CP \times PD</m> across your three circles? Write a conjecture.
                            </p>
                            <solution component="lesson-plan">
                                <p>
                                    Learners should observe that <m>AP \times PB \approx CP \times PD</m> for each circle (small differences are due to measurement error). The conjecture should state that the two products are always equal.
                                </p>
                            </solution>
                        </li>
                    </ol>
                </p>
                <table>
                    <title>Intersecting chord measurements</title>
                    <tabular halign="center" top="minor" bottom="minor" left="minor" right="minor">
                        <row header="yes" bottom="medium">
                            <cell>Circle</cell>
                            <cell><m>AP</m> (mm)</cell>
                            <cell><m>PB</m> (mm)</cell>
                            <cell><m>AP \times PB</m></cell>
                            <cell><m>CP</m> (mm)</cell>
                            <cell><m>PD</m> (mm)</cell>
                            <cell><m>CP \times PD</m></cell>
                        </row>
                        <row>
                            <cell>1</cell>
                            <cell></cell><cell></cell><cell></cell>
                            <cell></cell><cell></cell><cell></cell>
                        </row>
                        <row>
                            <cell>2</cell>
                            <cell></cell><cell></cell><cell></cell>
                            <cell></cell><cell></cell><cell></cell>
                        </row>
                        <row>
                            <cell>3</cell>
                            <cell></cell><cell></cell><cell></cell>
                            <cell></cell><cell></cell><cell></cell>
                        </row>
                    </tabular>
                </table>
            </paragraphs>
        </statement>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalise the pattern Learners discovered in the activity and present a proof using similar triangles.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ul>
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Ask a few learners to share their products. Confirm that everyone's measurements (approximately) agree — the products are always equal. Tell Learners: <q>This isn't a coincidence — it's always exactly true, and we can prove it using similar triangles.</q>
                    </p>
                </li>
                <li>
                    <p>
                        Ensure Learners recall that angles subtended by the same arc are equal (covered earlier in this chapter) — the proof depends on this result.
                    </p>
                </li>
                <li>
                    <p>
                        Stress that the theorem holds for <em>any</em> two chords that cross inside the circle, whether or not they meet at right angles.
                    </p>
                </li>
            </ul>
        </paragraphs>
    </axiom>

    <theorem xml:id="thm-intersecting-chords">
        <title>The Intersecting Chords Theorem</title>
        <statement>
            <figure xml:id="intersecting-chords-thm">
                <caption>Chords <m>AB</m> and <m>CD</m> intersecting at <m>P</m>.</caption>
                <image width="50%">
                    <shortdescription>A circle with two intersecting chords AB (blue) and CD (red) meeting at P. The four segments AP, PB, CP, PD are labelled.</shortdescription>
                    <latex-image>
                        \begin{tikzpicture}[scale=1.0]

                            %% --- SET ---
                            \tkzDefPoint(0,0){O}
                            \tkzDefPoint(3,0){cR}
                            \tkzDefPointBy[rotation=center O angle 175](cR) \tkzGetPoint{A}
                            \tkzDefPointBy[rotation=center O angle 18](cR)  \tkzGetPoint{B}
                            \tkzDefPointBy[rotation=center O angle 248](cR) \tkzGetPoint{C}
                            \tkzDefPointBy[rotation=center O angle 72](cR)  \tkzGetPoint{D}

                            %% --- CALCULATE ---
                            \tkzInterLL(A,B)(C,D) \tkzGetPoint{P}

                            %% --- DRAW ---
                            \tkzDrawCircle[thick](O,cR)
                            \tkzDrawSegment[blue, thick](A,B)
                            \tkzDrawSegment[red, thick](C,D)
                            \tkzDrawPoints(A,B,C,D,P)

                            %% --- MARK ---

                            %% --- LABEL ---
                            \tkzLabelPoints[left](A)
                            \tkzLabelPoints[right](B)
                            \tkzLabelPoints[below left](C)
                            \tkzLabelPoints[above](D)
                            \tkzLabelPoints[above right](P)
                            \tkzLabelSegment[above, sloped, font=\small](A,P){$AP$}
                            \tkzLabelSegment[above, sloped, font=\small](P,B){$PB$}
                            \tkzLabelSegment[above, sloped, font=\small](C,P){$CP$}
                            \tkzLabelSegment[above, sloped, font=\small](P,D){$PD$}

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                If two chords <m>AB</m> and <m>CD</m> of a circle intersect at a point <m>P</m> inside the circle, then
                <md>
                    AP \times PB = CP \times PD.
                </md>
            </p>
        </statement>
        <proof>
            <p>
                Consider the two triangles <m>\triangle APD</m> and <m>\triangle CPB</m>, shown below.
            </p>
            <figure xml:id="fig-intersecting-chords-proof">
                <caption>
                    Triangle <m>\triangle APD</m> (red) and triangle <m>\triangle CPB</m> (blue).
                    Matching angle labels show the two pairs of equal angles.
                </caption>
                <image width="55%">
                    <shortdescription>
                        A circle with chords AB and CD intersecting at P.
                        Triangle APD is shaded red and triangle CPB is shaded blue.
                        Angle alpha is marked at vertices A and C; angle beta at vertices D and B.
                    </shortdescription>
                    <latex-image>
                        \begin{tikzpicture}[scale=1.0]

                          %% --- SET ---
                          \tkzDefPoint(0,0){O}
                          \tkzDefPoint(3,0){cR}
                          \tkzDefPointBy[rotation=center O angle 196](cR) \tkzGetPoint{A}
                          \tkzDefPointBy[rotation=center O angle 28](cR)  \tkzGetPoint{B}
                          \tkzDefPointBy[rotation=center O angle 107](cR) \tkzGetPoint{C}
                          \tkzDefPointBy[rotation=center O angle 314](cR) \tkzGetPoint{D}

                          %% --- CALCULATE ---
                          \tkzInterLL(A,B)(C,D) \tkzGetPoint{P}

                          %% --- DRAW ---
                          \tkzDrawCircle[thick](O,cR)
                          \tkzFillPolygon[red!20](A,P,D)
                          \tkzFillPolygon[blue!20](C,P,B)
                          \tkzDrawSegments[thick](A,B C,D)
                          \tkzDrawPoints(A,B,C,D,P)

                          %% --- MARK ---
                          \tkzFillAngle[fill=red!20, opacity=0.6, size=0.45](D,A,P)
                          \tkzMarkAngle[size=0.45](D,A,P)
                          \tkzFillAngle[fill=blue!20, opacity=0.6, size=0.45](P,C,B)
                          \tkzMarkAngle[size=0.45](P,C,B)
                          \tkzFillAngle[fill=red!20, opacity=0.6, size=0.45](P,D,A)
                          \tkzMarkAngle[size=0.45](P,D,A)
                          \tkzFillAngle[fill=blue!20, opacity=0.6, size=0.45](C,B,P)
                          \tkzMarkAngle[size=0.45](C,B,P)

                          %% --- LABEL ---
                          \tkzLabelPoints[left](A)
                          \tkzLabelPoints[right](B)
                          \tkzLabelPoints[above](C)
                          \tkzLabelPoints[below right](D)
                          \tkzLabelPoints[above right](P)
                          \tkzLabelAngle[pos=0.75, color=red!70!black](D,A,P){$\alpha$}
                          \tkzLabelAngle[pos=0.75, color=blue!70!black](P,C,B){$\alpha$}
                          \tkzLabelAngle[pos=0.75, color=red!70!black](P,D,A){$\beta$}
                          \tkzLabelAngle[pos=0.75, color=blue!70!black](C,B,P){$\beta$}

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                We show that <m>\triangle APD \sim \triangle CPB</m> using the AA (angle-angle) condition.
                <ul>
                    <li>
                        <p>
                            <m>\angle DAP = \angle BCP</m> (both labelled <m>\alpha</m>): both angles are subtended by arc <m>BD</m> from the same side of the chord, so they are equal by the theorem on angles in the same segment.
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>\angle ADP = \angle CBP</m> (both labelled <m>\beta</m>): both angles are subtended by arc <m>AC</m> from the same side of the chord, so they are equal by the same theorem.
                        </p>
                    </li>
                </ul>
                Therefore <m>\triangle APD \sim \triangle CPB</m> (AA).
            </p>
            <p>
                Since corresponding sides of similar triangles are in proportion:
                <md>
                    <mrow> \frac{AP}{CP} \amp= \frac{DP}{BP} </mrow>
                </md>
                Cross-multiplying gives:
                <md>
                    AP \times BP = CP \times DP.
                </md>
            </p>
        </proof>
    </theorem>

    <insight>
        <p>
            <ul>
                <li>
                    <p>
                        <term>The Intersecting Chords Theorem:</term> when two chords <m>AB</m> and <m>CD</m> intersect at a point <m>P</m> inside a circle,
                        <md>
                            AP \times PB = CP \times PD.
                        </md>
                    </p>
                </li>
                <li>
                    <p>
                        The proof uses the fact that angles subtended by the same arc are equal — a result from earlier in this chapter.
                    </p>
                </li>
                <li>
                    <p>
                        If three of the four segment lengths are known, set up the equation <m>AP \times PB = CP \times PD</m> and solve for the unknown.
                    </p>
                </li>
            </ul>
        </p>
    </insight>

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <example>
        <statement>
            <p>
                Chords <m>AB</m> and <m>XY</m> intersect inside a circle at <m>R</m>. Given that <m>AR = 4</m> cm, <m>XR = 5</m> cm, and <m>RY = 3</m> cm, find the length of <m>AB</m>.
            </p>
        </statement>
        <solution>
            <figure>
                <caption>Chords <m>AB</m> and <m>XY</m> intersecting at <m>R</m>.</caption>
                <image width="55%">
                    <shortdescription>A circle with two intersecting chords AB and XY meeting at point R inside the circle.</shortdescription>
                    <latex-image>
                        \begin{tikzpicture}[scale=1.0]

                          %% --- SET ---
                          \tkzDefPoint(0,0){O}
                          \tkzDefPoint(3,0){cR}
                          \tkzDefPointBy[rotation=center O angle 177](cR) \tkzGetPoint{A}
                          \tkzDefPointBy[rotation=center O angle 22](cR)  \tkzGetPoint{B}
                          \tkzDefPointBy[rotation=center O angle 228](cR) \tkzGetPoint{X}
                          \tkzDefPointBy[rotation=center O angle 78](cR)  \tkzGetPoint{Y}

                          %% --- CALCULATE ---
                          \tkzInterLL(A,B)(X,Y) \tkzGetPoint{R}

                          %% --- DRAW ---
                          \tkzDrawCircle[thick](O,cR)
                          \tkzDrawSegment[blue, thick](A,B)
                          \tkzDrawSegment[red, thick](X,Y)
                          \tkzDrawPoints(A,B,X,Y,R)

                          %% --- MARK ---

                          %% --- LABEL ---
                          \tkzLabelPoints[left](A)
                          \tkzLabelPoints[right](B)
                          \tkzLabelPoints[below left](X)
                          \tkzLabelPoints[above right](Y)
                          \tkzLabelPoints[below right](R)
                          \tkzLabelSegment[above, sloped, font=\small](A,R){$4$ cm}
                          \tkzLabelSegment[above, sloped, font=\small](R,B){$x$ cm}
                          \tkzLabelSegment[below, sloped, font=\small](X,R){$5$ cm}
                          \tkzLabelSegment[above, sloped, font=\small](R,Y){$3$ cm}

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                Let <m>RB = x</m> cm. By the Intersecting Chords Theorem:
                <md>
                    <mrow> AR \times RB \amp= XR \times RY </mrow>
                    <mrow> 4 \times x   \amp= 5 \times 3 </mrow>
                    <mrow> 4x           \amp= 15 </mrow>
                    <mrow> x            \amp= 3.75 \text{ cm} </mrow>
                </md>
            </p>
            <p>
                Therefore:
                <md>
                    <mrow> AB \amp= AR + RB </mrow>
                    <mrow>    \amp= 4 + 3.75 </mrow>
                    <mrow>    \amp= 7.75 \text{ cm} </mrow>
                </md>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Chords <m>PQ</m> and <m>RS</m> intersect inside a circle at <m>T</m>. Given that <m>PT = x + 2</m>, <m>TQ = 3</m>, <m>RT = x</m>, and <m>TS = 6</m>, find <m>x</m> and the length of <m>RS</m>.
            </p>
        </statement>
        <solution>
            <figure>
                <caption>Chords <m>PQ</m> and <m>RS</m> intersecting at <m>T</m>, with algebraic segment lengths.</caption>
                <image width="55%">
                    <shortdescription>A circle with two intersecting chords PQ and RS meeting at T. Segments are labelled PT = x+2, TQ = 3, RT = x, TS = 6.</shortdescription>
                    <latex-image>
                        \begin{tikzpicture}[scale=1.0]

                          %% --- SET ---
                          \tkzDefPoint(0,0){O}
                          \tkzDefPoint(3,0){cR}
                          \tkzDefPointBy[rotation=center O angle 186](cR) \tkzGetPoint{P}
                          \tkzDefPointBy[rotation=center O angle 13](cR)  \tkzGetPoint{Q}
                          \tkzDefPointBy[rotation=center O angle 107](cR) \tkzGetPoint{R}
                          \tkzDefPointBy[rotation=center O angle 297](cR) \tkzGetPoint{S}

                          %% --- CALCULATE ---
                          \tkzInterLL(P,Q)(R,S) \tkzGetPoint{T}

                          %% --- DRAW ---
                          \tkzDrawCircle[thick](O,cR)
                          \tkzDrawSegment[blue, thick](P,Q)
                          \tkzDrawSegment[red, thick](R,S)
                          \tkzDrawPoints(P,Q,R,S,T)

                          %% --- MARK ---

                          %% --- LABEL ---
                          \tkzLabelPoints[left](P)
                          \tkzLabelPoints[right](Q)
                          \tkzLabelPoints[above](R)
                          \tkzLabelPoints[below right](S)
                          \tkzLabelPoints[above right](T)
                          \tkzLabelSegment[above, sloped, font=\small](P,T){$(x+2)$}
                          \tkzLabelSegment[above, sloped, font=\small](T,Q){$3$}
                          \tkzLabelSegment[right, font=\small](R,T){$x$}
                          \tkzLabelSegment[right, font=\small](T,S){$6$}

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                By the Intersecting Chords Theorem:
                <md>
                    <mrow> PT \times TQ     \amp= RT \times TS </mrow>
                    <mrow> (x + 2)(3)       \amp= x(6) </mrow>
                    <mrow> 3x + 6           \amp= 6x </mrow>
                    <mrow> 6                \amp= 3x </mrow>
                    <mrow> x                \amp= 2 </mrow>
                </md>
            </p>
            <p>
                Therefore:
                <md>
                    <mrow> RS \amp= RT + TS </mrow>
                    <mrow>    \amp= 2 + 6 </mrow>
                    <mrow>    \amp= 8 \text{ cm} </mrow>
                </md>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Two chords <m>AB</m> and <m>CD</m> of a circle intersect at right angles at a point <m>P</m> inside the circle. Given that <m>AP = 3</m> cm, <m>PB = 12</m> cm, and that <m>P</m> is the midpoint of <m>CD</m>,
                <ol marker="(a)">
                    <li><p>find <m>CP</m>,</p></li>
                    <li><p>find the length of <m>CD</m>.</p></li>
                </ol>
            </p>
        </statement>
        <solution>
            <figure>
                <caption>Perpendicular chords <m>AB</m> and <m>CD</m> intersecting at <m>P</m>.</caption>
                <image width="55%">
                    <shortdescription>A circle with a horizontal chord AB and a vertical chord CD crossing at right angles at P. AP = 3 cm, PB = 12 cm, and CP = PD = y cm are labelled.</shortdescription>
                    <latex-image>
                        \begin{tikzpicture}[scale=0.9]

                          %% --- SET ---
                          \tkzDefPoint(0,0){P}
                          \tkzDefPoint(-1,0){A}
                          \tkzDefPoint(4,0){B}
                          \tkzDefPoint(0,2){C}
                          \tkzDefPoint(0,-2){D}

                          %% --- CALCULATE ---
                          \tkzDefCircle[circum](A,B,C) \tkzGetPoint{O}

                          %% --- DRAW ---
                          \tkzDrawCircle[thick](O,A)
                          \tkzDrawSegment[blue, thick](A,B)
                          \tkzDrawSegment[red, thick](C,D)
                          \tkzDrawPoints(A,B,C,D,P)

                          %% --- MARK ---
                          \tkzMarkRightAngle[size=0.18](A,P,C)

                          %% --- LABEL ---
                          \tkzLabelPoints[left](A)
                          \tkzLabelPoints[right](B)
                          \tkzLabelPoints[above](C)
                          \tkzLabelPoints[below](D)
                          \tkzLabelPoints[below left](P)
                          \tkzLabelSegment[above, font=\small](A,P){$3$ cm}
                          \tkzLabelSegment[above, font=\small](P,B){$12$ cm}
                          \tkzLabelSegment[right, font=\small](C,P){$y$ cm}
                          \tkzLabelSegment[right, font=\small](P,D){$y$ cm}

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                Let <m>CP = PD = y</m> cm (since <m>P</m> is the midpoint of <m>CD</m>).
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            By the Intersecting Chords Theorem:
                            <md>
                                <mrow> AP \times PB \amp= CP \times PD </mrow>
                                <mrow> 3 \times 12  \amp= y \times y </mrow>
                                <mrow> 36           \amp= y^2 </mrow>
                                <mrow> y            \amp= 6 \text{ cm} </mrow>
                            </md>
                            Therefore <m>CP = 6</m> cm.
                        </p>
                    </li>
                    <li>
                        <p>
                            <md>
                                <mrow> CD \amp= CP + PD </mrow>
                                <mrow>    \amp= 6 + 6 </mrow>
                                <mrow>    \amp= 12 \text{ cm} </mrow>
                            </md>
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    In each part, two chords intersect inside a circle at point <m>P</m>. Find the missing length.
                </p>
    
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>AP = 6</m> cm, <m>PB = 4</m> cm, <m>CP = 8</m> cm. Find <m>PD</m>.
                        </p>
                        <figure xml:id="chord-1">
                            <caption>Chords <m>AB</m> and <m>CD</m> intersecting at <m>P</m>.</caption>
                            <image width="60%">
                                <shortdescription>A circle with two intersecting chords AB (blue) and CD (red) meeting at P. The four segments AP, PB, CP, PD are labelled.</shortdescription>
                                <latex-image>
                                    \begin{tikzpicture}[scale=0.5]
                                    \pgfmathsetmacro{\AP}{6}
                                        \pgfmathsetmacro{\PB}{4}
                                        \pgfmathsetmacro{\CP}{8}
                                        \pgfmathsetmacro{\r}{6}
                                        \pgfmathsetmacro{\Bangle}{30} % inclination of B from positive x-axis
                                        \pgfmathsetmacro{\PD}{(\AP * \PB)/(\CP)}

                                        %% --- SET ---
                                        \begin{scope}[rotate=\Bangle]
                                            \tkzDefPoint(0,0){O}
                                            \tkzDefPoint(0, 3){cR}


                                            %% --- CALCULATE ---
                                            \pgfmathsetmacro{\ABhalf}{(\AP + \PB)/2}
                                            \pgfmathsetmacro{\h}{sqrt(\r * \r - \ABhalf * \ABhalf)} % height
                                            \tkzDefCircle[R](O,\ABhalf) \tkzGetPoint{C}
                                            
                                            \tkzDefShiftPoint[O](-\ABhalf,\h){A}
                                            \tkzDefShiftPoint[O](\ABhalf,\h){B}
                                            \tkzDrawCircle[thick](O,A)
                                        \end{scope}

                                            \pgfmathsetmacro{\posP}{(\AP)/(\AP + \PB)}
                                            \tkzDefPointOnLine[pos=\posP](A,B) \tkzGetPoint{P}

                                            \tkzInterCC[R](O,\r)(P,\CP) \tkzGetPoints{C}{Calt}

                                            \tkzInterLC(C,P)(O,A) \tkzGetPoints{D}{Dalt}

                                            \tkzDrawSegment[blue, thick](A,B)
                                            \tkzDrawSegment[red, thick](C,D)

                                            %% --- LABEL ---
                                            \tkzDrawPoints(A,B,C,D,P)
                                            \tkzLabelPoints[left](A)
                                            \tkzLabelPoints[above right](B)
                                            \tkzLabelPoints[below left](C)
                                            \tkzLabelPoints[above](D)
                                            \tkzLabelPoints[right](P)
                                            \tkzLabelSegment[above, sloped, font=\small](A,P){$\pgfmathprintnumber{\AP}$ cm}
                                            \tkzLabelSegment[below, sloped, font=\small](P,B){$\pgfmathprintnumber{\PB}$ cm}
                                            \tkzLabelSegment[above, sloped, font=\small](C,P){$\pgfmathprintnumber{\CP}$ cm}
                                            \tkzLabelSegment[above, sloped, font=\small](P,D){$x$ cm}


                                    \end{tikzpicture}
                                </latex-image>
                            </image>
                        </figure>
                    </li>
                    <li>
                        <p>
                            <m>AP = 3</m> cm, <m>PB = 8</m> cm, <m>CP = 6</m> cm. Find <m>PD</m>.
                        </p>
                        <figure xml:id="chord-2">
                    <caption>Chords <m>AB</m> and <m>CD</m> intersecting at <m>P</m>.</caption>
                    <image width="60%">
                        <shortdescription>A circle with two intersecting chords AB (blue) and CD (red) meeting at P. The four segments AP, PB, CP, PD are labelled.</shortdescription>
                        <latex-image>
                            \begin{tikzpicture}[scale=0.5]
                              \pgfmathsetmacro{\AP}{3}
                                \pgfmathsetmacro{\PB}{8}
                                \pgfmathsetmacro{\CP}{6}
                                \pgfmathsetmacro{\r}{6}
                                \pgfmathsetmacro{\Bangle}{60} % inclination of B from positive x-axis
                                \pgfmathsetmacro{\PD}{(\AP * \PB)/(\CP)}

                                %% --- SET ---
                                \begin{scope}[rotate=\Bangle]
                                    \tkzDefPoint(0,0){O}
                                    \tkzDefPoint(0, 3){cR}


                                    %% --- CALCULATE ---
                                    \pgfmathsetmacro{\ABhalf}{(\AP + \PB)/2}
                                    \pgfmathsetmacro{\h}{sqrt(\r * \r - \ABhalf * \ABhalf)} % height
                                    \tkzDefCircle[R](O,\ABhalf) \tkzGetPoint{C}
                                    
                                    \tkzDefShiftPoint[O](-\ABhalf,\h){A}
                                    \tkzDefShiftPoint[O](\ABhalf,\h){B}
                                    \tkzDrawCircle[thick](O,A)
                                \end{scope}

                                    \pgfmathsetmacro{\posP}{(\AP)/(\AP + \PB)}
                                    \tkzDefPointOnLine[pos=\posP](A,B) \tkzGetPoint{P}

                                    \tkzInterCC[R](O,\r)(P,\CP) \tkzGetPoints{C}{Calt}

                                    \tkzInterLC(C,P)(O,A) \tkzGetPoints{D}{Dalt}

                                    \tkzDrawSegment[blue, thick](A,B)
                                    \tkzDrawSegment[red, thick](C,D)

                                    %% --- LABEL ---
                                    \tkzDrawPoints(A,B,C,D,P)
                                    \tkzLabelPoints[left](A)
                                    \tkzLabelPoints[above](B)
                                    \tkzLabelPoints[below left](C)
                                    \tkzLabelPoints[above](D)
                                    \tkzLabelPoints[right](P)
                                    \tkzLabelSegment[above, sloped, font=\small](A,P){$\pgfmathprintnumber{\AP}$ cm}
                                    \tkzLabelSegment[above, sloped, font=\small](P,B){$\pgfmathprintnumber{\PB}$ cm}
                                    \tkzLabelSegment[above, sloped, font=\small](C,P){$\pgfmathprintnumber{\CP}$ cm}
                                    \tkzLabelSegment[above, sloped, font=\small](P,D){$x$ cm}


                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
                    </li>
                    <li>
                        <p>
                            <m>AP = 2</m> cm, <m>PB = 9</m> cm, <m>CP = 6</m> cm. Find <m>PD</m>.
