    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>Compute the determinant of each matrix.</p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>A = \begin{bmatrix} 3 &amp; -1 \\ 2 &amp; 4 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>B = \begin{bmatrix} -5 &amp; 0 \\ 0 &amp; 2 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>C = \begin{bmatrix} 7 &amp; 2 \\ -3 &amp; 1 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>D = \begin{bmatrix} 0 &amp; -2 \\ 5 &amp; 1 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>E = \begin{bmatrix} -4 &amp; -1 \\ 2 &amp; 0 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>F = \begin{bmatrix} 1 &amp; 3 \\ 2 &amp; 6 \end{bmatrix}</m></p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>\det{A} = 14</m></p>
                    </li>
                    <li>
                        <p><m>\det{B} = -10</m></p>
                    </li>
                    <li>
                        <p><m>\det{C} = 13</m></p>
                    </li>
                    <li>
                        <p><m>\det{D} = 10</m></p>
                    </li>
                    <li>
                        <p><m>\det{E} = 2</m></p>
                    </li>
                    <li>
                        <p><m>\det{F} = 0</m></p>
                    </li>
                </ol>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>Compute the determinant of each matrix.</p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>A = \begin{bmatrix} 6 &amp; 0 \\ 0 &amp; -3 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>B = \begin{bmatrix} 1 &amp; -4 \\ 2 &amp; 5 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>C = \begin{bmatrix} -1 &amp; 2 \\ 3 &amp; -6 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>D = \begin{bmatrix} 2 &amp; -3 \\ 1 &amp; 4 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>E = \begin{bmatrix} 0 &amp; 1 \\ 4 &amp; 0 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>F = \begin{bmatrix} -2 &amp; 5 \\ 3 &amp; -1 \end{bmatrix}</m></p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>\det{A} = -18</m></p>
                    </li>
                    <li>
                        <p><m>\det{B} = 13</m></p>
                    </li>
                    <li>
                        <p><m>\det{C} = 0</m></p>
                    </li>
                    <li>
                        <p><m>\det{D} = 11</m></p>
                    </li>
                    <li>
                        <p><m>\det{E} = -4</m></p>
                    </li>
                    <li>
                        <p><m>\det{F} = -13</m></p>
                    </li>
                </ol>
            </answer>
        </exercise>
        <exercise>
            <title>Determinant of Inverse</title>
            <statement>
                <p>Let <m>A = \begin{bmatrix} 2 &amp; 1 \\ 3 &amp; 4 \end{bmatrix}</m>.
                    <ol>
                        <li>
                            <p>
                                Compute <m>\det{A}</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find <m>A^{-1}</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find <m>\det{A^{-1}}</m>, the determinant of the inverse of <m>A</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                What's the relationship between <m>\det{A^{-1}}</m> and <m>\det{A}</m>? Can you prove it?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <solution>
                <ol>
                    <li>
                        <p>
                            Using the formula:
                            <md>
                                <mrow> \det{A} \amp = ad - bc </mrow>
                                <mrow> \amp = (2)(4) - (1)(3) </mrow>
                                <mrow> \amp = 8 - 3 </mrow>
                                <mrow> \amp = 5 </mrow>
                            </md>

                            Therefore, <m>\det{A} = 5</m>.
                        </p>    
                    </li>
                    <li>
                        <p> 
                            To find the inverse of a 2 by 2 matrix, we can use the formula:
                            <md>
                                <mrow> A^{-1} \amp = \frac{1}{ad - bc} \begin{bmatrix} d &amp; -b \\ -c &amp; a \end{bmatrix} </mrow>
                            </md>

                            Substituting the values from matrix <m>A</m>, we get:
                            <md>
                                <mrow> A^{-1} \amp = \frac{1}{5} \begin{bmatrix} 4 &amp; -1 \\ -3 &amp; 2 \end{bmatrix} </mrow>
                                <mrow> \amp = \begin{bmatrix} \frac{4}{5} &amp; -\frac{1}{5} \\ -\frac{3}{5} &amp; \frac{2}{5} \end{bmatrix} </mrow>
                            </md>

                            Therefore, the inverse of matrix <m>A</m> is <m>A^{-1} = \begin{bmatrix} \frac{4}{5} &amp; -\frac{1}{5} \\ -\frac{3}{5} &amp; \frac{2}{5} \end{bmatrix}</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Now we compute the determinant of the inverse of <m>A</m>:
                            <md>
                                <mrow> \det{A^{-1}} \amp = ad - bc </mrow>
                                <mrow> \amp = \left(\frac{4}{5}\right)\left(\frac{2}{5}\right) - \left(-\frac{1}{5}\right)\left(-\frac{3}{5}\right) </mrow>
                                <mrow> \amp = \frac{8}{25} - \frac{3}{25} </mrow>
                                <mrow> \amp = \frac{5}{25} </mrow>
                                <mrow> \amp = \frac{1}{5} </mrow>
                            </md>

                            Therefore, <m>\det{A^{-1}} = \frac{1}{5}</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            The relationship between <m>\det{A^{-1}}</m> and <m>\det{A}</m> is that <m>\det{A^{-1}} = \frac{1}{\det{A}}</m>.
                        </p>
                        <p>
                            You can prove this using the fact that <me>(\det{A})(\det{A^{-1}}) = \det{AA^{-1}} = \det{I} = 1</me>, where <m>I</m> is the identity matrix.
                        </p>
                    </li>
                </ol>
            </solution>
        </exercise>
    </exercises>

