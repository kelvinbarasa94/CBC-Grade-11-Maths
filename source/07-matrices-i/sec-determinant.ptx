    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>Compute the determinant of each matrix.</p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>A = \begin{bmatrix} 3 &amp; -1 \\ 2 &amp; 4 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>B = \begin{bmatrix} -5 &amp; 0 \\ 0 &amp; 2 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>C = \begin{bmatrix} 7 &amp; 2 \\ -3 &amp; 1 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>D = \begin{bmatrix} 0 &amp; -2 \\ 5 &amp; 1 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>E = \begin{bmatrix} -4 &amp; -1 \\ 2 &amp; 0 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>F = \begin{bmatrix} 1 &amp; 3 \\ 2 &amp; 6 \end{bmatrix}</m></p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>\det{A} = 14</m></p>
                    </li>
                    <li>
                        <p><m>\det{B} = -10</m></p>
                    </li>
                    <li>
                        <p><m>\det{C} = 13</m></p>
                    </li>
                    <li>
                        <p><m>\det{D} = 10</m></p>
                    </li>
                    <li>
                        <p><m>\det{E} = 2</m></p>
                    </li>
                    <li>
                        <p><m>\det{F} = 0</m></p>
                    </li>
                </ol>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>Compute the determinant of each matrix.</p>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>A = \begin{bmatrix} 6 &amp; 0 \\ 0 &amp; -3 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>B = \begin{bmatrix} 1 &amp; -4 \\ 2 &amp; 5 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>C = \begin{bmatrix} -1 &amp; 2 \\ 3 &amp; -6 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>D = \begin{bmatrix} 2 &amp; -3 \\ 1 &amp; 4 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>E = \begin{bmatrix} 0 &amp; 1 \\ 4 &amp; 0 \end{bmatrix}</m></p>
                    </li>
                    <li>
                        <p><m>F = \begin{bmatrix} -2 &amp; 5 \\ 3 &amp; -1 \end{bmatrix}</m></p>
                    </li>
                </ol>
            </statement>
            <answer>
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>\det{A} = -18</m></p>
                    </li>
                    <li>
                        <p><m>\det{B} = 13</m></p>
                    </li>
                    <li>
                        <p><m>\det{C} = 0</m></p>
                    </li>
                    <li>
                        <p><m>\det{D} = 11</m></p>
                    </li>
                    <li>
                        <p><m>\det{E} = -4</m></p>
                    </li>
                    <li>
                        <p><m>\det{F} = -13</m></p>
                    </li>
                </ol>
            </answer>
        </exercise>
        <exercise>
            <statement>
            <p>
                Suppose <m>A</m> and <m>B</m> are 2 by 2 matrices. Which of the following statements are true? If a statement is false, provide a counterexample, and if a statement is true, provide a short proof.
                <ol marker="(a)" cols="2">
                    <li>
                        <p><m>\det{\left(A + B\right)} = \det{A} + \det{B}</m></p>
                    </li>
                    <li>
                        <p>
                            <m>\det{2A} = 2\det{A}</m>
                        </p>
                    </li>
                    <li xml:id="exercise-det-AB">
                        <p><m>\det{AB} = \det{A} \cdot \det{B}</m></p>
                    </li>
                    <li>
                        <p>
                            <m>\det{I} = 1</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>\det{\left(A^2\right)} = 2\det{A}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>\det{AB} = \det{BA} </m>
                        </p>
                    </li>
                </ol>
            </p>
            </statement>
            <solution>
                <p>
                    <ol>
                        <li>
                            <p>
                                This statement is false. A counterexample is:
                                <md>
                                    A = \begin{bmatrix} 1 \amp 0 \\ 0 \amp 1 \end{bmatrix},\quad  B = \begin{bmatrix} 2 \amp 0 \\ 0 \amp 2 \end{bmatrix}
                                </md>
                                We have:
                                <md>
                                    <mrow> \det{A} + \det{B} \amp = (1)(1) + (2)(2) </mrow>
                                    <mrow> \amp = 1 + 4 </mrow>
                                    <mrow> \amp = 5 </mrow>
                                </md>
                                However, we also have:
                                <md>
                                    <mrow> A + B \amp = \begin{bmatrix} 3 &amp; 0 \\ 0 &amp; 3 \end{bmatrix} </mrow>
                                    <mrow> \det{\left(A + B\right)} \amp = (3)(3) - (0)(0) </mrow>
                                    <mrow> \amp = 9 </mrow>
                                </md>

                                Therefore, <m>\det{\left(A + B\right)} = 9</m> and <m>\det{A} + \det{B} = 5</m>, which shows that the statement is false.
                            </p>
                        </li>
                        <li>
                            <p>
                                This statement is false. 
                                <aside>
                                    <title>A Related True Statement</title>
                                    <p>
                                        In fact, the related true result for any <m>n\times n</m> matrix <m>A</m> and scalar <m>k</m> is:
                                        <md>
                                            <mrow> \det{kA} \amp = k^n \det{A} </mrow>
                                        </md>
                                    </p>
                                </aside>
                                A counterexample is <m> A = \begin{bmatrix} 1 &amp; 0 \\ 0 &amp; 1 \end{bmatrix}</m>
                                We have
                                <md>
                                    <mrow> \det{A} \amp = (1)(1) - (0)(0) </mrow>
                                    <mrow> \amp = 1 </mrow>
                                </md>
                                However, we also have:
                                <md>
                                    <mrow> 2A \amp = \begin{bmatrix} 2 &amp; 0 \\ 0 &amp; 2 \end{bmatrix} </mrow>
                                    <mrow> \det{2A} \amp = (2)(2) - (0)(0) </mrow>
                                    <mrow> \amp = 4 </mrow>
                                </md>

                                Therefore, <m>\det{2A} = 4</m> and <m>2\det{A} = 2</m>, which shows that the statement is false.
                            </p>
                        </li>
                        <li xml:id="proof-det-AB">
                            <p>
                                This statement is true. The proof is as follows:
                                    Let <m>A</m> and <m>B</m> be 2 by 2 matrices. We can write <m>A</m> and <m>B</m> as:
                                    <md>
                                        <mrow> A \amp = \begin{bmatrix} a &amp; b \\ c &amp; d \end{bmatrix} </mrow>
                                        <mrow> B \amp = \begin{bmatrix} e &amp; f \\ g &amp; h \end{bmatrix} </mrow>
                                    </md>

                                    Then the product <m>AB</m> is given by:
                                    <md>
                                        <mrow> AB \amp = \begin{bmatrix} ae + bg &amp; af + bh \\ ce + dg &amp; cf + dh \end{bmatrix} </mrow>
                                    </md>

                                    Now we compute the determinant of <m>AB</m>:
                                    <md>
                                        <mrow> \det{AB} =\, \amp (ae + bg)(cf + dh) - (af + bh)(ce + dg) </mrow>
                                        <mrow> =\, \amp aecf + aedh + bgcf + bgdh </mrow>
                                        <mrow> \amp - afce - afdg - bhce - bhdg </mrow>
                                        <mrow> = \amp \phantom{+} \cancel{aecf} + aedh + bgcf + \cancel{bgdh} </mrow>
                                        <mrow> \amp - \cancel{afce} - afdg - bhce - \cancel{bhdg} </mrow>
                                        <mrow>= \,\amp \phantom{+}adeh - adfg - bceh + bcfg </mrow>
                                    </md>
                                    Tackling <m>\det{A} \cdot \det{B}</m>, we have:
                                    <md>
                                        <mrow>\det{A} \cdot \det{B} \amp = (ad - bc)(eh - fg) </mrow>
                                        <mrow> \amp = adeh - adfg - bceh + bcfg </mrow>
                                        <mrow> \amp = \det{AB} </mrow>
                                    </md>
                                    Therefore, we have shown that <m>\det{AB} = \det{A} \cdot \det{B}</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                This statement is true. The 2 by 2 identity matrix is given by:
                                <md>
                                    <mrow> I \amp = \begin{bmatrix} 1 &amp; 0 \\ 0 &amp; 1 \end{bmatrix} </mrow>
                                </md>

                                Now we compute the determinant of the identity matrix:
                                <md>
                                    <mrow> \det{I} \amp = (1)(1) - (0)(0) </mrow>
                                    <mrow> \amp = 1 </mrow>
                                </md>

                                Therefore, we have shown that <m>\det{I} = 1</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                This statement is false. 
                                <aside>
                                    <title>Another Related True Statement</title>
                                    <p>
                                        In fact, the related true result for any square matrix <m>A</m> and power <m>k</m> is:
                                        <md>
                                            <mrow> \det{\left(A^k\right)} \amp = \left(\det{A}\right)^k </mrow>
                                        </md>
                                        Can you use <xref ref="exercise-det-AB"/> to prove this statement?
                                    </p>
                                </aside>
                                A counterexample is:  <m> A = \begin{bmatrix} 1 &amp; 0 \\ 0 &amp; 1 \end{bmatrix} </m>
                                We have:
                                <md>
                                    <mrow> \det{A} \amp = (1)(1) - (0)(0) </mrow>
                                    <mrow> \amp = 1 </mrow>
                                </md>
                                However,
                                <md>
                                    <mrow> A^2 \amp = \begin{bmatrix} 1 &amp; 0 \\ 0 &amp; 1 \end{bmatrix} </mrow>
                                    <mrow> \det{A^2} \amp = (1)(1) - (0)(0) </mrow>
                                    <mrow> \amp = 1 </mrow>
                                </md>
                                So <m>2\det{A} = 2 \neq 1 = \det{\left(A^2\right)}</m>
                            </p>

                        </li>
                        <li>
                            <p>
                                This statement is true. From (c), we know that <md>\det{AB} = \det{A} \cdot \det{B}</md> 
                                
                                Swapping the roles of <m>A</m> and <m>B</m>, we get <md>\det{BA} = \det{B} \cdot \det{A}</md>. 
                                
                                Since multiplication of real numbers can be done in any order, we have <md> <mrow>\det{AB} = \det{A} \cdot \det{B} = \det{B} \cdot \det{A} = \det{BA}</mrow></md>
                            </p>
                            <p>
                                This is surprising! While <m>AB \neq BA</m>, we have <m>\det{AB} = \det{BA}</m>.
                            </p>
                        </li>
                    </ol>
                </p>
            </solution>
        </exercise>
        <exercise>
            <title>The Determinant of the Inverse</title>
            <statement>
                <p>Let <m>A = \begin{bmatrix} 2 &amp; 1 \\ 3 &amp; 4 \end{bmatrix}</m>.
                    <ol>
                        <li>
                            <p>
                                Compute <m>\det{A}</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find <m>A^{-1}</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find <m>\det{\left(A^{-1}\right)}</m>, the determinant of the inverse of <m>A</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                What's the relationship between <m>\det{\left(A^{-1}\right)}</m> and <m>\det{A}</m>? Can you prove it?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <solution>
                <ol>
                    <li>
                        <p>
                            Using the formula:
                            <md>
                                <mrow> \det{A} \amp = ad - bc </mrow>
                                <mrow> \amp = (2)(4) - (1)(3) </mrow>
                                <mrow> \amp = 8 - 3 </mrow>
                                <mrow> \amp = 5 </mrow>
                            </md>

                            Therefore, <m>\det{A} = 5</m>.
                        </p>    
                    </li>
                    <li>
                        <p> 
                            To find the inverse of a 2 by 2 matrix, we can use the formula:
                            <md>
                                <mrow> A^{-1} \amp = \frac{1}{ad - bc} \begin{bmatrix} d &amp; -b \\ -c &amp; a \end{bmatrix} </mrow>
                            </md>

                            Substituting the values from matrix <m>A</m>, we get:
                            <md>
                                <mrow> A^{-1} \amp = \frac{1}{5} \begin{bmatrix} 4 &amp; -1 \\ -3 &amp; 2 \end{bmatrix} </mrow>
                                <mrow> \amp = \begin{bmatrix} \frac{4}{5} &amp; -\frac{1}{5} \\ -\frac{3}{5} &amp; \frac{2}{5} \end{bmatrix} </mrow>
                            </md>

                            Therefore, the inverse of matrix <m>A</m> is <m>A^{-1} = \begin{bmatrix} \frac{4}{5} &amp; -\frac{1}{5} \\ -\frac{3}{5} &amp; \frac{2}{5} \end{bmatrix}</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Now we compute the determinant of the inverse of <m>A</m>:
                            <md>
                                <mrow> \det{\left(A^{-1}\right)} \amp = ad - bc </mrow>
                                <mrow> \amp = \left(\frac{4}{5}\right)\left(\frac{2}{5}\right) - \left(-\frac{1}{5}\right)\left(-\frac{3}{5}\right) </mrow>
                                <mrow> \amp = \frac{8}{25} - \frac{3}{25} </mrow>
                                <mrow> \amp = \frac{5}{25} </mrow>
                                <mrow> \amp = \frac{1}{5} </mrow>
                            </md>

                            Therefore, <m>\det{\left(A^{-1}\right)} = \frac{1}{5}</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            The relationship between <m>\det{\left(A^{-1}\right)}</m> and <m>\det{A}</m> is that <m>\det{\left(A^{-1}\right)} = \frac{1}{\det{A}}</m>.
                        </p>
                        <p>
                            You can prove this using the fact from <xref ref="proof-det-AB"/> that <md>\det{AB} = \det{A} \cdot \det{B}</md>. Letting <m>B = A^{-1}</m>, and remembering that <m>AA^{-1} = I</m> by definition, we have <md>(\det{A})(\det{\left(A^{-1}\right)}) = \det{AA^{-1}} = \det{I} = 1</md>, where <m>I</m> is the identity matrix.
                        </p>
                    </li>
                </ol>
            </solution>
        </exercise>
    </exercises>

