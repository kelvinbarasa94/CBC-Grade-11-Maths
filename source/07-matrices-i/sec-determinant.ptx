<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-determinant" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Determinant</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.7 Matrices I
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Compute the determinant of a 2 by 2 matrix
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To provide a visual explanation for the formula for the determinant.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    If time allows, prepare the shapes from <xref ref="det-triangles"/> in advance, so that you can cut them out and rearrange them with the class during the activity. If not, you can ask learners to draw and cut out the shapes themselves.
                </p>
            </li>
        </dl>
    </axiom>

    <!-- TODO, create a quick JS visualiser with different matrices, creating the parallelogram-->
    <activity>
        <statement>
            <paragraphs>
                <title>Visualising a Matrix</title>
                <p>
                    Suppose <m>A = \begin{bmatrix} 6 \amp 2.5 \\ 2.2 \amp 3 \end{bmatrix}</m>
                    <ol marker="(a)">
                        <li>
                            <p>
                                If <m>\mathbf{x} = \begin{bmatrix} 1\\ 0\end{bmatrix}</m> and <m>\mathbf{y} = \begin{bmatrix} 0 \\ 1 \end{bmatrix}</m>, find <m>A\mathbf{x}</m> and <m>A\mathbf{y}</m>.
                            </p>
                            <solution component="lesson-plan">
                                <p>
                                    <m>A\mathbf{x} = \begin{bmatrix}6 \\ 2.2\end{bmatrix}</m>, the first column of <m>A</m> and <m>A\mathbf{y} = \begin{bmatrix}2.5 \\ 3\end{bmatrix}</m>, the second column of <m>A</m>.
                                </p>
                            </solution>
                        </li>
                        <li>
                            <p>
                                Plot the vectors <m>A\mathbf{x}</m> and <m>A\mathbf{y}</m> on the coordinate plane, with their tails at the origin
                            </p>
                            <solution component="lesson-plan">
                                <p>
                                <figure xml:id="Ax-Ay">
                                <caption>Plotting the vectors</caption>
                                <image width="70%">
                                <latex-image>
                                    \begin{tikzpicture}[scale=0.8, line join=round, line cap=round]
                                        % Dimensions
                                        \def\a{6}
                                        \def\b{2.5}
                                        \def\c{2.2}
                                        \def\d{3}
                                        \pgfmathsetmacro{\W}{\a+\b}
                                        \pgfmathsetmacro{\H}{\c+\d}

                                        % Helper points (line intersections)
                                        \coordinate (x1) at (\a,\c);
                                        \coordinate (x2) at (\b,\d);

                                        \draw (0,0) grid (9,6);

                                        % Main outline and diagonals
                                        \draw[very thick, -&gt;] (0,0) -- (x1) node [below right, fill=white, opacity=0.8] {$A\mathbf{x} = (6, 2.2)$};
                                        \draw[very thick, -&gt;] (0,0) -- (x2) node [above left, fill=white, opacity=0.8] {$A\mathbf{y} = (2.5, 3)$};


                                        
                                        % Labels
                                        \node[below right] at (0,0) {$O$};
                                    \end{tikzpicture}
                                </latex-image>
                            </image>
                            </figure>
                                </p>
                            </solution>
                        </li>
                        <li>
                            <p>
                                Also plot a point representing the sum <m>A\mathbf{x} + A\mathbf{y}</m>, and connect the tips of your previous vectors to this point to form a parallelogram.
                            </p>
                            <solution component="lesson-plan">
                                <p>
                                <figure xml:id="Ax-Ay-P">
                                <caption>Creating the Parallelogram</caption>
                                <image width="70%">
                                <latex-image>
                                    \begin{tikzpicture}[scale=0.8, line join=round, line cap=round]
                                        % Dimensions
                                        \def\a{6}
                                        \def\b{2.5}
                                        \def\c{2.2}
                                        \def\d{3}
                                        \pgfmathsetmacro{\W}{\a+\b}
                                        \pgfmathsetmacro{\H}{\c+\d}

                                        % Helper points (line intersections)
                                        \coordinate (x1) at (\a,\c);
                                        \coordinate (x2) at (\b,\d);

                                        \draw (0,0) grid (9,6);
                                        % Main outline and diagonals
                                        \draw[very thick, -&gt;] (0,0) -- (x1) node [below right, fill=white, opacity=0.8] {$A\mathbf{x} = (6, 2.2)$};
                                        \draw[very thick] (x1) -- (\W, \H) -- (x2);
                                        \draw[very thick, -&gt;] (0,0) -- (x2) node [above left, fill=white, opacity=0.8] {$A\mathbf{y} = (2.5, 3)$};
                                        
                                        % Labels
                                        \node[below left] at (0,0) {$O$};
                                    \end{tikzpicture}
                                </latex-image>
                            </image>
                            </figure>
                                </p>
                            </solution>
                        </li>
                    </ol>
                    The <term>determinant</term> of a matrix tells us how it changes areas (like the parallelogram we just created). We'll explore how to find it.
                </p>
            </paragraphs>
            <paragraphs>
                <title>Finding an Expression for the Determinant</title>
                <p>
                    We'll consider how the general matrix <m>A = \begin{bmatrix}a \amp b\\ c \amp d\end{bmatrix}</m> changes areas. In general, we have:
                    <md>
                        <mrow>A\mathbf{x} \amp = \begin{bmatrix}a \amp b\\ c \amp d\end{bmatrix}\begin{bmatrix}1 \\ 0\end{bmatrix} = \begin{bmatrix}a \\ c\end{bmatrix} </mrow>
                        <mrow>A\mathbf{y} \amp = \begin{bmatrix}a \amp b\\ c \amp d\end{bmatrix}\begin{bmatrix}0 \\ 1\end{bmatrix} = \begin{bmatrix}b \\ d\end{bmatrix} </mrow>
                    </md>
                    To do so, this figure will help:
                <figure xml:id="det-triangles">
                    <caption>Finding the area of a parralelogram</caption>
                    <image width="70%">
                    <latex-image>
                        \begin{tikzpicture}[scale=0.8, line join=round, line cap=round]
                            % Dimensions
                            \def\a{6}
                            \def\b{2.5}
                            \def\c{2.2}
                            \def\d{3}
                            \pgfmathsetmacro{\W}{\a+\b}
                            \pgfmathsetmacro{\H}{\c+\d}

                            % Helper points (line intersections)
                            \coordinate (x1) at (\a,\c);
                            \coordinate (x2) at (\b,\d);

                            % Red regions
                            \fill[red!20, draw=black!20] (0,0) -- (x1) -- (\a, 0) -- cycle;
                            \fill[red!20, draw=black!20] (\W, \H) -- (x2) -- (\b, \H) -- cycle;

                            % Purple regions
                            \fill[blue!20, draw=black!20] (0,0) -- (x2) -- (0, \d) -- cycle;
                            \fill[blue!20, draw=black!20] (\W, \H) -- (x1) -- (\W, \c) -- cycle;

                            % Orange rectangles
                            \fill[orange!35, draw=black!20] (0,\d) -- (x2) -- (\b, \H) -- (0, \H) -- cycle;
                            \fill[orange!35, draw=black!20] (\a,0) -- (x1) -- (\W, \c) -- (\W, 0) -- cycle;

                            % Main outline and diagonals
                            \draw[thick] (0,0) rectangle (\W,\H);
                            \draw[very thick, -&gt;] (0,0) -- (x1) node [midway, above] {$A\mathbf{x}$};
                            \draw[very thick, -&gt;] (0,0) -- (x2) node [midway, below] {$A\mathbf{y}$};
                            \draw[very thick] (x2) -- (\W,\H) node [midway, below] {$A\mathbf{x}$};
                            \draw[very thick] (x1) -- (\W,\H) node [midway, above] {$A\mathbf{y}$};
                            

                            % Labels
                            \node at (\b + \a/2,\H+0.4) {$a$};
                            \node at (\a/2,-0.4) {$a$};
                            \node at (\b/2,\H+0.35) {$b$};
                            \node at (\a+\b/2,-0.35) {$b$};
                            \node at (-0.4,\H-\c/2) {$c$};
                            \node at (\W+0.4,\c/2) {$c$};
                            \node at (-0.4,\d/2) {$d$};
                            \node at (\W+0.4,\c+\d/2) {$d$};
                            \node at (\W/2,\d/2+\c/2) {$D$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
                </figure>
                <ol marker="(a)">
                    <li>
                        <p>
                            Copy out <xref ref="det-triangles"/> into a loose piece of paper, label all the side lengths (on the inside!).
                        </p>
                    </li>
                    <li>
                        <p>
                            What's the total area of the large rectangle?
                        </p>
                        <solution>
                            <p>
                                The area of the large rectangle is given by the product of its width and height, which are <m>a + b</m> and <m>c + d</m> respectively. Therefore, the area of the large rectangle is:
                                <md>
                                    <mrow> \text{Total Area} \amp = (a + b)(c + d) </mrow>
                                    <mrow number="yes" xml:id="total-area"> \amp = ac + ad + bc + bd </mrow>
                                </md>
                            </p>
                        </solution>
                    </li>
                    <li>
                        <p>
                            Cut out all the coloured triangles and squares. Can you find a helpful way to rearrange them to figure out the total coloured area?
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                The two red triangles can be combined to form a rectangle with area <m>ac</m>, and the two blue triangles can be combined to form a rectangle with area <m>bd</m>. Thus the combined area is:
                                <md>
                                    <mrow> \text{Coloured Area} \amp = \color{red}{\text{red area}} + \color{blue}{\text{blue area}} + \color{orange}{\text{orange area}} </mrow>
                                    <mrow number="yes" xml:id="coloured-area"> \amp = \color{red}{ac} + \color{blue}{bd} + \color{orange}{2bc} </mrow>
                                </md>
                            </p>
                        </solution>
                        <note component="lesson-plan">
                            <p>
                                Gently guide Learners if they are struggly to find the area. There are many different ways to rearrange the shapes, so encourage Learners to be creative.
                            </p>
                        </note>
                    </li>
                    <li>
                        <p>
                            What is the area of the parallelogram <m>D</m>?
                        </p>
                        <solution component="lesson-plan">
                            <p>
                                The area of the parallelogram <m>D</m> is given by the total area of the large rectangle minus the coloured area. Thus, using <xref ref="total-area"/> and <xref ref="coloured-area"/>, we have:
                                <md>
                                    <mrow> \text{Area of } D \amp = \text{Total Area} - \text{Coloured Area} </mrow>
                                    <mrow> \amp = (ac + ad + bc + bd) - (ac + bd + 2bc) </mrow>
                                    <mrow> \amp = ad + bc - 2bc </mrow>
                                    <mrow> \amp = ad - bc </mrow>
                                </md>
                            </p>
                        </solution>
                    </li>
                </ol>
                </p>
            </paragraphs>
        </statement>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    5 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the concepts and properties learners discovered in the anchor task.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ul>
                <li>
                    <p>
                        Make sure Learners recognise the area <m>D = ad - bc</m> from the Learner Experience is the determinant of the matrix <m>A</m>.
                    </p>
                </li>
                <li>
                    <p>
                        Stress the connection between determinants and inverses. Relate this to how we cannot divide by zero.
                    </p>
                </li>
                <li>
                    <p>
                        Remind Learners that they only need to find the determinant of 2 by 2 matrices in this course. Point them to <xref ref="det-technology"/> if they are curious about higher dimensions.
                    </p>
                </li>
            </ul>
        </paragraphs>
    </axiom>

    <insight>
        <p>
            <ul>
                <li>
                    <p>
                        The <term>determinant</term> measures how an area changes when we apply a matrix to it.
                    </p>
                </li>
                <li>
                    <p>
                        The determinant of a matrix <m>A</m> is denoted by <m>\det{A}</m>.
                    </p>
                </li>
                <li>
                    <p>
                        If <m>A = \begin{bmatrix}a \amp b \\ c \amp d\end{bmatrix}</m>, then <m>\det{A} = ad - bc</m>.
                    </p>
                </li>
            </ul>
        </p>
        <paragraphs>
            <title>The Determinant and the Inverse</title>
            <p>
                <ul>
                    <li>
                        <p>
                            You might recognise this expression from the formula for the inverse of a 2 by 2 matrix. We have: <md>
                                A^{-1} = \frac{1}{ad-bc}\begin{bmatrix}a \amp b \\ c \amp d\end{bmatrix} \frac{1}{\det{A}}\begin{bmatrix}a \amp b \\ c \amp d\end{bmatrix}
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            If the determinant of a matrix is zero, then the matrix does not have an inverse.
                        </p>
                    </li>
                    <li>
                        <p>
                            This is because the matrix <q>collapses</q> areas to zero, meaning that we cannot reverse the transformation to get back to our original vectors.
                        </p>
                    </li>
                </ul>
            </p>
        </paragraphs>
    </insight>

    <technology xml:id="det-technology">
        <p> For a visual introduction to the determinant, check out this video, by 3Blue1Brown. It uses a similar visual approach to the one we used in the activity, but also explores how the determinant changes when we apply different transformations to our matrix.</p>

        <video xml:id="yt-list-vars" youtube="Ip3X9LOh2dk"/>
    </technology>
    

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <!-- Show det(aM) = a det(A), det(AB) = det(A) det(B)-->

    <example>
        <statement>
            <p> If <m>A = \begin{bmatrix} 5 &amp; 3 \\ 1 &amp; 4 \end{bmatrix}</m>, compute the determinant of <m>A</m>, written <m>\det{A}</m>.</p>
        </statement>
        <solution>
            <p>
                We can compute the determinant of a 2 by 2 matrix using the formula <m>\det{\begin{bmatrix} a &amp; b \\ c &amp; d \end{bmatrix}} = ad - bc</m>. In this case, we have <m>a = 5</m>, <m>b = 3</m>, <m>c = 1</m>, and <m>d = 4</m>. Substituting these values into the formula gives us:

                <md>
                    <mrow> \det{A} \amp = (5)(4) - (3)(1) </mrow>
                    <mrow>  \amp = 20 - 3 </mrow>
                    <mrow> \amp = 17 </mrow>
                </md>

                Therefore, the determinant of matrix <m>A</m> is <m>17</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Let <m>M = \begin{bmatrix} 2 &amp; -1 \\ 4 &amp; -2 \end{bmatrix}</m>
                <ol marker="(a)">
                    <li>
                        <p>
                            Compute <m>\det{M}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            What does the value of the determinant tell us about the inverse of <m>M</m>?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <ol marker="(a)">
                <li>
                    <p>
                        Using the formula for the determinant of a 2 by 2 matrix, we have:

                        <md>
                            <mrow> \det{M} \amp = ad - bc </mrow>
                            <mrow> \amp = (2)(-2) - (-1)(4) </mrow>
                            <mrow> \amp = -4 + 4 </mrow>
                            <mrow> \amp = 0 </mrow>
                        </md>

                        Therefore, the determinant of matrix <m>M</m> is <m>0</m>.
                    </p>
                </li>
                <li>
                    <p>
                        Since <m>\det{M} = 0</m>, the matrix <m>M</m> does not have an inverse. 
                    </p>
                    <p>
                        This is because any system of equations <m>M\mathbf{x} = \mathbf{b}</m> would have either no solutions or infinitely many solutions, depending on the value of <m>\mathbf{b}</m>.
                    </p>
                    <p> 
                        For example, if <m>\mathbf{x} = \begin{bmatrix} x \\ y \end{bmatrix}</m> and <m>\mathbf{b} = \begin{bmatrix} 0 \\ 0 \end{bmatrix}</m>, then we get the system of equations:
                        <md>
                            <mrow> 2x - y \amp = 0 </mrow>
                            <mrow> 4x - 2y \amp = 0 </mrow>
                        </md>
                        These are two parallel lines that coincide, meaning there are infinitely many solutions to this system of equations.
                    </p>
                    <p>
                        In either case, we cannot find a unique solution for <m>\mathbf{x}</m>, which is why the matrix <m>M</m> does not have an inverse.
                    </p>
                </li>
            </ol>
        </solution>
    </example>

    

    <example>
        <statement>
            <p>
                Let <m>A = \begin{bmatrix}-4 \amp 0 \\ 0 \amp 3\end{bmatrix}</m> and <m> B = \begin{bmatrix} 1 \amp 2 \\ 3 \amp 2 \end{bmatrix}</m>.
                <ol marker="(a)">
                    <li>
                        <p>
                            Compute <m>\det{A}</m> and <m>\det{B}</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Find the product <m>AB</m>.
                        </p>
                    </li>
                    <li>
                        <p>
                            Compute <m>\det{AB}</m> and verify that it is equal to <m>\det{A} \cdot \det{B}</m>.
                        </p>
                    </li>
                </ol>   
            </p>
        </statement>
        <solution>
            <ol marker="(a)">
                <li>
                    <p>
                        Finding <m>\det{A}</m>:
                        <md>
                            <mrow> \det{A} \amp = ad - bc </mrow>
                            <mrow> \amp = (-4)(3) - (0)(0) </mrow>
                            <mrow> \amp = -12 </mrow>
                        </md>
                        Finding <m>\det{B}</m>:
                        <md>
                            <mrow> \det{B} \amp = ad - bc </mrow>
                            <mrow> \amp = (1)(2) - (2)(3) </mrow>
                            <mrow> \amp = 2 - 6 </mrow>
                            <mrow> \amp = -4 </mrow>
                        </md>
                    </p>
                </li>
                <li>
                    <p>
                        To find the product <m>AB</m>, we perform matrix multiplication:
                        <md>
                            <mrow> AB \amp = \begin{bmatrix} -4 \amp 0 \\ 0 \amp 3 \end{bmatrix} \begin{bmatrix} 1 \amp 2 \\ 3 \amp 2 \end{bmatrix} </mrow>
                            <mrow> \amp = \begin{bmatrix} (-4)(1) + (0)(3) \amp (-4)(2) + (0)(2) \\ (0)(1) + (3)(3) \amp (0)(2) + (3)(2) \end{bmatrix} </mrow>
                            <mrow> \amp = \begin{bmatrix} -4 \amp -8 \\ 9 \amp 6 \end{bmatrix} </mrow>
                        </md>
                    </p>
                </li>
                <li>
                    <p>
                        Finding <m>\det{AB}</m>:
                        <md>
                            <mrow> \det{AB} \amp = ad - bc </mrow>
                            <mrow> \amp = (-4)(6) - (-8)(9) </mrow>
                            <mrow> \amp = -24 + 72 </mrow>
                            <mrow> \amp = 48 </mrow>
                        </md>
                        Now we verify that <m>\det{AB} = \det{A} \cdot \det{B}</m>:
                        <md>
                            <mrow> \det{A} \cdot \det{B} \amp = (-12)(-4) </mrow>
                            <mrow> \amp = 48 </mrow>
                            <mrow> \amp = \det{AB} </mrow>
                        </md>
                    </p>
                    <p>
                        In fact, the property <m>\det{AB} = \det{A} \cdot \det{B}</m> holds for all matrices <m>A</m> and <m>B</m> (as long as <m>AB</m> is defined).
                    </p>
                </li>
            </ol>
        </solution>
    </example>

