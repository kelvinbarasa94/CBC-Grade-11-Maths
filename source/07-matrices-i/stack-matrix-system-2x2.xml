    <questionvariables>
      <text>/* --- Prices: Basic (pb) and Pro (pp), Ksh 2000..5000 in steps of 100, distinct. --- */
pb : 100*rand_with_prohib(20,50,[]);
pp : 100*rand_with_prohib(20,50,[pb/100]);
/* --- Quantities: a curated 2x2 matrix with positive determinant, no zero
       entries and non-proportional rows (so the inverse method always applies). --- */
Mq : rand([
  matrix([6,4],[3,7]),
  matrix([5,2],[3,4]),
  matrix([7,3],[2,5]),
  matrix([4,3],[2,5]),
  matrix([8,5],[3,4]),
  matrix([5,4],[2,6]),
  matrix([7,2],[4,5]),
  matrix([6,5],[2,7]),
  matrix([5,3],[4,7]),
  matrix([8,3],[5,4]),
  matrix([6,2],[5,7])
]);
n11 : Mq[1,1];
n12 : Mq[1,2];
n21 : Mq[2,1];
n22 : Mq[2,2];
/* --- Compute the takings from quantities x prices (design backwards). --- */
price  : matrix([pb],[pp]);
ta_rev : Mq . price;          /* model right-hand side (revenue vector) */
R1 : ta_rev[1,1];
R2 : ta_rev[2,1];
/* --- Model answers. --- */
ta_M   : Mq;                  /* (a) coefficient matrix */
det_ta : determinant(Mq);     /* (b) determinant (positive integer) */
adj_M  : matrix([n22,-n12],[-n21,n11]);  /* adjugate, for the worked solution */
ta_pb  : pb;                  /* (c) Basic price */
ta_pp  : pp;                  /* (c) Pro price */
/* --- Wrong-answer variables for misconception feedback. --- */
wrong_Mt      : transpose(Mq);          /* (a) used days as rows, products as columns */
wrong_det_add : n11*n22 + n12*n21;      /* (b) added the diagonal products */
wrong_det_neg : n12*n21 - n11*n22;      /* (b) subtracted the wrong way round (= -det) */</text>
    </questionvariables>
