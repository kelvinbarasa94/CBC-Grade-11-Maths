    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Consider the following matrices:
                </p>
                <p>
                    <md>
                        A = \begin{bmatrix} 0 &amp; 0 &amp; 0 \\ 0 &amp; 0 &amp; 0 \end{bmatrix},
                        \quad B = \begin{bmatrix} 1 &amp; 0 &amp; 0 \\ 0 &amp; 1 &amp; 0 \\ 0 &amp; 0 &amp; 1 \end{bmatrix},
                        \quad C = \begin{bmatrix} 3 &amp; -1 &amp; 4 \end{bmatrix}
                    </md>
                </p>
                <p>
                    <md>
                        D = \begin{bmatrix} 0 \\ 0 \\ 0 \end{bmatrix},
                        \quad E = \begin{bmatrix} 7 &amp; 2 \\ -3 &amp; 1 \\ 4 &amp; 0 \end{bmatrix},
                        \quad F = \begin{bmatrix} 1 &amp; 1 \\ 1 &amp; 1 \end{bmatrix}
                    </md>
                </p>
                <p>
                    Which matrices are:
                <ol marker="(a)" cols="2">
                    <li>
                        <p><em>null</em> matrices?</p>
                    </li>
                    <li>
                        <p><em>square</em> matrices?</p>
                    </li>
                    <li>
                        <p><em>rectangular</em> matrices?</p>
                    </li>
                    <li>
                        <p><em>identity</em> matrices?</p>
                    </li>
                    <li>
                        <p><em>row</em> matrices?</p>
                    </li>
                    <li>
                        <p><em>column</em> matrices?</p>
                    </li>
                </ol>
                </p>
            </statement>
            <answer>
                <ol marker="(a)" cols="2">
                    <li>
                        <p>Null: <m>A, D</m>.</p>
                    </li>
                    <li>
                        <p>Square: <m>B, F</m>.</p>
                    </li>
                    <li>
                        <p>Rectangular: <m>A, C, D, E</m>.</p>
                    </li>
                    <li>
                        <p>Identity: <m>B</m>.</p>
                    </li>
                    <li>
                        <p>Row: <m>C</m>.</p>
                    </li>
                    <li>
                        <p>Column: <m>D</m>.</p>
                    </li>
                </ol>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Write down the order of each of the matrices <m>A, B, C, D, E, F</m> from above.
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)" cols="2">
                        <li>
                            <p>
                                <m>A: 2 \times 3</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>B: 3 \times 3</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>C: 1 \times 3</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>D: 3 \times 1</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>E: 3 \times 2</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>F: 2 \times 2</m>
                            </p>
                        </li>     
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Let <m>B = \begin{bmatrix} 2 &amp; -1 &amp; 0 &amp; 5 \\ 3 &amp; 4 &amp; -2 &amp; 1 \\ 7 &amp; 0 &amp; 6 &amp; -3 \end{bmatrix}</m>.
                </p>
                <ol marker="(a)">
                    <li>
                        <p>Find <m>b_{34}</m>.</p>
                    </li>
                    <li>
                        <p>Find the entry in row 2, column 3.</p>
                    </li>
                    <li>
                        <p>Write the third column of <m>B</m> as a column matrix.</p>
                    </li>
                </ol>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p><m>b_{34} = -3</m>.</p>
                        </li>
                        <li>
                            <p>The entry is <m>-2</m>.</p>
                        </li>
                        <li>
                            <p><m>\begin{bmatrix} 0 \\ -2 \\ 6 \end{bmatrix}</m>.</p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <title>Magic Squares</title>
            <statement>
                <p>
                    The matrix in <xref ref="fig-sidebyside-melencolia-magic-square"/> is part of a 1514 engraving by the German artist Albrecht Dürer called "Melencolia I".
                </p>
                <figure xml:id="fig-sidebyside-melencolia-magic-square">
                    <caption>Melencolia I, 1514 (Public Domain)</caption>
                    <sidebyside widths="50% 40%">
                        <figure xml:id="fig-sidebyside-subfigure">
                            <caption>Albrecht Dürer's engraving</caption>
                            <image source="images/Melencolia_I.jpg">
                                <shortdescription>The 1514 engraving Melencolia I by Albrecht Dürer</shortdescription>
                            </image>
                        </figure>
                        <figure>
                            <caption>Detail on the Magic Square</caption>
                            <image source="images/magic_square_Melencolia_I.jpg"/>
                        </figure>
                    </sidebyside>
                </figure>
                <aside>
                    <p>
                        If you're struggling to make it out, the entry in the 3rd row and 1st column is 2.
                    </p>
                </aside>
                <ol markers="(a)">
                    <li>
                        <p>
                            For each row, find the sum of its entries
                        </p>
                    </li>
                    <li>
                        <p>
                            For each column, find the sum of its entries.
                        </p>
                    </li>
                    <li>
                        <p>
                            We can draw two diagonals through the square: one from the top left to the bottom right, and another from the top right to the bottom left. Find the sum of the entries in each diagonal.
                        </p>
                    </li>
                    <li>
                        <p>
                            What do you notice! Can you construct your own?
                        </p>
                    </li>
                </ol>
            <p>
                We call matrices with this property <term>magic squares</term>. Magic squares have been found in writings from Ancient China, Japan, India, the Middle East, and Europe, and have been studied for thousands of years. See <url href="https://en.wikipedia.org/wiki/Magic_square">this Wikipedia page</url> for more information on magic squares.
            </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>Each row sums to 34.</p>
                        </li>
                        <li>
                            <p>Each column sums to 34.</p>
                        </li>
                        <li>
                            <p>Each diagonal sums to 34.</p>
                        </li>
                        <li>
                            <p>
                                The sum of the entries in each row, column, and diagonal is the same! This is what makes it a magic square.
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
    </exercises>

