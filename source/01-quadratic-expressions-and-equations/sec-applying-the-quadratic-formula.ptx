    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <introduction>
            <p>
                Solve the following quadratic equations using the quadratic formula.
            </p>
        </introduction>
        <exercise>
            <statement>   
              <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>x^2+5x+6 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x^2-7x+10 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>2x^2 + 3x - 2 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m> 3x^2 - 5x - 2 = 0</m>
                        </p>
                    </li>
                </ol>
              </p>
            </statement>   
            <answer>
               <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>x = -2 \text{ or } x = -3</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x = 2 \text{ or } x = 5</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x = -2 \text{ or } x = \frac{1}{2}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x = -\frac{1}{3} \text{ or } x = 2</m>
                        </p>
                    </li>

                </ol>
               </p>
            </answer>             
        </exercise>  
        <exercise>
            <statement>
                <p>
                    Solve:
                </p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>x^2 - 2x - 1 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x^2 + 4x + 1 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>2x^2 + x - 1 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                           <m> 3x^2 - x - 1 = 0</m>
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>x = 1 + \sqrt{2} \text{ or } x = 1 - \sqrt{2}</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x = -2 + \sqrt{3} \text{ or } x = -2 - \sqrt{3}</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x = \frac{-1 + \sqrt{9}}{4} \text{ or } x = \frac{-1 - \sqrt{9}}{4}</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x = \frac{1 + \sqrt{13}}{6} \text{ or } x = \frac{1 - \sqrt{13}}{6}</m>
                            </p>
                        </li>

                    </ol>
                </p>
            </answer>
        </exercise>  
        <exercise>
            <statement>
                <p>
                    Solve:
                </p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>x^2 - 6x + 9 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>4x^2 - 4x + 1 = 0</m>
                        </p>
                    </li>
                </ol>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>x = 3</m> (a repeated root)
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x = \frac{1}{2}</m> (a repeated root)
                            </p>
                        </li>

                    </ol>
                </p>
            </answer>
        </exercise> 
        <exercise>
            <statement>
                <p>
                    Solve:
                </p>
                <p>
                    <ol>
                        <li>
                            <p>
                                <m>5x^2 + 2x - 3 = 0</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>2x^2 + 3x + 4 = 0</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>6x^2 + x - 2 = 0</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>x = \frac{-2 + \sqrt{64}}{10} \text{ or } x = \frac{-2 - \sqrt{64}}{10}</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>  
        <exercise>
            <statement>
                <p>
                    A school sells tickets for an event. The revenue <m>R</m> (in shillings) is given by the equation <m>R = -2x^2 + 100x</m>.
                </p>
                <p>
                    where x is the number of tickets sold (in tens).
                </p>
                <p>
                    Find the number of tickets sold when the revenue is <m>180</m> shillings.
                </p>
            </statement>
            <answer>
                
                <p>
                    <m>
                        2x^2 - 100x + 180 = 0
                    </m>
                </p>
                <p>
                    <m>
                        x^2 - 50x + 90 = 0
                    </m>
                </p>
                <p>
                    <m>
                        x = \frac{-(-50) \pm \sqrt{(-50)^2 - 4(1)(90)}}{2(1)}
                    </m>
                </p>
                <p>
                    <m>
                        x = \frac{50 + \sqrt{2140}}{2} \approx 48.16
                    </m>
                </p>
                <p>
                    and
                </p>
                <p>
                    <m>
                        x = \frac{50 - \sqrt{2140}}{2} \approx 1.84
                    </m>
                </p>
                <p>
                    Since x represents the number of tickets sold in tens, the number of tickets sold when the revenue is <m>180</m> shillings is approximately <m>481</m> or <m>18</m> tickets. 
                </p>
            </answer>
        </exercise> 
    </exercises> 

