    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>   
                <p>
                    Before using the formula, you must arrange the equation in standard form: <m>ax^2 + bx + c = 0</m>.
                    Identify the coefficients for <m>3x^2 - 5 = 2x</m>.
                </p>
            </statement>   
            <answer>
                <p>
                  <m>a = 3, b = -2, c = -5</m>
                </p>  
            </answer>           
        </exercise>  
        <exercise>
            <statement>
                <p>
                    Starting from: <m>(x + \frac{b}{2a})^2 = \frac{b^2-4ac}{4a^2}</m>
                </p>
                <p>
                    Show step-by-step how to obtain:
                </p>
                <p>
                    <m>x = \frac{-b \pm \sqrt{b^2-4ac}}{2a}</m>
                </p>
            </statement>
            <answer>
                <p>
                    Take square roots of both sides
                </p>
                <p>
                    Simplify the square root
                </p>
                <p>
                    Subtract <m>\frac{b}{2a}</m> from both sides to isolate <m>x</m>
                </p>
                <p>
                    Combine the terms on the right side over a common denominator to get the final formula
                </p>
            </answer>

        </exercise>   
        <exercise>
            <statement>
                <p>
                    Explain why we:
                </p>
                <p>
                    <ol marker="(i)">
                        <li>
                            <p>
                                 Divide the equation by <m>a</m> at the start

                            </p>
                        </li>
                        <li>
                            <p>
                                Add the same number to both sides of the equation
                            </p>
                        </li>
                        <li>
                            <p>
                                Introduce the term <m>\frac{b^2}{4a^2}</m> in the formula
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(i)">
                        <li>
                            <p>
                                We divide by <m>a</m> to make the coefficient of x<m>^2</m> equal to <m>1</m>, which allows us to complete the square.
                            </p>
                        </li>
                        <li>
                            <p>
                                We add the same number to both sides to maintain the equality of the equation while completing the square.
                            </p>
                        </li>
                        <li>
                            <p>
                                The term <m>\frac{b^2}{4a^2}</m> is introduced as part of the process of completing the square, which is necessary to derive the quadratic formula.
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>   
    </exercises> 

