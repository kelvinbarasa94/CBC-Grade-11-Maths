    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>   
                <p>
                    Solve the simultaneous equations: <m>y = 3x - 2</m> and <m>y = x^2 - 5x + 6</m>.
                </p>
            </statement>   
            <answer>
                <p>
                    <m>x=2</m> or <m>x=3</m>
                </p>
                <p>
                    Substituting <m>x=2</m> into the linear equation gives <m>y=4</m>, and substituting <m>x=3</m> gives <m>y=7</m>.
                </p>
            </answer>            
        </exercise>  
        <exercise>
            <statement>
                <p>
                    Solve:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                  <m>x + 5 = x^2 - 3x + 1</m>
                                </p>
                        </li>
                        <li>
                            <p>
                                <m>2x + 1 = x^2- x - 2</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>x = \frac{3 \pm \sqrt{21}}{2}</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x = -1</m> or <m>x = 2</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise> 
        <exercise>
            <statement>
                <p>
                    Given:
                </p>
                <p>
                    <m>P=x^2+2x+3,  Q=3x+1</m>
                </p>
                <p>
                    Find values of x when <m>P = Q</m>.
                </p>
            </statement>
            <answer>
                <p>
                    <m>x = -1</m> or <m>x = 2</m>
                </p>
            </answer>
        </exercise> 
        <exercise>
            <statement>
                <p>
                    Create your own linear equation <m>y = mx + c</m> that intersects with <m>y = x^2</m> at <m>x = 2</m> and <m>x = 3</m>.
                </p>
            </statement>
            <answer>
                <p>
                    The equation must be <m>x^2 - 5x + 6 = 0</m> when equated, so <m>y = 5x - 6</m>.
                </p>
            </answer>
        </exercise> 
        <exercise>
        <statement>
            <p>
                A ball is thrown following <m>y = -x^2 + 6x</m>. A bird is flying at a constant height <m>y = 5</m>. 
                At what horizontal distances (<m>x</m>) does the ball pass the bird?
            </p>
        </statement>
        <answer>
            <p>
                <m>x = 1</m> or <m>x = 5</m>
            </p>
        </answer>
    </exercise>   
    </exercises> 
    

