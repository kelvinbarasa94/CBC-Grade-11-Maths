<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-perfect-squares" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Perfect Squares</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.1 Quadratic Expressions and Equations
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Identify perfect squares in quadratic expressions and equations
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        15 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To explore the geometric representation of square numbers and identify the relationship between side length and total area.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Distribute materials, guide learners in drawing and counting accurately, and prompt them to look for patterns in the table.
                    </p>
                </li>
            </dl>
        </axiom>

    <activity>
        <statement>
            <p>
                <term>Work in Groups</term>
            </p>
            <p>
                <term>What you need</term>
            </p>
            <p>
                Graph paper, pencil, and ruler.
            </p>
            <p>
                    <term>What to do</term>     
            </p>
            <task>
                <statement>
                    <p>
                        Draw squares of side lengths: <m>1, 2, 3, 4, 5</m> units.
                    </p>
                    <image>
                        <latex-image>
                            \begin{tikzpicture}[scale=0.6]

                                \foreach \n in {1,2,3,4,5} {
                                    \begin{scope}[shift={(\n*5,0)}]
                                        \draw[step=1cm] (0,0) grid (\n,\n);
                                        \draw[thick] (0,0) rectangle (\n,\n);
                                        \node at (\n/2,-0.7) {$\n$};
                                    \end{scope}
                                }

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                         Count and record the number of small squares inside each square in the table below.
                    </p>
            
                    <tabular left="medium" right="medium" top="medium" bottom="medium">
                        <row>
                            <cell right="medium">Side Length (<m>n</m>)</cell>
                            <cell>Number of Unit Squares (<m>n^2</m>)</cell>
                        </row>
                        <row>
                            
                            <cell right="medium"><m>1</m></cell>
                            <cell><m>1</m></cell>
                        </row>
                        <row>
                            <cell right="medium"><m>2</m></cell>
                            <cell><m>4</m></cell>
                        </row>
                        <row>
                            <cell right="medium"><m>3</m></cell>
                            <cell><m></m></cell>
                        </row>
                        <row>
                            <cell right="medium"><m>4</m></cell>
                            <cell><m></m></cell>
                        </row>
                        <row>
                            <cell right="medium"><m>5</m></cell>
                            <cell><m></m></cell>
                        </row>
                    </tabular>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                      Observe how the number of small squares increases as the side length increases.
                    </p>
                    <p>
                     What pattern do you notice in the total number of unit squares?
                    </p>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        Can you express the total number of unit squares in terms of the side length <m>n</m>?
                    </p>
                    <p>
                        Based on your observations, define what a perfect square is.
                    </p>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        Share your work with your fellow learners.
                    </p>
                </statement>
            </task>        
        </statement>
    </activity> 

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the definition of perfect squares and introduce the algebraic identities for <m>(a+b)^2</m> and <m>(a-b)^2</m>.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                         Use the learners' discovery of <m>n^2</m> to define perfect squares formally and show how these appear in algebraic expressions like trinomials.
                    </p>
                </li>
                <li>
                    <p>
                         Present the identities for perfect squares, emphasizing how they can be used to factor and expand expressions.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <insight>
        <p>
            A perfect square is a number that can be written as <m>n^2</m> where <m>n</m> is an integer.
        </p>
        <p>
            For example, <m>1</m>, <m>4</m>, <m>9</m>, <m>16</m>, and <m>25</m> are perfect squares because they can be expressed as <m>1^2</m>, <m>2^2</m>, <m>3^2</m>, <m>4^2</m>, and <m>5^2</m> respectively.
        </p>
        <p>
            Perfect squares arise naturally in area problems and algebraic expressions.
        </p>
        <p>
            <term> Perfect Square identities</term>
        </p>
        <p>
            <md>
                <mrow>(a+b)^2 = a^2 + 2ab + b^2</mrow>
                <mrow>(a-b)^2 = a^2 - 2ab + b^2</mrow>
            </md>  
        </p>
        <p>
            Perfect squares are used in simplifying expressions, factorising quadratic expressions, and solving quadratic equations.
        </p>
    </insight> 

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
           <p>
              Which of the following are perfect squares?
           </p>
           <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>16</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>20</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>25</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>30</m>
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
              To determine if a number is a perfect square, we can check if it can be expressed as <m>n^2</m>.
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <m>16</m> is a perfect square because it can be expressed as <m>4^2</m>.
                    </li>
                    <li>
                        <m>20</m> is not a perfect square because there is no integer <m>n</m> such that <m>n^2 = 20</m>.
                    </li>
                    <li>
                        <m>25</m> is a perfect square because it can be expressed as <m>5^2</m>.
                    </li>
                    <li>
                        <m>30</m> is not a perfect square because there is no integer <m>n</m> such that <m>n^2 = 30</m>.
                    </li>
                </ol>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Factor the expression <m>x^2 + 6x + 9</m>.
            </p>
        </statement>
        <solution>
            <p>
                The expression <m>x^2 + 6x + 9</m> is a perfect square.
            </p>
            <p>
                Comparing <m>x^2 + 6x + 9</m> with <m>a^2 + 2ab + b^2</m>, we can see that it matches the pattern of a perfect square trinomial.
            </p> 
            <p>
                Where <m>a = x</m> and <m>b = 3</m>.
            </p>
            <p>
                Therefore, <m>x^2 + 6x + 9 = (x + 3)^2</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Expand the expression <m>(x + 5)^2</m>.
            </p>
        </statement>
        <solution>
            <p>
                Using the identity <m>(a + b)^2 = a^2 + 2ab + b^2</m>, we have:
            </p>
            <p>
                <md>
                    <mrow> (x + 5)^2 =\amp x^2 + 2(x)(5) + 5^2</mrow>
                    <mrow> =\amp x^2 + 10x + 25</mrow>
                </md>
            </p>
        </solution>
    </example> 
    <example>
        <statement>
            <p>
                Solve the equation <m>x^2 + 10x + 16 = 0</m>.
            </p>
        </statement>
        <solution>
            <p>
                To solve the equation <m>x^2 + 10x + 16 = 0</m>, we can factor the left-hand side.
            </p>
            <p>
                <m>x^2 + 10x + 16 = (x + 2)(x + 8) = 0</m>
            </p>
            <p>
                Therefore, <m>x = -2</m> or <m>x = -8</m>.
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                Solve the equation <m>x^2 + 6x + 8 = 0</m>.
            </p>
        </statement>
        <solution>
            <p>
                To solve the equation <m>x^2 + 6x + 8 = 0</m>, we can factor the left-hand side.
            </p>
            <p>
                <m>x^2 + 6x + 8 = (x + 2)(x + 4) = 0</m>
            </p>
            <p>
                Therefore, <m>x = -2</m> or <m>x = -4</m>.
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>   
              <p>
                 Which of the following are perfect squares?
              </p>
              <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>49</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>50</m>
                       </p>
                    </li>
                    <li>
                        <p>
                            <m>121</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>144</m>
                        </p>
                    </li>
                </ol>
              </p>
            </statement>   
            <answer>
                <p>
                     <ol marker="(a)">
                        <li>
                            <p>
                                <m>49</m> is a perfect square because it can be expressed as <m>7^2</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>50</m> is not a perfect square because there is no integer <m>n</m> such that <m>n^2 = 50</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>121</m> is a perfect square because it can be expressed as <m>11^2</m>.
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>144</m> is a perfect square because it can be expressed as <m>12^2</m>.
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>           
        </exercise>  
        <exercise>
            <statement>
                <p>
                    Factor the expression <m>x^2 - 4x + 4</m>.
                </p>
            </statement>
            <answer>   
                <p>
                    <m>(x - 2)^2</m>.
                </p>
            </answer> 
        </exercise>
        <exercise>
            <statement>
                <p>
                    Expand the following expressions:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>(x + 3)^2</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>(2a + 5)^2</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>(y - 4)^2</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m> x^2 + 6x + 9</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> 4a^2 + 20a + 25</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> y^2 - 8y + 16</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>  
        <exercise>
            <statement>
                <p>
                    A square has area of <m>169 \text{ cm}^2</m>. What is the length of each side of the square?
                </p>
            </statement>
            <answer>
                <p>
                    The length of each side of the square is <m> 13 \text{ cm}</m>.
                </p>
            </answer>
        </exercise>  
        <exercise>
            <statement>
                <p>
                    If <m>y = (x + 4)^2</m>, find the value of <m>y</m> when <m>x = 2</m>.
                </p>
            </statement>
            <answer>
                <p>
                    When <m>x = 2</m>, <m>y = 36</m>.
                </p>
            </answer>
        </exercise> 
        <exercise>
            <statement>
                <p>What should be added to make each expression a perfect square?</p>
                <ol marker="a">
                <p>
                  <li><m>x^2+6x+\square</m></li>
                  <li><m>x^2-10x+\square</m></li>
                  <li><m>a^2+12a+\square</m></li>
                </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="a">
                        <li><m>9</m></li>
                        <li><m>25</m></li>
                        <li><m>36</m></li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>Copy and complete the table by writing <q>Yes</q> if the expression is a perfect-square trinomial and <q>No</q> if it is not. If your answer is <q>Yes</q>, write the expression as the square of a binomial.</p>
                <tabular top="major" bottom="major" left="major" right="major">
                    <row>
                        <cell><p>Expression</p></cell>
                        <cell><p>Perfect-square trinomial?</p></cell>
                        <cell><p>Factorised form</p></cell>
                    </row>
                    <row>
                        <cell><m>x^2+4x+4</m></cell>
                        <cell><p></p></cell>
                        <cell><p></p></cell>
                    </row>
                    <row>
                        <cell><m>x^2+4x+8</m></cell>
                        <cell><p></p></cell>
                        <cell><p></p></cell>
                    </row>
                    <row>
                        <cell><m>9y^2-12y+4</m></cell>
                        <cell><p></p></cell>
                        <cell><p></p></cell>
                    </row>
                    <row>
                        <cell><m>a^2+10a+20</m></cell>
                        <cell><p></p></cell>
                        <cell><p></p></cell>
                    </row>
                    <row>
                        <cell><m>16m^2+24m+9</m></cell>
                        <cell><p></p></cell>
                        <cell><p></p></cell>
                    </row>
                </tabular>
            </statement>

            <answer>
                <tabular top="major" bottom="major" left="major" right="major">
                    <row>
                        <cell><p>Expression</p></cell>
                        <cell><p>Perfect-square trinomial?</p></cell>
                        <cell><p>Factorised form</p></cell>
                    </row>
                    <row>
                        <cell><m>x^2+4x+4</m></cell>
                        <cell><p>Yes</p></cell>
                        <cell><m>(x+2)^2</m></cell>
                    </row>
                    <row>
                        <cell><m>x^2+4x+8</m></cell>
                        <cell><p>No</p></cell>
                        <cell><p>—</p></cell>
                    </row>
                    <row>
                        <cell><m>9y^2-12y+4</m></cell>
                        <cell><p>Yes</p></cell>
                        <cell><m>(3y-2)^2</m></cell>
                    </row>
                    <row>
                        <cell><m>a^2+10a+20</m></cell>
                        <cell><p>No</p></cell>
                        <cell><p>—</p></cell>
                    </row>
                    <row>
                        <cell><m>16m^2+24m+9</m></cell>
                        <cell><p>Yes</p></cell>
                        <cell><m>(4m+3)^2</m></cell>
                    </row>
                </tabular>
            </answer>
        </exercise>
    </exercises> 

