    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <p>
            Completing the Square is an algebraic technique used to transform a quadratic expression into a perfect square trinomial. 
        </p>
        
        <p>
            We do this by adding a specific constant <m>(\frac{b}{2})^2</m> to transform the variable terms into a squared binomial format, allowing us to isolate <m>x</m> using square roots.
        </p>
        <p>
            <term>How to complete a square for the equation <m>x^2 + bx - c = 0</m>:</term>
        </p>
        <p>
            <ol marker="(i)">
                <li>
                    <p>
                        Move the constant term to the other side of the equation: <m>x^2 + bx = c</m>
                    </p>
                </li>
                <li>
                    <p>
                        Add <m>(\frac{b}{2})^2</m> to both sides to complete the square: <m>x^2 + bx + (\frac{b}{2})^2 = c + (\frac{b}{2})^2</m>
                    </p>
                </li>
                <li>
                    <p>
                        Factor the left side as a perfect square trinomial: <m>(x + \frac{b}{2})^2 = c + (\frac{b}{2})^2</m>
                    </p>
                </li>
                <li>
                    <p>
                        Take the square root of both sides: <m>x + \frac{b}{2} = \pm \sqrt{c + (\frac{b}{2})^2}</m>
                    </p>
                    <p>
                        Don't forget the <m>\pm</m> sign!
                    </p>
                </li>
                <li>
                    <p>
                        Solve for <m>x</m>: <m>x = -\frac{b}{2} \pm \sqrt{c + (\frac{b}{2})^2}</m>
                    </p>
                </li>
            </ol>
        </p>
        
    </insight> 

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Solve <m>x^2 - 4x + 2 = 0</m>
            </p>
        </statement>
        <solution>
            <p>
                 <alert>Step 1:</alert> Move the constant term to the other side
            </p>
            <p>
                <m>x^2 - 4x = -2</m>
            </p>
            <p>
                <alert>Step 2:</alert> Add <m>(\frac{-4}{2})^2 = 4</m> to both sides 
            </p>
            <p>
                <m>x^2 - 4x + 4 = -2 + 4</m>
            </p>
            <p>
                <alert>Step 3:</alert> Factor the left side into a perfect square
            </p>
            <p>
                <m>(x - 2)^2 = 2</m>
            </p>
            <p>
                <alert>Step 4:</alert> Take the square root of both sides 
            </p>
            <p>
                <m>x - 2 = \pm \sqrt{2}</m>
            </p>
            <p>
                <alert>Step 5:</alert> Solve for <m>x</m>
            </p>
            <p>
                <m>x = 2 \pm \sqrt{2}</m>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Solve <m>x^2 - 5x + 6 = 0</m>
            </p>
        </statement>
        <solution>
            <p>
                 <alert>Step 1:</alert> Move the constant term to the other side
            </p>
            <p>
                <m>x^2 - 5x = -6</m>
            </p>
            <p>
                <alert>Step 2:</alert> Add <m>(\frac{-5}{2})^2 = \frac{25}{4}</m> to both sides 
            </p>
            <p>
                <m>x^2 - 5x + \frac{25}{4} = -6 + \frac{25}{4}</m>
            </p>
            <p>
                <alert>Step 3:</alert> Factor the left side into a perfect square
            </p>
            <p>
                <m>(x - \frac{5}{2})^2 = \frac{1}{4}</m>
            </p>
            <p>
                <alert>Step 4:</alert> Take the square root of both sides 
            </p>
            <p>
                <m>x - \frac{5}{2} = \pm \frac{1}{2}</m>
            </p>
            <p>
                <alert>Step 5:</alert> Solve for <m>x</m>
            </p>
            <p>
                <m>x = \frac{5}{2} \pm \frac{1}{2}</m>, which gives us two solutions: 
                <m>x = 3</m> and <m>x = 2</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Solve <m>x^2 + 2x - 1 = 0</m>
            </p>
        </statement>
        <solution>
            <p>
                 <alert>Step 1:</alert> Move the constant term to the other side
            </p>
            <p>
                <m>x^2 + 2x = 1</m>
            </p>
            <p>
                <alert>Step 2:</alert> Add <m>(\frac{2}{2})^2 = 1</m> to both sides 
            </p>
            <p>
                <m>x^2 + 2x + 1 = 1 + 1</m>
            </p>
            <p>
                <alert>Step 3:</alert> Factor the left side into a perfect square
            </p>
            <p>
                <m>(x + 1)^2 = 2</m>
            </p>
            <p>
                <alert>Step 4:</alert> Take the square root of both sides 
            </p>
            <p>
                <m>x + 1 = \pm \sqrt{2}</m>
            </p>
            <p>
                <alert>Step 5:</alert> Solve for <m>x</m>
            </p>
            <p>
                <m>x = -1 \pm \sqrt{2}</m>
            </p>

        </solution>
    </example> 

