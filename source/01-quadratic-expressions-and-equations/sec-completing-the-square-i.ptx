    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>   
               <p>
                 Solve the following equations by completing the square method:
               </p>
               <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>x^2 - 6x + 5 = 0</m> 
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x^2 + 8x + 3 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x^2 - 3x - 4 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x^2 + 5x +2 = 0</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x^2 - 7x + 1 = 0</m>
                        </p>
                    </li>
                </ol>
               </p>
            </statement>   
            <answer>
               <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>x = 3 \pm 2\sqrt{2}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x = -4 \pm \sqrt{13}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x = \frac{3}{2} \pm \frac{5}{2}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x = -\frac{5}{2} \pm \frac{\sqrt{17}}{2}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>x = \frac{7}{2} \pm \frac{\sqrt{45}}{2}</m>
                        </p>
                        <p>
                            <m>x= \frac{7}{2} + \frac{\sqrt{45}}{2}</m> or <m>x= \frac{7}{2} - \frac{\sqrt{45}}{2}</m>
                        </p>
                    </li>

                </ol>
               </p>
            </answer>             
        </exercise>  
        <exercise>
            <statement>
                <p>
                    The height <m>h</m> of a ball thrown upwards is given by a quadratic equation. 
                    Suppose the height in meters after <m>t</m> seconds is <m>h = -t^2 + 6t + 2</m>. 
                    A student wants to know at what time the ball reaches a height of <m>6</m> meters.
                </p>
            </statement>
            <answer>
                <p>
                     <m>t = 3 \pm \sqrt{5}</m>
                </p>
                <p>
                    The ball reaches a height of 6 meters at approximately <m>t = 3 + \sqrt{5}</m> seconds and <m>t = 3 - \sqrt{5}</m> seconds. 
                </p>
            </answer>
        </exercise> 
        <exercise>
            <statement>
                <p>
                    Solve for <m>x</m> in the following equations by completing the square
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>x^2 + 4x - 7 = 0</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x^2 -2x - 3 = 0</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x^2 + 6x + 1 = 0</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>x = -2 \pm \sqrt{11}</m>
                            </p>
                            <p>
                                <m>x = -2 + \sqrt{11}</m> or <m>x = -2 - \sqrt{11}</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x = 3</m>, <m>x = -1</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>x = -3 \pm \sqrt{8}</m>
                            </p>
                            <p>
                                <m>x = -3 + \sqrt{8}</m> or <m>x = -3 - \sqrt{8}</m>
                            </p>
                        </li>       
                    </ol>
                </p>
            </answer>
        </exercise>     
    </exercises> 

