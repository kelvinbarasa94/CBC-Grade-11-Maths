     <activity>
        <introduction>
            <p>
                Explore how the equation <m>x^2 + 6x + 3 = 0</m> can be solved using the completing the square method.
            </p>
        </introduction>
            <task>
                <statement>
                    <p>
                        Imagine a square with side length <m>x</m> and its area as <m>x^2</m>
                    </p>
                    <image width="40%">
                        <latex-image>
                            \begin{tikzpicture}
                                \begin{tikzpicture}[scale=0.8]
                                    \draw[thick] (0,0) rectangle (3,3);
                                    \node at (1.5,1.5) {$x^2$};
                                    \node at (1.5,-0.5) {$x$};
                                    \node at (-0.5,1.5) {$x$};
                                \end{tikzpicture}  
                            \end{tikzpicture}
                        </latex-image>
                        
                    </image>
                    
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                       Represent <m>6x</m> using two rectangles attached to the square.
                    </p>
                    <p>
                        <m>6x= 3x + 3x</m>
                    </p>
                    <p>
                        Attach: One rectangle of area <m>3x</m> to the right and one rectangle of area <m>3x</m> to the bottom.
                    </p>
                       
                    <image width="40%">
                        <latex-image>
                            \begin{tikzpicture}[scale=0.8]

                                % Main square
                                \draw[thick] (0,0) rectangle (3,3);
                                \node at (1.5,1.5) {$x^2$};

                                % Right rectangle
                                \draw[thick] (3,0) rectangle (6,3);
                                \node at (4.5,1.5) {$3x$};

                                % Bottom rectangle
                                \draw[thick] (0,-3) rectangle (3,0);
                                \node at (1.5,-1.5) {$3x$};

                            \end{tikzpicture}
                        </latex-image>
                        
                    </image>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        What is the side length of the missing piece?
                    </p>
                    <image width="40%">
                        <latex-image>
                            \begin{tikzpicture}
                                % Main square
                                \draw[thick] (0,0) rectangle (3,3);
                                \node at (1.5,1.5) {$x^2$};

                                % Right rectangle
                                \draw[thick] (3,0) rectangle (6,3);
                                \node at (4.5,1.5) {$3x$};

                                % Bottom rectangle
                                \draw[thick] (0,-3) rectangle (3,0);
                                \node at (1.5,-1.5) {$3x$};

                                % Missing square (dashed)
                                \draw[dashed, thick] (3,-3) rectangle (6,0);
                                \node at (4.5,-1.5) {$?$};
                            \end{tikzpicture}
                        </latex-image>
                        
                    </image>

                <p>
                   The missing corner forms a square with side length <m>3</m>.
                </p>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        Add the missing square (area = 9) to form a full square.
                    </p>
                    <image width="40%">
                        <latex-image>
                            \begin{tikzpicture}[scale=0.8]

                                % Main square
                                \draw[thick] (0,0) rectangle (3,3);
                                \node at (1.5,1.5) {$x^2$};

                                % Right rectangle
                                \draw[thick] (3,0) rectangle (6,3);
                                \node at (4.5,1.5) {$3x$};

                                % Bottom rectangle
                                \draw[thick] (0,-3) rectangle (3,0);
                                \node at (1.5,-1.5) {$3x$};

                                % Missing square
                                \draw[thick] (3,-3) rectangle (6,0);
                                \node at (4.5,-1.5) {$9$};

                            \end{tikzpicture}
                        </latex-image>
                        
                    </image>
                        
                       <p>
                         Now we have: <m>(x + 3)^2</m> 
                       </p>
                       <p>
                         How did we get the expression <m>(x + 3)^2</m> ?
                       </p>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        Connect this to the original equation <m>x^2 + 6x + 3 = 0</m> and solve for <m>x</m>.
                    </p>
                    <p>
                        We can rewrite the original equation as: <m>(x + 3)^2 - 9 + 3 = 0</m>
                    </p>
                    <p>
                        This simplifies to: <m>(x + 3)^2 - 6 = 0</m>
                    </p>
                    <p>
                       Solve for <m>x</m> in the equation <m>(x + 3)^2 - 6 = 0</m>.
                    </p>

                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        <ol marker="(i)">
                            <li>
                                <p>
                                    Why did we split <m>6x</m> into two equal parts?
                                </p>
                            </li>
                            <li>
                                <p>
                                     How did you know the missing square was <m>9</m>?
                                </p>
                            </li>
                            <li>
                                <p>
                                     Why must we add the same number to both sides?
                                </p>
                            </li>
                            <li>
                                <p>
                                    What does the <m>\pm</m> symbol represent?
                                </p>
                            </li>
                        </ol>
                    </p>
                </statement>
            </task>
    </activity> 

