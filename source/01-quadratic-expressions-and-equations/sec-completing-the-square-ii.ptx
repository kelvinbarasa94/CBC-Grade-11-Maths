<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-completing-the-square-ii" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Completing the Square II</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.1 Quadratic Expressions and Equations
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Solve quadratic equations by completing square method
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        20 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To realize the necessity of a leading coefficient of 1 when completing the square, using the context of rearranging a garden design.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Facilitate the group work on the garden redesign task. Prompt learners to explain why they chose to factor out or divide by the leading coefficient and how it simplifies the geometry.
                    </p>
                </li>
            </dl>
        </axiom>

     <activity>
        <introduction>
            <p>
                <alert>Work in Groups</alert>
            </p>
            <p>
                You are a contractor assigned to build a rectangular school garden using identical square tiles of side length <m>x</m> metres.
            </p>
            <p>
                The current design uses 2 square sections (each of area <m>x^2</m>), <m>5</m> rectangular strips (each of area <m>x</m>) plus an extra fixed area of <m>4</m>.
                The total area of the garden is <m>2x^2 + 5x + 4</m>.
            </p>
            <p>
                However, the school wants to rearrange the garden into one large square to make it more symmetrical.
            </p>
        </introduction>
        <task>
            <statement>
                <p>
                    Help redesign the garden so that it forms one perfect square, and then determine the possible values of the side length <m>x</m> of the tiles by:
                </p>
                <p>
                    <line>1. Rearranging the area of the garden to form a perfect square.</line>
                    <line>2. Solving for <m>x</m> using the new arrangement.</line>
                </p>
                <p>
                    What did you add to form a perfect square? What does this represent in terms of the garden design?
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Why was it necessary to factor out <m>2</m> first?
                </p>
                <p>
                    What is the most important step in the process of solving for <m>x</m> in the equation <m>2x^2 + 5x + 4 = 0</m> by completing the square method? Why?
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Share your work with your fellow learners.
                </p>
            </statement>
        </task>
    </activity> 

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the method for completing the square when the leading coefficient is not 1, highlighting division by 'a' as a critical preliminary step.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                         Refer to the garden task where they had to factor out 2. Explain that algebraically, this corresponds to dividing the entire equation by 'a' to enable the use of the <m>(b/2)^2</m> pattern.
                    </p>
                </li>
                <li>
                    <p>
                        Emphasize that the step of dividing by 'a' is crucial because it allows the quadratic to be expressed in a form where completing the square can be applied directly, leading to a perfect square trinomial.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        
        <p>
            When the <m>x^2</m> term has a coefficient other than 1, we call it a non-monic quadratic.
        </p>
        <p>
            Dividing the entire equation by the leading coefficient <m>a</m> is a necessary step to convert it into a monic quadratic, which allows us to apply the completing square method effectively.
        </p>
        <p>
            <term>How to solve the equation <m>ax^2 + bx + c = 0</m> by completing square method</term>
        </p>
        <p>
            <line>Step 1: Move the constant term <m>c</m> to the other side of the equation.</line>
            <line>Step 2: Divide the entire equation by <m>a</m>, the coefficient of <m>x^2</m> to make it 1.</line>
            <line>We divide by the coefficient of <m>x^2</m> because completing the square relies on the pattern <m>(x+a)^2 = x^2+2ax+a^2</m>.</line>
            <line>Step 3: Take <m>(\frac{b}{2})^2</m>, and add it to both sides of the equation.</line>
            <line>Step 4: Factor the left-hand side as a perfect square trinomial.</line>
            <line>Step 5: Take the square root of both sides and solve for <m>x</m>.</line>
        </p>
    </insight> 


    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Solve the equation <m>2x^2 + 8x + 6 = 0</m> by completing the square.
            </p>
        </statement>
        <solution>
            <p>
                Step 1: Move the constant term to the other side of the equation.
            </p>
            <p>
                <m>2x^2 + 8x = -6</m>
            </p>
            <p>
                Step 2: Divide the entire equation by <m>2</m> to make the coefficient of <m>x^2</m> equal to 1
                
            </p>
            <p>
                <m>x^2 + 4x = -3</m>
            </p>
            <p>
                Step 3: Take <m>(\frac{4}{2})^2 = 4</m>, and add it to both sides of the equation   
            </p>
            <p>
                <m>x^2 + 4x + 4 = -3 + 4</m>
            </p>
            <p>
                Step 4: Factor the left-hand side as a perfect square trinomial   
            </p>
            <p>
                <m>(x + 2)^2 = 1</m>
            </p>
            <p>
                Step 5: Take the square root of both sides and solve for <m>x</m>
            </p>
            <p>
                <m>x + 2 = \pm 1</m>
            </p>
            <p>
                Therefore, <m>x = -2 \pm 1</m>, which gives <m>x = -1</m> or <m>x = -3</m>.
            </p>

        </solution>
    </example>

    <example>
        <statement>
            <p>
                Solve the equation <m>3x^2 - 2x - 5 = 0</m> by completing the square.
            </p>
        </statement>
        <solution>
            <p>
                Step 1: Move the constant term to the other side of the equation           
            </p>
            <p>
                <m>3x^2 - 2x = 5</m>
            </p>
            <p>
                Step 2: Divide the entire equation by <m>3</m> to make the coefficient of <m>x^2</m> equal to 1
            </p>
            <p>
                 <m>x^2 - \frac{2}{3}x = \frac{5}{3}</m>
            </p>
            <p>
                Step 3: Find half the coefficient of x and square it <m>(\frac{-\frac{2}{3}}{2})^2</m>
            </p>
            <p>
                <md>
                    <mrow> =\amp (\frac{-1}{3})^2</mrow>
                    <mrow> =\amp \frac{1}{9}</mrow>
                </md>
            </p>
            <p>
                Add it to both sides of the equation
            </p>
            <p>
                <m>x^2 - \frac{2}{3}x + \frac{1}{9} = \frac{5}{3} + \frac{1}{9}</m>
            </p>
            <p>
                Step 4: Factor the left-hand side as a perfect square trinomial:
                <m>(x - \frac{1}{3})^2 = \frac{16}{9}</m>
            </p>
            <p>
                Step 5: Take the square root of both sides and solve for <m>x</m>:
                <m>x - \frac{1}{3} = \pm \frac{4}{3}</m>
            </p>
            <p>
                Therefore, <m>x = \frac{1}{3} \pm \frac{4}{3}</m>.
            </p>
            <p>
                <m>x = \frac{5}{3}</m> or <m>x = -1</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Solve the equation <m>2x^2 + 5x + 4 = 10</m> by completing the square.
            </p>
        </statement>
        <solution>
            <p>
                Step 1: Move the constant term to the other side of the equation
            </p>
            <p>
                <m>2x^2 + 5x = 6</m>
            </p>
            <p>
                Step 2: Divide the entire equation by <m>2</m> to make the coefficient of <m>x^2</m> equal to 1  
            </p>
            <p>
                <m>x^2 + \frac{5}{2}x = 3</m>
            </p>
            <p>
                Step 3: Solve for <m>(\frac{\frac{5}{2}}{2})^2.</m>
            </p>
            <p>
                <md>
                    <mrow>(\frac{\frac{5}{2}}{2})^2 =\amp (\frac{5}{4})^2</mrow>
                    <mrow> =\amp \frac{25}{16}</mrow>
                </md>  
            </p>
            <p>
                Add it to both sides of the equation:
            </p>
            <p>
                <m>x^2 + \frac{5}{2}x + \frac{25}{16} = 3 + \frac{25}{16}</m>
            </p>
            <p>
                Step 4: Factor the left-hand side as a perfect square trinomial:
                <m>(x + \frac{5}{4})^2 = \frac{73}{16}</m>
            </p>
            <p>
                Step 5: Take the square root of both sides and solve for <m>x</m>:
                <m>x + \frac{5}{4} = \pm \frac{\sqrt{73}}{4}</m>
            </p>
            <p>
                <md>
                    <mrow> x =\amp -\frac{5}{4} \pm \frac{\sqrt{73}}{4}</mrow>
                    <mrow>x =\amp \frac{-5 + \sqrt{73}}{4} \text{or}</mrow>
                    <mrow>x =\amp \frac{-5 - \sqrt{73}}{4}</mrow>
                </md>
                
            </p>

        </solution>
    </example> 

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <introduction>
            <p>
                Solve the following equations by completing the square method.
            </p>
        </introduction>
        <exercise>
            <statement>   
                <m>4x^2 - 12x + 9 = 0</m>.
            </statement>   
            <answer>
                <p>
                 <m>x = \frac{3}{2}</m>.
                </p>

            </answer>            
        </exercise>  
        <exercise>
            <statement>   
                 <m>5x^2 + 10x - 15 = 0</m> .
            </statement>   
            <answer>
                <p>
                 <m>x = -1 \pm \sqrt{4} = -1 \pm 2</m>.
                </p>

            </answer>
        </exercise>   
        <exercise>
            <statement>   
                <m>6x^2 - 3x - 1 = 0</m>
            </statement>   
            <answer>
                <p>
                <m>x = \frac{3}{12} \pm \frac{\sqrt{33}}{12}</m>.
                </p>

            </answer>   
        </exercise>
        <exercise>
            <statement>
                <p>
                 <m>2x^2 + 7x - 3 = 0</m>
                </p>
            </statement>
            <answer>
                <p>
                    <m> x = \frac{-7 \pm \sqrt{73}}{4} </m>   

                </p>
            </answer>
        </exercise>
    </exercises> 

    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        Provide a step-by-step checklist for the method. Use examples where dividing by 'a' results in integer coefficients for <m>x</m> to minimize fraction errors initially.
                    </cell>
                    
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above, solving non-monic quadratics including those with fractional intermediate steps.</line>
                    </cell>
                    
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        Challenge learners to derive the general Quadratic Formula by applying the method of completing the square to the literal equation <m>ax^2 + bx + c = 0</m>.
                    </cell>
                    
                </row>
            </tabular>
        </table>
    </axiom>

