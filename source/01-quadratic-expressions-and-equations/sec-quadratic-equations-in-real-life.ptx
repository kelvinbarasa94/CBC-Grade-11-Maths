<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-quadratic-equations-in-real-life" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Quadratic Equations in Real Life</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.1 Quadratic Expressions and Equations
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                            <ul>
                              <li>Apply quadratic equations in real-life situations</li>
                              <li>Appreciate the application of quadratic equations in real-life situations</li>
                            </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    20 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To discover how quadratic equations model physical paths and geometric constraints.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Guide learners to see the connection between the "math" (equations) and the "reality" (the ball hitting the ground or the string forming a square).
                </p>
            </li>
        </dl>
    </axiom>

