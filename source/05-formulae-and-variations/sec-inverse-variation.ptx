    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>It is known that <m>y \propto \frac{1}{x}</m>. If <m>y = 20</m> when <m>x = 3</m>, find <m>y</m> when <m>x = \frac{1}{2}</m>.</p>
            </statement>
            <answer>
                <p><strong>Answer: <m>y = 120</m></strong></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>Given that <m>p \propto \frac{1}{q}</m> and that when <m>p = 8, q = 25</m>, find:</p>
                <p>(a) the equation connecting <m>p</m> and <m>q</m>.</p>
                <p>(b) <m>p</m> when <m>q = 10</m>.</p>
            </statement>
            <answer>
                <p>(a) <strong>Answer: Equation: <m>p = \frac{200}{q}</m></strong></p>
                <p>(b) <strong>Answer: <m>p = 20</m></strong></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>A quantity <m>y</m> varies inversely as a quantity <m>x</m>. Copy and complete the table:</p>
                <tabular halign="center">
                    <row header="yes">
                        <cell><m>x</m></cell>
                        <cell>2</cell>
                        <cell>4</cell>
                        <cell>8</cell>
                        <cell>16</cell>
                    </row>
                    <row>
                        <cell><m>y</m></cell>
                        <cell>16</cell>
                        <cell>—</cell>
                        <cell>—</cell>
                        <cell>2</cell>
                    </row>
                </tabular>
                <p>(a) Find the constant of proportionality.</p>
                <p>(b) Describe the shape of the graph if <m>y</m> is plotted against <m>x</m>.</p>
            </statement>
            <answer>
                <p>(a) <strong>Answer: <m>k = 32</m></strong></p>
                <p>(b) <strong>Answer: A rectangular hyperbola</strong></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>The data below follows the relationship <m>y = \frac{k}{x}</m>.</p>
                <tabular halign="center">
                    <row header="yes">
                        <cell><m>x</m></cell>
                        <cell>1</cell>
                        <cell>2</cell>
                        <cell>5</cell>
                        <cell>10</cell>
                    </row>
                    <row>
                        <cell><m>1/x</m></cell>
                        <cell>1.0</cell>
                        <cell>0.5</cell>
                        <cell>0.2</cell>
                        <cell>0.1</cell>
                    </row>
                    <row>
                        <cell><m>y</m></cell>
                        <cell>50</cell>
                        <cell>25</cell>
                        <cell>10</cell>
                        <cell>5</cell>
                    </row>
                </tabular>
                <p>If you were to draw a graph of <m>y</m> against <m>\frac{1}{x}</m>, what would be the gradient (slope) of the resulting line?</p>
            </statement>
            <answer>
                <p><strong>Answer: The gradient is 50.</strong></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>The pressure (<m>P</m>) of a gas varies inversely as the volume (<m>V</m>). When <m>V = 10, P = 2</m>.</p>
                <p>(a) Find the equation relating <m>P</m> and <m>V</m>.</p>
                <p>(b) If the volume is doubled, what happens to the pressure? Show this using the graph.</p>
            </statement>
            <answer>
                <p>(a) <strong>Answer: Equation: <m>P = \frac{20}{V}</m></strong></p>
                <p>(b) <strong>Answer: The pressure is halved.</strong></p>
            </answer>
        </exercise>
    </exercises>

