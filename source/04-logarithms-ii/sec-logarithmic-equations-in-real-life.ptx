    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    A population of rabbits doubles every <m>4</m> months, starting with <m>50</m> rabbits. After how many months will the population reach <m>3200</m>? Use logarithms to solve.
                </p>
            </statement>
            <solution>
                <p>
                    The growth model is <m>P(t) = 50 \times 2^{t/4}</m>. Setting <m>P(t) = 3200</m>:
                </p>
                <md>
                    <mrow>3200 \amp= 50 \times 2^{t/4}</mrow>
                    <intertext>Divide both sides by 50:</intertext>
                    <mrow>64 \amp= 2^{t/4}</mrow>
                    <intertext>Take <m>\log_2</m> of both sides:</intertext>
                    <mrow>\log_2(64) \amp= \frac{t}{4}</mrow>
                    <mrow>6 \amp= \frac{t}{4}</mrow>
                    <intertext>Multiply both sides by 4:</intertext>
                    <mrow>t \amp= 24</mrow>
                </md>
                <p>
                    Therefore, the population will reach <m>3200</m> after <m>24</m> months (2 years).
                </p>
            </solution>             
        </exercise> 
        <exercise>
            <introduction>   
                <p>
                    The pH of a solution is given by the formula:
                </p>
                <p>
                    <md>\text{pH} = -\log_{10}([H^+])</md>
                </p>
                <p>
                    Where <m>[H^+]</m> is the concentration of hydrogen ions in moles per liter
                </p>
            </introduction>  
            <task>
                <statement>
                    <p>
                        Is this formula equivalent to <md>\text{pH} = \log_{10}\left(\frac{1}{[H^+]}\right)</md>
                        Why or why not?
                    </p>
                </statement>
                <solution>
                    <p>
                        Yes, the two formulas are equivalent. This is because of quotient law: 
                        <md>\log_b\left(\frac{1}{x}\right) = \log_b\left(x^{-1}\right) = -\log_b(x)</md>
                    </p>
                </solution>
            </task> 
            <task>
                <statement>
                    <p>
                        If a solution has a pH of <m>3</m>, what is the concentration of hydrogen ions in the solution?
                    </p>
                </statement>
                <solution>
                    <p>
                        Substitute <m>pH = 3</m> into the formula and solve for <m>[H^+]</m>:
                    </p>
                    <md>
                        <mrow>3 \amp= -\log_{10}([H^+])</mrow>
                        <mrow>\log_{10}([H^+]) \amp= -3</mrow>
                        <intertext>Rewrite in exponential form:</intertext>
                        <mrow>[H^+] \amp= 10^{-3} = 0.001</mrow>
                    </md>
                    <p>
                        Therefore, the concentration of hydrogen ions is <m>0.001</m> moles per liter.
                    </p>
                </solution> 
            </task>
        </exercise>
        <exercise>
            <statement>   
                <p>
                    A sound has an intensity of <m>I = 80</m> decibels. The relation between intensity and power is given by <md>I = 10 \times \log_{10}(P/P_0)</md> Where <m>P</m> is the power of the sound and <m>P_0</m> is the reference power. If the reference power is <m>10^{-12}</m> watts, what is the power of the sound in watts?
                </p>
            </statement>   
            <solution>
                <p>
                    Substitute <m>I = 80</m> and <m>P_0 = 10^{-12}</m> into <m>I = 10 \times \log_{10}(P/P_0)</m> and solve for <m>P</m>:
                </p>
                <md>
                    <mrow>80 \amp= 10 \times \log_{10}\!\left(\frac{P}{10^{-12}}\right)</mrow>
                    <intertext>Divide both sides by 10:</intertext>
                    <mrow>8 \amp= \log_{10}\!\left(\frac{P}{10^{-12}}\right)</mrow>
                    <intertext>Rewrite in exponential form:</intertext>
                    <mrow>\frac{P}{10^{-12}} \amp= 10^{8}</mrow>
                    <intertext>Multiply both sides by <m>10^{-12}</m>:</intertext>
                    <mrow>P \amp= 10^{8} \times 10^{-12} = 10^{-4} = 0.0001</mrow>
                </md>
                <p>
                    Therefore, the power of the sound is <m>0.0001</m> watts.
                </p>
            </solution> 
        </exercise>

    </exercises>

