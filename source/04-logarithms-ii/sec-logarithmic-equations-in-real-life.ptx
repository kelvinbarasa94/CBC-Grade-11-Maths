    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>   
                <p>
                    A population of rabbits doubles every 4 months. If there are initially 50 rabbits, how many rabbits will there be after 2 years? Use logarithms to solve this problem.
                </p>
            </statement>   
            <solution> 
                <p>
                    <m>P(24) = 50 * 2^(24/4) = 50 * 2^6 = 50 * 64 = 3200</m>
                </p>
                <p>
                    Therefore, after 2 years, there will be 3,200 rabbits.
                </p>
            </solution>             
        </exercise> 
        <exercise>
            <statement>   
                <p>
                    The pH of a solution is given by the formula:
                </p>
                <p>
                    <m>pH = -log_{10}([H^+])</m>
                </p>
                <p>
                    Where [H^+] is the concentration of hydrogen ions in moles per liter. If a solution has a pH of 3, what is the concentration of hydrogen ions in the solution?
                </p>
            </statement>   
            <solution> 
                <p>
                    <m>[H^+] = 10^{-3} = 0.001</m>
                </p>
                <p>
                    Therefore, the concentration of hydrogen ions in the solution is 0.001 moles per liter.
                </p>
            </solution> 
        </exercise>
        <exercise>
            <statement>   
                <p>
                    A sound has an intensity of 80 decibels. If the reference power is 10^-12 watts, what is the power of the sound in watts? Use logarithms to solve this problem.
                </p>
            </statement>   
            <solution> 
                <p>
                    <m>P = 10^8 * 10^{-12} = 10^{-4} = 0.0001</m>
                </p>
                <p>
                    Therefore, the power of the sound is 0.0001 watts.
                </p>
            </solution> 
        </exercise>

    </exercises>

