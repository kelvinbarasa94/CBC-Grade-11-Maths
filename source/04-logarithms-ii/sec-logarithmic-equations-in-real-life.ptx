    <!-- Add Activity -->

    <activity>
    <statement>
        <p>
            <term>Work in groups</term>
        </p>

        <p>
            <term>What you need</term>
        </p>

        <p>
            Scenario cards on real-life applications of logarithms
            Manila paper
            Markers
            Scientific calculators
            Graph paper (optional)
        </p>

        <p>
            <term>What to do</term>
        </p>

        <task>
            <statement>
                <p>
                    Divide into groups and let each group receive a scenario card showing a real-life application of logarithms such as disease spread, mobile network signal strength, food cooling, or fraud detection.
                </p>

                <p>
                    Read the scenario carefully and discuss how logarithms are used in that situation.
                </p>

                <p>
                    Solve the questions provided on the scenario card and record your answers on the manila paper.
                </p>
            </statement>
        </task>

        <task>
            <statement>
                <p>
                    Use calculators to evaluate logarithmic expressions related to your scenario and explain what the answers mean in real life.
                </p>
            </statement>
        </task>

        <task>
            <statement>
                <p>
                    Exchange your scenario card and solutions with another group and check each other's work.
                </p>
            </statement>
        </task>

        <task>
            <statement>
                <p>
                    Discuss any differences in answers with the other group and work together to determine the correct interpretation of the logarithmic calculations.
                </p>
            </statement>
        </task>

        <task>
            <statement>
                <p>
                    Present your findings to the class and explain how logarithms help solve real-life problems in your assigned scenario.
                </p>
            </statement>
        </task>
    </statement>
</activity>

