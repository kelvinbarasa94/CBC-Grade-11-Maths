    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>   
                <p>
                    A population of rabbits doubles every <m>4</m> months. If there are initially <m>50</m> rabbits, how many rabbits will there be after <m>2</m> years? Use logarithms to solve this problem.
                </p>
            </statement>   
            <solution> 
                <p>
                    <m>P(24) = 50 \times 2^{24/4} = 50 \times 2^6 = 50 \times 64 = 3200</m>
                </p>
                <p>
                    Therefore, after <m>2</m> years, there will be <m>3,200</m> rabbits.
                </p>
            </solution>             
        </exercise> 
        <exercise>
            <statement>   
                <p>
                    The pH of a solution is given by the formula:
                </p>
                <p>
                    <m>pH = -log_{10}([H^+])</m>
                </p>
                <p>
                    Where <m>[H^+]</m> is the concentration of hydrogen ions in moles per liter. If a solution has a pH of <m>3</m>, what is the concentration of hydrogen ions in the solution?
                </p>
            </statement>   
            <solution> 
                <p>
                    <m>[H^+] = 10^{-3} = 0.001</m>
                </p>
                <p>
                    Therefore, the concentration of hydrogen ions in the solution is <m>0.001</m> moles per liter.
                </p>
            </solution> 
        </exercise>
        <exercise>
            <statement>   
                <p>
                    A sound has an intensity of <m>80</m> decibels. If the reference power is <m>10^{-12}</m> watts, what is the power of the sound in watts? Use logarithms to solve this problem.
                </p>
            </statement>   
            <solution> 
                <p>
                    <m>P = 10^8 \times 10^{-12} = 10^{-4} = 0.0001</m>
                </p>
                <p>
                    Therefore, the power of the sound is <m>0.0001</m> watts.
                </p>
            </solution> 
        </exercise>

    </exercises>

