            <statement>   
                <p>
                    Calculate <m>\log_x(25) = \log_x(5) + 1</m>
                </p>
            </statement>   
            <solution>
                        <p>
                            Solving for x gives us:
                            <m>x = 5</m>
                        </p>
            </solution>             
        </exercise> 
        <exercise>
            <statement>   
                <p>
                    Calculate <m>\log_x(64) = \log_x(8) + 1</m>
                </p>
            </statement>   
            <solution>
                        <p>
                            Solving for x gives us:
                            <m>x = 8</m>
                        </p>
            </solution>
        </exercise> 
        <exercise>
            <statement>   
                <p>
                    Calculate <m>\log_x(100) = \log_x(10) + 1</m>
                </p>
            </statement>   
            <solution>
                        <p>
                            Solving for x gives us:
                            <m>x = 10</m>
                        </p>
            </solution> 
        </exercise>     
    </exercises>

