    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                <term>Work in groups</term>
            </p>
            <p>
                <term>What you need</term>
            </p>
            <p>
                <ul>
                    <li>
                        <p>
                        Plain sheets of paper and pens for recording your solutions.
                        </p>
                    </li>
                    <li>
                        <p>
                            Calculators
                        </p>
                    </li>
                    <li>
                        <p>
                            Set of logarithmic equations on cards, which can be prepared in advance by the teacher.
                        </p>
                    </li>
                </ul>
            </p>
            <p>
                <term>What to do</term>
            </p>
            <task>
                <statement>
                    <p>
                        Divide into groups of 4 and each group will receive a set of cards with logarithmic equations.
                    </p>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        Work collaboratively in your groups to solve the equations on the cards, then record your solutions on the sheet of paper provided. 
                    </p>
                </statement>
            </task>
            <task>
                <statement>
                    <p>
                        After solving the equations, and a representative from each group will present their solutions to the class, explaining the steps they took to arrive at their answers.
                    </p>
                </statement>
            </task>
                <task>
                    <statement>
                        <p>
                            With the teachers guidance, discuss the different approaches used by each group to solve the equations, and clarify any misconceptions that may arise during the presentations.
                        </p>
                    </statement>
                </task>
        </statement>
 </activity>

