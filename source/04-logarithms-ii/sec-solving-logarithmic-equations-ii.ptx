<section xml:id="sec-solving-logarithmic-equations-ii" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Solving Logarithmic Equations II</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.4 Logarithms II
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Solve logarithmic equations in different situations
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

