    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight> 
        <p>
            While solving logarithmic equations, it is important to watch out for the operation symbols in between the logs so that you choose the most relevant property to apply.
            Ensure that logarithims are of the same base before attempting to solve the equation.
        </p>  
        <p>
        It is important to remember that the argument of a logarithm must be positive. Double check your solutions by substituting back into the original equation to ensure they are valid.
        </p>
    </insight> 

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Solve the logarithmic equation: <m>\log_2(x+5) = \log_2(2x-1) + 1 </m>
            </p>
        </statement>
        <solution>
            <p>
                Rewrite <m>1 = \log_2(2)</m>, then apply the product rule <m>\log_b(m) + \log_b(n) = \log_b(m \cdot n)</m>:
            </p>
            <md>
                <mrow>\log_2(x+5) \amp= \log_2(2x-1) + \log_2(2)</mrow>
                <mrow>\log_2(x+5) \amp= \log_2(2(2x-1))</mrow>
                <mrow>\log_2(x+5) \amp= \log_2(4x-2)</mrow>
                <intertext>Since the bases are the same, set the arguments equal:</intertext>
                <mrow>x + 5 \amp= 4x - 2</mrow>
                <intertext>Collect like terms:</intertext>
                <mrow>3x \amp= 7</mrow>
                <mrow>x \amp= \frac{7}{3}</mrow>
            </md>
            <p>
                Check: <m>\log_2\!\left(\tfrac{7}{3}+5\right) = \log_2\!\left(\tfrac{22}{3}\right)</m> is positive, so the solution is valid.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Solve the logarithmic equation: <m>\log_3(2x+1) - \log_3(x-2) = 1</m>
            </p>
        </statement>
        <solution>
            <p>
                Apply the quotient rule <m>\log_b(m) - \log_b(n) = \log_b(m/n)</m>:
            </p>
            <md>
                <mrow>\log_3\!\left(\frac{2x+1}{x-2}\right) \amp= 1</mrow>
                <intertext>Rewrite in exponential form using <m>\log_b(a) = c \iff b^c = a</m>:</intertext>
                <mrow>3^1 \amp= \frac{2x+1}{x-2}</mrow>
                <intertext>Cross-multiply:</intertext>
                <mrow>3(x-2) \amp= 2x + 1</mrow>
                <mrow>3x - 6 \amp= 2x + 1</mrow>
                <intertext>Collect like terms:</intertext>
                <mrow>x \amp= 7</mrow>
            </md>
            <p>
                Check: <m>\log_3(2(7)+1) = \log_3(15)</m> and <m>\log_3(7-2) = \log_3(5)</m> are both positive, so the solution is valid.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Solve the logarithmic equation: <m>\log_2(x+5) - \log_2(x-3) = 2</m>
            </p>
        </statement>
        <solution>
            <p>
                Apply the quotient rule <m>\log_b(m) - \log_b(n) = \log_b(m/n)</m>:
            </p>
            <md>
                <mrow>\log_2\!\left(\frac{x+5}{x-3}\right) \amp= 2</mrow>
                <intertext>Rewrite in exponential form:</intertext>
                <mrow>2^2 \amp= \frac{x+5}{x-3}</mrow>
                <mrow>4 \amp= \frac{x+5}{x-3}</mrow>
                <intertext>Cross-multiply:</intertext>
                <mrow>4(x-3) \amp= x + 5</mrow>
                <mrow>4x - 12 \amp= x + 5</mrow>
                <intertext>Collect like terms:</intertext>
                <mrow>3x \amp= 17</mrow>
                <mrow>x \amp= \frac{17}{3}</mrow>
            </md>
            <p>
                Check: <m>\log_2\!\left(\tfrac{32}{3}\right)</m> and <m>\log_2\!\left(\tfrac{8}{3}\right)</m> are both positive, so the solution is valid.
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Solve <m>\log_2(x+3)+\log_2(x-1)=5</m>, rejecting any extraneous solutions.
                </p>
            </statement>
            <solution>
                <p>Apply the product rule to combine the logarithms:</p>
                <md>
                    <mrow>\log_2\!\bigl((x+3)(x-1)\bigr) \amp= 5</mrow>
                    <mrow>(x+3)(x-1) \amp= 2^5 = 32</mrow>
                    <mrow>x^2+2x-3 \amp= 32</mrow>
                    <mrow>x^2+2x-35 \amp= 0</mrow>
                    <mrow>(x+7)(x-5) \amp= 0</mrow>
                </md>
                <p>
                    The algebra gives <m>x=5</m> or <m>x=-7</m>.
                    Domain check: for <m>x=-7</m>, the argument <m>x+3=-4\lt 0</m>, so this solution is extraneous.
                    For <m>x=5</m>: <m>x+3=8\gt0</m> and <m>x-1=4\gt0</m> — valid.
                </p>
                <p>
                    The solution is <m>x=5</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve <m>\log_3(x+8)-\log_3(x-4)=2</m>.
                </p>
            </statement>
            <solution>
                <p>Apply the quotient rule:</p>
                <md>
                    <mrow>\log_3\!\left(\frac{x+8}{x-4}\right) \amp= 2</mrow>
                    <mrow>\frac{x+8}{x-4} \amp= 3^2 = 9</mrow>
                    <mrow>x+8 \amp= 9(x-4)</mrow>
                    <mrow>x+8 \amp= 9x-36</mrow>
                    <mrow>8x \amp= 44</mrow>
                    <mrow>x \amp= \frac{11}{2}</mrow>
                </md>
                <p>
                    Domain check: <m>x+8=\tfrac{27}{2}\gt0</m> and <m>x-4=\tfrac{3}{2}\gt0</m>.
                    The solution is <m>x=\dfrac{11}{2}</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve <m>\log_3(x-1)+\log_3(x+5)=3</m>, rejecting any extraneous solutions.
                </p>
            </statement>
            <solution>
                <p>Apply the product rule:</p>
                <md>
                    <mrow>\log_3\!\bigl((x-1)(x+5)\bigr) \amp= 3</mrow>
                    <mrow>(x-1)(x+5) \amp= 3^3 = 27</mrow>
                    <mrow>x^2+4x-5 \amp= 27</mrow>
                    <mrow>x^2+4x-32 \amp= 0</mrow>
                    <mrow>(x+8)(x-4) \amp= 0</mrow>
                </md>
                <p>
                    The algebra gives <m>x=4</m> or <m>x=-8</m>.
                    Domain check: for <m>x=-8</m>, the argument <m>x-1=-9\lt0</m> — extraneous.
                    For <m>x=4</m>: <m>x-1=3\gt0</m> and <m>x+5=9\gt0</m> — valid.
                </p>
                <p>
                    The solution is <m>x=4</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve <m>\log_5(x-4)=\log_5(3-2x)</m>.
                </p>
            </statement>
            <solution>
                <p>
                    Since the bases are equal, set the arguments equal:
                </p>
                <md>
                    <mrow>x-4 \amp= 3-2x</mrow>
                    <mrow>3x \amp= 7</mrow>
                    <mrow>x \amp= \frac{7}{3}</mrow>
                </md>
                <p>
                    Domain check: <m>x-4=\tfrac{7}{3}-4=-\tfrac{5}{3}\lt0</m>.
                    The argument is negative, so this solution is extraneous.
                    The equation has <em>no solution</em>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve <m>\log_2(4x+1)-\log_2(x-2)=3</m>.
                </p>
            </statement>
            <solution>
                <p>Apply the quotient rule:</p>
                <md>
                    <mrow>\log_2\!\left(\frac{4x+1}{x-2}\right) \amp= 3</mrow>
                    <mrow>\frac{4x+1}{x-2} \amp= 2^3 = 8</mrow>
                    <mrow>4x+1 \amp= 8(x-2)</mrow>
                    <mrow>4x+1 \amp= 8x-16</mrow>
                    <mrow>4x \amp= 17</mrow>
                    <mrow>x \amp= \frac{17}{4}</mrow>
                </md>
                <p>
                    Domain check: <m>4x+1=18\gt0</m> and <m>x-2=\tfrac{9}{4}\gt0</m>.
                    The solution is <m>x=\dfrac{17}{4}</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve <m>\log_4(x)+\log_4(x+3)=1</m>, rejecting any extraneous solutions.
                </p>
            </statement>
            <solution>
                <p>Apply the product rule:</p>
                <md>
                    <mrow>\log_4\!\bigl(x(x+3)\bigr) \amp= 1</mrow>
                    <mrow>x(x+3) \amp= 4^1 = 4</mrow>
                    <mrow>x^2+3x-4 \amp= 0</mrow>
                    <mrow>(x+4)(x-1) \amp= 0</mrow>
                </md>
                <p>
                    The algebra gives <m>x=1</m> or <m>x=-4</m>.
                    Domain check: for <m>x=-4</m>, the argument <m>x=-4\lt0</m> — extraneous.
                    For <m>x=1</m>: <m>x=1\gt0</m> and <m>x+3=4\gt0</m> — valid.
                </p>
                <p>
                    The solution is <m>x=1</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve <m>\log_3(x+12)=\log_3(x)+\log_3(x-3)</m>, rejecting any extraneous solutions.
                </p>
            </statement>
            <solution>
                <p>Apply the product rule to the right-hand side:</p>
                <md>
                    <mrow>\log_3(x+12) \amp= \log_3\!\bigl(x(x-3)\bigr)</mrow>
                    <intertext>Since the bases are equal, set the arguments equal:</intertext>
                    <mrow>x+12 \amp= x^2-3x</mrow>
                    <mrow>x^2-4x-12 \amp= 0</mrow>
                    <mrow>(x-6)(x+2) \amp= 0</mrow>
                </md>
                <p>
                    The algebra gives <m>x=6</m> or <m>x=-2</m>.
                    Domain check: for <m>x=-2</m>, the argument <m>x=-2\lt0</m> — extraneous.
                    For <m>x=6</m>: <m>x=6\gt0</m>, <m>x-3=3\gt0</m>, and <m>x+12=18\gt0</m> — valid.
                </p>
                <p>
                    The solution is <m>x=6</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Solve <m>\log_2(x+2)+\log_2(x-2)=5</m>, rejecting any extraneous solutions.
                </p>
            </statement>
            <solution>
                <p>Apply the product rule and note the difference-of-squares pattern:</p>
                <md>
                    <mrow>\log_2\!\bigl((x+2)(x-2)\bigr) \amp= 5</mrow>
                    <mrow>x^2-4 \amp= 2^5 = 32</mrow>
                    <mrow>x^2 \amp= 36</mrow>
                    <mrow>x \amp= \pm 6</mrow>
                </md>
                <p>
                    Domain check: for <m>x=-6</m>, the argument <m>x+2=-4\lt0</m> — extraneous.
                    For <m>x=6</m>: <m>x+2=8\gt0</m> and <m>x-2=4\gt0</m> — valid.
                </p>
                <p>
                    The solution is <m>x=6</m>.
                </p>
            </solution>
        </exercise>
    </exercises>

