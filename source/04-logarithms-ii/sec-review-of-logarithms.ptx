                    <title>Sub-Strand</title>
                    <p>
                        1.4 Logarithms II
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                            <ul>
                              <li>Relate index form to logarithmic notation</li>
                              <li>Simplify logarithmic expressions using laws of logarithms</li>
                            </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>  
    </objectives>

