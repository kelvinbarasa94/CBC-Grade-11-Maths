<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-review-of-logarithms" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Review of Logarithms</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.4 Logarithms II
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                            <ul>
                              <li>Relate index form to logarithmic notation</li>
                              <li>Simplify logarithmic expressions using laws of logarithms</li>
                            </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>  
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan">
            <title>Problem-Solving and Discovery</title>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        10 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To re-familiarise learners with the definition and laws of logarithms, and to provide an opportunity for learners to apply these in a problem-solving context.
                    </p>
                </li>
                <li>
                    <title>Teacher's Role</title>
                    <p>
                        Prepare cut outs of the 15 dominoes in the activity below. Facilitate group work and discussion as learners work on the activity.
                    </p>
                </li>
            </dl>
        </axiom>

        <activity xml:id="act-log-dominoes">
        <title>Logarithm Dominoes</title>
        <introduction>
            <p>
                In this activity you will use logarithm laws to form a domino chain. Each half of a domino shows a logarithmic or exponential expression. Two halves <em>match</em> when they have the same numerical value.
            </p>
            <figure xml:id="fig-log-dominoes">
                <caption>The 15 dominoes. Your teacher will provide a printed copy to cut out.</caption>
                <image width="100%">
                    <latex-image>
                        \begin{tikzpicture}[font=\footnotesize]
                        % 3 columns x 5 rows. Domino: 4.2 wide, 1.3 tall, divider at 2.1
                        % Col stride 4.8: cols at x=0, 4.8, 9.6
                        % Row stride 1.7: tops at y=0, -1.7, -3.4, -5.1, -6.8

                        % ---- Row 1 ----
                        \draw[thick, rounded corners=2pt] (0,0) rectangle (4.2,-1.3);
                        \draw[thick] (2.1,0) -- (2.1,-1.3);
                        \node[font=\tiny] at (0.25,-1.1) {1};
                        \node at (1.05,-0.65) {$\log_2\!4 + \log_2\!2$};
                        \node at (3.15,-0.65) {$\log_3 9$};

                        \draw[thick, rounded corners=2pt] (4.8,0) rectangle (9.0,-1.3);
                        \draw[thick] (6.9,0) -- (6.9,-1.3);
                        \node[font=\tiny] at (5.05,-1.1) {2};
                        \node at (5.85,-0.65) {$2^3 = 8$};
                        \node at (7.95,-0.65) {$\log_2\!8 - \log_2\!2$};

                        \draw[thick, rounded corners=2pt] (9.6,0) rectangle (13.8,-1.3);
                        \draw[thick] (11.7,0) -- (11.7,-1.3);
                        \node[font=\tiny] at (9.85,-1.1) {3};
                        \node at (10.65,-0.65) {$2\log_2 4$};
                        \node at (12.75,-0.65) {$\log_2 2$};

                        % ---- Row 2 ----
                        \draw[thick, rounded corners=2pt] (0,-1.7) rectangle (4.2,-3.0);
                        \draw[thick] (2.1,-1.7) -- (2.1,-3.0);
                        \node[font=\tiny] at (0.25,-2.8) {4};
                        \node at (1.05,-2.35) {$\log_2\!8 + \log_2\!2$};
                        \node at (3.15,-2.35) {$\log_{10} 100$};

                        \draw[thick, rounded corners=2pt] (4.8,-1.7) rectangle (9.0,-3.0);
                        \draw[thick] (6.9,-1.7) -- (6.9,-3.0);
                        \node[font=\tiny] at (5.05,-2.8) {5};
                        \node at (5.85,-2.35) {$\log_4 4$};
                        \node at (7.95,-2.35) {$\log_4 16$};

                        \draw[thick, rounded corners=2pt] (9.6,-1.7) rectangle (13.8,-3.0);
                        \draw[thick] (11.7,-1.7) -- (11.7,-3.0);
                        \node[font=\tiny] at (9.85,-2.8) {6};
                        \node at (10.65,-2.35) {$\log_2\!16 - \log_2\!2$};
                        \node at (12.75,-2.35) {$\log_3 81$};

                        % ---- Row 3 ----
                        \draw[thick, rounded corners=2pt] (0,-3.4) rectangle (4.2,-4.7);
                        \draw[thick] (2.1,-3.4) -- (2.1,-4.7);
                        \node[font=\tiny] at (0.25,-4.5) {7};
                        \node at (1.05,-4.05) {$4\log_5 5$};
                        \node at (3.15,-4.05) {$\log_{10} 1000$};

                        \draw[thick, rounded corners=2pt] (4.8,-3.4) rectangle (9.0,-4.7);
                        \draw[thick] (6.9,-3.4) -- (6.9,-4.7);
                        \node[font=\tiny] at (5.05,-4.5) {8};
                        \node at (5.85,-4.05) {$\log_2 8$};
                        \node at (7.95,-4.05) {$3^2 = 9$};

                        \draw[thick, rounded corners=2pt] (9.6,-3.4) rectangle (13.8,-4.7);
                        \draw[thick] (11.7,-3.4) -- (11.7,-4.7);
                        \node[font=\tiny] at (9.85,-4.5) {9};
                        \node at (10.65,-4.05) {$2\log_3 3$};
                        \node at (12.75,-4.05) {$\log_{10} 10$};

                        % ---- Row 4 ----
                        \draw[thick, rounded corners=2pt] (0,-5.1) rectangle (4.2,-6.4);
                        \draw[thick] (2.1,-5.1) -- (2.1,-6.4);
                        \node[font=\tiny] at (0.25,-6.2) {10};
                        \node at (1.05,-5.75) {$\log_3 3$};
                        \node at (3.15,-5.75) {$\log_3 27$};

                        \draw[thick, rounded corners=2pt] (4.8,-5.1) rectangle (9.0,-6.4);
                        \draw[thick] (6.9,-5.1) -- (6.9,-6.4);
                        \node[font=\tiny] at (5.05,-6.2) {11};
                        \node at (5.85,-5.75) {$\log_5\!5 + \log_5\!5$};
                        \node at (7.95,-5.75) {$2^4 = 16$};

                        \draw[thick, rounded corners=2pt] (9.6,-5.1) rectangle (13.8,-6.4);
                        \draw[thick] (11.7,-5.1) -- (11.7,-6.4);
                        \node[font=\tiny] at (9.85,-6.2) {12};
                        \node at (10.65,-5.75) {$\log_2 4$};
                        \node at (12.75,-5.75) {$\log_3\!9 + \log_3\!3$};

                        % ---- Row 5 ----
                        \draw[thick, rounded corners=2pt] (0,-6.8) rectangle (4.2,-8.1);
                        \draw[thick] (2.1,-6.8) -- (2.1,-8.1);
                        \node[font=\tiny] at (0.25,-7.9) {13};
                        \node at (1.05,-7.45) {$3\log_2 2$};
                        \node at (3.15,-7.45) {$\log_7 7$};

                        \draw[thick, rounded corners=2pt] (4.8,-6.8) rectangle (9.0,-8.1);
                        \draw[thick] (6.9,-6.8) -- (6.9,-8.1);
                        \node[font=\tiny] at (5.05,-7.9) {14};
                        \node at (5.85,-7.45) {$\log_5 5$};
                        \node at (7.95,-7.45) {$\log_5 125$};

                        \draw[thick, rounded corners=2pt] (9.6,-6.8) rectangle (13.8,-8.1);
                        \draw[thick] (11.7,-6.8) -- (11.7,-8.1);
                        \node[font=\tiny] at (9.85,-7.9) {15};
                        \node at (10.65,-7.45) {$\log_5 25$};
                        \node at (12.75,-7.45) {$\log_2 16$};
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                <term>Work in groups of 3–4.</term>
                You will need a printed copy of the 15 dominoes above (your teacher will provide this) and scissors.
            </p>
        </introduction>
        <task>
            <statement>
                <p>
                    Cut out all 15 dominoes.
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Evaluate the expression on each half to find its numerical value.
                    Some halves are a single logarithm (e.g. <m>\log_2 8</m>), some require a logarithm law (e.g. <m>\log_2 4 + \log_2 2</m>), and some are in exponential form (e.g. <m>3^2 = 9</m>, which tells you a logarithm equals 2).
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Arrange all 15 dominoes in a single chain so that every pair of touching halves has the same value. Each domino is used exactly once.
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    For each domino in your chain, identify which fact you used to evaluate each half: the definition <m>b^x = a \Leftrightarrow \log_b a = x</m>, the product law, the quotient law, or the power law.
                </p>
            </statement>
            <solution component="lesson-plan">
                <p>
                    The correct chain order is: 8 → 15 → 3 → 10 → 1 → 12 → 6 → 4 → 9 → 14 → 2 → 11 → 7 → 13 → 5.
                </p>
                <p>
                    The values at each join (left to right): 3, 2, 4, 1, 3, 2, 3, 4, 2, 1, 3, 2, 4, 3, 1.
                    (Domino 5 ends with value 2.)
                </p>
                <p>
                    Laws used:
                    <ul>
                        <li><p><em>Definition</em>: left half of domino 2 (<m>2^3=8</m>), right half of domino 8 (<m>3^2=9</m>), right half of domino 11 (<m>2^4=16</m>).</p></li>
                        <li><p><em>Product law</em>: left of dominoes 1, 4, 11; right of domino 12.</p></li>
                        <li><p><em>Quotient law</em>: right of domino 2; left of domino 6.</p></li>
                        <li><p><em>Power law</em>: left of dominoes 3, 7, 9, 13.</p></li>
                    </ul>
                </p>
            </solution>
        </task>
    </activity>

    <insight>
        <p>
            As you learnt in Grade 10, a logarithm and an index are two ways of writing the same relationship:
        </p>
        <md>
            <mrow>b^x = a \quad \Longleftrightarrow \quad \log_b a = x</mrow>
        </md>
        <p>
            We also have three laws of logarithms:
            <ul>
                <li><p><term>Product law:</term> <m>\log_b(ac) = \log_b a + \log_b c</m></p></li>
                <li><p><term>Quotient law:</term> <m>\log_b\!\left(\dfrac{a}{c}\right) = \log_b a - \log_b c</m></p></li>
                <li><p><term>Power law:</term> <m>\log_b(a^n) = n\log_b a</m></p></li>
            </ul>
        </p>
                
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Simplify <m>\log_{10} 6 + \log_{10} 3 - \log_{10} 9</m>
            </p>
        </statement>
        <solution>
            <p>
                Using the product law of logarithms, we can rewrite the expression as:
                <md>
                    <mrow> \log_{10} (6 \times 3) - \log_{10} 9 \amp = \log_{10} 18 - \log_{10} 9</mrow>
                    <intertext>Using the quotient law:</intertext>
                    <mrow> \amp = \log_{10} \left(\frac{18}{9}\right) </mrow>
                    <mrow> \amp = \log_{10} 2 </mrow>
                </md>
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Calculate <m>\log_{3} 100 - \log_{3} 10</m>
            </p>
        </statement>
        <solution>
              <p>
                Using the quotient law of logarithms, we can rewrite the expression as <m>\log_{3} \left(\frac{100}{10}\right)</m>. 
                Solving this gives us <m>\log_{3} 10</m> as the final answer.
              </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Calculate <m>\log_2 (8)</m>
            </p>
        </statement>
        <solution>
            <p>
                Using the power law of logarithms, we can rewrite the expression as:
                <md>
                    <mrow>\log_2(8) \amp = 3 \log_2(2) = 3</mrow>
                </md>
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <introduction>
                <p>Expand each expression using the laws of logarithms.</p>
            </introduction>
            <task>
                <statement>
                    <p><m>\log_2(16y)</m></p>
                </statement>
                <solution>
                    <p>Apply the product law:
                    <md>
                        <mrow>\log_2(16y) \amp= \log_2(16) + \log_2(y)</mrow>
                        <mrow> \amp= 4 + \log_2(y)</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>\log_3\!\left(\dfrac{x}{27}\right)</m></p>
                </statement>
                <solution>
                    <p>Apply the quotient law:
                    <md>
                        <mrow>\log_3\!\left(\frac{x}{27}\right) \amp= \log_3(x) - \log_3(27)</mrow>
                        <mrow> \amp= \log_3(x) - 3</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>\log(x^5)</m></p>
                </statement>
                <solution>
                    <p>Apply the power law:
                    <md>
                        <mrow>\log(x^5) \amp= 5\log(x)</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>\log_3(9x^2)</m></p>
                </statement>
                <solution>
                    <p>Apply the product law, then the power law:
                    <md>
                        <mrow>\log_3(9x^2) \amp= \log_3(9) + \log_3(x^2)</mrow>
                        <mrow> \amp= 2 + 2\log_3(x)</mrow>
                    </md>
                    </p>
                </solution>
            </task>
        </exercise>

        <exercise>
            <introduction>
                <p>Write each expression as a single logarithm, simplifying where possible.</p>
            </introduction>
            <task>
                <statement>
                    <p><m>2\log(5) + \log(4)</m></p>
                </statement>
                <solution>
                    <p>Apply the power law first, then the product law:
                    <md>
                        <mrow>2\log(5) + \log(4) \amp= \log(5^2) + \log(4)</mrow>
                        <mrow> \amp= \log(25 \times 4)</mrow>
                        <mrow> \amp= \log(100) = 2</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>\log(12) - \log(4) + \log(3)</m></p>
                </statement>
                <solution>
                    <p>Apply the quotient law, then the product law:
                    <md>
                        <mrow>\log(12) - \log(4) + \log(3) \amp= \log\!\left(\frac{12}{4}\right) + \log(3)</mrow>
                        <mrow> \amp= \log(3) + \log(3)</mrow>
                        <mrow> \amp= \log(9)</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>3\log_2(x) - \log_2(x^2) + \log_2(4)</m></p>
                </statement>
                <solution>
                    <p>Apply the power law to the first two terms, then combine using the quotient and product laws:
                    <md>
                        <mrow>3\log_2(x) - \log_2(x^2) + \log_2(4) \amp= \log_2(x^3) - \log_2(x^2) + \log_2(4)</mrow>
                        <mrow> \amp= \log_2\!\left(\frac{x^3}{x^2}\right) + \log_2(4)</mrow>
                        <mrow> \amp= \log_2(x) + \log_2(4)</mrow>
                        <mrow> \amp= \log_2(4x)</mrow>
                    </md>
                    </p>
                </solution>
            </task>
        </exercise>

        <exercise>
            <introduction>
                <p>Evaluate each expression.</p>
            </introduction>
            <task>
                <statement>
                    <p><m>\log_3(27)</m></p>
                </statement>
                <solution>
                    <p>Rewrite 27 as a power of 3 and apply the power law:
                    <md>
                        <mrow>\log_3(27) \amp= \log_3(3^3) = 3\log_3(3) = 3</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>\log_2(24) - \log_2(3)</m></p>
                </statement>
                <solution>
                    <p>Apply the quotient law:
                    <md>
                        <mrow>\log_2(24) - \log_2(3) \amp= \log_2\!\left(\frac{24}{3}\right)</mrow>
                        <mrow> \amp= \log_2(8) = 3</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>\log_6(12) + \log_6(3)</m></p>
                </statement>
                <solution>
                    <p>Apply the product law:
                    <md>
                        <mrow>\log_6(12) + \log_6(3) \amp= \log_6(12 \times 3)</mrow>
                        <mrow> \amp= \log_6(36) = \log_6(6^2) = 2</mrow>
                    </md>
                    </p>
                </solution>
            </task>
            <task>
                <statement>
                    <p><m>\log 4 + \log 25 - \log 5</m></p>
                </statement>
                <solution>
                    <p>Apply the product law, then the quotient law:
                    <md>
                        <mrow>\log 4 + \log 25 - \log 5 \amp= \log(4 \times 25) - \log 5</mrow>
                        <mrow> \amp= \log(100) - \log 5</mrow>
                        <mrow> \amp= \log\!\left(\frac{100}{5}\right)</mrow>
                        <mrow> \amp= \log(20)</mrow>
                    </md>
                    </p>
                </solution>
            </task>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Yash was given the following four expressions:
                    <md>
                        <mrow> A \amp= \log_2\!\left(2^3\right) </mrow>
                        <mrow>B \amp= 2^3 </mrow>
                        <mrow> C \amp= 4 \log_2(2) </mrow>
                        <mrow> D \amp= \log_2(32) - \log_2(8) </mrow>
                    </md>
                    He initially ordered them from smallest to largest but has forgotten the correct order. Write the expressions in order from smallest to largest.
                </p>
            </statement>
            <solution>
                <p>
                    Evaluating each expression:
                    <md>
                        <mrow>A \amp= \log_2\!\left(2^3\right) = 3\log_2(2) = 3</mrow>
                        <mrow>B \amp= 2^3 = 8</mrow>
                        <mrow>C \amp= 4\log_2(2) = 4</mrow>
                        <mrow>D \amp= \log_2(32) - \log_2(8) = \log_2\!\left(\frac{32}{8}\right) = \log_2(4) = 2</mrow>
                    </md>
                    Since <m>2 \lt 3 \lt 4 \lt 8</m>, the order is <m>D \lt A \lt C \lt B</m>.
                </p>
            </solution>
        </exercise>
    </exercises>

