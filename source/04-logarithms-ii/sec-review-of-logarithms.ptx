    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Calculate <m>\log 3 + \log 5 - \log 3</m>
            </p>
        </statement>
        <solution>
                <p>
                        With refrence to the product and quotient laws of logarithms, we rewrite the expression as: 
                        <m>\log (3 \times 5) \div \log 3</m>.      
              </p>
              <p>
                Solving this gives us <m>\log 5</m> as the final answer.
              </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Calculate <m>\log 100 - \log 10</m>
            </p>
        </statement>
        <solution>
              <p>
                Using the quotient law of logarithms, we can rewrite the expression as <m>\log (100 \div 10)</m>. 
                Solving this gives us <m>\log 10</m> as the final answer.
              </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Calculate <m>\log_2 (8)</m>
            </p>
        </statement>
        <solution>
               <p>
                 Rewrite the expression in exponential form as <m>\2^t = 8</m>. 
              </p>
              <p>
                Rewrite the expression such that right side to has a common base with the left side. By doing this the result is <m>\2^t = \2^3</m>. 
              </p>
              <p>
                Since the bases are the same, we can equate the exponents to get <m>t = 3</m>.
              </p>
        </solution>
    </example>

