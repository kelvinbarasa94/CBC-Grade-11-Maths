    <!-- Add static exercises -->

     <exercises>
        <exercise>
            <statement>   
                <p>
                    Calculate <m>log 4 + log 25 - log 5</m>
                </p>
            </statement>   
            <solution>
                <p>
                    <m>log 20</m>
                </p>
            </solution>             
        </exercise>
        <exercise>
            <statement>   
                <p>
                    Calculate <m>log 50 - log 5</m>
                </p>
            </statement>   
            <solution>
                <p>
                    <m>log 10</m>
                </p>
            </solution>
        </exercise>
        <exercise>
            <statement>   
                <p>
                    Calculate <m>log_3(27)</m>
                </p>
            </statement>   
            <solution>
                <p>
                    <m>3</m>
                </p>
            </solution>
        </exercise>
        <exercise>
            <statement>   
                <p>
                    A student calculates <m>log_5(25)</m>. What is the correct answer?
                </p>
            </statement>   
            <solution>
                <p>
                    <m>2</m>
                </p>
            </solution> 
        </exercise>
    </exercises>

