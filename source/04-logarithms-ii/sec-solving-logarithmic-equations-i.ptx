    <exercises>
        <exercise>
            <statement>   
                <p>
                    Bella is trying to solve the logarithmic equation <m>\log_5(x) = 2</m>. What answer does she get?
                </p>
            </statement>   
            <solution>
                <p>
                    <m>x = 25</m>
                </p>
            </solution>             
        </exercise>  
        <exercise>
            <statement>   
                <p>
                    Liam is trying to solve the logarithmic equation <m>\log_4(x - 3) = 1</m>. What answer does he get?
                </p>
            </statement>   
            <solution>
                <p>
                    <m>x = 7</m>
                </p>
            </solution> 
        </exercise> 
        <exercise>
            <statement>   
                <p>
                    Zuri is trying to solve the logarithmic equation <m>\log_2(x + 5) = 3</m>. What answer does she get?
                </p>
            </statement>   
            <solution>
                <p>
                    <m>x = 3</m>
                </p>
            </solution>
        </exercise>   
    </exercises>

