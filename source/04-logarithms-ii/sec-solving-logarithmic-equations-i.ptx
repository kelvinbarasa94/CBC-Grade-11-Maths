    <!-- Add Activity -->

    <activity>
        <statement>
        <p>
            <term> Work in groups</term>
        </p>
        <p>
            <term>What you need</term>
        </p>
           <ul>
            <li>
                <p>
                   Small cards with logarithmic equations
                </p>
            </li>
                <li>
                    <p>
                        Manila paper
                    </p>
                </li>
                <li>
                    <p>
                        Markers
                    </p>
                </li>
                <li>
                    <p>
                        Calculators (optional)
                    </p>
                </li>
           </ul>
          <p>
            <term>What to do</term>
          </p>
          <task>
             <statement>
                       <p>
                          Divide into groups and each group will receive a set of cards with logarithmic equations. 
                      </p>
             </statement>
          </task>
          <task>
            <statement>
                 <p>
                     Work collaboratively in your groups to solve the equations on the cards, then record your solutions on the manila paper.
                 </p>
            </statement>
          </task>
              <task>
                 <statement>
                     <p>
                      Exchange the cards with another group and check each other's solutions.
                     </p>
                  </statement>
              </task>
          <task>
            <statement>
                <p>
                    After checking the solutions, discuss any discrepancies with the other group and try to understand the correct solution together.
                </p>
            </statement>
          </task>
        </statement>
    </activity>

