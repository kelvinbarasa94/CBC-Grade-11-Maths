    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
          <p>
             <term>Key Takeaway:</term> Solving logarithmic equations often involves rewriting the equation in exponential form, which allows us to find the value of the variable. 
             This process relies on understanding the relationship between logarithms and exponents.
          </p>
           <p>
             When solving logarithmic equations, it's important to remember that the argument of the logarithm must be positive. This is because the logarithm of a negative number or zero is undefined in the real number system.
           </p>
           <p>
             Additionally, when solving logarithmic equations, remember the basic properties of logarithims such as the
             product rule that is <m>\log_b(xy) = \log_b(x) + \log_b(y)</m>, the quotient rule that is <m>\log_b(x/y) = \log_b(x) - \log_b(y)</m>, and the power rule that is <m>\log_b(x^n) = n \cdot \log_b(x)</m>.
          </p>
    </insight> 

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
            Solve for x: <m>\log_2(x) = 3</m>
            </p>
        </statement>
        <solution>
            <p>
                Rewrite in exponential form using <m>\log_b(a) = c \iff b^c = a</m>:
            </p>
            <md>
                <mrow>2^3 \amp= x</mrow>
                <mrow>x \amp= 8</mrow>
            </md>
        </solution>
    </example>

    <example>
        <statement>
            <p>
            Solve for x: <m>\log_3(x + 1) = 2</m>
            </p>
        </statement>
        <solution>
            <p>
                Rewrite in exponential form:
            </p>
            <md>
                <mrow>3^2 \amp= x + 1</mrow>
                <mrow>9 \amp= x + 1</mrow>
                <intertext>Subtract 1 from both sides:</intertext>
                <mrow>x \amp= 8</mrow>
            </md>
        </solution>
    </example>

    <example>
        <statement>
            <p>
            Solve for x: <m>\log_4(x - 2) = 1</m>
            </p>
        </statement>
        <solution>
            <p>
                Rewrite in exponential form:
            </p>
            <md>
                <mrow>4^1 \amp= x - 2</mrow>
                <mrow>4 \amp= x - 2</mrow>
                <intertext>Add 2 to both sides:</intertext>
                <mrow>x \amp= 6</mrow>
            </md>
        </solution>
    </example> 

