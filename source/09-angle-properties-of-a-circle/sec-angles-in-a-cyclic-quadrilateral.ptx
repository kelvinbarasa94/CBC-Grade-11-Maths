<section xml:id="sec-angles-in-a-cyclic-quadrilateral" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Angles in a Cyclic Quadrilateral</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.2 Angle Properties of a Circle
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Determine angles in a cyclic quadrilateral
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->
     <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>15 minutes</p>
            </li>
            <li>
                <title>Objective</title>
                <p>To allow learners to discover that the opposite interior angles of a cyclic quadrilateral sum to <m>180^\circ</m> and that an exterior angle equals the interior opposite angle.</p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>Organize learners into pairs or small groups. Provide template circles and straightedges. Monitor groups to ensure all four vertices of their quadrilaterals lie exactly on the circle's edge.</p>
            </li>
        </dl>
    </axiom>

    <activity>
        <statement>
            <paragraphs>
                <title>Learner Experience Sequence</title>
                <p>
                    <ul>
                        <li>
                            <p><alert>Group Work Formulation:</alert> Join a small peer collaborative group of <m>3</m> to <m>4</m> members to map out, measure, and verify geometric trends collectively.</p>
                        </li>
                        <li>
                            <p><alert>Materials Needed:</alert>
                                <ul>
                                    <li>Blank chart paper</li>
                                    <li>Drawing compass</li>
                                    <li>Clear straightedge ruler</li>
                                    <li>Protractor</li>
                                    <li>Colored fine-liner pens</li>
                                </ul>
                            </p>
                        </li>
                        <li>
                            <p><alert>Step-by-Step Activity Instruction:</alert>
                                <ul>
                                    <li>Use your compass to construct a large circle with center <m>O</m>.</li>
                                    <li>Mark four random, distinct points anywhere along the outer edge of the circumference. Label these points in order as <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m>.</li>
                                    <li>Use your straightedge to draw segments <m>AB</m>, <m>BC</m>, <m>CD</m>, and <m>DA</m> to form an inscribed quadrilateral <m>ABCD</m>.</li>
                                    <li>Measure the internal magnitudes of all four corner vertices: <m>\angle DAB</m>, <m>\angle ABC</m>, <m>\angle BCD</m>, and <m>\angle CDA</m>.</li>
                                    <li>Calculate the sum of the pairs facing across from each other: <m>\angle DAB + \angle BCD</m> and <m>\angle ABC + \angle CDA</m>. What constant mathematical value do you compute?</li>
                                    <li>Extend line segment <m>AB</m> past vertex <m>B</m> to an external point <m>E</m>. Measure the exterior angle <m>\angle CBE</m> and compare it directly to the interior opposite angle <m>\angle ADC</m>. Record your observations.</li>
                                </ul>
                            </p>
                        </li>
                    </ul>
                </p>
            </paragraphs>
        </statement>
    </activity>
