    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>A circular irrigation field has four control boxes located at points <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m> on its perimeter fence. If the angle between the lines at box <m>B</m> is <m>\angle ABC = 104^\circ</m>, find the magnitude of the angle at the opposite control box, <m>\angle ADC</m>.</p>
                <figure xml:id="fig-cyclic-quad-irrigation-field">
    <caption>A circular irrigation field containing four control boxes at points <m>A, B, C, D</m> that form an inscribed quadrilateral, where the angle at box <m>B</m> is <m>\angle ABC = 104^{\circ}</m>.</caption>
    <image width="65%">
        <description>A circle diagram outlining a cyclic quadrilateral ABCD representing an irrigation field layout. The opposite interior angles at vertices B and D are highlighted with color fills to show that they sum to 180 degrees.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle circumference ---
            \tkzDefPoint(0,0){O}

            % Define positions around the perimeter sequentially
            \tkzDefPointOnCircle[R = center O angle 190 radius 3]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 290 radius 3]\tkzGetPoint{B}
            \tkzDefPointOnCircle[R = center O angle 30 radius 3]\tkzGetPoint{C}
            \tkzDefPointOnCircle[R = center O angle 100 radius 3]\tkzGetPoint{D}

            % Draw the outer circular perimeter fence boundary
            \tkzDrawCircle[thick, color=teal](O,C)

            % --- Draw the structural connection lines between control boxes ---
            \tkzDrawPolygon[thick, color=darkgray](A,B,C,D)

            % --- Shading and marking the opposite angle pairs ---
            \tkzFillAngle[fill=magenta!25,opacity=.7, size=.6](C,B,A)
            \tkzFillAngle[fill=cyan!20,opacity=.7, size=.6](A,D,C)
            
            \tkzMarkAngle[size=.6,color=magenta!80!black,thick](C,B,A)
            \tkzMarkAngle[size=.6,color=cyan!80!black,thick](A,D,C)

            % --- Text value labels for the target positions ---
            \tkzLabelAngle[pos=1.0](C,B,A){$104^{\circ}$}
            \tkzLabelAngle[pos=0.9](A,D,C){$?$}

            % --- Dot indicators and node character labels ---
            \tkzDrawPoints[size=5,fill=black](A,B,C,D)
            \tkzLabelPoints[below left,color=black](A)
            \tkzLabelPoints[below right,color=black](B)
            \tkzLabelPoints[above right,color=black](C)
            \tkzLabelPoints[above left,color=black](D)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>Because all four points lie on the circular boundary, <m>ABCD</m> is a cyclic quadrilateral. Opposite angles sum to <m>180^\circ</m>:
                    <md>\angle ABC + \angle ADC = 180^\circ</md>
                    <md>104^\circ + \angle ADC = 180^\circ</md>
                    <md>\angle ADC = 180^\circ - 104^\circ = 76^\circ</md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>A mechanic balances a circular motorcycle wheel rim containing four reference marks <m>P</m>, <m>Q</m>, <m>R</m>, and <m>S</m>. Rim segment <m>PQ</m> is extended in a straight line past point <m>Q</m> to an external valve alignment point <m>E</m>. If the interior opposite angle across the rim is <m>\angle PSR = 98^\circ</m>, determine the measure of the exterior angle <m>\angle RQE</m>.</p>
                <figure xml:id="fig-cyclic-quad-motorcycle-wheel">
    <caption>A circular motorcycle wheel rim layout featuring four reference marks <m>P, Q, R, S</m> forming a cyclic quadrilateral, where side segment <m>PQ</m> is extended straight past point <m>Q</m> to an external valve alignment point <m>E</m>.</caption>
    <image width="65%">
        <description>A circle geometry diagram displaying a cyclic quadrilateral PQRS inside. The bottom horizontal edge PQ extends outward past vertex Q to an external point E, creating an exterior angle RQE that is equal to the interior opposite angle PSR measuring 98 degrees.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle circumference ---
            \tkzDefPoint(0,0){O}

            % Define positions around the perimeter sequentially
            \tkzDefPointOnCircle[R = center O angle 200 radius 3]\tkzGetPoint{P}
            \tkzDefPointOnCircle[R = center O angle 320 radius 3]\tkzGetPoint{Q}
            \tkzDefPointOnCircle[R = center O angle 40 radius 3]\tkzGetPoint{R}
            \tkzDefPointOnCircle[R = center O angle 110 radius 3]\tkzGetPoint{S}

            % Project an external point E past Q to illustrate the extended straight line
            \tkzDefPointBy[homothety=center P ratio 1.4](Q)\tkzGetPoint{E}

            % Draw the outer circular motorcycle rim boundary
            \tkzDrawCircle[thick, color=teal](O,R)

            % --- Draw structural segment paths ---
            \tkzDrawSegments[thick, color=darkgray](Q,R R,S S,P)
            \tkzDrawSegment[thick, color=purple](P,E) % Extended side path through Q to E

            % --- Shading and marking the equal theorem angles ---
            \tkzFillAngle[fill=cyan!20,opacity=.7, size=.6](P,S,R)
            \tkzFillAngle[fill=cyan!35,opacity=.7, size=.6](E,Q,R)
            
            \tkzMarkAngle[size=.6,color=cyan!80!black,thick](P,S,R)
            \tkzMarkAngle[size=.6,color=cyan!80!black,thick](E,Q,R)

            % --- Mathematical notation and value text labels ---
            \tkzLabelAngle[pos=0.9](P,S,R){$98^{\circ}$}
            \tkzLabelAngle[pos=1.0](E,Q,R){$?$}

            % --- Vertex point nodes and text identifier labels ---
            \tkzDrawPoints[size=5,fill=black](P,Q,R,S)
            \tkzLabelPoints[below left,color=black](P)
            \tkzLabelPoints[below,color=black](Q)
            \tkzLabelPoints[above right,color=black](R)
            \tkzLabelPoints[above left,color=black](S)
            \tkzLabelPoints[right,color=purple](E)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>By the exterior angle theorem of a cyclic quadrilateral, the exterior angle formed by an extended edge matches the interior opposite angle:
                    <md>\angle RQE = \angle PSR</md>
                    <md>\angle RQE = 98^\circ</md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>Four corner posts of a circular playground zone are positioned at <m>W</m>, <m>X</m>, <m>Y</m>, and <m>Z</m>. The opposite interior boundary angles are given by the expressions <m>\angle WXY = 4x + 12^\circ</m> and <m>\angle WZY = 2x + 18^\circ</m>. Solve for <m>x</m>.</p>
                <figure xml:id="fig-cyclic-quad-playground-zone">
    <caption>A circular playground zone featuring four corner posts located at <m>W, X, Y, Z</m> forming an inscribed quadrilateral, where the opposite boundary angles are expressed as <m>\angle WXY = 4x + 12^{\circ}</m> and <m>\angle WZY = 2x + 18^{\circ}</m>.</caption>
    <image width="65%">
        <description>A circle geometry layout showing a cyclic quadrilateral WXYZ representing a playground boundary. Opposite interior angles at vertices X and Z are filled with color shading to visually demonstrate that they sum to 180 degrees.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle circumference ---
            \tkzDefPoint(0,0){O}

            % Define positions around the circle perimeter sequentially
            \tkzDefPointOnCircle[R = center O angle 150 radius 3]\tkzGetPoint{W}
            \tkzDefPointOnCircle[R = center O angle 240 radius 3]\tkzGetPoint{X}
            \tkzDefPointOnCircle[R = center O angle 340 radius 3]\tkzGetPoint{Y}
            \tkzDefPointOnCircle[R = center O angle 60 radius 3]\tkzGetPoint{Z}

            % Draw the outer circular playground boundary line
            \tkzDrawCircle[thick, color=teal](O,Y)

            % --- Draw the inner boundary fence lines ---
            \tkzDrawPolygon[thick, color=darkgray](W,X,Y,Z)

            % --- Fill and mark the opposite interior angle pairs ---
            \tkzFillAngle[fill=magenta!20,opacity=.7, size=.6](Y,X,W)
            \tkzFillAngle[fill=cyan!20,opacity=.7, size=.6](W,Z,Y)
            
            \tkzMarkAngle[size=.6,color=magenta!80!black,thick](Y,X,W)
            \tkzMarkAngle[size=.6,color=cyan!80!black,thick](W,Z,Y)

            % --- Geometric mathematical text annotations ---
            \tkzLabelAngle[pos=1.1](Y,X,W){$4x + 12^{\circ}$}
            \tkzLabelAngle[pos=1.1](W,Z,Y){$2x + 18^{\circ}$}

            % --- Post node markers and point labels ---
            \tkzDrawPoints[size=5,fill=black](W,X,Y,Z)
            \tkzLabelPoints[above left,color=black](W)
            \tkzLabelPoints[below left,color=black](X)
            \tkzLabelPoints[below right,color=black](Y)
            \tkzLabelPoints[above right,color=black](Z)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>Set up the equation using the supplementary property of opposite angles:
                    <md>(4x + 12^\circ) + (2x + 18^\circ) = 180^\circ</md>
                    <md>6x + 30^\circ = 180^\circ</md>
                </p>
                <p>Isolate the variable <m>x</m>:
                    <md>6x = 150^\circ</md>
                    <md>x = 25^\circ</md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>A circular wooden shield has four decorative metal studs along its perimeter labeled <m>K</m>, <m>L</m>, <m>M</m>, and <m>N</m>. An artisan extends the straight line pattern <m>NM</m> past stud <m>M</m> to the edge of the shield frame point <m>F</m>. If the interior angle at the opposite stud is <m>\angle KNL = 71^\circ</m>, evaluate the size of the exterior angle <m>\angle LMF</m>.</p>
                <figure xml:id="cyclic-quad-wooden-shield">
    <caption>A geometric representation of the circular wooden shield forming a cyclic quadrilateral $KLMN$ with an extended line past stud $M$ to point $F$.</caption>
    <image width="65%">
        <latex-image>
            <![CDATA[
            \begin{tikzpicture}[scale=1.2]
                % --- Step 1: Define Center and Points via Pure Angles ---
                \coordinate (O) at (0,0);
                
                \coordinate (K) at (110:2.5);
                \coordinate (L) at (35:2.5);
                \coordinate (M) at (310:2.5);
                \coordinate (N) at (190:2.5);
                
                % Step 2: Safe Extension calculation (No calc library needed)
                % Uses a relative polar shift to extend NM past M natively
                \coordinate (F) at ($(M) + (348:1.2)$);

                % --- Step 3: Draw Circle ---
                \draw[thick] (O) circle (2.5);
                
                % --- Step 4: Draw Highlighted Angles ---
                % Interior Angle at N (71 degrees)
                \begin{scope}
                    \clip (N) -- (M) -- (K) -- cycle;
                    \draw[draw=none, fill=blue!20, opacity=0.6] (N) circle (0.5);
                    \draw[blue, thick] (N) circle (0.5);
                \end{scope}
                \node[blue, right] at ($(N)+(5:0.6)$) {$71^{\circ}$};

                % Exterior Angle at M (Angle LMF)
                \begin{scope}
                    \clip (M) -- (L) -- (F) -- cycle;
                    \draw[draw=none, fill=red!20, opacity=0.6] (M) circle (0.5);
                    \draw[red, thick] (M) circle (0.5);
                \end{scope}
                \node[red, above right] at ($(M)+(30:0.5)$) {$\angle LMF$};

                % --- Step 5: Draw Lines ---
                \draw[thick] (K) -- (L) -- (M) -- (N) -- cycle;
                \draw[thick, dashed] (M) -- (F); 

                % --- Step 6: Points and Labels ---
                \foreach \pt/\pos in {K/above, L/right, M/below right, N/left, F/below right} {
                    \fill (\pt) circle (2pt);
                    \node[\pos] at (\pt) {$\pt$};
                }
            \end{tikzpicture}
            ]]>
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>Since the studs form an inscribed cyclic quadrilateral, the exterior angle at vertex <m>M</m> equals the opposite interior angle at vertex <m>N</m>:
                    <md>\angle LMF = \angle KNL = 71^\circ</md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>A circular observation deck has four structural support columns positioned at <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m>. The angle measured at column <m>A</m> is exactly four times the size of the angle measured at the opposite column <m>C</m>. Calculate the measures of both <m>\angle BAD</m> and <m>\angle BCD</m>.</p>
                <figure xml:id="fig-cyclic-quad-observation-deck">
    <caption>A circular observation deck with four structural support columns at points <m>A, B, C, D</m> forming an inscribed quadrilateral, where the interior angle <m>\angle BAD</m> is exactly four times the size of its opposite angle <m>\angle BCD</m>.</caption>
    <image width="65%">
        <description>A circle diagram depicting an inscribed cyclic quadrilateral ABCD modeling an observation deck layout. Opposite interior angles at vertices A and C are colored with distinct fills to emphasize that one is four times the size of the other, totaling 180 degrees.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle circumference ---
            \tkzDefPoint(0,0){O}

            % Position the four column points sequentially around the observation deck
            \tkzDefPointOnCircle[R = center O angle 162 radius 3]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 250 radius 3]\tkzGetPoint{B}
            \tkzDefPointOnCircle[R = center O angle 342 radius 3]\tkzGetPoint{C}
            \tkzDefPointOnCircle[R = center O angle 70 radius 3]\tkzGetPoint{D}

            % Draw the circular perimeter edge line of the deck
            \tkzDrawCircle[thick, color=teal](O,B)

            % --- Draw the structural column connection lines ---
            \tkzDrawPolygon[thick, color=darkgray](A,B,C,D)

            % --- Fill and mark the opposite interior angle pairs ---
            \tkzFillAngle[fill=magenta!20,opacity=.7, size=.6](B,A,D)
            \tkzFillAngle[fill=cyan!20,opacity=.7, size=.6](D,C,B)
            
            \tkzMarkAngle[size=.6,color=magenta!80!black,thick](B,A,D)
            \tkzMarkAngle[size=.6,color=cyan!80!black,thick](D,C,B)

            % --- Geometric mathematical text annotations ---
            \tkzLabelAngle[pos=1.0](B,A,D){$4w$}
            \tkzLabelAngle[pos=0.9](D,C,B){$w$}

            % --- Column nodes and identifier labels ---
            \tkzDrawPoints[size=5,fill=black](A,B,C,D)
            \tkzLabelPoints[above left,color=black](A)
            \tkzLabelPoints[below left,color=black](B)
            \tkzLabelPoints[below right,color=black](C)
            \tkzLabelPoints[above right,color=black](D)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>Let the smaller interior angle <m>\angle BCD = w</m>. Therefore, opposite angle <m>\angle BAD = 4w</m>.</p>
                <p>Sum the opposite angles to <m>180^\circ</m>:
                    <md>4w + w = 180^\circ</md>
                    <md>5w = 180^\circ \implies w = 36^\circ</md>
                </p>
                <p>State both structural angle values:
                    <md>\angle BCD = 36^\circ</md>
                    <md>\angle BAD = 4(36^\circ) = 144^\circ</md>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>A dome-shaped greenhouse framework connects four perimeter joints sequentially labeled <m>P</m>, <m>Q</m>, <m>R</m>, and <m>S</m>. The base metal tube segment <m>SR</m> extends past joint <m>R</m> to an external structural peg <m>T</m>. If the exterior joint angle measures <m>\angle QRT = 93^\circ</m>, determine the value of the interior opposite frame angle <m>\angle QPS</m>.</p>
                <figure xml:id="cyclic-quad-greenhouse">
    <caption>A geometric representation of the dome-shaped greenhouse framework forming a cyclic quadrilateral $PQRS$ with an extended base segment to peg $T$.</caption>
    <image width="65%">
        <latex-image>
            <![CDATA[
            \begin{tikzpicture}[scale=1.2]
                % --- Define Coordinates via Trigonometry ---
                \coordinate (O) at (0,0);
                
                \coordinate (P) at (105:2.5);
                \coordinate (Q) at (25:2.5);
                \coordinate (R) at (285:2.5);
                \coordinate (S) at (195:2.5);
                
                \coordinate (T) at ($(R)!-1.2cm!(S)$);

                % --- Draw the Circle ---
                \draw[thick] (O) circle (2.5);
                
                % --- Draw Angles ---
                \begin{scope}
                    \clip (P) -- (S) -- (Q) -- cycle;
                    \draw[draw=none, fill=red!20, opacity=0.6] (P) circle (0.5);
                    \draw[red, thick] (P) circle (0.5);
                \end{scope}
                \node[red, below right] at ($(P)+(310:0.5)$) {$\angle QPS$};

                \begin{scope}
                    \clip (R) -- (Q) -- (T) -- cycle;
                    \draw[draw=none, fill=blue!20, opacity=0.6] (R) circle (0.5);
                    \draw[blue, thick] (R) circle (0.5);
                \end{scope}
                \node[blue, right] at ($(R)+(20:0.6)$) {$93^{\circ}$};

                % --- Draw Framework Segments ---
                \draw[thick] (P) -- (Q) -- (R) -- (S) -- cycle;
                \draw[thick, dashed] (R) -- (T); 

                % --- Plot Points and Labels ---
                \foreach \pt/\pos in {P/above, Q/right, R/below left, S/left, T/right} {
                    \fill (\pt) circle (2pt);
                    \node[\pos] at (\pt) {$\pt$};
                }
            \end{tikzpicture}
            ]]>
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>Applying the exterior angle property of an inscribed cyclic quadrilateral:
                    <md>\angle QPS = \angle QRT</md>
                    <md>\angle QPS = 93^\circ</md>
                    The interior structural frame angle measures <m>93^\circ</m>.
                </p>
            </solution>
        </exercise>
    </exercises>

