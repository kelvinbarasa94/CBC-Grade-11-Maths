    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises xml:id="ex-same-arc-only-practice">

        <exercise>
            <statement>
                <p>
                    On a circular radar display, two sensor beams originate from the same boundary points <m>A</m> and <m>B</m>. One beam meets the outer ring at target point <m>P</m> and the other meets at target point <m>Q</m>. If the angle measured at target <m>P</m> is <m>\angle APB = 44^\circ</m>, calculate the angle <m>\angle AQB</m> measured at target <m>Q</m>.
                </p>
               <figure xml:id="figure-radar-display">
            <caption>Sensor beams on a circular radar display creating angles in the same segment</caption>
            <image width="65%">
                <latex-image>
                    \begin{tikzpicture}
                    % --- Centre and points on the circle ---
                    \tkzDefPoint(0,0){O}
                    
                    % Angle AOB is 88 degrees to ensure inscribed angles are exactly 44 degrees
                    \tkzDefPointOnCircle[R = center O angle 210 radius 3]\tkzGetPoint{A}
                    \tkzDefPointOnCircle[R = center O angle 298 radius 3]\tkzGetPoint{B}
                    \tkzDefPointOnCircle[R = center O angle 100 radius 3]\tkzGetPoint{P}
                    \tkzDefPointOnCircle[R = center O angle 40  radius 3]\tkzGetPoint{Q}

                    % Draw the radar boundary ring
                    \tkzDrawCircle[thick](O,A)

                    % --- Draw sensor beams ---
                    \tkzDrawSegments(P,A P,B Q,A Q,B)

                    % --- Fill and mark the target angles ---
                    \tkzFillAngle[fill=red!20,opacity=.6, size=.6](A,P,B)
                    \tkzFillAngle[fill=blue!20,opacity=.6, size=.6](A,Q,B)

                    \tkzMarkAngle[size=.6,color=red](A,P,B)
                    \tkzMarkAngle[size=.6,color=blue](A,Q,B)

                    % --- Angle labels ---
                    \tkzLabelAngle[pos=1.1](A,P,B){$44^{\circ}$}
                    \tkzLabelAngle[pos=1.1](A,Q,B){$?$}

                    % --- Points and point labels ---
                    \tkzDrawPoints(A,B,P,Q)
                    \tkzLabelPoints[below left](A)
                    \tkzLabelPoints[below right](B)
                    \tkzLabelPoints[above left](P)
                    \tkzLabelPoints[above right](Q)

                    \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
            </statement>
            <solution>
                <p>
                    Both angles <m>\angle APB</m> and <m>\angle AQB</m> are subtended at the circumference by the exact same boundary arc <m>AB</m>.
                </p>
                <p>
                    According to the theorem, angles standing on the same arc are equal in measure:
                </p>
                <md>\angle AQB = \angle APB = 44^\circ</md>
                <p>
                    The measure of the angle <m>\angle AQB</m> is <m>44^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
             <statement>
                <p>
                    Four peg markers are placed on a circular school playing field at points <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m> in clockwise order. Students tie ropes between the pegs forming paths <m>AC</m>, <m>AD</m>, <m>BC</m>, and <m>BD</m>. If the angle formed at peg <m>C</m> by paths <m>AC</m> and <m>BC</m> is <m>\angle ACB = 47^\circ</m>, state the measure of <m>\angle ADB</m> and explain your reasoning.
                </p>
               <figure xml:id="angles-in-same-segment-clockwise-fixed">
                    <caption></caption>
                    <image width="65%">
                        <latex-image>
                            \begin{tikzpicture}
                            % --- Centre and points on the circle ---
                            \tkzDefPoint(0,0){O}
                            
                            % Points positioned in strict clockwise order: A -> B -> C -> D
                            \tkzDefPointOnCircle[R = center O angle 160 radius 3]\tkzGetPoint{A}
                            \tkzDefPointOnCircle[R = center O angle 80 radius 3]\tkzGetPoint{B}
                            \tkzDefPointOnCircle[R = center O angle 20 radius 3]\tkzGetPoint{C}
                            \tkzDefPointOnCircle[R = center O angle 280 radius 3]\tkzGetPoint{D}

                            % Draw the circle
                            \tkzDrawCircle[thick](O,A)

                            % --- Draw paths (ropes) ---
                            \tkzDrawSegments(A,C A,D B,C B,D)

                            % --- Fill and mark interior angles (reversing order fixes the reflex angle issue) ---
                            \tkzFillAngle[fill=blue!20,opacity=.6, size=.8](B,C,A)
                            \tkzFillAngle[fill=orange!20,opacity=.6, size=.8](B,D,A)

                            \tkzMarkAngle[size=.8,color=blue](B,C,A)
                            \tkzMarkAngle[size=.8,color=orange](B,D,A)

                            % --- Angle labels ---
                            \tkzLabelAngle[pos=1.3](B,C,A){$47^{\circ}$}
                            \tkzLabelAngle[pos=1.3](B,D,A){$x^{\circ}$}

                            % --- Points and point labels ---
                            \tkzDrawPoints(A,B,C,D)
                            \tkzLabelPoints[above left](A)
                            \tkzLabelPoints[above right](B)
                            \tkzLabelPoints[right](C)
                            \tkzLabelPoints[below](D)

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
            </statement>
            <solution>
                <p>
                    By the Angles in the Same Segment Theorem, angles subtended by the same arc at the circumference in the same segment are equal:
                </p>
                <md>\angle ADB = \angle ACB = 47^\circ</md>
                <p>
                    Therefore, the measure of <m>\angle ADB</m> is <m>47^\circ</m> because both angles are subtended by the same boundary arc <m>AB</m>.
                </p>
            </solution>
        </exercise>
         
        <exercise>
            <statement>
                <p>
                    Two angles on the circumference of a circle stand on the same arc <m>MN</m>. The first angle is <m>\angle MKN = 3k + 12^\circ</m> and the second is <m>\angle MLN = 5k - 8^\circ</m>. Solve for <m>k</m> and determine the actual measure of the angles.
                </p>
                <figure xml:id="figure-angles-same-arc-k">
            <caption>Angles <m>\angle MKN</m> and <m>\angle MLN</m> subtended by arc <m>MN</m></caption>
            <image width="65%">
                <latex-image>
                    \begin{tikzpicture}
                    % --- Centre and points on the circle ---
                    \tkzDefPoint(0,0){O}
                    
                    % Central angle of 84 degrees ensures inscribed angles are exactly 42 degrees
                    \tkzDefPointOnCircle[R = center O angle 110 radius 3]\tkzGetPoint{K}
                    \tkzDefPointOnCircle[R = center O angle 40  radius 3]\tkzGetPoint{L}
                    \tkzDefPointOnCircle[R = center O angle 220 radius 3]\tkzGetPoint{M}
                    \tkzDefPointOnCircle[R = center O angle 304 radius 3]\tkzGetPoint{N}

                    % Draw the circle boundary
                    \tkzDrawCircle[thick](O,K)

                    % --- Draw chords forming the angles ---
                    \tkzDrawSegments(K,M K,N L,M L,N)

                    % --- Fill and mark the equal angles ---
                    \tkzFillAngle[fill=red!20,opacity=.6, size=.6](M,K,N)
                    \tkzFillAngle[fill=blue!20,opacity=.6, size=.6](M,L,N)

                    \tkzMarkAngle[size=.6,color=red](M,K,N)
                    \tkzMarkAngle[size=.6,color=blue](M,L,N)

                    % --- Angle algebraic labels ---
                    \tkzLabelAngle[pos=1.4](M,K,N){$3k + 12^{\circ}$}
                    \tkzLabelAngle[pos=1.4](M,L,N){$5k - 8^{\circ}$}

                    % --- Points and point labels ---
                    \tkzDrawPoints(M,N,K,L)
                    \tkzLabelPoints[above left](K)
                    \tkzLabelPoints[above right](L)
                    \tkzLabelPoints[below left](M)
                    \tkzLabelPoints[below right](N)

                    \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
            </statement>
            <solution>
                <p>
                    Since both angles stand on the same arc <m>MN</m> at the circumference, they must be equal:
                </p>
                <md>\angle MKN = \angle MLN</md>
                <md>3k + 12 = 5k - 8</md>
                <p>
                    Isolate the terms with variable <m>k</m>:
                </p>
                <md>12 + 8 = 5k - 3k</md>
                <md>20 = 2k</md>
                <md>k = 10</md>
                <p>
                    Substitute <m>k = 10</m> back into either equation to calculate the angle measure:
                </p>
                <md>\angle MKN = 3(10) + 12 = 30 + 12 = 42^\circ</md>
                <p>
                    The value of <m>k</m> is <m>10</m>, and both angles measure <m>42^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
    <statement>
        <p>
            Four points <m>A, B, C</m>, and <m>D</m> are positioned sequentially on the circumference of a circle. The chords <m>AC</m> and <m>BD</m> intersect at an interior point <m>E</m>. If <m>\angle BAC = 39^{\circ}</m>, determine the measure of <m>\angle BDC</m>.
        </p>
        <figure xml:id="figure-sequential-chords">
            <caption>Intersecting chords <m>AC</m> and <m>BD</m> with sequential points</caption>
            <image width="65%">
                <latex-image>
                    \begin{tikzpicture}
                    % --- Centre and points on the circle ---
                    \tkzDefPoint(0,0){O}
                    
                    % Central angle BOC = 2 * 39 = 78 degrees to ensure exact visual proportion
                    \tkzDefPointOnCircle[R = center O angle 340 radius 3]\tkzGetPoint{A}
                    \tkzDefPointOnCircle[R = center O angle 60  radius 3]\tkzGetPoint{B}
                    \tkzDefPointOnCircle[R = center O angle 138 radius 3]\tkzGetPoint{C}
                    \tkzDefPointOnCircle[R = center O angle 220 radius 3]\tkzGetPoint{D}
                    
                    % Intersection point E
                    \tkzInterLL(A,C)(B,D)\tkzGetPoint{E}

                    % Draw the circle boundary
                    \tkzDrawCircle[thick](O,A)

                    % --- Draw intersecting chords and boundary segments ---
                    \tkzDrawSegments(A,C B,D A,B C,D)

                    % --- Fill and mark the given and required angles ---
                    \tkzFillAngle[fill=red!20,opacity=.6, size=.6](B,A,C)
                    \tkzFillAngle[fill=blue!20,opacity=.6, size=.6](B,D,C)

                    \tkzMarkAngle[size=.6,color=red](B,A,C)
                    \tkzMarkAngle[size=.6,color=blue](B,D,C)

                    % --- Angle labels ---
                    \tkzLabelAngle[pos=1.1](B,A,C){$39^{\circ}$}
                    \tkzLabelAngle[pos=1.1](B,D,C){$?$}

                    % --- Points and point labels ---
                    \tkzDrawPoints(A,B,C,D,E)
                    \tkzLabelPoints[below right](A)
                    \tkzLabelPoints[above right](B)
                    \tkzLabelPoints[above left](C)
                    \tkzLabelPoints[below left](D)
                    \tkzLabelPoints[above](E)

                    \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
    </statement>
    <solution>
        <p>
            To find the size of the unknown angle, we trace the geometric lines back to their source on the circle's boundary.
        </p>
        <p>
            The given angle <m>\angle BAC = 39^{\circ}</m> has its vertex at <m>A</m>, and its arms open out to touch the endpoints of the minor arc <m>BC</m>.
        </p>
        <p>
            Similarly, the target angle <m>\angle BDC</m> has its vertex at <m>D</m>, and its arms open out to touch the exact same minor arc <m>BC</m>.
        </p>
        <p>
            According to the circle theorem, angles subtended by the same arc at the circumference are equal (angles in the same segment):
            <me>\angle BDC = \angle BAC</me>
            <me>\angle BDC = 39^{\circ}</me>
        </p>
        <p>
            Thus, the measure of  <me>\angle BDC = 39^{\circ}</me>(reason: angles subtended by the same arc at the circumference are equal).
        </p>
    </solution>

        </exercise>

        <exercise>
            <statement>
                <p>
                    An arc <m>AB</m> subtends two angles at the circumference of a circle, <m>\angle APB = x^2 - 10^\circ</m> and <m>\angle AQB = 3x + 18^\circ</m>. Set up a quadratic equation, solve for the positive value of <m>x</m>, and calculate the size of <m>\angle APB</m>.
                </p>
                <figure xml:id="angles-same-segment-quadratic">
    <caption></caption>
    <image width="65%">
        <latex-image>
            <![CDATA[
            \begin{tikzpicture}[scale=1.2]
                % --- Step 1: Define Center and Perimeter Coordinates ---
                \coordinate (O) at (0,0);
                
                % Base arc endpoints fixed on the lower perimeter rim
                \coordinate (A) at (220:2.5);
                \coordinate (B) at (320:2.5);
                
                % Subtended points on the same major arc segment
                \coordinate (P) at (125:2.5);
                \coordinate (Q) at (55:2.5);

                % --- Step 2: Draw the Main Geometry Circle ---
                \draw[thick] (O) circle (2.5);
                
                % --- Step 3: Draw Highlighted Inscribed Angles ---
                % Angle APB subtended at point P
                \begin{scope}
                    \clip (P) -- (A) -- (B) -- cycle;
                    \draw[draw=none, fill=blue!20, opacity=0.6] (P) circle (0.5);
                    \draw[blue, thick] (P) circle (0.5);
                \end{scope}
                \node[blue, below] at ($(P)+(285:0.65)$) {$x^2 - 10^{\circ}$};

                % Angle AQB subtended at point Q
                \begin{scope}
                    \clip (Q) -- (A) -- (B) -- cycle;
                    \draw[draw=none, fill=red!20, opacity=0.6] (Q) circle (0.5);
                    \draw[red, thick] (Q) circle (0.5);
                \end{scope}
                \node[red, below] at ($(Q)+(255:0.65)$) {$3x + 18^{\circ}$};

                % --- Step 4: Draw Structural Inscribed Rays ---
                \draw[thick] (A) -- (P) -- (B);
                \draw[thick] (A) -- (Q) -- (B);

                % --- Step 5: Points and Labels ---
                \foreach \pt/\pos in {A/below left, B/below right, P/above left, Q/above right} {
                    \fill (\pt) circle (2pt);
                    \node[\pos] at (\pt) {$\pt$};
                }
            \end{tikzpicture}
            ]]>
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Since both angles stand on the same arc <m>AB</m> at the circumference, they are equal:
                </p>
                <md>x^2 - 10 = 3x + 18</md>
                <p>
                    Rearrange the terms to form a standard quadratic equation (<m>ax^2 + bx + c = 0</m>):
                </p>
                <md>x^2 - 3x - 10 - 18 = 0</md>
                <md>x^2 - 3x - 28 = 0</md>
                <p>
                    Factor the quadratic expression (find two numbers that multiply to <m>-28</m> and add to <m>-3</m>, which are <m>-7</m> and <m>4</m>):
                </p>
                <md>(x - 7)(x + 4) = 0</md>
                <p>
                    This gives two possible solutions:
                </p>
                <md>x = 7 \quad \text{or} \quad x = -4</md>
                <p>
                    Since we are looking for the positive value of <m>x</m>, we select <m>x = 7</m>.
                </p>
                <p>
                    Calculate the actual angle size:
                </p>
                <md>\angle APB = (7)^2 - 10 = 49 - 10 = 39^\circ</md>
                <p>
                    The positive value of <m>x</m> is <m>7</m>, and the angle size is <m>39^\circ</m>.
                </p>
            </solution>
        </exercise>
    </exercises>

