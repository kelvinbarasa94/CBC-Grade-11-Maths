    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    Examples
    <example>
        <statement>
            <p>
                Find the length of the minor arc <m>ACB</m> in a circle with a radius of <m>10\text{ cm}</m> and a central angle <m>\angle AOB = 60^\circ</m>. Use <m>\pi \approx 3.14</m>.
            </p>
            <figure xml:id="minor-arc-acb-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 60 degree central angle at the bottom
            \tkzDefPointOnCircle[R = center O angle 240 radius \radius]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 300 radius \radius]\tkzGetPoint{B}
            
            % Point along the arc to naturally denote the arc path ACB
            \tkzDefPointOnCircle[R = center O angle 270 radius \radius]\tkzGetPoint{C}

            % Draw the main circle
            \tkzDrawCircle[thick](O,A)

            % --- Radii ---
            \tkzDrawSegments(O,A O,B)

            % --- Fill and mark the central angle ---
            \tkzFillAngle[fill=red!20,opacity=.6, size=.6](A,O,B)
            \tkzMarkAngle[size=.6,color=red](A,O,B)

            % --- Labels ---
            % Central angle label
            \tkzLabelAngle[pos=0.9](A,O,B){$60^{\circ}$}
            
            % Radius label (placed along segment OA)
            \path (O) -- (A) node[midway, left, xshift=-2pt] {$r = 10\text{ cm}$};
            
            % Arc length path notation label near point C
            \tkzLabelPoint[below](C){$C$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B,C)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[right](B)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
        </statement>
        <solution>
            <p>
                First, identify the given variables: radius <m>r = 10\text{ cm}</m> and central angle <m>\theta = 60^\circ</m>.
            </p>
            <p>
                Using the arc length formula:
            </p>
            <md>\text{Arc Length} = \frac{\theta}{360^\circ} \times 2\pi r</md>
            <p>
                Substitute the values into the formula:
            </p>
            <md>\text{Arc Length} = \frac{60}{360} \times 2 \times 3.14 \times 10</md>
            <md>\text{Arc Length} = \frac{1}{6} \times 62.8 \approx 10.47\text{ cm}</md>
            <p>
                Thus, the length of the minor arc <m>ACB</m> is approximately <m>10.47\text{ cm}</m>.
            </p>
           
        </solution>
    </example>

    <example>
        <statement>
            <p>
                The length of a minor arc is <m>15.7\text{ cm}</m>. If the radius of the circle is <m>12\text{ cm}</m>, find the central angle <m>\theta</m> that subtends this arc. Use <m>\pi \approx 3.14</m>.
            </p>
            <figure xml:id="arc-length-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}
            
            % Symmetrical points about the bottom or side to make theta clear
            % Setting an angle of 75 degrees for a clean geometric look
            \tkzDefPointOnCircle[R = center O angle 232.5 radius 3]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 307.5 radius 3]\tkzGetPoint{B}

            % Draw the circle through one of the points
            \tkzDrawCircle[thick](O,A)

            % --- Radii for the central angle ---
            \tkzDrawSegments(O,A O,B)

            % --- Fill and mark the central angle theta ---
            \tkzFillAngle[fill=red!20,opacity=.6, size=.6](A,O,B)
            \tkzMarkAngle[size=.6,color=red](A,O,B)

            % --- Labels ---
            % Central angle label
            \tkzLabelAngle[pos=0.9](A,O,B){$\theta$}
            
            % Radius label (placed along segment OA)
            \path (O) -- (A) node[midway, left, xshift=-2pt] {$r = 12\text{ cm}$};
            
            % Arc length label (placed along the minor arc AB)
            \tkzLabelArc[pos=1.2](O,A,B){$s = 15.7\text{ cm}$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[right](B)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
        </statement>
        <solution>
            <p>
                Identify the variables: Arc Length <m>= 15.7\text{ cm}</m> and radius <m>r = 12\text{ cm}</m>. Rearrange the arc length formula to solve for the central angle <m>\theta</m>:
            </p>
            <md>\theta = \frac{\text{Arc Length} \times 360^\circ}{2\pi r}</md>
            <p>
                Substitute the given values into the rearranged formula:
            </p>
            <md>\theta = \frac{15.7 \times 360}{2 \times 3.14 \times 12}</md>
            <md>\theta = \frac{5652}{75.36} = 75^\circ</md>
            <p>
                The central angle subtended by the arc is <m>75^\circ</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                A pizza has a diameter of <m>40\text{ cm}</m> and is cut into 8 equal slices. Find the area of one slice (sector). Use <m>\pi \approx 3.14</m>.
            </p>
           
        </statement>
        <solution>
            <p>
                First, find the radius from the diameter: <m>r = \frac{40}{2} = 20\text{ cm}</m>. Since the pizza is cut into 8 equal sectors, the central angle <m>\theta</m> for one slice is:
            </p>
            <md>\theta = \frac{360^\circ}{8} = 45^\circ</md>
            <p>
                Now, apply the sector area formula:
            </p>
            <md>\text{Area of Sector} = \frac{\theta}{360^\circ} \times \pi r^2</md>
            <md>\text{Area of Sector} = \frac{45}{360} \times 3.14 \times (20)^2</md>
            <md>\text{Area of Sector} = \frac{1}{8} \times 3.14 \times 400 = 157\text{ cm}^2</md>
            <p>
                The area of one slice of pizza is <m>157\text{ cm}^2</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                Find the area of the minor segment defined by chord <m>AB</m> in a circle with a radius of <m>8\text{ cm}</m>, given that the central angle <m>\angle AOB</m> is <m>90^\circ</m>. Use <m>\pi \approx 3.14</m>.
            </p>
            <figure xml:id="minor-segment-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 90 degree central angle at the bottom
            \tkzDefPointOnCircle[R = center O angle 225 radius \radius]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 315 radius \radius]\tkzGetPoint{B}

            % Draw the main circle
            \tkzDrawCircle[thick](O,A)

            % --- Radii and Chord ---
            \tkzDrawSegments(O,A O,B A,B)

            % --- Fill the Minor Segment ---
            % We fill the sector first, then overlay the triangle with background color 
            % to isolate the segment, or fill the segment directly via path.
            \begin{scope}
                \tkzClipCircle(O,A)
                \path[clip] (A) -- (O) -- (B) -- cycle;
                % Inverse clip or simple fill between arc and chord:
            \end{scope}
            
            % Alternative precise PreTeXt/TikZ fill for segment:
            \fill[red!20, opacity=.6] (A) arc[start angle=225, end angle=315, radius=\radius] -- cycle;
            
            % Redraw lines so they are on top of the fill
            \tkzDrawSegments[thick](O,A O,B A,B)

            % --- Mark Right Angle ---
            \tkzMarkRightAngle[size=0.3,color=red](A,O,B)

            % --- Labels ---
            % Radius labels
            \path (O) -- (A) node[midway, left, xshift=-2pt] {$r = 8\text{ cm}$};
            \path (O) -- (B) node[midway, right, xshift=2pt] {$r = 8\text{ cm}$};
            
            % Central angle label
            \tkzLabelAngle[pos=0.6](A,O,B){$90^{\circ}$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[right](B)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
        </statement>
        <solution>
            <p>
                The area of a segment is calculated by subtracting the area of the central triangle <m>AOB</m> from the area of the sector <m>AOB</m>:
            </p>
            <md>\text{Area of Segment} = \text{Area of Sector} - \text{Area of Triangle}</md>
            <p>
                1. Calculate the Area of Sector <m>AOB</m>:
            </p>
            <md>\text{Area of Sector} = \frac{90}{360} \times 3.14 \times 8^2 = 0.25 \times 3.14 \times 64 = 50.24\text{ cm}^2</md>
            <p>
                2. Calculate the Area of Triangle <m>AOB</m>. Since the central angle is <m>90^\circ</m>, this is a right-angled triangle with base and height equal to the radius (<m>8\text{ cm}</m>):
            </p>
            <md>\text{Area of Triangle} = \frac{1}{2} \times \text{base} \times \text{height} = \frac{1}{2} \times 8 \times 8 = 32\text{ cm}^2</md>
            <p>
                3. Subtract the triangle area from the sector area:
            </p>
            <md>\text{Area of Segment} = 50.24 - 32 = 18.24\text{ cm}^2</md>
            <p>
                The area of the minor segment is <m>18.24\text{ cm}^2</m>.
            </p>
        </solution>
    </example>

    <example>
        <statement>
            <p>
                A chord subtends a central angle of <m>120^\circ</m> in a circle with a radius of <m>6\text{ cm}</m>. Calculate the length of this chord. Use <m>\sin(60^\circ) \approx 0.866</m>.
            </p>
            <figure xml:id="chord-length-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 120 degree central angle at the bottom
            \tkzDefPointOnCircle[R = center O angle 210 radius \radius]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 330 radius \radius]\tkzGetPoint{B}
            
            % Midpoint of the chord for the perpendicular bisector
            \tkzDefMidPoint(A,B)\tkzGetPoint{M}

            % Draw the main circle
            \tkzDrawCircle[thick](O,A)

            % --- Radii, Chord, and Perpendicular Height ---
            \tkzDrawSegments(O,A O,B A,B)
            \tkzDrawSegment[dashed, color=gray](O,M)

            % --- Mark Angles ---
            % Central Angle (120 degrees)
            \tkzMarkAngle[size=0.5,color=red](A,O,B)
            % Right angle at the midpoint
            \tkzMarkRightAngle[size=0.25,color=gray](O,M,B)

            % --- Labels ---
            % Radius labels
            \path (O) -- (A) node[midway, left, xshift=-2pt] {$r = 6\text{ cm}$};
            \path (O) -- (B) node[midway, right, xshift=2pt] {$r = 6\text{ cm}$};
            
            % Central angle label
            \tkzLabelAngle[pos=0.8](A,O,B){$120^{\circ}$}
            
            % Chord halves labels
            \path (A) -- (M) node[midway, below] {$\frac{d}{2}$};
            \path (M) -- (B) node[midway, below] {$\frac{d}{2}$};

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B,M)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[right](B)
            \tkzLabelPoints[below](M)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
        </statement>
        <solution>
            <p>
                We can calculate the chord length directly using the trigonometric chord formula:
            </p>
            <md>\text{Chord Length} = 2r \sin\left(\frac{\theta}{2}\right)</md>
            <p>
                Substitute the given values <m>r = 6\text{ cm}</m> and <m>\theta = 120^\circ</m>:
            </p>
            <md>\text{Chord Length} = 2 \times 6 \times \sin\left(\frac{120^\circ}{2}\right)</md>
            <md>\text{Chord Length} = 12 \times \sin(60^\circ)</md>
            <md>\text{Chord Length} = 12 \times 0.866 = 10.392\text{ cm}</md>
            <p>
                The length of the chord is approximately <m>10.39\text{ cm}</m>.
            </p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <exercises>
        <exercise>
            <statement>
                <p>
                    In a circle with centre <m>O</m> and radius <m>14\text{ cm}</m>, a central angle <m>\angle POQ</m> is <m>40^\circ</m>. Find the length of the minor arc <m>PQ</m>. Use <m>\pi \approx 3.14</m>.
                </p>
                <figure xml:id="minor-arc-length-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 40 degree central angle at the bottom
            \tkzDefPointOnCircle[R = center O angle 250 radius \radius]\tkzGetPoint{P}
            \tkzDefPointOnCircle[R = center O angle 290 radius \radius]\tkzGetPoint{Q}

            % Draw the main circle
            \tkzDrawCircle[thick](O,P)

            % --- Radii ---
            \tkzDrawSegments(O,P O,Q)

            % --- Fill and mark the central angle ---
            \tkzFillAngle[fill=red!20,opacity=.6, size=.7](P,O,Q)
            \tkzMarkAngle[size=.7,color=red](P,O,Q)

            % --- Labels ---
            % Central angle label
            \tkzLabelAngle[pos=1.0](P,O,Q){$40^{\circ}$}
            
            % Radius label (placed along segment OP)
            \path (O) -- (P) node[midway, left, xshift=-2pt] {$r = 14\text{ cm}$};
            
            % Arc length label (the unknown target s)
            \tkzLabelArc[pos=1.2](O,P,Q){$s$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,P,Q)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](P)
            \tkzLabelPoints[right](Q)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Using the arc length formula:
                </p>
                <md>\text{Arc Length} = \frac{\theta}{360^\circ} \times 2\pi r</md>
                <md>\text{Arc Length} = \frac{40}{360} \times 2 \times 3.14 \times 14 = \frac{1}{9} \times 87.92 \approx 9.77\text{ cm}</md>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A sector has a central angle of <m>150^\circ</m> and an area of <m>235.5\text{ cm}^2</m>. What is the radius of the circle? Use <m>\pi \approx 3.14</m>.
                </p>
                <figure xml:id="sector-radius-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 150 degree central angle at the bottom
            \tkzDefPointOnCircle[R = center O angle 195 radius \radius]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 345 radius \radius]\tkzGetPoint{B}

            % Draw the main circle
            \tkzDrawCircle[thick](O,A)

            % --- Radii ---
            \tkzDrawSegments(O,A O,B)

            % --- Fill and mark the central angle ---
            \tkzFillAngle[fill=red!20,opacity=.6, size=.6](A,O,B)
            \tkzMarkAngle[size=.6,color=red](A,O,B)

            % --- Labels ---
            % Central angle label
            \tkzLabelAngle[pos=0.9](A,O,B){$150^{\circ}$}
            
            % Radius label (the unknown target r)
            \path (O) -- (A) node[midway, left, xshift=-2pt] {$r$};
            
            % Sector Area label inside the sector region
            \path (O) -- (0,-1.2) node {$A = 235.5\text{ cm}^2$};

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[right](B)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Using the sector area formula, solve for <m>r^2</m>:
                </p>
                <md>\text{Area} = \frac{\theta}{360^\circ} \times \pi r^2 \implies r^2 = \frac{\text{Area} \times 360^\circ}{\theta \times \pi}</md>
                <md>r^2 = \frac{235.5 \times 360}{150 \times 3.14} = \frac{84780}{471} = 180</md>
                <md>r = \sqrt{180} \approx 13.42\text{ cm}</md>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Calculate the area of the major sector defined by a central angle of <m>70^\circ</m> in a circle with a radius of <m>5\text{ cm}</m>. Use <m>\pi \approx 3.14</m>.
                </p>
                <figure xml:id="major-sector-area-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 70 degree central angle at the bottom
            \tkzDefPointOnCircle[R = center O angle 235 radius \radius]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 305 radius \radius]\tkzGetPoint{B}

            % Draw the main circle
            \tkzDrawCircle[thick](O,A)

            % --- Radii ---
            \tkzDrawSegments(O,A O,B)

            % --- Fill and mark the MAJOR central angle ---
            % Since 360 - 70 = 290, we fill the outer/upper part
            \tkzFillAngle[fill=red!20,opacity=.6, size=.6](B,O,A)
            \tkzMarkAngle[size=.6,color=red](B,O,A)

            % --- Labels ---
            % Major central angle label (360 - 70 = 290)
            \tkzLabelAngle[pos=0.9](B,O,A){$290^{\circ}$}
            
            % Minor angle indicator for context
            \tkzLabelAngle[pos=-0.7](B,O,A){$70^{\circ}$}
            
            % Radius label (placed along segment OA)
            \path (O) -- (A) node[midway, left, xshift=-2pt] {$r = 5\text{ cm}$};

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[right](B)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    The central angle for the major sector is:
                </p>
                <md>\theta_{\text{major}} = 360^\circ - 70^\circ = 290^\circ</md>
                <p>
                    Using the sector area formula:
                </p>
                <md>\text{Area} = \frac{290}{360} \times 3.14 \times 5^2 \approx 0.8056 \times 78.5 \approx 63.24\text{ cm}^2</md>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Find the area of the minor segment formed by chord <m>RS</m> in a circle with radius <m>12\text{ cm}</m>, given that the central angle <m>\angle ROS</m> is <m>60^\circ</m>. Use <m>\pi \approx 3.14</m> and <m>\sqrt{3} \approx 1.732</m>.
                </p>
                <figure xml:id="minor-segment-60deg-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 60 degree central angle at the bottom
            \tkzDefPointOnCircle[R = center O angle 240 radius \radius]\tkzGetPoint{R}
            \tkzDefPointOnCircle[R = center O angle 300 radius \radius]\tkzGetPoint{S}

            % Draw the main circle
            \tkzDrawCircle[thick](O,R)

            % --- Radii and Chord ---
            \tkzDrawSegments(O,R O,S R,S)

            % --- Fill the Minor Segment ---
            \fill[red!20, opacity=.6] (R) arc[start angle=240, end angle=300, radius=\radius] -- cycle;
            
            % Redraw lines so they sit on top of the fill
            \tkzDrawSegments[thick](O,R O,S R,S)

            % --- Mark Central Angle ---
            \tkzMarkAngle[size=0.6,color=red](R,O,S)

            % --- Labels ---
            % Radius labels
            \path (O) -- (R) node[midway, left, xshift=-2pt] {$r = 12\text{ cm}$};
            \path (O) -- (S) node[midway, right, xshift=2pt] {$r = 12\text{ cm}$};
            
            % Central angle label
            \tkzLabelAngle[pos=0.9](R,O,S){$60^{\circ}$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,R,S)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](R)
            \tkzLabelPoints[right](S)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    1. Calculate the Sector Area:
                </p>
                <md>\text{Area of Sector} = \frac{60}{360} \times 3.14 \times 12^2 = \frac{1}{6} \times 3.14 \times 144 = 75.36\text{ cm}^2</md>
                <p>
                    2. Calculate the Area of Triangle <m>ROS</m>. Since the central angle is <m>60^\circ</m> and the two sides are radii, <m>\triangle ROS</m> is an equilateral triangle with side length <m>s = 12\text{ cm}</m>:
                </p>
                <md>\text{Area of Triangle} = \frac{\sqrt{3}}{4}s^2 = \frac{1.732}{4} \times 12^2 = 0.433 \times 144 = 62.352\text{ cm}^2</md>
                <p>
                    3. Calculate Segment Area:
                </p>
                <md>\text{Area of Segment} = 75.36 - 62.352 = 13.008\text{ cm}^2 \approx 13.01\text{ cm}^2</md>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A circle has a radius of <m>9\text{ cm}</m>. A sector formed by radii <m>OT</m> and <m>OU</m> has an area of <m>63.585\text{ cm}^2</m>. Calculate the measure of the central angle <m>\angle TOU</m> in degrees. Use <m>\pi \approx 3.14</m>.
                </p>
                <figure xml:id="sector-central-angle-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Symmetrical points for a 90 degree central angle layout (for visual clarity)
            \tkzDefPointOnCircle[R = center O angle 225 radius \radius]\tkzGetPoint{T}
            \tkzDefPointOnCircle[R = center O angle 315 radius \radius]\tkzGetPoint{U}

            % Draw the main circle
            \tkzDrawCircle[thick](O,T)

            % --- Radii ---
            \tkzDrawSegments(O,T O,U)

            % --- Fill and mark the central angle ---
            \tkzFillAngle[fill=red!20,opacity=.6, size=.6](T,O,U)
            \tkzMarkAngle[size=.6,color=red](T,O,U)

            % --- Labels ---
            % Central angle label (the unknown target angle theta)
            \tkzLabelAngle[pos=0.9](T,O,U){$\theta$}
            
            % Radius label (placed along segment OT)
            \path (O) -- (T) node[midway, left, xshift=-2pt] {$r = 9\text{ cm}$};
            
            % Sector Area label inside the sector region
            \path (O) -- (0,-1.1) node {$\text{Area} = 63.585\text{ cm}^2$};

            % --- Points and point labels ---
            \tkzDrawPoints(O,T,U)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](T)
            \tkzLabelPoints[right](U)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Using the sector area formula, solve for <m>\theta</m>:
                </p>
                <md>\text{Area} = \frac{\theta}{360^\circ} \times \pi r^2 \implies \theta = \frac{\text{Area} \times 360^\circ}{\pi r^2}</md>
                <md>\theta = \frac{63.585 \times 360}{3.14 \times 9^2} = \frac{22890.6}{3.14 \times 81} = \frac{22890.6}{254.34} = 90^\circ</md>
                <p>
                    The measure of the central angle <m>\angle TOU</m> is <m>90^\circ</m>.
                </p>
            </solution>
        </exercise>
    </exercises>

