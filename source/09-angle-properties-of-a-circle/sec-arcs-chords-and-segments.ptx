    <!-- Examples with worked solutions -->
    <example>
        <statement>
            <p>In a circle with centre O, chord AB subtends a central angle of 60° at O. Identify the minor arc AB, the major arc ACB, and the segment bounded by AB and the minor arc.</p>
        </statement>
        <solution>
            <p>The line AB is the chord joining points A and B on the circle. The shorter curved path from A to B is the minor arc AB and its measure is 60°. The longer curved path around the circle is the major arc ACB and its measure is 300° (because 360° - 60° = 300°). The segment is the region inside the circle bounded by chord AB and the minor arc AB.</p>
            <figure>
                <caption>Diagram for the first example showing chord AB and arcs AB and ACB.</caption>
                <image>
                    <shortdescription>A circle with chord AB and labelled minor and major arcs.</shortdescription>
                    <latex-image>
                        \begin{tikzpicture}[scale=0.9]
                            \draw[thick] (0,0) circle (2.5);
                            \coordinate (O) at (0,0);
                            \coordinate (A) at (160:2.5);
                            \coordinate (B) at (30:2.5);
                            \draw[thick] (A) -- (B);
                            \draw[blue, very thick] (A) arc (160:30:2.5);
                            \draw[blue, dashed, very thick] (A) arc (160:-330:2.5);
                            \node[above left] at (A) {A};
                            \node[above right] at (B) {B};
                            \node[below] at (O) {O};
                            \node[below left] at (-1.2,-0.5) {AB};
                            \node[above] at (0,2.6) {minor arc AB};
                            \node[below right] at (1.2,-0.8) {major arc ACB};
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
        </solution>
    </example>

    <example>
        <statement>
            <p>A circle has radius 7 cm. Find the length of a minor arc that subtends a central angle of 90°.</p>
        </statement>
        <solution>
            <p>Arc length = circumference × angle/360°. The circumference is 2π × 7 = 14π cm. The arc length is 14π × 90/360 = 14π × 1/4 = 3.5π cm.</p>
        </solution>
    </example>

    <example>
        <statement>
            <p>If a chord XY divides a circle into two regions, explain how to tell which region is the minor segment and which is the major segment.</p>
        </statement>
        <solution>
            <p>The minor segment is bounded by the chord XY and the smaller arc XY. The major segment is bounded by the same chord XY and the larger arc of the circle. The minor segment corresponds to the smaller central angle and the major segment to the larger central angle.</p>
        </solution>
    </example>

    <example>
        <statement>
            <p>In a circle, minor arc PQ measures 120°. What is the measure of the corresponding major arc PQ? Name the chord and segment associated with these arcs.</p>
        </statement>
        <solution>
            <p>The major arc measure is 360° - 120° = 240°. The chord joining P and Q is chord PQ. The segment bounded by chord PQ and the minor arc PQ is the minor segment; the segment bounded by chord PQ and the major arc PQ is the major segment.</p>
        </solution>
    </example>

    <example>
        <statement>
            <p>A circle has circumference 40 cm. A chord determines an arc that measures 72°. Find the length of that arc.</p>
        </statement>
        <solution>
            <p>The arc length is 40 × 72/360 = 40 × 0.2 = 8 cm. The arc is a curved part of the circle, and the chord is the straight line connecting the two endpoints of the arc.</p>
        </solution>
    </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- Exercises with answers provided -->
    <exercises>
        <exercise>
            <statement>
                <p>In a circle with centre O and radius 10 cm, a central angle AOB is 45°. Find the length of minor arc AB.</p>
            </statement>
            <solution>
                <p>Circumference = 2π × 10 = 20π cm. Arc length = 20π × 45/360 = 20π × 1/8 = 2.5π cm.</p>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>Describe the chord, arc, and segment in a circle when two points A and B are joined by a line and the curved path between A and B is recorded.</p>
            </statement>
            <solution>
                <p>The line AB is the chord. The curved path from A to B along the circle is the arc AB. The region between chord AB and the shorter arc AB is the minor segment.</p>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>A minor arc measures 80°. What is the measure of the corresponding major arc?</p>
            </statement>
            <solution>
                <p>Major arc measure = 360° - 80° = 280°.</p>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>A chord CD subtends a central angle of 120°. State the measure of minor arc CD, and say whether the segment bounded by CD and this arc is the minor or major segment.</p>
            </statement>
            <solution>
                <p>The minor arc CD measures 120°. The segment bounded by chord CD and the minor arc CD is the minor segment.</p>
            </solution>
        </exercise>
        <exercise>
            <statement>
                <p>A circle has radius 5 cm. An arc has length 5π cm. Find the measure of the arc in degrees.</p>
            </statement>
            <solution>
                <p>Arc length = radius × angle in radians. Here angle = 5π / 5 = π radians, which equals 180°.</p>
            </solution>
        </exercise>
    </exercises>

