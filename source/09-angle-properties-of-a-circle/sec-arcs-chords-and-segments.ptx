<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-arcs-chords-and-segments" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Arcs, Chords, and Segments</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.2 Angle Properties of a Circle
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Identify an arc, chord, and segment in a circle
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Learners identify and describe arcs, chords, and segments in circles, and distinguish between minor and major arcs.
                </p>
            </li>
            <!-- <li>
                <title>Materials Needed</title>
                <p>
                    Paper, compass, ruler, protractor, and a set of coloured pencils or markers.
                </p>
            </li> -->
            <li>
                <title>Teacher's Role</title>
                <p>
                    Guide learners through diagrams and ask questions that focus on identifying parts of a circle and comparing curved and straight boundaries.
                </p>
            </li>
        </dl>
    </axiom>

    <activity>
        <statement>
            <li>
                <title>Materials Needed</title>
                <p>
                    Paper, compass, ruler, protractor, and a set of coloured pencils or markers.
                </p>
            </li>
            <p><strong>Part A: Draw and Identify</strong></p>
            <p>
                Learners work in groups to study or draw a circle with centre <m>O</m> and points <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m> on the circumference. In each group, identify and label the following on your diagram:
            </p>
            <ol>
                <li><p><strong>The chord AB</strong>: Draw a straight line connecting points <m>A</m> and <m>B</m>.</p></li>
                <li><p><strong>The minor arc ACB</strong>: Trace the shortest curved path along the edge from <m>A</m> to <m>B</m> passing through <m>C</m>.</p></li>
                <li><p><strong>The major arc ADB</strong>: Trace the longer curved path along the edge from <m>A</m> to <m>B</m> passing through <m>D</m>.</p></li>
                <li><p><strong>The segment defined by chord CD</strong>: Shade the region enclosed between the straight line chord <m>CD</m> and the boundary arc <m>CD</m>.</p></li>
                <li><p><strong>The sector formed by radii OC and OD</strong>: Shade the region enclosed by the center <m>O</m> and the radii <m>OC</m> and <m>OD</m> (resembling a pizza slice).</p></li>
            </ol>
            <image xml:id="img-circle-geometry-parts">
    <description>A circle with center O showing chord AB, minor arc ACB, major arc ADB, segment CD, and sector OCD.</description>
    <latex-image>
        \begin{tikzpicture}[scale=1.5, >=stealth]
            % Define the circle radius and center
            \def\R{2.5}
            \coordinate (O) at (0,0);
            
            % Define coordinates on the circumference using angles
            \coordinate (A) at (140:\R);
            \coordinate (B) at (40:\R);
            \coordinate (C) at (90:\R);
            \coordinate (D) at (280:\R);
            
            % Shading the Sector OCD (Pizza slice)
            \fill[orange!20] (O) -- (C) arc (90:280:\R) -- cycle;
            
            % Shading the Segment CD (Region between chord CD and arc CD)
            \fill[blue!20] (C) arc (90:-80:\R) -- cycle;

            % Draw the main circle
            \draw[thick] (O) circle (\R);
            
            % Draw radii for the sector
            \draw[dashed, thick, orange!80!black] (O) -- (C);
            \draw[dashed, thick, orange!80!black] (O) -- (D);
            
            % Draw Chord AB
            \draw[thick, red] (A) -- (B);
            
            % Draw Chord CD (to bound the segment)
            \draw[thick, blue] (C) -- (D);
            
            % Highlight Minor Arc ACB (Thicker red arc)
            \draw[ultra thick, red] (40:\R) arc (40:140:\R);
            
            % Plot and label points
            \fill (O) circle (1.5pt) node[below left] {$O$};
            \fill (A) circle (1.5pt) node[above left] {$A$};
            \fill (B) circle (1.5pt) node[above right] {$B$};
            \fill (C) circle (1.5pt) node[above] {$C$};
            \fill (D) circle (1.5pt) node[below] {$D$};
            
            % Explanatory Text labels for regions
            \node[orange!80!black] at (185:1.2) {Sector};
            \node[blue!80!black] at (5:1.8) {Segment};
            \node[red] at (90:\R+0.3) {Minor Arc $ACB$};
            \node[gray] at (210:\R+0.3) {Major Arc $ADB$};
        \end{tikzpicture}
    </latex-image>
</image>
            <p><term>Part B: Hands-On Measurements</term></p>
            <p>
            <ul>
                <li><p><alert>The Chord Length:</alert> Use a ruler to measure the straight line <m>AB</m> in centimeters. Note how it compares to the diameter (a chord can never be longer than the diameter).</p></li>
                <li><p><alert>The Sector Angle (<m>\theta</m>):</alert> Use a protractor to measure the central angle <m>\angle COD</m> at the center.</p></li>
                <li><p><alert>The Arc Fraction:</alert> Divide your measured angle by <m>360^\circ</m> to find what fraction of the circle your sector represents: <m>\text{Fraction} = \frac{\theta}{360^\circ}</m>.</p></li>
            </ul>
             </p>
        </statement>
        <figure>
            <caption>Circle diagram showing chord AB, minor arc ACB, major arc ADB, segment CD, and sector COD.</caption>
            <image>
                <shortdescription>A circle with labeled points A, B, C, D, and O showing the chords, arcs, sector, and segment shading.</shortdescription>
                <latex-image>
                    \begin{tikzpicture}[scale=1.2]
                        % Draw circle and center
                        \draw[thick] (0,0) circle (2.5);
                        \coordinate (O) at (0,0);
                        
                        % Define angles for points
                        \coordinate (A) at (160:2.5);
                        \coordinate (B) at (20:2.5);
                        \coordinate (C) at (-40:2.5);
                        \coordinate (D) at (120:2.5);
                        
                        % 1. Shade Segment CD (between chord CD and arc CD)
                        \fill[gray!20] (D) -- (C) arc (-40:120:2.5) -- cycle;
                        
                        % 2. Shade Sector COD (light blue tint)
                        \fill[blue!10] (O) -- (C) arc (-40:120:2.5) -- cycle;
                        
                        % Redraw lines so they sit on top of shading
                        \draw[thick] (0,0) circle (2.5);
                        \draw[thick, black] (A) -- (B); % Chord AB
                        \draw[thick, dashed, black] (C) -- (D); % Chord CD
                        
                        \draw[red, thick] (O) -- (C); % Radius OC
                        \draw[red, thick] (O) -- (D); % Radius OD
                        
                        % Labels
                        \node[above left] at (A) {A};
                        \node[above right] at (B) {B};
                        \node[below right] at (C) {C};
                        \node[above left] at (D) {D};
                        \node[below] at (O) {O};
                        
                        \node[below right] at (1.1,-0.3) {ACB (Minor Arc)};
                        \node[left] at (-1.7,0.3) {ADB (Major Arc)};
                    \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
    </activity>

    <insight>
        <p>
            Understanding arcs, chords, and segments strengthens learners' ability to read circle diagrams and prepares them for reasoning about angles, lengths, and areas using the following calculation steps:
        </p>
        <ul>
            <li>
                <p><strong>Arc Length:</strong> An arc is a curved portion of the circumference. To work out its length, multiply the total circumference by the fraction of the circle's central angle <m>\theta</m>:</p>
                <md>\text{Arc Length} = \frac{\theta}{360^\circ} \times 2\pi r</md>
            </li>
            <li>
                <p><strong>Sector Area:</strong> A sector is a region bounded by two radii and an arc. To work out its area, multiply the total area of the circle by the fraction of the central angle:</p>
                <md>\text{Area of Sector} = \frac{\theta}{360^\circ} \times \pi r^2</md>
            </li>
            <li>
                <p><strong>Chord Length:</strong> A chord is a straight line joining two points on the circle. If the radius <m>r</m> and the central angle <m>\theta</m> are known, the chord length can be calculated using trigonometry:</p>
                <md>\text{Chord Length} = 2r \sin\left(\frac{\theta}{2}\right)</md>
            </li>
            <li>
                <p><strong>Segment Area:</strong> A segment is the region between a chord and its associated arc. To work out its area, subtract the area of the central triangle formed by the radii and the chord from the total sector area:</p>
                <md>\text{Area of Segment} = \text{Area of Sector} - \text{Area of Triangle}</md>
                <md>\text{Area of Segment} = \left(\frac{\theta}{360^\circ} \times \pi r^2\right) - \left(\frac{1}{2}r^2 \sin\theta\right)</md>
            </li>
        </ul>
        <figure xml:id="geometry-of-a-sector">
    <caption>Components of a circle: Sector, segment, arc, chord, and radius.</caption>
    <image width="65%">
        <shortdescription>A circle diagram clearly labeling the sector area, segment area, bounding radii, arc length, and chord line.</shortdescription>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points forming the sector ---
            \tkzDefPoint(0,0){O}
            
            % Define boundary points on the circumference
            \tkzDefPointOnCircle[R = center O angle 40 radius 3.5]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 140 radius 3.5]\tkzGetPoint{B}

            % Draw the baseline circle
            \tkzDrawCircle[thick](O,A)

            % --- Shading the geometric regions ---
            % Light green for the inner triangular sector area
            \tkzFillPolygon[fill=green!15,opacity=0.6](O,A,B)
            % Light teal for the outer minor segment area
            \tkzFillSector[fill=teal!20,opacity=0.6](O,A)(B)

            % --- Boundaries and lines ---
            \tkzDrawSegments[thick](O,A O,B) % Radii
            \tkzDrawSegment[thick, color=blue, dashed](A,B) % Chord

            % --- Central Angle Theta ---
            \tkzFillAngle[fill=red!20,opacity=0.7, size=0.6](A,O,B)
            \tkzMarkAngle[size=0.6,color=red](A,O,B)
            \tkzLabelAngle[pos=0.9](A,O,B){$\theta$}

            % --- Feature Labels ---
            % Labeling lines (Radii and Chord)
            \tkzLabelSegment[pos=0.5, right](O,A){Radius ($r$)}
            \tkzLabelSegment[pos=0.5, left](O,B){Radius ($r$)}
            \tkzLabelSegment[pos=0.5, above, color=blue!80!black](A,B){Chord}
            
            % Labeling the curved arc line along the top circumference
            \node[color=black] at (0,3.8) {Arc Length};

            % Shaded region descriptive labels
            \node[text=teal!90!black, font=\bfseries] at (0,2.6) {Segment};
            \node[text=green!50!black, font=\bfseries] at (0,1.2) {Sector};

            % --- Draw points and labels ---
            \tkzDrawPoints(O,A,B)
            \tkzLabelPoints[below](O)
            \tkzLabelPoints[right](A)
            \tkzLabelPoints[left](B)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
    </insight>

