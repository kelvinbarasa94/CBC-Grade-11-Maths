<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-angles-subtended-by-the-diameter" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Angles Subtended by the Diameter</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.2 Angle Properties of a Circle
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Determine angles subtended by a chord and a diameter at the circumference
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->
   <axiom component="lesson-plan">
    <title>Problem-Solving and Discovery</title>
    <dl>
        <li>
            <title>Suggested Time</title>
            <p>15 minutes</p>
        </li>
        <li>
            <title>Objective</title>
            <p>
                To allow learners to intuitively discover that any angle subtended by a diameter at the circumference is a right angle of ninety degrees.
            </p>
        </li>
        <li>
            <title>Teacher's Role</title>
            <p>
                Facilitate the group formation, distribute the necessary physical toolkits, and clear up any initial confusion regarding terminology (such as distinguishing a chord from a diameter). Circulate around the room to prompt discoveries without giving away the final theorem.
            </p>
        </li>
    </dl>
</axiom>

<activity>
    <statement>
        <paragraphs>
            <title>Learner Experience Sequence</title>
            <p>
                <ul>
                    <li>
                        <p>
                            <alert>Group Work Formulation:</alert> Work in small collaborative groups of three to four learners to promote peer discussion, shared measuring responsibilities, and collective data verification.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Materials Needed:</alert>
                            <ul>
                                <li>Blank sheet of paper</li>
                                <li>Geometry compass</li>
                                <li>Straightedge ruler</li>
                                <li>Protractor</li>
                                <li>Colored pens or highlighters</li>
                            </ul>
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Step-by-Step Activity Instruction:</alert>
                            <ul>
                                <li>Using your compass, draw a large, clear circle on your paper and mark its exact center point as O.</li>
                                <li>Use your straightedge to draw a straight line passing directly through the center O from one side of the circle to the other. Label this diameter line segment as AB.</li>
                                <li>Choose any random point C on the circumference of the circle, making sure it does not overlap with points A or B.</li>
                                <li>Draw two straight lines to connect point A to point C, and point B to point C, creating an inscribed angle labeled angle ACB.</li>
                                <li>Carefully measure the exact size of angle ACB using your protractor and record it.</li>
                                <li>Repeat this process by selecting two more random points along the edge of the circle (such as point D and point E). Draw their respective lines back to the diameter endpoints and measure angle ADB and angle AEB. Compare your group results and identify the constant property observed across all trials.</li>
                            </ul>
                        </p>
                    </li>
                </ul>
            </p>
        </paragraphs>
    </statement>
</activity>

