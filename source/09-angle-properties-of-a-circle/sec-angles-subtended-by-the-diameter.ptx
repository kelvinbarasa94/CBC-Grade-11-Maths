    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
    <exercise>
        <statement>
            <p>
                In a circle with center <m>O</m>, <m>AB</m> is a diameter and <m>C</m> is a point on the circumference. If <m>\triangle ABC</m> is an isosceles triangle where <m>AC = BC</m>, determine the measure of <m>\angle CAB</m>.
            </p>
            <figure xml:id="fig-circle-isosceles-semicircle">
    <caption>A circle with center <m>O</m> and diameter <m>AB</m>, containing an isosceles triangle <m>\Delta ABC</m> where <m>AC = BC</m>.</caption>
    <image width="65%">
        <description>A circle with center O and horizontal diameter AB. A point C sits at the top peak of the circle, forming a right-angled isosceles triangle ACB with identical marks on sides AC and BC.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}

            % Since AB is the diameter, we place A on the left (-180 deg) and B on the right (0 deg).
            \tkzDefPointOnCircle[R = center O angle 180 radius 3]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 0 radius 3]\tkzGetPoint{B}

            % Point C is on the circumference. Since ABC is a right-angled isosceles triangle,
            % the central angle COB is exactly 2 * 45 = 90 degrees.
            \tkzDefPointOnCircle[R = center O angle 90 radius 3]\tkzGetPoint{C}

            % Draw the circle
            \tkzDrawCircle[thick](O,B)

            % --- Draw diameter and triangle sides ---
            \tkzDrawSegments(A,B A,C B,C)

            % --- Mark equal sides (AC = BC) ---
            \tkzMarkSegments[mark=||,size=4pt,color=gray](A,C B,C)

            % --- Fill and mark the given and unknown angles ---
            \tkzFillAngle[fill=blue!20,opacity=.6, size=.8](B,A,C)
            
            % Thales's theorem angle (angle in a semicircle is 90 degrees)
            \tkzMarkRightAngle[size=.3,color=black](A,C,B)

            \tkzMarkAngle[size=.8,color=blue](B,A,C)

            % --- Angle labels ---
            \tkzLabelAngle[pos=1.2](B,A,C){$?$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B,C)
            \tkzLabelPoints[below](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[right](B)
            \tkzLabelPoints[above](C)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
        </statement>
        <solution>
            <p>
                1. Since <m>AB</m> is a diameter, <m>\angle ACB = 90^\circ</m>.
            </p>
            <p>
                2. In an isosceles triangle, angles opposite equal sides are equal. Since <m>AC = BC</m>, we know that <m>\angle CAB = \angle CBA</m>.
            </p>
            <p>
                3. Let <m>\angle CAB = y</m>. Then:
                <me>y + y + 90^\circ = 180^\circ</me>
                <me>2y = 90^\circ \implies y = 45^\circ</me>
                Therefore, <m>\angle CAB = 45^\circ</m>.
            </p>
        </solution>
    </exercise>

    <exercise>
        <statement>
            <p>
                A circle has a diameter <m>MN</m> of length <m>26\text{ mm}</m>. A point <m>K</m> is on the circumference such that the chord <m>MK</m> has a length of <m>10\text{ mm}</m>. Find the length of chord <m>NK</m>.
            </p>
            <figure xml:id="fig-circle-diameter-chord-calc">
    <caption>A circle with diameter <m>MN = 26\text{ mm}</m> and chord <m>MK = 10\text{ mm}</m>.</caption>
    <image width="65%">
        <description>A circle with center O and horizontal diameter MN. A point K on the circumference forms a right-angled triangle MKN, with chord MK labeled 10 mm and diameter MN labeled 26 mm.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}

            % Since MN is the diameter, we place M on the left (-180 deg) and N on the right (0 deg).
            \tkzDefPointOnCircle[R = center O angle 180 radius 3]\tkzGetPoint{M}
            \tkzDefPointOnCircle[R = center O angle 0 radius 3]\tkzGetPoint{N}

            % Point K is on the circumference. Based on the 10-24-26 right triangle,
            % the central angle KON is exactly 134.76 degrees.
            \tkzDefPointOnCircle[R = center O angle 134.76 radius 3]\tkzGetPoint{K}

            % Draw the circle
            \tkzDrawCircle[thick](O,N)

            % --- Draw diameter and chords ---
            \tkzDrawSegments(M,N M,K N,K)

            % --- Mark the right angle at K (angle in a semicircle) ---
            \tkzMarkRightAngle[size=.3,color=black](M,K,N)

            % --- Segment labels ---
            \tkzLabelSegment[above left,pos=0.5](M,K){$10\text{ mm}$}
            \tkzLabelSegment[above right,pos=0.5](N,K){$?$}
            \tkzLabelSegment[below,pos=0.5](M,N){$26\text{ mm}$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,M,N,K)
            \tkzLabelPoints[below](O)
            \tkzLabelPoints[left](M)
            \tkzLabelPoints[right](N)
            \tkzLabelPoints[above](K)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
        </statement>
        <solution>
            <p>
                1. <m>MN</m> is the diameter, meaning <m>\angle MKN = 90^\circ</m>. <m>\triangle MKN</m> is a right-angled triangle where <m>MN</m> is the hypotenuse.
            </p>
            <p>
                2. Apply the Pythagorean theorem:
                <me>MN^2 = MK^2 + NK^2</me>
                <me>26^2 = 10^2 + NK^2</me>
                <me>676 = 100 + NK^2</me>
            </p>
            <p>
                3. Isolate <m>NK^2</m>:
                <me>NK^2 = 576</me>
                <me>NK = \sqrt{576} = 24\text{ mm}</me>
            </p>
        </solution>
    </exercise>
    <exercise>
            <statement>
                <p>
                    An engineer is inspecting a circular water tank. A straight walkway bridge spanning across the middle forms its diameter, labeled <m>AB</m>. An emergency control valve is positioned at point <m>P</m> on the perimeter wall. If <m>\angle PAB = 28^\circ</m>, calculate the measure of <m>\angle PBA</m>.
                </p>
                <figure xml:id="fig-circle-water-tank">
    <caption>A circular water tank with diameter walkway <m>AB</m> and a control valve at <m>P</m>, where <m>\angle PAB = 28^{\circ}</m>.</caption>
    <image width="65%">
        <description>A circle representing a water tank with center O and diameter AB. A point P on the perimeter wall forms a right-angled triangle APB with a shaded angle of 28 degrees at vertex A.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}

            % Since AB is the diameter, we place A on the left (-180 deg) and B on the right (0 deg).
            \tkzDefPointOnCircle[R = center O angle 180 radius 3]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 0 radius 3]\tkzGetPoint{B}

            % Point P is on the circumference. Given angle PAB = 28 degrees,
            % the central angle POB will be 2 * 28 = 56 degrees.
            \tkzDefPointOnCircle[R = center O angle 56 radius 3]\tkzGetPoint{P}

            % Draw the circle boundary
            \tkzDrawCircle[thick, color=teal](O,B)

            % --- Draw diameter walkway and paths to the valve ---
            \tkzDrawSegments[thick, color=purple](A,B)
            \tkzDrawSegments[thick, color=darkgray](A,P B,P)

            % --- Fill and mark the given and unknown angles ---
            \tkzFillAngle[fill=cyan!30,opacity=.7, size=.8](B,A,P)
            \tkzFillAngle[fill=magenta!20,opacity=.7, size=.7](P,B,A)
            
            % Thales's theorem angle (angle in a semicircle is 90 degrees at the valve)
            \tkzMarkRightAngle[size=.3,color=red,thick](A,P,B)

            \tkzMarkAngle[size=.8,color=cyan!80!black,thick](B,A,P)
            \tkzMarkAngle[size=.7,color=magenta!80!black,thick](P,B,A)

            % --- Angle labels ---
            \tkzLabelAngle[pos=1.3](B,A,P){$28^{\circ}$}
            \tkzLabelAngle[pos=1.1](P,B,A){$?$}

            % --- Points and point labels ---
            \tkzDrawPoints[size=5,fill=black](O,A,B,P)
            \tkzLabelPoints[below,color=purple](O)
            \tkzLabelPoints[left,color=purple](A)
            \tkzLabelPoints[right,color=purple](B)
            \tkzLabelPoints[above,color=darkgray](P)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Since the walkway bridge <m>AB</m> is the diameter of the circular tank, the angle subtended at the perimeter wall point <m>P</m> must be a right angle. Therefore, <m>\angle APB = 90^\circ</m>.
                </p>
                <p>
                    Set up the interior angle sum equation for the triangle <m>\triangle ABP</m>:
                    <me>\angle PAB + \angle APB + \angle PBA = 180^\circ</me>
                    <me>28^\circ + 90^\circ + \angle PBA = 180^\circ</me>
                </p>
                <p>
                    Solve for the remaining angle <m>\angle PBA</m>:
                    <me>\angle PBA = 180^\circ - 118^\circ = 62^\circ</me>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A landscape architect designs a circular courtyard garden. A pathway runs straight through the center from gate <m>X</m> to gate <m>Y</m>, acting as the diameter. A fountain is placed at point <m>Z</m> on the outer wall. If <m>\angle XZY = 4x + 10^\circ</m>, find the value of <m>x</m>.
            </p>
            <figure xml:id="fig-circle-courtyard-garden">
    <caption>A circular courtyard garden with diameter pathway <m>XY</m> and a fountain at <m>Z</m>, where <m>\angle XZY = 4x + 10^{\circ}</m>.</caption>
    <image width="65%">
        <description>A circle representing a courtyard garden with center O and diameter XY. A point Z on the outer wall forms a right-angled triangle XZY with a right angle marker at vertex Z labeled 4x + 10 degrees.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}

            % Since XY is the diameter, we place X on the left (-180 deg) and Y on the right (0 deg).
            \tkzDefPointOnCircle[R = center O angle 180 radius 3]\tkzGetPoint{X}
            \tkzDefPointOnCircle[R = center O angle 0 radius 3]\tkzGetPoint{Y}

            % Point Z is placed on the outer wall circumference
            \tkzDefPointOnCircle[R = center O angle 100 radius 3]\tkzGetPoint{Z}

            % Draw the courtyard circular boundary
            \tkzDrawCircle[thick, color=teal](O,Y)

            % --- Draw diameter pathway and paths to the fountain ---
            \tkzDrawSegments[thick, color=purple](X,Y)
            \tkzDrawSegments[thick, color=darkgray](X,Z Y,Z)

            % --- Fill and mark the angle at the fountain ---
            \tkzFillAngle[fill=orange!20,opacity=.7, size=.6](X,Z,Y)
            
            % Thales's theorem angle (angle in a semicircle is 90 degrees at the fountain Z)
            \tkzMarkRightAngle[size=.3,color=red,thick](X,Z,Y)
            \tkzMarkAngle[size=.6,color=orange!80!black,thick](X,Z,Y)

            % --- Angle label ---
            \tkzLabelAngle[pos=1.2](X,Z,Y){$4x + 10^{\circ}$}

            % --- Points and point labels ---
            \tkzDrawPoints[size=5,fill=black](O,X,Y,Z)
            \tkzLabelPoints[below,color=purple](O)
            \tkzLabelPoints[left,color=purple](X)
            \tkzLabelPoints[right,color=purple](Y)
            \tkzLabelPoints[above,color=darkgray](Z)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Because pathway <m>XY</m> is the diameter of the circular courtyard, the angle subtended at the outer wall fountain <m>Z</m> must equal exactly <m>90^\circ</m>.
                    <me>\angle XZY = 90^\circ</me>
                </p>
                <p>
                    Set up the algebraic equation using the given angle expression:
                    <me>4x + 10^\circ = 90^\circ</me>
                    <me>4x = 80^\circ</me>
                    <me>x = 20^\circ</me>
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A round dining table has a straight seam splitting it in half along its diameter <m>MN</m>, which measures <m>20\text{ dm}</m>. A designer paints a right-angled triangle pattern whose third vertex sits at point <m>K</m> on the table edge. If chord side <m>MK</m> must measure exactly <m>12\text{ dm}</m>, calculate the required length of side <m>NK</m>.
                </p>
                <figure xml:id="fig-circle-dining-table">
    <caption>A round dining table split by diameter seam <m>MN = 20\text{ dm}</m>, with a painted triangular pattern reaching point <m>K</m> where side <m>MK = 12\text{ dm}</m>.</caption>
    <image width="65%">
        <description>A circle representing a dining table with center O and a horizontal diameter seam MN. A point K on the edge forms a right-angled triangle MKN, with side MK labeled 12 dm and diameter seam MN labeled 20 dm.</description>
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}

            % Since MN is the diameter seam, we place M on the left (-180 deg) and N on the right (0 deg).
            \tkzDefPointOnCircle[R = center O angle 180 radius 3]\tkzGetPoint{M}
            \tkzDefPointOnCircle[R = center O angle 0 radius 3]\tkzGetPoint{N}

            % Point K is on the circumference. Based on the 12-16-20 right triangle,
            % the central angle KON is exactly 106.26 degrees.
            \tkzDefPointOnCircle[R = center O angle 106.26 radius 3]\tkzGetPoint{K}

            % Draw the circle boundary of the table
            \tkzDrawCircle[thick, color=teal](O,N)

            % --- Draw diameter seam and triangle pattern boundaries ---
            \tkzDrawSegments[thick, color=purple](M,N)
            \tkzDrawSegments[thick, color=darkgray](M,K N,K)

            % --- Mark the right angle at K (angle in a semicircle) ---
            \tkzMarkRightAngle[size=.3,color=red,thick](M,K,N)

            % --- Segment labels ---
            \tkzLabelSegment[above left,pos=0.5](M,K){$12\text{ dm}$}
            \tkzLabelSegment[above right,pos=0.5](N,K){$?$}
            \tkzLabelSegment[below,pos=0.5](M,N){$20\text{ dm}$}

            % --- Points and point labels ---
            \tkzDrawPoints[size=5,fill=black](O,M,N,K)
            \tkzLabelPoints[below,color=purple](O)
            \tkzLabelPoints[left,color=purple](M)
            \tkzLabelPoints[right,color=purple](N)
            \tkzLabelPoints[above,color=darkgray](K)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Since <m>MN</m> is the table's diameter, the inscribed angle at the table edge is a right angle (<m>\angle MKN = 90^\circ</m>). This means <m>\triangle MKN</m> is a right-angled triangle with the diameter <m>MN</m> serving as the hypotenuse.
                </p>
                <p>
                    Apply the Pythagorean theorem to find the missing side length <m>NK</m>:
                    <me>MN^2 = MK^2 + NK^2</me>
                    <me>20^2 = 12^2 + NK^2</me>
                    <me>400 = 144 + NK^2</me>
                </p>
                <p>
                    Isolate and solve for <m>NK</m>:
                    <me>NK^2 = 400 - 144 = 256</me>
                    <me>NK = \sqrt{256} = 16\text{ dm}</me>
                </p>
            </solution>
        </exercise>
</exercises>
