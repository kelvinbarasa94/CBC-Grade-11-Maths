    <!-- Add at least 3 examples -->
    
        <example>
            <statement>
                <p>
                    An arc <m>AB</m> of a circle with center <m>O</m> subtends an angle <m>\angle AOB = 148^\circ</m> at the center. If point <m>P</m> is a variable point moving along the major arc <m>AB</m> on the circumference, determine the size of <m>\angle APB</m>.
                </p>
                <figure xml:id="angle-subtended-1">
                    <caption></caption>
                    <image width="65%">
                        <latex-image>
                            \begin{tikzpicture}
                            % --- Centre and points on the circle ---
                            \tkzDefPoint(0,0){O}
                            % Endpoints of the arc (central angle AOB = 148 deg),
                            % placed symmetrically about the bottom of the circle.
                            \tkzDefPointOnCircle[R = center O angle 196 radius 3]\tkzGetPoint{A}
                            \tkzDefPointOnCircle[R = center O angle 344 radius 3]\tkzGetPoint{B}
                            % Point on the major arc (on the circumference).
                            \tkzDefPointOnCircle[R = center O angle 90 radius 3]\tkzGetPoint{P}

                            % Draw the circle through one of the points so radii always match.
                            \tkzDrawCircle[thick](O,A)

                            % --- Radii (centre angle) and chords (circumference angle) ---
                            \tkzDrawSegments(O,A O,B P,A P,B)

                            % --- Fill and mark the two angles ---
                            \tkzFillAngle[fill=red!20,opacity=.6, size=.5](A,O,B)
                            \tkzFillAngle[fill=blue!20,opacity=.6, size=.9](A,P,B)

                            \tkzMarkAngle[size=.5,color=red](A,O,B)
                            \tkzMarkAngle[size=.9,color=blue](A,P,B)

                            % --- Angle labels ---
                            \tkzLabelAngle[pos=0.9](A,O,B){$148^{\circ}$}
                            \tkzLabelAngle[pos=1.2](A,P,B){$x^{\circ}$}

                            % --- Points and point labels ---
                            \tkzDrawPoints(O,A,B,P)
                            \tkzLabelPoints[above](O)
                            \tkzLabelPoints[left](A)
                            \tkzLabelPoints[right](B)
                            \tkzLabelPoints[above](P)

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
            </statement>
            <solution>
                <p>
                    Identify the relationship between the central angle and the angle at the circumference standing on the same arc <m>AB</m>:
                </p>
                <md>\angle AOB = 2 \times \angle APB</md>
                <p>
                    Substitute the given value <m>\angle AOB = 148^\circ</m> into the formula:
                </p>
                <md>148^\circ = 2 \times \angle APB</md>
                <md>\angle APB = \frac{148^\circ}{2} = 74^\circ</md>
                <p>
                    Because of the Angles in the Same Segment Theorem, the angle <m>\angle APB</m> remains constant at <m>74^\circ</m> no matter where point <m>P</m> moves along the major arc.
                </p>
            </solution>
        </example>

        <example>
            <statement>
                <p>
                    In a circle with center <m>O</m>, a triangle <m>ABC</m> is drawn such that the side <m>AC</m> passes through the center <m>O</m>. If the angle <m>\angle ACB = 28^\circ</m>, find the measure of the remaining interior angle <m>\angle BAC</m>.
                </p>
           
<figure xml:id="angle-semicircle-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}
            
            % AC is a diameter passing through O. Let's make it horizontal for clean layout.
            \tkzDefPointOnCircle[R = center O angle 180 radius 3]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 0 radius 3]\tkzGetPoint{C}
            
            % To get exactly a 28 degree angle at C, angle BOC (central angle) needs to be 2 * 28 = 56 degrees.
            \tkzDefPointOnCircle[R = center O angle 56 radius 3]\tkzGetPoint{B}

            % Draw the circle through point A
            \tkzDrawCircle[thick](O,A)

            % --- Draw Triangle ABC and the center point ---
            \tkzDrawSegments(A,C A,B B,C)

            % --- Right angle mark at B ---
            \tkzMarkRightAngle[size=0.3,color=black](A,B,C)

            % --- Fill and mark the interior angles ---
            \tkzFillAngle[fill=blue!10,opacity=.6, size=.7](B,C,A)
            \tkzMarkAngle[size=.7,color=blue](B,C,A)
            
            \tkzFillAngle[fill=red!10,opacity=.6, size=.6](C,A,B)
            \tkzMarkAngle[size=.6,color=red](C,A,B)

            % --- Angle labels ---
            \tkzLabelAngle[pos=1.1](B,C,A){$28^{\circ}$}
            \tkzLabelAngle[pos=1.0](C,A,B){$x^{\circ}$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,A,B,C)
            \tkzLabelPoints[below](O)
            \tkzLabelPoints[left](A)
            \tkzLabelPoints[above right](B)
            \tkzLabelPoints[right](C)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Since the side <m>AC</m> passes through the center of the circle <m>O</m>, <m>AC</m> is a diameter. By the Angle in a Semicircle Theorem, the angle subtended by the diameter at the circumference is a right angle:
                </p>
                <md>\angle ABC = 90^\circ</md>
                <p>
                    The sum of the angles in triangle <m>ABC</m> is <m>180^\circ</m>:
                </p>
                <md>\angle BAC + \angle ABC + \angle ACB = 180^\circ</md>
                <p>
                    Substitute the known values to find the missing angle:
                </p>
                <md>\angle BAC + 90^\circ + 28^\circ = 180^\circ</md>
                <md>\angle BAC + 118^\circ = 180^\circ</md>
                <md>\angle BAC = 180^\circ - 118^\circ = 62^\circ</md>
                <p>
                    The measure of the angle <m>\angle BAC</m> is <m>62^\circ</m>.
                </p>
            </solution>
        </example>

        <example>
            <statement>
                <p>
                    Points <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m> lie on a circle in that order. The chords <m>AC</m> and <m>BD</m> intersect at point <m>E</m>. If the inscribed angle <m>\angle ABD = 42^\circ</m> and <m>\angle BEC = 85^\circ</m>, calculate the measure of <m>\angle ACD</m>.
                </p>
                <figure xml:id="intersecting-chords-angles-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and Points on the Circle ---
            \tkzDefPoint(0,0){O}
            \def\radius{3}
            
            % Positions for points A, B, C, D in order around the circle
            \tkzDefPointOnCircle[R = center O angle 140 radius \radius]\tkzGetPoint{A}
            \tkzDefPointOnCircle[R = center O angle 224 radius \radius]\tkzGetPoint{B}
            \tkzDefPointOnCircle[R = center O angle 320 radius \radius]\tkzGetPoint{C}
            \tkzDefPointOnCircle[R = center O angle 40  radius \radius]\tkzGetPoint{D}

            % --- Intersection Point E ---
            % E is the intersection of chords AC and BD
            \tkzInterLL(A,C)(B,D)\tkzGetPoint{E}

            % Draw the main circle
            \tkzDrawCircle[thick](O,A)

            % --- Draw Chords and Extra Boundary Segment ---
            \tkzDrawSegments(A,C B,D)
            % Draw AD or CD explicitly if helpful to visualize subtended arcs
            \tkzDrawSegments[dashed, color=gray](A,B C,D)

            % --- Mark Angles ---
            % Inscribed angle ABD = 42 degrees
            \tkzMarkAngle[size=0.5,color=blue](D,B,A)
            % Intersecting angle BEC = 85 degrees
            \tkzMarkAngle[size=0.4,color=red](B,E,C)
            % Target angle ACD = x degrees
            \tkzMarkAngle[size=0.5,color=teal](D,C,A)

            % --- Labels ---
            \tkzLabelAngle[pos=0.8, color=blue](D,B,A){$42^{\circ}$}
            \tkzLabelAngle[pos=0.7, color=red](B,E,C){$85^{\circ}$}
            \tkzLabelAngle[pos=0.8, color=teal](D,C,A){$x$}

            % --- Points and point labels ---
            \tkzDrawPoints(A,B,C,D,E)
            \tkzLabelPoints[above left](A)
            \tkzLabelPoints[below left](B)
            \tkzLabelPoints[below right](C)
            \tkzLabelPoints[above right](D)
            \tkzLabelPoints[above](E)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    According to the Angles in the Same Segment Theorem, the angles subtended by the same arc <m>AD</m> at the circumference are equal:
                </p>
                <md>\angle ACD = \angle ABD</md>
                <p>
                    Since the problem states that <m>\angle ABD = 42^\circ</m>, we can conclude directly without further calculation that:
                </p>
                <md>\angle ACD = 42^\circ</md>
            </solution>
        </example>

        <example>
            <statement>
                <p>
                    In a circle with center <m>O</m>, a triangle <m>OAB</m> is formed where <m>A</m> and <m>B</m> lie on the circumference. If the base angle <m>\angle OAB = 35^\circ</m>, find the measure of the central angle <m>\angle AOB</m>.
                </p>
                <figure xml:id="angle-isosceles-triangle">
    <caption>Isosceles triangle OAB formed by radii within a circle.</caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}[scale=1.5]
            % --- Define Coordinates ---
            \coordinate (O) at (0,0);
            
            % Symmetrical points for a clean base triangle at the bottom
            % For a central angle of 110 degrees, we offset by 55 degrees from 270 (bottom)
            \coordinate (A) at (215:2);
            \coordinate (B) at (325:2);

            % --- Draw Circle and Triangle ---
            \draw[thick] (O) circle (2cm);
            \draw[thick] (O) -- (A) -- (B) -- cycle;

            % --- Fill and Mark Angles ---
            % Central Angle AOB (110 degrees)
            \draw[fill=red!20, opacity=0.6] (0,0) -- (215:0.4) arc (215:325:0.4) -- cycle;
            \node at (270:0.6) {$x^{\circ}$};

            % Base Angle OAB (35 degrees)
            \begin{scope}
                \clip (O) -- (A) -- (B) -- cycle;
                \draw[fill=blue!20, opacity=0.6] (A) circle (0.4cm);
            \end{scope}
            \node at ($(A) + (0.5,0.25)$) {$35^{\circ}$};

            % Base Angle OBA (35 degrees)
            \begin{scope}
                \clip (O) -- (A) -- (B) -- cycle;
                \draw[fill=blue!10, opacity=0.6] (B) circle (0.4cm);
            \end{scope}
            \node at ($(B) + (-0.5,0.25)$) {$35^{\circ}$};

            % --- Points and Labels ---
            \fill (O) circle (1.5pt) node[above] {$O$};
            \fill (A) circle (1.5pt) node[left] {$A$};
            \fill (B) circle (1.5pt) node[right] {$B$};
            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Because the line segments <m>OA</m> and <m>OB</m> are lines drawn from the center <m>O</m> to the circumference, they are radii of the circle. Since all radii are equal in length:
                </p>
                <md>OA = OB</md>
                <p>
                    This makes triangle <m>OAB</m> an isosceles triangle, meaning the base angles opposite the equal sides are also equal:
                </p>
                <md>\angle OBA = \angle OAB = 35^\circ</md>
                <p>
                    The sum of angles in a triangle is <m>180^\circ</m>:
                </p>
                <md>\angle AOB + \angle OAB + \angle OBA = 180^\circ</md>
                <md>\angle AOB + 35^\circ + 35^\circ = 180^\circ</md>
                <md>\angle AOB + 70^\circ = 180^\circ</md>
                <md>\angle AOB = 180^\circ - 70^\circ = 110^\circ</md>
                <p>
                    The central angle <m>\angle AOB</m> measures <m>110^\circ</m>.
                </p>
            </solution>
        </example>

        <example>
            <statement>
                <p>
                    An arc <m>CD</m> subtends a central angle <m>\angle COD = 4x + 16^\circ</m> and an angle at the circumference <m>\angle CGD = 3x - 12^\circ</m>. Solve for <m>x</m> and calculate the actual measures of both angles.
                </p>
               <figure xml:id="central-inscribed-algebra-problem">
    <caption></caption>
    <image width="65%">
        <latex-image>
            \begin{tikzpicture}
            % --- Centre and points on the circle ---
            \tkzDefPoint(0,0){O}
            
            % Endpoints of the arc CD, placed symmetrically near the bottom
            \tkzDefPointOnCircle[R = center O angle 210 radius 3]\tkzGetPoint{C}
            \tkzDefPointOnCircle[R = center O angle 330 radius 3]\tkzGetPoint{D}
            
            % Point G on the major arc (circumference)
            \tkzDefPointOnCircle[R = center O angle 90 radius 3]\tkzGetPoint{G}

            % Draw the main circle
            \tkzDrawCircle[thick](O,C)

            % --- Radii and Chords ---
            \tkzDrawSegments(O,C O,D G,C G,D)

            % --- Fill and mark the angles ---
            \tkzFillAngle[fill=red!20,opacity=.6, size=.5](C,O,D)
            \tkzFillAngle[fill=blue!20,opacity=.6, size=.8](C,G,D)

            \tkzMarkAngle[size=.5,color=red](C,O,D)
            \tkzMarkAngle[size=.8,color=blue](C,G,D)

            % --- Angle algebraic labels ---
            \tkzLabelAngle[pos=1.0](C,O,D){$(4x + 16)^{\circ}$}
            \tkzLabelAngle[pos=1.3](C,G,D){$(3x - 12)^{\circ}$}

            % --- Points and point labels ---
            \tkzDrawPoints(O,C,D,G)
            \tkzLabelPoints[above](O)
            \tkzLabelPoints[left](C)
            \tkzLabelPoints[right](D)
            \tkzLabelPoints[above](G)

            \end{tikzpicture}
        </latex-image>
    </image>
</figure>
            </statement>
            <solution>
                <p>
                    Apply the Angle at the Centre Theorem to establish the mathematical relationship:
                </p>
                <md>\angle COD = 2 \times \angle CGD</md>
                <p>
                    Substitute the given algebraic expressions into the equation:
                </p>
                <md>4x + 16 = 2(3x - 12)</md>
                <p>
                    Expand the right side of the equation:
                </p>
                <md>4x + 16 = 6x - 24</md>
                <p>
                    Rearrange the equation to isolate the terms with <m>x</m> on one side:
                </p>
                <md>16 + 24 = 6x - 4x</md>
                <md>40 = 2x</md>
                <md>x = 20</md>
                <p>
                    Substitute <m>x = 20</m> back into the expressions to find the angle measurements:
                </p>
                <md>\angle CGD = 3(20) - 12 = 60 - 12 = 48^\circ</md>
                <md>\angle COD = 4(20) + 16 = 80 + 16 = 96^\circ</md>
                <p>
                    Verifying the result: <m>2 \times 48^\circ = 96^\circ</m>, which matches the theorem.
                </p>
            </solution>
        </example>
    

