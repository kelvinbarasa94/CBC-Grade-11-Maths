    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises xml:id="exercises-circle-geometry">
        <title>Exercises</title>

        <exercise>
            <statement>
                <p>
                    A circular community shield design has three decorative brass studs placed at points <m>A</m>, <m>B</m>, and <m>P</m> on its outer rim. If the center of the shield is <m>O</m> and the central angle is <m>\angle AOB = 130^\circ</m>, calculate the angle <m>\angle APB</m> on the rim.
                </p>
            
             <figure xml:id="angle-subtended-2">
                    <caption></caption>
                    <image width="65%">
                        <latex-image>
                            \begin{tikzpicture}
                            % --- Centre and points on the circle ---
                            \tkzDefPoint(0,0){O}
                            % Endpoints of the arc (central angle AOB = 130 deg),
                            % placed symmetrically about the bottom of the circle.
                            \tkzDefPointOnCircle[R = center O angle 218 radius 3]\tkzGetPoint{A}
                            \tkzDefPointOnCircle[R = center O angle 348 radius 3]\tkzGetPoint{B}
                            % Point on the major arc (on the circumference).
                            \tkzDefPointOnCircle[R = center O angle 110 radius 3]\tkzGetPoint{P}

                            % Draw the circle through one of the points so radii always match.
                            \tkzDrawCircle[thick](O,A)

                            % --- Radii (centre angle) and chords (circumference angle) ---
                            \tkzDrawSegments(O,A O,B P,A P,B)

                            % --- Fill and mark the two angles ---
                            \tkzFillAngle[fill=red!20,opacity=.6, size=.5](A,O,B)
                            \tkzFillAngle[fill=blue!20,opacity=.6, size=.9](A,P,B)

                            \tkzMarkAngle[size=.5,color=red](A,O,B)
                            \tkzMarkAngle[size=.9,color=blue](A,P,B)

                            % --- Angle labels ---
                            \tkzLabelAngle[pos=0.9](A,O,B){$130^{\circ}$}
                            \tkzLabelAngle[pos=1.2](A,P,B){$k^{\circ}$}

                            % --- Points and point labels ---
                            \tkzDrawPoints(O,A,B,P)
                            \tkzLabelPoints[above](O)
                            \tkzLabelPoints[left](A)
                            \tkzLabelPoints[right](B)
                            \tkzLabelPoints[above](P)

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
            </statement>
            <solution>
                <p>
                    By the Angle at the Centre Theorem, the angle at the center is twice the angle at the circumference:
                </p>
                <md>\angle APB = \frac{\angle AOB}{2}</md>
                <md>\angle APB = \frac{130^\circ}{2} = 65^\circ</md>
                <p>
                    The angle on the rim is <m>65^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    In a local irrigation layout, water pipes form a triangle <m>XYZ</m> inside a circular holding field with center <m>O</m>. The main feed pipe <m>XZ</m> is a straight line passing through the center of the reservoir. If <m>\angle YXZ = 55^\circ</m>, calculate the angle <m>\angle YZX</m>.
                </p>
                <figure xml:id="fig-irrigation-semicircle">
            <caption>Irrigation pipe layout forming triangle XYZ inside a circular field.</caption>
            <image width="65%">
                <latex-image>
                    \begin{tikzpicture}[scale=1.5]
                    % --- Define Coordinates ---
                    \coordinate (O) at (0,0);
                    
                    % XZ passes through center O, making it a diameter. Let's place it horizontally.
                    \coordinate (X) at (-2,0);
                    \coordinate (Z) at (2,0);
                    
                    % Since angle YXZ = 55 degrees, central angle YOZ = 2 * 55 = 110 degrees.
                    % Therefore, angle of Y from positive x-axis is 110 degrees.
                    \coordinate (Y) at (110:2);

                    % --- Draw Circle and Triangle ---
                    \draw[thick] (O) circle (2cm);
                    \draw[thick] (X) -- (Y) -- (Z) -- cycle;

                    % --- Right Angle Mark at Y (Semicircle Theorem) ---
                    \draw[thick] ($(Y)!0.2cm!(X)$) -- ($($(Y)!0.2cm!(X)$)!0.2cm!90:(X)$) -- ($(Y)!0.2cm!(Z)$);

                    % --- Annotate Angles ---
                    % Angle YXZ = 55 degrees
                    \draw (-1.5,0) arc (0:55:0.5);
                    \node at (-1.2,0.25) {$55^{\circ}$};

                    % Angle YZX = 35 degrees (Target angle)
                    \draw (1.5,0) arc (180:145:0.5);
                    \node at (1.2,0.2) {$x^{\circ}$};

                    % --- Label Points ---
                    \fill (O) circle (1.5pt) node[below] {$O$};
                    \fill (X) circle (1.5pt) node[left] {$X$};
                    \fill (Y) circle (1.5pt) node[above left] {$Y$};
                    \fill (Z) circle (1.5pt) node[right] {$Z$};
                    \end{tikzpicture}
                </latex-image>
            </image>
        </figure>
            </statement>
            <solution>
                <p>
                    Since <m>XZ</m> passes through the center, it is a diameter. By the Angle in a Semicircle Theorem:
                </p>
                <md>\angle XYZ = 90^\circ</md>
                <p>
                    Using the sum of angles in triangle <m>XYZ</m>:
                </p>
                <md>\angle YXZ + \angle XYZ + \angle YZX = 180^\circ</md>
                <md>55^\circ + 90^\circ + \angle YZX = 180^\circ</md>
                <md>145^\circ + \angle YZX = 180^\circ</md>
                <md>\angle YZX = 180^\circ - 145^\circ = 35^\circ</md>
                <p>
                    The angle <m>\angle YZX</m> is <m>35^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Four peg markers are placed on a circular school playing field at points <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m> in clockwise order. Students tie ropes between the pegs forming paths <m>AC</m>, <m>AD</m>, <m>BC</m>, and <m>BD</m>. If the angle formed at peg <m>C</m> by paths <m>AC</m> and <m>BC</m> is <m>\angle ACB = 47^\circ</m>, state the measure of <m>\angle ADB</m> and explain your reasoning.
                </p>
               <figure xml:id="angles-in-same-segment-clockwise-fixed">
                    <caption></caption>
                    <image width="65%">
                        <latex-image>
                            \begin{tikzpicture}
                            % --- Centre and points on the circle ---
                            \tkzDefPoint(0,0){O}
                            
                            % Points positioned in strict clockwise order: A -> B -> C -> D
                            \tkzDefPointOnCircle[R = center O angle 160 radius 3]\tkzGetPoint{A}
                            \tkzDefPointOnCircle[R = center O angle 80 radius 3]\tkzGetPoint{B}
                            \tkzDefPointOnCircle[R = center O angle 20 radius 3]\tkzGetPoint{C}
                            \tkzDefPointOnCircle[R = center O angle 280 radius 3]\tkzGetPoint{D}

                            % Draw the circle
                            \tkzDrawCircle[thick](O,A)

                            % --- Draw paths (ropes) ---
                            \tkzDrawSegments(A,C A,D B,C B,D)

                            % --- Fill and mark interior angles (reversing order fixes the reflex angle issue) ---
                            \tkzFillAngle[fill=blue!20,opacity=.6, size=.8](B,C,A)
                            \tkzFillAngle[fill=orange!20,opacity=.6, size=.8](B,D,A)

                            \tkzMarkAngle[size=.8,color=blue](B,C,A)
                            \tkzMarkAngle[size=.8,color=orange](B,D,A)

                            % --- Angle labels ---
                            \tkzLabelAngle[pos=1.3](B,C,A){$47^{\circ}$}
                            \tkzLabelAngle[pos=1.3](B,D,A){$x^{\circ}$}

                            % --- Points and point labels ---
                            \tkzDrawPoints(A,B,C,D)
                            \tkzLabelPoints[above left](A)
                            \tkzLabelPoints[above right](B)
                            \tkzLabelPoints[right](C)
                            \tkzLabelPoints[below](D)

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
            </statement>
            <solution>
                <p>
                    By the Angles in the Same Segment Theorem, angles subtended by the same arc at the circumference in the same segment are equal:
                </p>
                <md>\angle ADB = \angle ACB = 47^\circ</md>
                <p>
                    Therefore, the measure of <m>\angle ADB</m> is <m>47^\circ</m> because both angles are subtended by the same boundary arc <m>AB</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A circular structural gear has points <m>M</m> and <m>N</m> on its perimeter. The axle is at the center <m>O</m>. A sensor at point <m>K</m> on the outer shell measures the angle <m>\angle MKN = 41^\circ</m>. What central angle <m>\angle MON</m> is formed by the spokes connecting <m>M</m> and <m>N</m> to the axle <m>O</m>?
                </p>
               <figure xml:id="angle-subtended-gear">
                    <caption></caption>
                    <image width="65%">
                        <latex-image>
                            \begin{tikzpicture}
                            % --- Centre and points on the circle ---
                            \tkzDefPoint(0,0){O}
                            % Endpoints of the arc (central angle MON = 82 deg),
                            % placed symmetrically about the bottom of the circle.
                            \tkzDefPointOnCircle[R = center O angle 229 radius 3]\tkzGetPoint{M}
                            \tkzDefPointOnCircle[R = center O angle 311 radius 3]\tkzGetPoint{N}
                            % Sensor point on the major arc (on the circumference).
                            \tkzDefPointOnCircle[R = center O angle 90 radius 3]\tkzGetPoint{K}

                            % Draw the circle through one of the points so radii always match.
                            \tkzDrawCircle[thick](O,M)

                            % --- Radii (centre angle) and chords (circumference angle) ---
                            \tkzDrawSegments(O,M O,N K,M K,N)

                            % --- Fill and mark the two angles ---
                            \tkzFillAngle[fill=red!20,opacity=.6, size=.6](M,O,N)
                            \tkzFillAngle[fill=blue!20,opacity=.6, size=.9](M,K,N)

                            \tkzMarkAngle[size=.6,color=red](M,O,N)
                            \tkzMarkAngle[size=.9,color=blue](M,K,N)

                            % --- Angle labels ---
                            \tkzLabelAngle[pos=0.9](M,O,N){$?^{\circ}$}
                            \tkzLabelAngle[pos=1.2](M,K,N){$41^{\circ}$}

                            % --- Points and point labels ---
                            \tkzDrawPoints(O,M,N,K)
                            \tkzLabelPoints[above](O)
                            \tkzLabelPoints[left](M)
                            \tkzLabelPoints[right](N)
                            \tkzLabelPoints[above](K)

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
            </statement>
            <solution>
                <p>
                    By applying the Angle at the Centre Theorem:
                </p>
                <md>\angle MON = 2 \times \angle MKN</md>
                <md>\angle MON = 2 \times 41^\circ = 82^\circ</md>
                <p>
                    The central angle formed by the spokes is <m>82^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    In a circle with center <m>O</m>, the central angle subtended by arc <m>AB</m> is <m>\angle AOB = 5y - 20^\circ</m>. If the angle subtended by the same arc at the circumference is <m>\angle APB = 2y + 5^\circ</m>, solve for <m>y</m> and calculate the size of <m>\angle APB</m>.
                </p>
               <figure xml:id="central-inscribed-algebra">
                    <caption></caption>
                    <image width="65%">
                        <latex-image>
                            \begin{tikzpicture}
                            % --- Centre and points on the circle ---
                            \tkzDefPoint(0,0){O}
                            
                            % Points A and B on the circumference
                            \tkzDefPointOnCircle[R = center O angle 210 radius 3]\tkzGetPoint{A}
                            \tkzDefPointOnCircle[R = center O angle 330 radius 3]\tkzGetPoint{B}
                            % Point P on the major arc
                            \tkzDefPointOnCircle[R = center O angle 90 radius 3]\tkzGetPoint{P}

                            % Draw the circle
                            \tkzDrawCircle[thick](O,A)

                            % --- Draw central and inscribed angles ---
                            \tkzDrawSegments(O,A O,B P,A P,B)

                            % --- Fill and mark the angles ---
                            \tkzFillAngle[fill=red!20,opacity=.6, size=.5](A,O,B)
                            \tkzFillAngle[fill=blue!20,opacity=.6, size=.9](A,P,B)

                            \tkzMarkAngle[size=.5,color=red](A,O,B)
                            \tkzMarkAngle[size=.9,color=blue](A,P,B)

                            % --- Angle labels using the algebraic expressions ---
                            \tkzLabelAngle[pos=1.1](A,O,B){$5y - 20^{\circ}$}
                            \tkzLabelAngle[pos=1.3](A,P,B){$2y + 5^{\circ}$}

                            % --- Points and point labels ---
                            \tkzDrawPoints(O,A,B,P)
                            \tkzLabelPoints[above](O)
                            \tkzLabelPoints[left](A)
                            \tkzLabelPoints[right](B)
                            \tkzLabelPoints[above](P)

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>
            </statement>
            <solution>
                <p>
                    By the Angle at the Centre Theorem:
                </p>
                <md>\angle AOB = 2 \times \angle APB</md>
                <p>
                    Substitute the algebraic expressions:
                </p>
                <md>5y - 20 = 2(2y + 5)</md>
                <md>5y - 20 = 4y + 10</md>
                <p>
                    Solve for <m>y</m>:
                </p>
                <md>5y - 4y = 10 + 20</md>
                <md>y = 30</md>
                <p>
                    Now calculate the size of <m>\angle APB</m>:
                </p>
                <md>\angle APB = 2(30) + 5^\circ = 65^\circ</md>
            </solution>
        </exercise>
    </exercises>

