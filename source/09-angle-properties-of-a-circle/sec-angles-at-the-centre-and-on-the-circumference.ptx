<section xml:id="sec-angles-at-the-centre-and-on-the-circumference" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Angles at the Centre and on the Circumference</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.2 Angle Properties of a Circle
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Relate angles subtended by the same arc at the circumference
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>
    

    <!-- [LP] Add guidance on activity -->
<axiom component="lesson-plan">
        <title>Teacher's Guide: Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To guide learners through empirical measurement and data collection so they construct conjectures regarding the central angle and inscribed angles in the same segment.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Circulate around the groups to ensure precise measurements with protractors. Encourage students to compare column entries in their data sets. Prompts should guide them to recognize that the circumference angle is half the central angle, and that it remains invariant across the major segment.
                </p>
            </li>
        </dl>
    </axiom>
