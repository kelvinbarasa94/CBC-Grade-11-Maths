    <!-- Add static exercises -->
     <exercises xml:id="exercises-circle-geometry">
        <title>Exercises</title>

        <exercise>
            <statement>
                <p>
                    A circular community shield design has three decorative brass studs placed at points <m>A</m>, <m>B</m>, and <m>P</m> on its outer rim. If the center of the shield is <m>O</m> and the central angle is <m>\angle AOB = 130^\circ</m>, calculate the angle <m>\angle APB</m> on the rim.
                </p>
            </statement>
            <solution>
                <p>
                    By the Angle at the Centre Theorem, the angle at the center is twice the angle at the circumference:
                </p>
                <me>\angle APB = \frac{\angle AOB}{2}</me>
                <me>\angle APB = \frac{130^\circ}{2} = 65^\circ</me>
                <p>
                    The angle on the rim is <m>65^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    In a local irrigation layout, water pipes form a triangle <m>XYZ</m> inside a circular holding field with center <m>O</m>. The main feed pipe <m>XZ</m> is a straight line passing through the center of the reservoir. If <m>\angle YXZ = 55^\circ</m>, calculate the angle <m>\angle YZX</m>.
                </p>
            </statement>
            <solution>
                <p>
                    Since <m>XZ</m> passes through the center, it is a diameter. By the Angle in a Semicircle Theorem:
                </p>
                <me>\angle XYZ = 90^\circ</me>
                <p>
                    Using the sum of angles in triangle <m>XYZ</m>:
                </p>
                <me>\angle YXZ + \angle XYZ + \angle YZX = 180^\circ</me>
                <me>55^\circ + 90^\circ + \angle YZX = 180^\circ</me>
                <me>145^\circ + \angle YZX = 180^\circ</me>
                <me>\angle YZX = 180^\circ - 145^\circ = 35^\circ</me>
                <p>
                    The angle <m>\angle YZX</m> is <m>35^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Four peg markers are placed on a circular school playing field at points <m>A</m>, <m>B</m>, <m>C</m>, and <m>D</m> in clockwise order. Students tie ropes between the pegs forming paths <m>AC</m>, <m>AD</m>, <m>BC</m>, and <m>BD</m>. If the angle formed at peg <m>C</m> by paths <m>AC</m> and <m>BC</m> is <m>\angle ACB = 47^\circ</m>, state the measure of <m>\angle ADB</m> and explain your reasoning.
                </p>
            </statement>
            <solution>
                <p>
                    By the Angles in the Same Segment Theorem, angles subtended by the same arc at the circumference in the same segment are equal:
                </p>
                <me>\angle ADB = \angle ACB = 47^\circ</me>
                <p>
                    Therefore, the measure of <m>\angle ADB</m> is <m>47^\circ</m> because both angles are subtended by the same boundary arc <m>AB</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    A circular structural gear has points <m>M</m> and <m>N</m> on its perimeter. The axle is at the center <m>O</m>. A sensor at point <m>K</m> on the outer shell measures the angle <m>\angle MKN = 41^\circ</m>. What central angle <m>\angle MON</m> is formed by the spokes connecting <m>M</m> and <m>N</m> to the axle <m>O</m>?
                </p>
            </statement>
            <solution>
                <p>
                    By applying the Angle at the Centre Theorem:
                </p>
                <me>\angle MON = 2 \times \angle MKN</me>
                <me>\angle MON = 2 \times 41^\circ = 82^\circ</me>
                <p>
                    The central angle formed by the spokes is <m>82^\circ</m>.
                </p>
            </solution>
        </exercise>

        <exercise>
            <statement>
                <p>
                    In a circle with center <m>O</m>, the central angle subtended by arc <m>AB</m> is <m>\angle AOB = 5y - 20^\circ</m>. If the angle subtended by the same arc at the circumference is <m>\angle APB = 2y + 5^\circ</m>, solve for <m>y</m> and calculate the size of <m>\angle APB</m>.
                </p>
            </statement>
            <solution>
                <p>
                    By the Angle at the Centre Theorem:
                </p>
                <me>\angle AOB = 2 \times \angle APB</me>
                <p>
                    Substitute the algebraic expressions:
                </p>
                <me>5y - 20 = 2(2y + 5)</me>
                <me>5y - 20 = 4y + 10</me>
                <p>
                    Solve for <m>y</m>:
                </p>
                <me>5y - 4y = 10 + 20</me>
                <me>y = 30</me>
                <p>
                    Now calculate the size of <m>\angle APB</m>:
                </p>
                <me>\angle APB = 2(30) + 5^\circ = 65^\circ</me>
            </solution>
        </exercise>
    </exercises>

