<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-approximation-and-errors-in-real-life" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Approximation and Errors in Real Life</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Approximation and Errors
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Appreciate the use of approximations and errors in real life situations
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan" xml:id="lesson-plan-real-life-discovery">
        <title>Problem-Solving and Discovery: Athletic Selections</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    20 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To evaluate how minor fluctuations in fieldwork measurements significantly alter critical competitive decision-making thresholds.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Set up the scenario by highlighting why absolute tracking precision matters when picking teams for national games. Guide groups as they compute limits, keeping an eye on how they set up the divisions for maximum and minimum athlete speeds.
                </p>
            </li>
        </dl>
    </axiom>

    <!-- Add Activity -->

    <activity xml:id="act-madam-esther-sprinters">
        <statement>
            <p>
                Madam Esther, a games teacher, is measuring the speed of sprinters in a <m>100</m> metres race to select the best contender for the upcoming national games. She uses a standard sports field tape measure and a digital stopwatch. 
            </p>

            <figure xml:id="fig-esther-sprinter-bounds">
                <caption>Visualizing measurement tolerances and rate calculation cross-pairing in a sports race</caption>
                <image xml:id="img-esther-sprinter-bounds">
                    <description>
                        A 2D schematic layout of a school running track. 
                        The track shows a standard 100 m distance with error intervals marked at the start and finish lines indicating the actual bounds are between 99.5 m and 100.5 m. 
                        To the right, a calculation rule map connects Maximum Speed directly to Maximum Distance divided by Minimum Time, and Minimum Speed to Minimum Distance divided by Maximum Time.
                    </description>
                    <latex-image>
                        \begin{tikzpicture}[scale=0.14, every node/.style={font=\sffamily\small}]
                            
                            \tikzset{
                                trackLane/.style={fill=red!15, draw=red!40!black, line width=1.2pt},
                                finishLine/.style={draw=black, line width=2pt, dashed},
                                ruleBox/.style={draw=gray!40, fill=gray!2, rounded corners=3pt, line width=1pt}
                            }

                            
                            \node[anchor=south, font=\bfseries] at (15, 32) {Track Measurement Tolerances ($\pm$0.5 m)};
                            
                            
                            \draw[trackLane] (0, 15) rectangle (32, 27);
                            \draw[white, line width=1pt, dashed] (0, 21) -- (32, 21);
                            
                            \draw[finishLine] (30, 13) -- (30, 29);
                            \node[rotate=90, anchor=south, scale=0.8] at (30, 22) {Recorded Finish};
                            
                           
                            \draw[|-|, thick, gray!80!black] (0, 10) -- node[below, scale=0.85, text=black] {Stated Distance = 100 m} (30, 10);
                            \draw[red!80!black, ->, thick] (28.5, 7) -- (31.5, 7);
                            \node[red!80!black, scale=0.75, below] at (30, 7) {99.5 m to 100.5 m Interval};

                            
                            \draw[fill=blue!5, draw=blue!60!black, line width=1pt] (10, 24) circle (1.8);
                            \draw[line width=1.5pt, blue!60!black] (10,24) -- (11,25.3);
                            \node[scale=0.75, blue!40!black, anchor=south] at (10, 26) {Time Error: $\pm$0.05 s};

                            
                            \draw[ruleBox] (40, 17) rectangle (88, 29);
                            \node[anchor=west, red!80!black, font=\bfseries] at (42, 26.5) {To Calculate Maximum Speed:};
                            \node[anchor=west, scale=0.85] at (44, 23.5) {$\bullet$ Take the largest possible distance};
                            \node[anchor=west, scale=0.85] at (44, 20.5) {$\bullet$ Divide by the shortest possible time};
                            
                            
                            \draw[ruleBox] (40, 1) rectangle (88, 13);
                            \node[anchor=west, green!40!black, font=\bfseries] at (42, 10.5) {To Calculate Minimum Speed:};
                            \node[anchor=west, scale=0.85] at (44, 7.5) {$\bullet$ Take the smallest possible distance};
                            \node[anchor=west, scale=0.85] at (44, 4.5) {$\bullet$ Divide by the longest possible time};

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>

            <p>
                <term>In Groups</term> of <m>3 - 4</m>.
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            Determine the absolute limits within which the track distance lies.
                        </p>
                    </li>
                    <li>
                        <p>
                            Madam Esther records the final time for the four contenders as shown below. Fill in the missing upper and lower time limits for each athlete:
                        </p>
                        <tabular left="medium" right="medium" top="medium" bottom="medium">
                            <row header="yes">
                                <cell>Contender</cell>
                                <cell>Minimum Time (s)</cell>
                                <cell>Working Time (s)</cell>
                                <cell>Maximum Time (s)</cell>
                            </row>
                            <row>
                                <cell>Kelvin</cell>
                                <cell>?</cell>
                                <cell>10.4</cell>
                                <cell>?</cell>
                            </row>
                            <row>
                                <cell>John</cell>
                                <cell>?</cell>
                                <cell>10.2</cell>
                                <cell>?</cell>
                            </row>
                            <row>
                                <cell>Michael</cell>
                                <cell>?</cell>
                                <cell>10.5</cell>
                                <cell>?</cell>
                            </row>
                            <row>
                                <cell>Benard</cell>
                                <cell>?</cell>
                                <cell>10.1</cell>
                                <cell>?</cell>
                            </row>
                        </tabular>
                    </li>
                    <li>
                        <p>
                            Calculate the <alert>working speed</alert> for each contender using the formula:
                            <md>
                                <mrow>\text{working speed} = \frac{\text{working distance}}{\text{working time}}</mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            Calculate the <alert>maximum possible speed</alert> and the <alert>minimum possible speed</alert> for the current fastest runner, Benard.
                        </p>
                    </li>
                    <li>
                        <p>
                            Find the absolute error, relative error, and percentage error in the calculation of Benard's speed.
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                <term>Class Discussion Questions</term>
            </p>
             <p>
                Look closely at the maximum speed calculation. Why does dividing the maximum possible distance by the minimum possible time give us the highest speed threshold?
            </p>
            
        </statement>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan" xml:id="lesson-plan-real-life-structured">
        <title>Structured Instruction: Error Consequences in Industry</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To transition learners from manual workspace operations to understanding the broad socio-economic and safety impacts of error margins across key industrial sectors.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Use Madam Esther's problem to show that error margins are not just academic theory. In competitive fields, a calculation error can change selection results entirely.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Tolerance Intervals in Engineering:</alert> Explain that errors accumulate across structural components. For example, in bridge construction, a small error in one beam's length can lead to misalignment, affecting the entire structure's integrity. This illustrates why engineers calculate absolute maximum bounds for each component.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Risk Management in Medicine:</alert> Highlight sectors where limits are strictly regulated. In pharmacy or clinical medicine, an error margin over <m>1\%</m> in dosage formulations could compromise patient safety, showing why we calculate absolute maximum bounds.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->

