    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan" xml:id="lesson-plan-differentiation">
        <title>Differentiation</title>

        <table>
            <title>Differentiation Strategies for Measurement Activity</title>
            <tabular halign="left" top="medium" bottom="medium" left="medium" right="medium">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row bottom="minor">
                    <cell><alert>Struggling Learners (Support)</alert></cell>
                    <cell>
                        Provide pre-marked guidelines on the desk or a longer strip of paper to help them align the <m>15</m> cm ruler accurately without losing their place. Pair them with a peer to help hold the tools steady while recording data.
                    </cell>
                </row>
                <row bottom="minor">
                    <cell><alert>On-Level Learners (Core)</alert></cell>
                    <cell>
                        The core lesson activities as described above, independently executing the three measurements, completing the data table, and answering the comparison questions.
                    </cell>
                </row>
                <row>
                    <cell><alert>Advanced Learners (Challenge)</alert></cell>
                    <cell>
                        Have them calculate the absolute differences between the three measurements. Ask them to predict how the total error would accumulate if they used the <m>15</m> cm ruler to measure the total length of the entire classroom floor.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

    <xi:include href="../lesson-plan-templates/assessment-methods.ptx" />

    <xi:include href="../lesson-plan-templates/reflection.ptx"/>
</section>
