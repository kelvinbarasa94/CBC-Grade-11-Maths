<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-estimations-and-approximations" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Estimations and Approximations</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Approximation and Errors
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Determine errors from measurements of quantities
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan" xml:id="lesson-plan-measurement">
        <title>Problem-Solving and Discovery: Measurement Accuracy</title>
        <ol marker="(a)">
            <li>
                <title>Suggested Time</title>
                <p>
                    40 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Students will understand that using different measuring tools leads to variations in accuracy, consistency, and human error when measuring the same object.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Organize students into small groups and provide them with 15 cm rulers, 30 cm rulers, and metre rules. Guide the groups during the reflection phase to help them connect multiple placements of a shorter tool with the accumulation of human error.
                </p>
            </li>
        </ol>
    </axiom>

    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                Work in <term>Groups</term> to do the following measurement activity as demonstrated below.
            </p>
            <figure xml:id="fig-desk-measurement-comparison">
                <caption>Comparing desk measurements using different tools</caption>
                <image xml:id="img-desk-measurement-comparison">
                    <description>
                        A clean 2D vector diagram showing a wooden classroom desk from a top-down front perspective. 
                        The desk demonstrates three measurement methods aligned vertically:
                        Top: A yellow 15 cm ruler with 'repeat' arrows indicating multiple consecutive placements.
                        Middle: A cyan 30 cm ruler with a single 'repeat' arrow indicating fewer placements.
                        Bottom: A long green 100 cm metre rule spanning the width of the desk in a single direct measurement.
                    </description>
                    <latex-image>
                        \begin{tikzpicture}[scale=0.12, every node/.style={font=\sffamily\small}]
                            % --- DESIGN STYLES ---
                            \tikzset{
                                desk/.style={fill=brown!15, draw=brown!70!black, line width=1.5pt, rounded corners=2pt},
                                leg/.style={fill=brown!40, draw=brown!70!black, line width=1.2pt},
                                ruler15/.style={fill=yellow!30, draw=yellow!60!black, thin},
                                ruler30/.style={fill=cyan!20, draw=cyan!60!black, thin},
                                ruler100/.style={fill=green!20, draw=green!60!black, thin}
                            }

                            
                            % Desk Legs
                            \draw[leg] (5,-5) rectangle (8,32);
                            \draw[leg] (12,-2) rectangle (15,30);
                            \draw[leg] (75,-2) rectangle (78,30);
                            \draw[leg] (82,-5) rectangle (85,32);
                            % Desk Main Top
                            \draw[desk] (0,0) rectangle (90,32);

                            
                            \node[anchor=west, text=brown!50!black] at (3, 28) {\textbf{Method A (15 cm): Multiple Placements}};
                            
                            % First placement
                            \draw[ruler15] (5,23) rectangle (20,25.5);
                            \node[scale=0.7] at (12.5, 24.25) {15 cm};
                            
                            % Repeat indicators
                            \draw[thick,->,bend left=60] (18,26.5) to node[above,scale=0.7] {repeat} (24,26.5);
                            \draw[ruler15, dashed, opacity=0.6] (20,23) rectangle (35,25.5);
                            
                            \draw[thick,->,bend left=60] (33,26.5) to node[above,scale=0.7] {repeat} (39,26.5);
                            \draw[ruler15, dashed, opacity=0.4] (35,23) rectangle (50,25.5);
                            
                            % Dimension indicator
                            \draw[red,->,line width=0.8pt] (5,21.5) -- (50,21.5);
                            \node[red,scale=0.7,below] at (27.5,21.5) {Multiple steps required};

                            
                            \node[anchor=west, text=brown!50!black] at (3, 17) {\textbf{Method B (30 cm): Fewer Placements}};
                            
                            % Placements
                            \draw[ruler30] (5,12) rectangle (35,14.5);
                            \node[scale=0.75] at (20, 13.25) {30 cm Ruler};
                            
                            \draw[thick,->,bend left=45] (32,15.5) to node[above,scale=0.7] {repeat} (40,15.5);
                            \draw[ruler30, dashed, opacity=0.5] (35,12) rectangle (65,14.5);

                            % Dimension indicator
                            \draw[blue,->,line width=0.8pt] (5,10.5) -- (65,10.5);

                            
                            \node[anchor=west, text=brown!50!black] at (3, 7) {\textbf{Method C (Metre Rule): Direct Measurement}};
                            
                            % Spans almost the whole desk comfortably
                            \draw[ruler100] (5,2) rectangle (85,4.5);
                            \node[scale=0.8] at (45, 3.25) {1 Metre Rule (100 cm)};
                            
                            % Ticks along the bottom edge
                            \foreach \t in {5,15,25,35,45,55,65,75,85} {
                                \draw (\t,2) -- (\t,2.7);
                            }

                            % Dimension indicator
                            \draw[green!40!black,->,line width=1pt] (5,1) -- (85,1);

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>Measure the length of the desk using a <m>15</m> cm ruler.</p>
                    </li>
                    <li>
                        <p>Measure the same desk using a <m>30</m> cm ruler.</p>
                    </li>
                    <li>
                        <p>Measure it using a metre rule or tape measure.</p>
                    </li>
                    <li>
                        <p>Record all your results clearly.</p>
                    </li>
                </ol>
            </p>
            <tabular left="medium" right="medium" top="medium" bottom="medium">
                <row header="yes">
                    <cell>Measuring Tool</cell>
                    <cell>Length (cm)</cell>
                </row>
                <row>
                    <cell><m>15</m> cm</cell>
                    <cell>?</cell>
                </row>
                <row>
                    <cell><m>30</m> cm</cell>
                    <cell>?</cell>
                </row>
                <row>
                    <cell>Metre Rule</cell>
                    <cell>?</cell>
                </row>
            </tabular>
            <p>
                <term>Part B: Comparing Results</term>
            </p>
            <p>
                <ol marker="(i)">
                    <li>
                        <p>Do all groups obtain the same measurement? Explain.</p>
                    </li>
                    <li>
                        <p>Which measuring tool gave the most consistent result? Why?</p>
                    </li>
                    <li>
                        <p>Which tool do you think is most accurate? Give reasons.</p>
                    </li>
                </ol>
            </p>
            <p>
                <term>Part C: Investigating Differences</term>
            </p>
            <p>
                <ol marker="(i)">
                    <li>
                        <p>Compare your results with another group's measurements.</p>
                    </li>
                    <li>
                        <p>Suggest possible reasons why the results are different.</p>
                    </li>
                    <li>
                        <p>Discuss how human error may have affected the results.</p>
                    </li>
                </ol>
            </p>
            <p>
                <term>Guided Reflection:</term>
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>What happens if the ruler is not placed exactly at the edge of the desk?</p>
                    </li>
                    <li>
                        <p>Does the thickness of the measuring tool affect accuracy?</p>
                    </li>
                    <li>
                        <p>Can two correct measurements still be slightly different? Explain.</p>
                    </li>
                </ol>
            </p>
            <p>
                What are the ways of improving accuracy when measuring long objects.
            </p>
        </statement>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan" xml:id="lesson-plan-structured-instruction">
    <title>Structured Instruction: Formalizing Measurement Concepts</title>
    <p>
        <ol marker="(a)">
            <li>
                <title>Suggested Time</title>
                <p>
                    20 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the concepts of precision, consistency, and sources of experimental error discovered during the practical activity.
                </p>
            </li>
        </ol>
    </p>
    <paragraphs>
        <title>Key Takeaways &amp; Teacher Connection</title>
        <ol marker="(i)">
            <li>
                <p>
                    <alert>Connecting to Learner Work:</alert> Use the students' filled tables to point out variations in the results. Highlight that the <m>15</m> cm ruler required multiple placements, which introduced a new chance for error each time the ruler was moved.
                </p>
            </li>
            <li>
                <p>
                    <alert>Defining Accuracy and Consistency:</alert> Explain that the metre rule gives the most consistent result because it measures the desk in a single step, minimizing alignment errors.
                </p>
            </li>
            <li>
                <p>
                    <alert>Human Error Mitigation:</alert> Formalize methods for improving accuracy, such as aligning the zero-mark of the tool exactly with the edge, keeping the tool flat, and reading the scale directly from above to avoid parallax error.
                </p>
            </li>
        </ol>
    </paragraphs>
</axiom>

    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>

        <p>
            Measurement is never perfectly exact. Every measurement has a small degree of uncertainty due to limitations of measuring instruments and human factors.
        </p>
        <p>
            Differences in results may arise due to:
        </p>
        <p>
            <ol marker="(a)">
                <li>
                    <p>Different measuring instruments (resolution and size)</p> 
                </li>
                <li>
                    <p>Parallax error (incorrect viewing angle)</p>
                </li>
                <li>
                    <p>Starting point misalignment</p>
                </li>
                <li>
                    <p>Human estimation differences</p>
                </li>
            </ol>
        </p>
        <p>
            Because of these limitations, we often give measurements as approximations rather than exact values.
        </p>

        <p>
            This leads to the idea of:
        </p>

        <p>
            <term>Absolute Error:</term> the difference between the measured value and the true value (when known).
        </p>
        <p>
            Therefore, repeated measurements and better instruments improve reliability but never completely remove error.
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Three students measure the same desk and obtain 120 cm, 121 cm, and 119 cm. Explain why the results are not identical.
            </p>
        </statement>

        <solution>
            <p>
                Differences occur due to measurement errors such as parallax error, instrument precision, and human reading differences.
            </p>
        </solution>
    </example>

    <example>

        <statement>
            <p>
                A tape measure gives a more consistent result than a 15 cm ruler when measuring a desk. Explain why.
            </p>
        </statement>

        <solution>
            <p>
                A tape measure covers a longer distance at once, reducing repeated placements and therefore reducing cumulative error.
            </p>
        </solution>
    </example>

