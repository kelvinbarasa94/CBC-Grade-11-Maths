<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-addition-and-subtraction-of-errors" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Addition and Subtraction of Errors</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Approximation and Errors
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Perform propagation of errors using limits of measurements
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan" xml:id="lesson-plan-textbook-discovery">
        <title>Problem-Solving and Discovery: Error Propagation</title>
        <ol marker="(a)">
            <li>
                <title>Suggested Time</title>
                <p>
                    40 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Students will discover how maximum and minimum bounds behave when adding or subtracting two measured values that contain a margin of error.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Have students use standard metric rulers where the smallest graduation is <m>1</m> mm (<m>0.1</m> cm), making the maximum error <m>\pm 0.05</m> cm. Let them systematically compute all combinations of sums and differences in their groups. Do not give away the subtraction pattern ahead of time; let them notice the surprising result on their own.
                </p>
            </li>
        </ol>
    </axiom>

    <activity>
        <statement>
            <p>
                <term>Work in Groups</term>
            </p>
            <figure xml:id="fig-textbook-error-propagation">
                <caption>Visualizing limits of accuracy and error limits in operations</caption>
                <image xml:id="img-textbook-error-propagation">
                    <description>
                        A 2D vector diagram illustrating an English textbook with error margins. 
                        Left side: The textbook showing length and width measurements with shaded outer and inner border zones representing the maximum and minimum measurement boundaries due to ruler precision. 
                        Right side: Two visual calculation tracks. The addition track shows minimum bounds adding together and maximum bounds adding together. The subtraction track highlights the unique combination required for a maximum difference: Maximum Length minus Minimum Width.
                    </description>
                    <latex-image>
                        \begin{tikzpicture}[scale=0.15, every node/.style={font=\sffamily\small}]
                           
                            \tikzset{
                                bookActual/.style={fill=blue!10, draw=blue!60!black, line width=1.2pt},
                                bookMax/.style={draw=red!60!black, dashed, line width=0.8pt, fill=red!5, opacity=0.3},
                                bookMin/.style={draw=green!60!black, dotted, line width=1pt},
                                bracket/.style={thick, decoration={brace, mirror, raise=2pt}, decorate}
                            }
                            \node[anchor=south] at (15, 33) {\textbf{Limits of Accuracy on a Textbook}};
                            
                            
                            \draw[bookMax] (-1.5,-1.5) rectangle (26.5, 31.5);
                            
                            
                            \draw[bookActual] (0,0) rectangle (25,30);
                            \node[blue!40!black, font=\bfseries] at (12.5, 15) {English Textbook};
                            
                           
                            \draw[bookMin] (1.5,1.5) rectangle (23.5, 28.5);

                           
                            \draw[->, line width=0.8pt] (-4, 0) -- node[left] {Actual Length} (-4, 30);
                            \draw[red, dashed] (-1.5, 31.5) -- (2, 31.5) node[right, scale=0.75] {Maximum Length (+0.05 cm)};
                            \draw[green!50!black, dotted, thick] (1.5, 28.5) -- (5, 28.5) node[right, scale=0.75] {Minimum Length (-0.05 cm)};

                           
                            \draw[->, line width=0.8pt] (0, -4) -- node[below] {Actual Width} (25, -4);
                            
                            \draw[rounded corners, draw=gray!40, fill=gray!2] (38, 16) rectangle (88, 32);
                            \node[anchor=west] at (40, 29.5) {\textbf{Addition Rule:}};
                            \node[anchor=west, scale=0.85] at (42, 26) {$\bullet$ \textbf{Maximum Sum} = Maximum Length + Maximum Width};
                            \node[anchor=west, scale=0.85] at (42, 22) {$\bullet$ \textbf{Working Sum} = Working Length + Working Width};
                            \node[anchor=west, scale=0.85] at (42, 18) {$\bullet$ \textbf{Minimum Sum} = Minimum Length + Minimum Width};
                            

                            
                            \draw[rounded corners, draw=gray!40, fill=gray!2] (38, -3) rectangle (88, 13);
                            \node[anchor=west] at (40, 10.5) {\textbf{Subtraction Rule:}};
                            \node[anchor=west, scale=0.85] at (42, 7) {$\bullet$ \textbf{Maximum Difference} = Maximum Length $-$ \textcolor{red}{\textbf{Minimum}} Width};
                            \node[anchor=west, scale=0.85] at (42, 1) {$\bullet$ \textbf{Working Difference} = Working Length $-$ Working Width};
                            \node[anchor=west, scale=0.85] at (42, -3) {$\bullet$ \textbf{Minimum Difference} = Minimum Length $-$ \textcolor{red}{\textbf{Maximum}} Width};
                            

                        \end{tikzpicture}
                    </latex-image>
                </image>
            </figure>
            <p>
                Measure the working length and width of an English textbook and record in the table below.
            </p>
            <tabular top="medium" bottom="medium" left="medium" right="medium">
                <row header="yes">
                    <cell>Side</cell>
                    <cell>Measurement (cm)</cell>
                </row>
                <row>
                    <cell>Length</cell>
                    <cell>?</cell>
                </row>
                <row>
                    <cell>Width</cell>
                    <cell>?</cell>
                </row>
            </tabular>
            <p>
                <term>Find and calculate</term>
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The smallest unit of measurement.
                        </p>
                    </li>
                    <li>
                        <p>
                            The maximum and minimum errors of;
                        </p>
                        <p>
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Length
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Width
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                    <li>
                        <p>
                            Record the values obtained in the table below
                        </p>
                        <tabular top="medium" bottom="medium" left="medium" right="medium">
                            <row header="yes">
                                <cell>Side</cell>
                                <cell>Working Measurement</cell>
                                <cell>maximum Measurement</cell>
                                <cell>minimum Measurement</cell>
                            </row>
                            <row>
                                <cell>Length</cell>
                                <cell>?</cell>
                                <cell>?</cell>
                                <cell>?</cell>
                            </row>
                             <row>
                                <cell>Width</cell>
                                <cell>?</cell>
                                <cell>?</cell>
                                <cell>?</cell>
                            </row>
                        </tabular>
                    </li>
                </ol>
            </p>
            <p>
                <term>Additional Exploration:</term> In groups find:
            </p>
            <p>
                <ol>
                    <li>
                        <p>
                            Sum of actual length and;
                        </p>
                        <p>
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Working width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Maximum width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Minimum width
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                    <li>
                        <p>
                            Sum of maximum length and;
                        </p>
                        <p>
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Working width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Maximum width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Minimum width
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                    <li>
                        <p>
                            Sum of minimum length and;
                        </p>
                        <p>
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Working width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Maximum width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Minimum width
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                From the additional exploration above, what are:
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The maximum sum
                        </p>
                    </li>
                    <li>
                        <p>
                            The minimum sum
                        </p>
                    </li>
                    <li>
                        <p>
                            The working sum (use the formula:)
                        </p>
                        <p>
                            <md>
                                <mrow> \text{working sum} = \amp \; \text{working length} + \text{working width} </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                <term>Subtraction Exploration: </term> In groups find;
            </p>
            <p>
                <ol>
                    <li>
                        <p>
                            The difference between working length and;
                        </p>
                        <p>
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Working width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Maximum width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Minimum width
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                    <li>
                        <p>
                            The difference between maximum length and;
                        </p>
                        <p>
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Working width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Maximum width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Minimum width
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                    <li>
                        <p>
                            The difference between minimum length and;
                        </p>
                        <p>
                            <ol marker="(i)">
                                <li>
                                    <p>
                                        Working width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Maximum width
                                    </p>
                                </li>
                                <li>
                                    <p>
                                        Minimum width
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                From the subtraction exploration above, what are:
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The maximum difference
                        </p>
                    </li>
                    <li>
                        <p>
                            The minimum difference
                        </p>
                    </li>
                    <li>
                        <p>
                            The working difference (use the formula:)
                        </p>
                        <p>
                            <md>
                                <mrow> \text{working difference} = \amp \; \text{working length} - \text{working width} </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                <term>Calculate stepwise the following:</term>
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The absolute error in the addition?
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error in the addition?
                        </p>
                    </li>
                    <li>
                        <p>
                            The percentage error in the addition?
                        </p>
                    </li>
                    <li>
                        <p>
                            The absolute error in the difference?
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error in the difference?
                        </p>
                    </li>
                    <li>
                        <p>
                            The percentage error in the difference?
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                <term>Discuss and share with other groups:</term>
            </p>
            <p>
                The pattern observed in the addition and subtraction of errors. What do you notice about the maximum and minimum sums and differences?
            </p>
        </statement>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan" xml:id="lesson-plan-textbook-structured-instruction">
        <title>Structured Instruction: Formalizing Errors in Operations</title>
        <p>
            <ol marker="(a)">
                <li>
                    <title>Suggested Time</title>
                    <p>
                        15 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To formalize the core rules of error analysis: absolute errors accumulate (add up) during both addition and subtraction.
                    </p>
                </li>
            </ol>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol marker="(i)">
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Review the subtraction exploration. Point out that to get the widest possible space between two numbers (the maximum difference), you must subtract the minimum value from the maximum value (<m>\text{Max} - \text{Min}</m>).
                    </p>
                </li>
                <li>
                    <p>
                        <alert>The Pattern Concept:</alert> Explicitly formalize that whether you add or subtract measurements, their absolute errors always add together.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Relative and Percentage error Calculations:</alert> Remind students that relative error is always divided by the working value, and percentage error is simply the relative error multiplied by 100 %.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <insight>
        <p>
            <term>Observe and note that:</term>
        </p>
        <p>
            <md>
                <mrow> \text{Absolute error}\; = \amp \; \text{Maximum value} \; - \; \text{Working value} </mrow>
                <mrow> \text{Relative error} \; = \amp \; \frac{\text{Absolute error}}{\text{Working value}} </mrow>
                <mrow> \text{Percentage error} \; = \amp \; \text{Relative error} \; \times 100 \% </mrow>
            </md>
            
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->
     <example>
        <statement>
            <p>
                What is the error in the sum of <m>4.5</m> cm and <m>6.1</m> cm, if each represent a measurement?
            </p>
        </statement>
        <solution>
            <p>
                The limits within which the measurements lie are;
            </p>
            <p>
                <m>4.5</m> lies in <m>4.5 \pm 0.05</m> cm and <m>6.1</m> lies in <m>6.1 \pm 0.05</m>
            </p>
            <p>
                <md>
                    <mrow> \text{The maximum sum} \; = \amp \; 4.55 + 6.15 = 10.7 \;\text{cm} </mrow>
                    <mrow> \text{The minimum sum} \; =\amp \; 4.45 + 6.05 = 10.5 \;\text{cm} </mrow>
                    <mrow> \text{The working sum} \; = \amp \; 4.5 + 6.1 = 10.6 \;\text{cm} </mrow>
                    <mrow> \text{Absolute error} \; = \amp \; \text{maximum sum} - \text{working sum} </mrow>
                    <mrow> \amp = \; \left| 10.7 - 10.6 \right| </mrow>
                    <mrow> \amp = \; 0.1 \;\text{cm} </mrow>
                </md>
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                What is the error in the difference of <m>0.72</m> g and <m>0.31</m> g?
            </p>
        </statement>
        <solution>
            <p>
                The limits within which the measurements lie are;
            </p>
            <p>
                <m>0.72</m> lies in <m>0.72 \pm 0.005</m> g and <m>0.31</m> lies in <m>0.31 \pm 0.005</m>
            </p>
            <p>
                <md>
                    <mrow> \text{The maximum difference} \; = \amp \; 0.725 - 0.305 = 0.420 \;\text{g} </mrow>
                    <mrow> \text{The minimum difference} \; = \amp \; 0.715 - 0.315 = 0.400 \;\text{g} </mrow>
                    <mrow> \text{The working difference} \; = \amp \; 0.72 - 0.31 = 0.41 \;\text{g} </mrow>
                    <mrow> \text{Absolute error} \; = \amp \; \text{maximum difference} - \text{working difference} </mrow>
                    <mrow> =\amp \; \left| 0.42 - 0.41 \right| </mrow>
                    <mrow> =\amp \; 0.01 \;\text{g} </mrow>
                </md>
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                A rectangular card measures <m>5.3</m> cm by <m>2.5</m> cm. Find?
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The absolute error in the perimeter of the card.
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error in the perimeter of the card.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The absolute error in the perimeter of the card.
                        </p>
                        <p>
                            <md>
                                <mrow> \text{The length lies within} \; \amp \; 5.3 \pm 0.05 \;\text{cm} </mrow>
                                <mrow> \text{The width lies within} \; \amp \; 2.5 \pm 0.05 \;\text{cm} </mrow>
                                <mrow> \text{The maximum perimeter} \; =\amp \; 2(5.35 + 2.55) \;\text{cm} </mrow>
                                <mrow> =\amp \; 2(5.35 + 2.55) = 15.8 \;\text{cm} </mrow>
                                <mrow> \text{The minimum perimeter} \; = \amp \; 2(5.25 + 2.45) \;\text{cm} </mrow>
                                <mrow> =\amp \; 2(5.25 + 2.45) = 15.4 \;\text{cm} </mrow>
                                <mrow> \text{The working perimeter} \; = \amp \; 2(5.3 + 2.5) \;\text{cm} </mrow>
                                <mrow> =\amp \; 2(5.3 + 2.5) = 15.6 \;\text{cm} </mrow>
                                <mrow> \text{Absolute error} \; = \amp \; \text{maximum perimeter} - \text{working perimeter} </mrow>
                                <mrow> =\amp \; 0.2 \;\text{cm} </mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error in the perimeter of the card.
                        </p>
                        <p>
                            <md>
                                <mrow> \text{relative error} \; \amp = \; \frac{0.2}{15.6} </mrow>
                                <mrow> \amp = \; 0.0128 \;\text{cm} </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
     </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    Find the minimum and maximum possible sums of the following measurements;
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                               <m>10.34 \; \text{cm}</m> and <m>0.84 \;\text{cm}</m> 
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>8.63 \; \text{l}</m> and <m>3.25 \;\text{l}</m> 
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>450 \; \text{m}</m>, <m>32.6 \; \text{m}</m> and <m>0.39 \;\text{m}</m> 
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                               <md>
                                    <mrow>\text{minimum sum} \;  =  \amp \; 11.170 \; \text{cm} </mrow>
                                    <mrow>\text{maximum sum} \;  =  \amp \; 11.190 \; \text{cm} </mrow>
                                </md>
                            </p>
                        </li>
                        <li>
                            <p>
                                <md>
                                    <mrow>\text{minimum sum} \;  =  \amp \; 12.140 \; \text{l}</mrow>
                                    <mrow>\text{maximum sum} \;  =  \amp \; 12.160 \; \text{l}</mrow>
                               </md>
                            </p>
                        </li>
                        <li>
                            <p>
                                <md>
                                    <mrow>\text{minimum sum} \;  =  \amp \; 482.435 \; \text{m}</mrow>
                                    <mrow>\text{maximum sum} \;  =  \amp \; 483.545 \; \text{m}</mrow>
                               </md>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                   The first and the second athletes in a <m>9,200</m> m race were timed at <m>21.1</m> s, and <m>21.3</m> s respectively. Calculate the maximum and minimum possible differences between their times. 
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow>\text{minimum difference} \;  =  \amp \; 0.10 \; \text{s}</mrow>
                        <mrow>\text{maximum difference} \;  =  \amp \; 0.30 \; \text{s}</mrow>
                    </md>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Find the minimum possible perimeter of a regular pentagon whose side is <m>15.0</m> cm.
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow>\text{minimum perimeter} \;  =  \amp \; 74.75 \; \text{cm}</mrow>
                    </md>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Ten washers, each <m>3.7</m> mm in thickness, are piled one on top of the other. Find the maximum possible error in calculation of the height of the pile.
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow>\text{maximum error} \;  =  \amp \; 0.5 \; \text{mm}</mrow>
                    </md>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Temperatures, to the nearest <m>0.1 ^\circ \;\text{C}</m>, are stated as <m>a = 2.7 ^\circ \;\text{C}</m> and <m>b = 3.4 ^\circ\; \text{C}</m>, <m>c = 9.8 ^\circ \;\text{C}</m>, and <m>d = 3.0 ^\circ \;\text{C} </m>. Find the relative and percentage errors in each of the following expressions:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>a + b</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>d - c</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>a - b + c</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol>
                        <li>
                            <p>
                                <m>0.01639</m>, <m>1.639 \%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>0.01471</m>, <m>1.471 \%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>0.01648</m>, <m>1.648 \%</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
     </exercises>

    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan" xml:id="lesson-plan-textbook-differentiation">
        <title>Differentiation</title>

        <table>
            <title>Differentiation Strategies for Error Propagation</title>
            <tabular halign="left" top="medium" bottom="medium" left="medium" right="medium">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row bottom="minor">
                    <cell><alert>Struggling Learners (Support)</alert></cell>
                    <cell>
                        Use simpler whole-number measurements (e.g., Length = <m>20</m> cm, Width = <m>10</m> cm, with an error of <m>\pm 1</m> cm) to write out the addition and subtraction variations manually on cards before working with decimals.
                    </cell>
                </row>
                <row bottom="minor">
                    <cell><alert>On-Level Learners (Core)</alert></cell>
                    <cell>
                        Calculating combined sums and differences, and transitioning values into relative or percentage errors step-by-step.
                    </cell>
                </row>
                <row>
                    <cell><alert>Advanced Learners (Challenge)</alert></cell>
                    <cell>
                        Ask them to derive a general algebraic formula for the maximum percentage error.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

