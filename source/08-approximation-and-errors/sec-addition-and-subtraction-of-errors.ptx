    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    Find the minimum and maximum possible sums of the following measurements;
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                               <m>10.34 \; \text{cm}</m> and <m>0.84 \;\text{cm}</m> 
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>8.63 \; \text{l}</m> and <m>3.25 \;\text{l}</m> 
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>450 \; \text{m}</m>, <m>32.6 \; \text{m}</m> and <m>0.39 \;\text{m}</m> 
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                               <md>
                                    <mrow>\text{min} \;  =  \amp \; 11.170 \; \text{cm} </mrow>
                                    <mrow>\text{max} \;  =  \amp \; 11.190 \; \text{cm} </mrow>
                                </md>
                            </p>
                        </li>
                        <li>
                            <p>
                                <md>
                                    <mrow>\text{min} \;  =  \amp \; 12.140 \; \text{l}</mrow>
                                    <mrow>\text{max} \;  =  \amp \; 12.160 \; \text{l}</mrow>
                               </md>
                            </p>
                        </li>
                        <li>
                            <p>
                                <md>
                                    <mrow>\text{min} \;  =  \amp \; 482.435 \; \text{m}</mrow>
                                    <mrow>\text{max} \;  =  \amp \; 483.545 \; \text{m}</mrow>
                               </md>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                   The first and the second athletes in a <m>9,200</m> m race were timed at <m>21.1</m> s, and <m>21.3</m> s respectively. Calculate the maximum and minimum possible differences between their times. 
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow>\text{min} \;  =  \amp \; 0.10 \; \text{s}</mrow>
                        <mrow>\text{max} \;  =  \amp \; 0.30 \; \text{s}</mrow>
                    </md>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Find the minimum possible perimeter of a regular pentagon whose side is <m>15.0</m> cm.
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow>\text{min} \;  =  \amp \; 74.75 \; \text{cm}</mrow>
                    </md>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Ten washers, each <m>3.7</m> mm in thickness, are piled one on top of the other. Find the maximum possible erroe in calculation of the height of the pile.
                </p>
            </statement>
            <answer>
                <p>
                    <md>
                        <mrow>\text{max error} \;  =  \amp \; 0.5 \; \text{mm}</mrow>
                    </md>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Temperatures, to the nearest <m>0.1 ^\circ \;\text{C}</m>, are stated as <m>a = 2.7 ^\circ \;\text{C}</m> and <m>b = 3.4 ^\circ\; \text{C}</m>, <m>c = 9.8 ^\circ \;\text{C}</m>, and <m>d = 3.0 ^\circ \;\text{C} </m>. Find the relative and percentage errors in each of the following expressions:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>a + b</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>d - c</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>a - b + c</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol>
                        <li>
                            <p>
                                <m>0.01639</m>, <m>1.639 \%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>0.01471</m>, <m>1.471 \%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>0.01648</m>, <m>1.648 \%</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
     </exercises>

