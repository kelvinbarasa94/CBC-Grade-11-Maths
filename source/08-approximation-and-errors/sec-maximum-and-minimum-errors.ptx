    <!-- Add Activity -->

    <activity>
        <statement>
            <p>
                <term>Work in Groups to:</term>
            </p>
            <p>
                Measure the length of a mathematics textbook using a <m>30</m> cm ruler and compare your measurements with the other groups.
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                           Do you find the same measurements as the other groups? If not, what could be the reason for the different measurements? 
                        </p>
                    </li>
                    <li>
                        <p>
                            Could the measurement be slightly longer or shorter?
                        </p>
                    </li>
                    <li>
                        <p>
                            What is the smallest unit of measurement on the ruller?
                        </p>
                    </li>
                    <li>
                        <p>
                            Divide the smallest unit of measurement on the ruler by <m>2</m>?
                        </p>
                    </li>
                </ol>
            </p>
            <p>
                Use your group's length to find?
            </p>
            <p>
                <ol marker="(i)">
                    <li>
                        <p>
                            The sum of the working length and (d)?
                        </p>
                    </li>
                    <li>
                        <p>
                            The difference between the working length and (d)?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
    </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

