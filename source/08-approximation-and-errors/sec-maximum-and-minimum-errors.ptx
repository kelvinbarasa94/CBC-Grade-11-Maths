    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->


    <exercises>
        <exercise>
            <statement>   
                <p>
                    Find the limits within which the measurements below lie:
                </p> 
                <p>
                    <ol marker="(a)">
                        <li>
                            <m>45 </m> cm
                        </li>
                        <li>
                            <m>45.0 </m> cm
                        </li>
                        <li>
                            <m>45.00 </m> cm
                        </li>
                    </ol>
                </p>
            </statement>   
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <m>44.5 </m> cm and <m>45.5 </m> cm
                        </li>
                        <li>
                            <m>44.95 </m> cm and <m>45.05 </m> cm
                        </li>
                        <li>
                            <m>44.995 </m> cm and <m>45.005 </m> cm
                        </li>
                    </ol>
                </p>
            </answer>             
        </exercise>  
        <exercise>
            <statement>
                <p>
                    A length is measured as <m>8.6 </m> cm. Find the limits within which the measurement lies.
                </p>
            </statement>
            <answer>
                <p>
                    <m>8.55 </m> cm and <m>8.65 </m> cm
                </p>
            </answer>  
        </exercise>
        <exercise>
            <statement>
                    <p>
                        An angle was measured to the nearest degree as <m> 40^ \circ</m>. Calculate:
                    </p>
                    <p>
                        <ol marker="(a)">
                            <li>
                                <p>
                                    The maximum possible value of the stated angle.
                                </p>
                            </li>
                            <li>
                                <p>
                                    The minimum possible value of the stated angle.
                                </p>
                            </li>
                        </ol>
                    </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <m>40.5^ \circ</m>
                        </li>
                        <li>
                            <m> 39.5^ \circ</m>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
    </exercises>

