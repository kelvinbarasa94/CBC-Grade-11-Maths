<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-multiplication-of-errors" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Multiplication of Errors</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Approximation and Errors
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Perform propagation of errors using limits of measurements
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan" xml:id="lesson-plan-multiplication-discovery">
        <title>Problem-Solving and Discovery: Compounding Tolerances</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    25 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Students will gather real physical dimensions, determine maximum and minimum linear boundaries based on instrument precision, and discover how variations combine during multiplication.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Divide the class into small working units. Provide each team with a metric rule. Let them run measurements independently to build data structures. Walk around to ensure they are recording measurements to the nearest millimeter, meaning their operating upper and lower bounds will utilize a standard <m>\pm 0.05</m> cm limit of accuracy.
                </p>
            </li>
        </dl>
    </axiom>
        <activity>
            <statement>
                <p>
                    <term>Work in Groups</term> of <m>3 - 5</m> to study the diagram below and answer the questions that follow.
                </p>
                <p>
                    A nested geometric area diagram showing three distinct rectangular regions. The innermost region is outlined with a green dotted line representing the Minimum Area. The middle region is solid light blue representing the Working Area. The outermost region is outlined with a red dashed line representing the Maximum Area.
                </p>

                <figure xml:id="fig-textbook-area-multiplication-error">
                    <caption>Visualizing compounding limits of accuracy in area multiplication</caption>
                    <image xml:id="img-textbook-area-multiplication-error">
                        
                        <latex-image>
                            \begin{tikzpicture}[scale=0.15, every node/.style={font=\sffamily\small}]
                                
                                \tikzset{
                                    areaWorking/.style={fill=blue!10, draw=blue!60!black, line width=1.5pt},
                                    areaMax/.style={draw=red!60!black, dashed, line width=1pt, fill=red!5, opacity=0.4},
                                    areaMin/.style={draw=green!60!black, dotted, line width=1.2pt},
                                    dimension/.style={{Stealth}-{Stealth}, line width=0.8pt, gray!80!black}
                                }
                                
                                \draw[areaMax] (-1.5, -1.5) rectangle (36.5, 26.5);
                                
                                
                                \draw[areaWorking] (0, 0) rectangle (35, 25);
                                \node[blue!50!black, font=\bfseries\large] at (17.5, 12.5) {Working Area};
                                \node[blue!40!black, scale=0.85] at (17.5, 9) {Working Length $\times$ Working Width};

                                
                                \draw[areaMin] (1.5, 1.5) rectangle (33.5, 23.5);

                            
                                \node[red!80!black, anchor=west, scale=0.85] at (38, 25) {$\bullet$ \textbf{Maximum Area} = Maximum Length $\times$ Maximum Width};
                                \node[green!40!black, anchor=west, scale=0.85] at (38, 1.5) {$\bullet$ \textbf{Minimum Area} = Minimum Length $\times$ Minimum Width};
                                

                               
                                \draw[dimension] (0, -4) -- node[below] {Working Width} (35, -4);
                                \draw[red!70!black, dashed, line width=0.6pt] (-1.5, -6) -- (36.5, -6);

                               
                                \draw[dimension] (-4, 0) -- node[left, rotate=90, anchor=south] {Working Length} (-4, 35);

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </figure>

                <p>
                    <term>Work in Groups to:</term>
                </p>
                <p>
                    Measure the length and the width of a mathematics textbook and record in the table below.
                </p>
                <tabular bottom="medium" top="medium" left="medium" right="medium">
                    <row header="yes">
                        <cell>Side</cell>
                        <cell>Measurement</cell>
                    </row>
                    <row>
                        <cell>Length</cell>
                        <cell>?</cell>
                    </row>
                    <row>
                        <cell>Width</cell>
                        <cell>?</cell>

                    </row>
                </tabular>
                <p>
                    <term>In Groups you are required to:</term>
                </p>
                <p>
                    <ol>
                        <li>
                            <p>
                               Find the limits within which the length and the width of the textbook lie. 
                            </p>
                        </li>
                        <li>
                            <p>
                                Find the maximum, minimum, and actual area of the textbook.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find the limits within which the area of the textbook lie.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find the absolute error, relative error, and percentage error in the area of the textbook.
                            </p>
                        </li>
                    </ol>
                </p>
                <p>
                    <term>After the activity, discuss the following:</term>
                </p>
                <p>
                    <ol>
                        <li>
                            <p>
                                How did you find the limits within which the area of the textbook lie?
                            </p>
                        </li>
                        <li>
                            <p>
                                How did you find the absolute error, relative error, and percentage error in the area of the textbook?
                            </p>
                        </li>
                    </ol>
                </p>
                
            </statement>
        </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan" xml:id="lesson-plan-multiplication-structured">
        <title>Structured Instruction: Formalizing Product Errors</title>
        <p>
            <dl>
                <li>
                    <title>Suggested Time</title>
                    <p>
                        15 minutes
                    </p>
                </li>
                <li>
                    <title>Objective</title>
                    <p>
                        To formalize formulas for maximum, working, and minimum areas and analyze relative errors in calculated products.
                    </p>
                </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol marker="(a)">
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Use the students' results to highlight that <m>\text{Maximum Area} = \text{Maximum Length} \times \text{Maximum Width}</m> and <m>\text{Minimum Area} = \text{Minimum Length} \times \text{Minimum Width}</m>. Explain that this boundary defines the limits within which the area must lie.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Absolute Error in Products:</alert> Show students that absolute error in multiplication is obtained by computing <m>\text{Maximum Area} - \text{Working Area}</m> (or half the difference between Maximum and Minimum Area).
                    </p>
                </li>
                <li>
                    <p>
                        <alert>The Core Concept Pattern:</alert> Conclude the formalization phase by highlighting that percentage errors accumulate when quantities are multiplied or divided.
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

    <insight>
        <p>
            The limits within which the area of the textbook lie is found by finding the maximum and minimum area of the textbook.
        </p>
        <p>
            The maximum area is found by multiplying the maximum length and the maximum width, while the minimum area is found by multiplying the minimum length and the minimum width.
        </p>
        <p>
            The absolute error is found by subtracting the actual area from the maximum area, while the relative error is found by dividing the absolute error by the actual area.
        </p>
        <p>
            The percentage error is found by multiplying the relative error by <m>100 \%</m>.
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->
     <example>
        <statement>
            <p>
                The radius and height of a cylindrical mug are <m>4.5</m> cm and <m>8.2</m> cm respectively. Find the limits within which its capacity lies (leave your answer in terms of <m>\pi</m>).
            </p>
        </statement>
        <solution>
            <p>
                Capacity of a cylinder is given by the formula <m>V = \pi r^2 h</m>, where <m>r</m> is the radius and <m>h</m> is the height. The maximum and minimum capacity of the mug is given by:
            </p>
            <p>
                <md>
                    <mrow> \text{Maximum} \; \amp = \; \pi (4.55)^2 (8.25)\;\text{cm}^3 </mrow>
                    <mrow> \amp = \; 170.8 \pi \;\text{cm}^3 </mrow>
                    <mrow> \text{Minimum} \; \amp = \; \pi (4.45)^2 (8.15) \;\text{cm}^3</mrow>
                    <mrow> \amp = \; 160.4 \pi \;\text{cm}^3 </mrow>
                </md>
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                The measurements of a rectangular card is given as <m>10.3</m> cm by <m>5.2</m> cm. Find:
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The absolute error in the area of the card.
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error in the area of the card.
                        </p>
                    </li>
                    <li>
                        <p>
                            The percentage error in the area of the card.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The limits within which the measurements lie are <m>10.25 \leq l \leq 10.35</m> cm, and <m>5.15 \leq w \leq 5.25</m> cm. The working area of the card is given by <m>A = l \times w</m>, where <m>l</m> is the length and <m>w</m> is the width. The maximum and minimum area of the card is given by:
                        </p>
                        <p>
                            <md>
                                <mrow> \text{Maximum} \; \amp = \; 10.35 \times 5.25 </mrow>
                                <mrow> \amp = \; 54.34 \;\text{cm}^2 </mrow>
                                <mrow> \text{Minimum} \; \amp = \; 10.25 \times 5.15 </mrow>
                                <mrow> \amp = \; 52.79 \;\text{cm}^2 </mrow>
                                <mrow> \text{Working area} \; \amp = \; 10.3 \times 5.2 </mrow>
                                <mrow> \amp = \; 53.56 \;\text{cm}^2 </mrow>
                                <mrow> \text{Absolute error} \; = \text{Maximum} - \text{Working area} </mrow>
                                <mrow> \amp = \; 54.34 - 53.56 </mrow>
                                <mrow> \amp = \; 0.78 \;\text{cm}^2 </mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error in the area of the card.
                        </p>
                        <p>
                            <md>
                                <mrow> \text{Relative error} \; \amp = \; \frac{\text{Absolute error}}{\text{Working area}}  </mrow>
                                <mrow> \amp = \; \frac{0.78}{53.56} </mrow>
                                <mrow> \amp = \; 0.01456 </mrow>
                            </md>
                            
                        </p>
                    </li>
                    <li>
                        <p>
                            The percentage error in the area of the card.
                        </p>
                        <p>
                            <md>
                                <mrow> \text{Percentage error} \; \amp = \; \text{Absolute error} \times 100 \% </mrow>
                                <mrow> \amp = \; 0.01456 \times 100 \% </mrow>
                                <mrow> \amp = \; 1.456 \% </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
            
        </solution>
     </example>
     <example>
        <statement>
            <p>
                The dimmensions of a rectangle are <m>10</m> cm and <m>15</m> cm. If there is an error of <m>5 \% </m> in each of the measurements, Find the percentage error in the area of the rectangle.
            </p>
        </statement>
        <solution>
            <p>
                <md>
                    <mrow> \text{Maximum length} \; \amp = \; 15 + \frac{5}{100} \times 15 </mrow>
                    <mrow> \amp = \; 15 + 0.75 </mrow>
                    <mrow> \amp = \; 15.75 </mrow>
                    <mrow>\text{Maximum width} \; \amp = \; 10 + \frac{5}{100} \times 10 </mrow>
                    <mrow> \amp = \; 10 + 0.5 </mrow>
                    <mrow> \amp = \; 10.5 </mrow>
                    <mrow> \text{Maximum area} \; \amp = \; 15.75 \times 10.5 </mrow>
                    <mrow> \amp = \; 165.375 \;\text{cm}^2 </mrow>
                    <mrow> \text{Working area} \; \amp = \; 15 \times 10 </mrow>
                    <mrow> \amp = \; 150 \;\text{cm}^2 </mrow>
                    <mrow> \text{Absolute error} \; \amp = \;165.375 - 150 </mrow>
                    <mrow> \amp = \;15.375 \;\text{cm}^2 </mrow>
                    <mrow> \text{Percentage error} \; \amp = \; \frac{\text{Absolute error}}{\text{Working area}} \times 100 \% </mrow>
                    <mrow> \amp = \; \frac{15.375}{150} \times 100 \% </mrow>
                    <mrow> \amp = \; 10.25 \% </mrow>
                </md>
            </p>
        </solution>
     </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>
                    Find the percentage error in the calculation of the volume of a sphere with a radius of <m>4.9</m> cm.
                </p>
            </statement>
            <answer>
                <p>
                    <m>3.06 \%</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                  The dimension of a box of matches are stated as <m>5.2</m> cm <m>\times 3.8</m> cm <m>\times 1.5</m> cm. Within which limit does its:   
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                Volume lie.
                            </p>
                        </li>
                        <li>
                            <p>
                                Surface area lie.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                               <md>
                                    <mrow> \text{Min} \; \amp = \; 28.00 \text{ cm}^3 </mrow>
                                    <mrow> \text{Max} \; \amp = \; 31.33 \text{ cm}^3 </mrow>

                                </md> 
                            </p>
                        </li>
                        <li>
                            <p>
                                <md>
                                    <mrow> \text{Min} \; \amp = \; 64.435 \text{ cm}^2 </mrow>
                                    <mrow> \text{Max} \; \amp = \; 68.635 \text{ cm}^2 </mrow>

                                </md> 
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A triangle ABC is right angled at B, with <m> AB = 5 \text{ cm} </m>, <m> BC = 12 \text{ cm} </m>, to the nearest centimeter. Find the percentage error (to 4 s.f.) in the calculation of the area of the triangle using the formulae:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>A = \frac{1}{2} \times b \times h </m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>A = \sqrt{s(s-a)(s-b)(s-c)} </m>
                            </p>
                        </li>
                        <li>
                            <p> The hypotenuse AC is measured as <m>13 \text{ cm} </m> to the nearest centimeter, and the angle <m>\angle BCA</m> is measured as <m>23^\circ</m>, to the nearest degree.  Find the percentage error (to 4 s.f.) in the calculation of the area of the triangle using the formula:
                                <m> A = \frac{1}{2} \times BC \times AC \times \sin \angle BCA </m>
                            </p>
                        </li>
                        <li>
                            <p>
                                Which of these methods is most accurate? Why do you think this is the case?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                Working area:
                            </p>
                            <p>
                                <md>
                                    <mrow> A_0 \amp = \frac{1}{2} \times 5 \times 12 </mrow>
                                    <mrow> \amp = 30\text{ cm}^2 </mrow>
                                </md>
                            </p>
                            <p>
                                Since the measurements are to the nearest centimeter,
                                <m>4.5 \leq AB \leq 5.5</m>, <m>11.5 \leq BC \leq 12.5</m>.
                            </p>
                            <p>
                                <md>
                                    <mrow> A_{\max} \amp = \frac{1}{2} \times 5.5 \times 12.5 </mrow>
                                    <mrow> \amp = 34.375\text{ cm}^2 </mrow>
                                    <mrow> \text{Absolute error} \amp = A_{\max} - A_0 </mrow>
                                    <mrow> \amp = 34.375 - 30 </mrow>
                                    <mrow> \amp = 4.375 </mrow>
                                    <mrow> \text{Percentage error} \amp = \frac{4.375}{30} \times 100\% </mrow>
                                    <mrow> \amp = 14.58\% </mrow>
                                </md>
                            </p>
                        </li>
                        <li>
                            <p>
                                Using Heron's formula <m>A = \sqrt{s(s-a)(s-b)(s-c)}</m>:
                            </p>
                            <p>
                                Working sides are <m>a=5</m>, <m>b=12</m>, <m>c=\sqrt{5^2+12^2}=13</m>.
                            </p>
                            <p>
                                <md>
                                    <mrow> s_0 \amp = \frac{5+12+13}{2} </mrow>
                                    <mrow> \amp = 15 </mrow>
                                    <mrow> A_0 \amp = \sqrt{15(15-5)(15-12)(15-13)} </mrow>
                                    <mrow> \amp = 30\text{ cm}^2 </mrow>
                                </md>
                            </p>
                            <p>
                                At upper limits: <m>a=5.5</m>, <m>b=12.5</m>,
                                <m>c=\sqrt{5.5^2+12.5^2}=13.6565\ldots</m>.
                            </p>
                            <p>
                                <md>
                                    <mrow> s_{\max} \amp = \frac{5.5+12.5+13.6565\ldots}{2} </mrow>
                                    <mrow> \amp = 15.8283\ldots </mrow>
                                </md>
                            </p>
                            <p>
                                <md>
                                    <mrow> A_{\max} \amp = \sqrt{s_{\max}(s_{\max}-5.5)(s_{\max}-12.5)(s_{\max}-13.6565\ldots)} </mrow>
                                    <mrow> \amp = 34.375\text{ cm}^2 </mrow>
                                </md>
                            </p>
                            <p>
                                <md>
                                    <mrow> \text{Percentage error} \amp = \frac{34.375-30}{30}\times 100\% </mrow>
                                    <mrow> \amp = 14.583\ldots\% </mrow>
                                </md>
                            </p>
                            <p>
                                <m>\therefore\; 14.58\%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                Using <m>A = \frac{1}{2}\times BC\times AC\times \sin\angle BCA</m>, and treating all measured quantities as having error.
                            </p>
                            <p>
                                Working values are <m>BC=12</m>, <m>AC=13</m>, <m>\angle BCA=23^\circ</m>.
                            </p>
                            <p>
                                <md>
                                    <mrow> A_0 \amp = \frac{1}{2}\times 12\times 13\times \sin 23^\circ </mrow>
                                    <mrow> \amp = 30.477\ldots\text{ cm}^2 </mrow>
                                </md>
                            </p>
                            <p>
                                Since measurements are to the nearest unit,
                                <m>11.5\le BC\le 12.5</m>,
                                <m>12.5\le AC\le 13.5</m>,
                                <m>22.5^\circ\le C\le 23.5^\circ</m>.
                            </p>
                            <p>
                                <md>
                                    <mrow> A_{\max} \amp = \frac{1}{2}\times 12.5\times 13.5\times\sin 23.5^\circ </mrow>
                                    <mrow> \amp = 33.6445\ldots\text{ cm}^2 </mrow>
                                </md>
                            </p>
                            <p>
                                <md>
                                    <mrow> A_{\min} \amp = \frac{1}{2}\times 11.5\times 12.5\times\sin 22.5^\circ </mrow>
                                    <mrow> \amp = 27.5104\ldots\text{ cm}^2 </mrow>
                                </md>
                            </p>
                            <p>
                                <md>
                                    <mrow> \text{Maximum absolute error} \amp = \max(A_{\max}-A_0,\,A_0-A_{\min}) </mrow>
                                    <mrow> \amp = 3.1674\ldots </mrow>
                                </md>
                            </p>
                            <p>
                                <md>
                                    <mrow> \text{Percentage error} \amp = \frac{3.1674\ldots}{30.4770\ldots}\times 100\% </mrow>
                                    <mrow> \amp = 10.39\ldots\% </mrow>
                                </md>
                            </p>
                            <p>
                                <m>\therefore\; 10.39\%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                The most accurate method here is part <m>(c)</m>, with percentage error <m>10.39\%</m>, which is smaller than parts <m>(a)</m> and <m>(b)</m> (both <m>14.58\%</m>). This is because the relative errors in <m>BC</m>, <m>AC</m> and <m>\sin C</m> combine to a smaller overall effect than using <m>AB=5</m>, since 0.5 is a larger percentage of 5 than of 12 or 13. 
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
    </exercises>
    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan" xml:id="lesson-plan-multiplication-differentiation">
        <title>Differentiation</title>

        <table>
            <title>Differentiation Strategies for Error Multiplication</title>
            <tabular halign="left" top="medium" bottom="medium" left="medium" right="medium">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row bottom="minor">
                    <cell><alert>Struggling Learners (Support)</alert></cell>
                    <cell>
                        Provide pre-rounded whole numbers for a temporary practice example (e.g., a card measuring <m>10</m> cm by <m>5</m> cm with a <m>\pm 1</m> cm error limit) so they master the sequence of multiplying regional boundaries before tracking decimal values.
                    </cell>
                </row>
                <row bottom="minor">
                    <cell><alert>On-Level Learners (Core)</alert></cell>
                    <cell>
                        Calculating bounds of accuracy in the activity, executing product calculations, and finding relative or percentage errors.
                    </cell>
                </row>
                <row>
                    <cell><alert>Advanced Learners (Challenge)</alert></cell>
                    <cell>
                        Have them inspect exercise question 3. Ask them to write down why changing the mathematical formula used to calculate an area dramatically alters the resulting calculation's percentage error.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

    <xi:include href="../lesson-plan-templates/assessment-methods.ptx" />

    <xi:include href="../lesson-plan-templates/reflection.ptx"/>
</section>
