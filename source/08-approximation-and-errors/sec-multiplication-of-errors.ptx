        <activity>
            <statement>
                <p>
                    <term>Work in Groups to:</term>
                </p>
                <p>
                    Measure the length and the width of a mathematics textbook and record in the table below.
                </p>
                <tabular bottom="medium" top="medium" left="medium" right="medium">
                    <row header="yes">
                        <cell>Side</cell>
                        <cell>Measurement</cell>
                    </row>
                    <row>
                        <cell>Length</cell>
                        <cell>?</cell>
                    </row>
                    <row>
                        <cell>Width</cell>
                        <cell>?</cell>

                    </row>
                </tabular>
                <p>
                    <term>In Groups you are required to:</term>
                </p>
                <p>
                    <ol>
                        <li>
                            <p>
                               Find the limits within which the length and the width of the textbook lie. 
                            </p>
                        </li>
                        <li>
                            <p>
                                Find the maximum, minimum, and actual area of the textbook.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find the limits within which the area of the textbook lie.
                            </p>
                        </li>
                        <li>
                            <p>
                                Find the absolute error, relative error, and percentage error in the area of the textbook.
                            </p>
                        </li>
                    </ol>
                </p>
                <p>
                    <term>After the activity, discuss the following:</term>
                </p>
                <p>
                    <ol>
                        <li>
                            <p>
                                How did you find the limits within which the area of the textbook lie?
                            </p>
                        </li>
                        <li>
                            <p>
                                How did you find the absolute error, relative error, and percentage error in the area of the textbook?
                            </p>
                        </li>
                    </ol>
                </p>
                
            </statement>
        </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <!-- <axiom component="lesson-plan">
