<?xml version="1.0" encoding="utf-8"?>

<section xml:id="sec-division-of-errors" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Division of Errors</title>
    <!--  -->
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Approximation and Errors
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Perform propagation of errors using limits of measurements
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

    <!-- [LP] Add guidance on activity -->

    <axiom component="lesson-plan" xml:id="lesson-plan-division-discovery">
        <title>Problem-Solving and Discovery: Desk Dimension Ratios</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    40 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Learner will investigate how upper and lower measurement boundaries interact dynamically during division to alter the scale of resulting quotients.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Move around the room to ensure groups establish correct absolute error. Help learners discover during calculations how to choose a larger or smaller value for the denominator shifts their output.
                </p>
            </li>
        </dl>
    </axiom>
        <activity>
            <statement>
                <p>
                    <term>Work in Groups</term> of 3-4 learners.
                </p>

                <p>
                    Using a ruler or tape measure, measure the length and width of your desk to the nearest centimetre.
                </p>

                <p>
                    Record your results in the table below.
                </p>

                <tabular left="medium" right="medium" top="medium" bottom="medium">
                    <row header="yes">
                        <cell>Quantity</cell>
                        <cell>Measurement (cm)</cell>
                        <cell>Minimum Value</cell>
                        <cell>Maximum Value</cell>
                    </row>
                    <row>
                        <cell>Length</cell>
                        <cell></cell>
                        <cell></cell>
                        <cell></cell>
                    </row>
                    <row>
                        <cell>Width</cell>
                        <cell></cell>
                        <cell></cell>
                        <cell></cell>
                    </row>
                </tabular>

                <p>
                    <term>Instructions</term>
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                Determine the minimum and maximum possible values for the length and width.
                            </p>
                        </li>

                        <li>
                            <p>
                                Calculate the ratio
                                <m>\frac{\text{Length}}{\text{Width}}</m>
                                using the measured values.
                            </p>
                        </li>

                        <li>
                            <p>
                                Calculate the maximum possible value of the ratio.
                            </p>
                        </li>

                        <li>
                            <p>
                                Calculate the minimum possible value of the ratio.
                            </p>
                        </li>

                        <li>
                            <p>
                                Compare your answers with those of other groups.
                            </p>
                        </li>
                    </ol>
                </p>

                

                <p>
                    <term>Class Discussion</term>
                </p>

                <p>
                    Which combination of measurements produces the largest ratio? Which combination produces the smallest ratio?
                </p>
            </statement>
        </activity>

    <!-- [LP] Add guidance on structured lesson plan-->

    <axiom component="lesson-plan" xml:id="lesson-plan-division-structured">
        <title>Structured Instruction: Formalizing Division Rules</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the specific inverse relationships discovered during the desk anchor task.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Key Takeaways &amp; Teacher Connection</title>
            <ol>
                <li>
                    <p>
                        <alert>Connecting to Learner Work:</alert> Walk around to review group working. Emphasize that the highest ratio did not come from dividing maximum length by maximum width. Instead, it required the maximum numerator to be paired with the minimum denominator.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>The Inverse Denominator Property:</alert> Formalize that division features an inverse relationship with the divisor. A smaller divisor increases the size of the share, while a larger divisor reduces it.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Synthesizing Quotient Bounds:</alert> Write out the operational rules explicitly:
                        <md>
                            <mrow>\text{Maximum Quotient} \amp = \frac{\text{Maximum Numerator}}{\text{Minimum Denominator}}</mrow>
                            <mrow>\text{Minimum Quotient} \amp = \frac{\text{Minimum Numerator}}{\text{Maximum Denominator}}</mrow>
                        </md>
                    </p>
                </li>
            </ol>
        </paragraphs>
    </axiom>

   <insight>
    <p>
        We calculate the absolute error, relative error and percentage error using the following formulae;
    </p>
    <p>
        <md>
            <mrow> \text{Absolute error} \; = \amp \; \text{Maximum value}\; - \;\text{Working value} or </mrow>
            <mrow> \text{Absolute error} \; = \amp \; \text{Working value}\; - \;\text{Minimum value} </mrow>
            <mrow> \text{Relative error} \; = \amp \; \frac{\text{Absolute error}}{\text{Working value}} </mrow>
            <mrow> \text{Percentage error} \; = \amp \; \text{Relative error} \times 100\% </mrow>
        </md>
        
    </p>
    <p>
        <term>Note:</term> The absolute error tells us the size of the mistake, while the percentage error tells us how significant that mistake is compared to the total size of the object.
    </p>
   </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->
     <example>
        <statement>
            <p>
                A sprinter runs a <m>100</m> m dash. The distance is accurate to the nearest <m>1</m> m. His time is recorded as <m>10</m> seconds to the nearest <m>1</m> second. Calculate the maximum possible speed.
            </p>
        </statement>
        <solution>
            <p>
                The limits for distance are; <m>100 \pm 0.5</m> m
            </p>
            <p>
                The limits for time are; <m>10 \pm 0.5</m> seconds
            </p>
            <p>
                Apply the division rule for maximum possible value of the quotient, we have;
            </p>
            <p>
                <md>
                    <mrow> \text{Maximum speed} \amp = \; \frac{\text{Maximum distance}}{\text{Minimum time}} </mrow>
                    <mrow> \amp = \; \frac{100.5}{9.5} </mrow>
                    <mrow> \amp = \; 10.6 \; \text{m/s to 3 significant figures} </mrow>
                </md>
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                A bag of sugar costs Sh. <m>150</m> (measured to the nearest Sh. <m>10</m>). The bag weighs <m>2</m> kg (measured to the nearest <m>0.1</m> kg). Find the minimum possible price per kg.
            </p>
        </statement>
        <solution>
            <p>
                The limits for price are; <m>150 \pm 5</m> shillings
            </p>
            <p>
                The limits for weight are; <m>2 \pm 0.05</m> kg
            </p>
            <p>
                To find the minimum possible price per kg, we use the minimum price and the maximum weight.
            </p>
            <p>
                <md>
                    \text{Minimum price per kg} = \frac{\text{Minimum price}}{\text{Maximum weight}} = \frac{145}{2.05} = 70.7 \; \text{shillings / kg to 3 significant figures}
                </md>
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                A piece of metal has a mass of <m>20.4</m> g and a volume of <m>5.0</m> cm<m>^3</m>, both measured to <m>1</m> decimal place. Calculate the absolute error in its density.
            </p>
        </statement>
        <solution>
            <p>
                The limits for mass are; <m>20.4 \pm 0.05</m> g
            </p>
            <p>
                The limits for volume are; <m>5.0 \pm 0.05</m> cm<m>^3</m>
            </p>
            <p>
                The density is given by <m>\rho = \frac{m}{V}</m>.
            </p>
            <p>
                To find the absolute error in the density, we use the maximum and minimum values of mass and volume.
            </p>
            <p>
                <md>
                    \text{Maximum density} = \frac{\text{Maximum mass}}{\text{Minimum volume}} = \frac{20.45}{4.95} = 4.13 \; \text{g / cm}^3
                </md>
            </p>
            <p>
                <md>
                    \text{Minimum density} = \frac{\text{Minimum mass}}{\text{Maximum volume}} = \frac{20.35}{5.05} = 4.03 \; \text{g / cm}^3
                </md>
            </p>
            <p>
                The working density is <m>\rho = \frac{20.4}{5.0} = 4.08 \; \text{g / cm}^3</m>.
            </p>
            <p>
                The absolute error in the density is;
            </p>
            <p>
                <md>
                    <mrow>\frac{4.13 - 4.03}{2} \amp = \; \frac{1}{2} \times 0.10</mrow>
                    <mrow> \amp = \; 0.050 \; \text{g / cm}^3 \text{ to 2 significant figures} </mrow>
                </md>
            </p>

        </solution>

     </example>
     <example>
        <statement>
            <p>
                Given <m>8.6</m> cm <m>\div </m> <m>3.4</m> cm, Find?
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The absolute error in the quotient.
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error in the quotient.
                        </p>
                    </li>
                    <li>
                        <p>
                            The percentage error in the quotient.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>8.6</m> cm has limits <m>8.55</m> cm and <m>8.65</m> cm. <m>3.4</m> cm has limits <m>3.35</m> cm and <m>3.45</m> cm. The maximum possible quotient will be given by the maximum possible value of the numerator and the smallest possible value of the denominator, i.e
                        </p>
                        <p>
                            <m>\frac{8.65}{3.35} = 2.58 </m> (to <m>3</m> significant figures). 
                        </p>
                        <p>
                            The minimum possible quotient will be given by the minimum possible value of the numerator and the largest possible value of the denominator, i.e
                        </p>
                        <p>
                            <m>\frac{8.55}{3.45} = 2.48 </m> (to <m>3</m> significant figures).
                        </p>
                        <p>
                            The working quotient is <m>\frac{8.6}{3.4} = 2.53 </m> (to <m>3</m> significant figures). 
                        </p>
                        <p>
                            The absolute error in the quotient is;
                        </p>
                        <p>
                            <md>
                                <mrow> \frac{2.58 - 2.48}{2} \amp = \; \frac{1}{2} \times 0.10 </mrow>
                                <mrow> \amp = \; 0.050 \; \text{cm to 2 significant figures} </mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            The relative error is
                        </p>
                        <p>
                            <md>
                                <mrow>\frac{0.05}{2.53} \amp = \; 0.0197 </mrow>
                                <mrow> \amp = \; 0.020 \; \text{to 2 significant figures} </mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            Percentage error is;
                        </p>
                        <p>
                            <md>
                                <mrow> \% \text{error} \amp = \; \text{Relative error} \times 100 \% </mrow>
                                <mrow> \amp = \; 0.020 \times 100 \% </mrow>
                                <mrow> \amp = \; 2.0 \% \; \text{to 2 significant figures} </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
     </example>

    <xi:include href="../lesson-plan-templates/assessment-intro.ptx" />

    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                   A bus travels <m>60</m> km in <m>1.5</m> hours. What is the lowest possible average speed? 
                </p>
            </statement>
            <answer>
                <p>
                    <m>38.39</m> km / h
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A floor of a room has an area of <m>12</m> m<m>^2</m>, it is to be tiled with tiles of area <m>0.25</m> m<m>^2</m>. What is the maximum number of tiles needed to cover the floor?
                </p>
            </statement>
            <answer>
                <p>
                    <m>52</m> tiles
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A farmer harvests <m>500</m> kg of maize (nearest <m>10</m> kg) from a field of <m>2.5</m> hectares (nearest <m>0.5</m> ha). Calculate the percentage error in the yield per hectare.
                </p>
            </statement>
            <answer>
                <p>
                    <m>11 \%</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A solution has <m>10</m> grams of salt (nearest gram) dissolved in <m>2</m> litres of water (nearest <m>0.2</m> litres). Find the range (min and max) of the concentration in g/l.
                </p>
            </statement>
            <answer>
                <p>
                    <m>4.52 \text{ g / l} \leq \text{concentration} \leq 5.53 \text{ g / l}</m>
                </p>
            </answer>
        </exercise>
     </exercises>

    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan" xml:id="lesson-plan-division-differentiation">
        <title>Differentiation</title>

        <table>
            <title>Differentiation Strategies for Desk Ratio Estimation</title>
            <tabular halign="left" top="medium" bottom="medium" left="medium" right="medium">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row bottom="minor">
                    <cell><alert>Struggling Learners (Support)</alert></cell>
                    <cell>
                        Provide small numeric substitution cards showing simple integers (e.g., <m>\frac{10}{2}</m>, <m>\frac{10}{5}</m>) to help them manually observe how expanding a divisor shrinks a quotient before dealing with decimal desk data.
                    </cell>
                </row>
                <row bottom="minor">
                    <cell><alert>On-Level Learners (Core)</alert></cell>
                    <cell>
                        Determine raw physical dimensions, calculate boundary values, absolute, relative, and percentage errors.
                    </cell>
                </row>
                <row>
                    <cell><alert>Advanced Learners (Challenge)</alert></cell>
                    <cell>
                        Challenge learners to analyze Exercise 3 (the agricultural yield problem). Have them justify why the maximum crop yield calculation matches the maximum harvest weight divided by the minimum farm land area.
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

    <xi:include href="../lesson-plan-templates/assessment-methods.ptx" />

    <xi:include href="../lesson-plan-templates/reflection.ptx"/>
</section>
