<section xml:id="sec-absolute-relative-and-percentage-errors" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Absolute, Relative, and Percentage Errors</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurement and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Approximation and Errors
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                        Determine absolute, relative and percentage errors from measurements
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
        </introduction>
    </objectives>

