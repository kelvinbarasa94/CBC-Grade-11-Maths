    <insight>
        <p>
            <term>An absolute error:</term> is the difference between the measured value and the actual value.
        </p>
        <p>
            <md>
                <mrow> \text{Absolute error} = \amp \; \text{measured value} - \text{actual value} </mrow>
            </md>
            
        </p>
        <p>
            <term>Relative error:</term> is the quotient of the absolute error and the actual value.
        </p>
        <p>
            <md>
                <mrow>\text{Relative error} = \amp \; \text{absolute error} \div \text{actual value} </mrow>
            </md>
            
        </p>
        <p>
            <term>Percentage error:</term> is the quotient of the absolute error and the actual value multiplied by <m>100 \%</m>.
        </p>
        <p>
            <md>
                <mrow>\text{Percentage error} = \amp \; \frac{\text{absolute error}}{\text{actual value}} \; \times 100 \% </mrow>
                <mrow> = \amp \; \text{Relative erroe} \times 100 \% </mrow>
            </md>
            
        </p>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->
     <example>
        <statement>
            <p>
                The capacity of a gourd is stated as <m>2,000</m> millilitres to the nearest <m>10</m> millilitres. Find:
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The limit within which the capacity lies.
                        </p>
                    </li>
                    <li>
                        <p>
                            The percentage error.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The limit within which the capacity lies.
                        </p>
                        <p>
                            Absolute error is <m>\frac{1}{2} \times 10 = 5 \;\text{ml} </m>
                        </p>
                        <p>
                            Lowest possible capacity is <m>2,000 \;\text{ml} - 5\;\text{ml}\; = 1,995 \;\text{ml} </m>
                        </p>
                        <p>
                           Highest possible capacity is <m>2,000 \;\text{ml} + 5\;\text{ml}\; = 2,005 \;\text{ml} </m>  
                        </p>
                    </li>
                    <li>
                        <p>
                            The percentage error.
                        </p>
                        <p>
                            <md>
                                <mrow> 
                                \text{Percentage error} \; = \amp \; \frac{\text{absolute error}}{\text{actual measurement}} \; \times 100 \% </mrow>
                                <mrow> = \amp \; \frac{5 \; \text{ml}}{2,000 \;\text{ml}}\; \times 100 \% </mrow>
                                <mrow> = \amp \; 0.25 \% </mrow>
                            </md>
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
     </example>
     <example>
        <statement>
            <p>
                The thickness of a coin is <m>0.20</m> cm.
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            What is the percentage error?
                        </p>
                    </li>
                    <li>
                        <p>
                            What would be the percentage error if its thickness was stated as <m>0.2</m> cm?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            The smallest unit of measurement is <m>0.01</m>.
                        </p>
                        <p>
                            <md>
                                <mrow> \text{Absolute error} \; = \amp \; \frac{1}{2} \times 0.01 </mrow>
                                <mrow> = \amp \; 0.005 </mrow>
                                <mrow> \text{Percentage error} \; = \amp \; \frac{0.005}{0.20} \times 100 \% </mrow>
                                <mrow> = \amp \; 2.5 \% </mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            The smallest unit of measurement is <m>0.1</m>.
                        </p>
                        <p>
                            <md>
                                <mrow> \text{Absolute error} \; = \amp \; \frac{1}{2} \times 0.1 </mrow>
                                <mrow> = \amp \; 0.05 \;\text{cm}</mrow> 
                                <mrow> \text{Percentage error} \; = \amp \; \frac{0.05}{0.2} \times 100 \% </mrow>
                                <mrow> = \amp \; 25 \% </mrow>
                            </md>
                            
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
     </example>

