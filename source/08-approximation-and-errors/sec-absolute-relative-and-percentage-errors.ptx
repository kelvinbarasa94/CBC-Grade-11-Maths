    <!-- If STACK questions are included, uncomment this: -->

    <!-- <xi:include href="../lesson-plan-templates/checkpoint.ptx" /> -->

    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    Find the absolute error, relative error, and percentage error in each of the following measurements:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m> 45.138 \;\text{s}</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> 0.45 \;\text{g} </m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> 7.62 \;\text{l} </m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>12.004 \;\text{cm}</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>2505 \;\text{tonnes}</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m>0.005</m> ; <m>0.0001</m>, and <m>0.011 \%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>0.005</m> ; <m>0.0111</m>, and <m>1.11 \%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                               <m>0.005</m> ; <m>0.0007</m>, and <m>0.066 \%</m> 
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>0.0005</m> ; <m>0.00004</m>, and <m>0.0042 \%</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>0.5</m> ; <m>0.0002</m>, and <m>0.02 \%</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The thickness of a book was measured to the nearest <m>0.02</m> cm as <m>8.0</m> cm. What is the percentage error? 
                </p>
            </statement>
            <answer>
                <p>
                    <m>0.125 \%</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                  An angle was measured to the nearest degree as <m>40^\circ</m>. Calculate:  
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                The maximum possible value of the stated angle.
                            </p>
                        </li>
                        <li>
                            <p>
                               The minimum possible value of the stated angle. 
                            </p>
                        </li>
                        <li>
                            <p>
                                The percentage error
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                              <m>40.5 ^\circ</m>  
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>39.5 ^\circ</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>1.25 \%</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
     </exercises>


