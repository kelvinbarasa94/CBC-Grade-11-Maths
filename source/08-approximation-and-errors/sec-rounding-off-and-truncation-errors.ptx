    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>   
                <p>
                    For each of the following numbers:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                Round off to <m>2</m> significant figures and calculate the percentage error.
                            </p>
                        </li>
                        <li>
                            <p>
                                Truncate off to <m>2</m> significant figures and calculate the percentage error.
                            </p>
                        </li>
                    </ol>
                </p>
                <p>
                    <ol marker="(i)">
                        <li>
                            <p>
                                <m>0.32</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>4.05</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>2.718</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>3.142</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>10.36</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m>395</m>
                            </p>
                        </li>
                    </ol>
                </p>
                        
            </statement>   
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                Rounding off
                            </p>
                            <p>
                                <ol marker="(i)">
                                    <li>
                                        <p>
                                            <m> 0.33</m> ; <m> 0.9 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 4.1</m> ; <m> 1.23 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 2.7</m> ; <m> 0.66 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 3.1</m> ; <m> 1.27 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 10</m> ; <m> 3.47 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 400</m> ; <m> 1.27 \%</m>
                                        </p>
                                    </li>
                                </ol>
                            </p>
                        </li>
                        <li>
                            <p>
                                Truncation
                            </p>
                            <p>
                                <ol marker="(i)">
                                    <li>
                                        <p>
                                            <m> 0.32</m> ; <m> 2.1 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 4.0</m> ; <m> 1.23 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 2.7</m> ; <m> 0.66 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 3.1</m> ; <m> 1.27 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 10</m> ; <m> 3.47 \%</m>
                                        </p>
                                    </li>
                                    <li>
                                        <p>
                                            <m> 390</m> ; <m> 1.27 \%</m>
                                        </p>
                                    </li>
                                </ol>
                            </p>
                        </li>
                    </ol>
                </p>



            </answer>             
        </exercise> 
        <exercise>
            <statement>
                <p>
                    The following numbers are rounded off to the degree of accuracy in brackets.
                </p>
                <p>
                    Find the upper and lower bounds:
                </p>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m> -186.00 (2 \;\text{d.p})</m>
                            </p> 
                        </li>
                        <li>
                            <p>
                                <m> 8,000 (\text{to the nearest} 100)</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> -43,000 (\text{to the nearest thousand})</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> 649.0 (\text{to the nearest} 0.1)</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p>
                    <ol marker="(a)">
                        <li>
                            <p>
                                <m> -186.005</m> and <m> -185.995</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> 7950</m> and <m> 8050</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> -43500</m> and <m> -42500</m>
                            </p>
                        </li>
                        <li>
                            <p>
                                <m> 693.95</m> and <m> 694.05</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>              
    </exercises>

    <!-- [LP] Add information on how to differentiate  -->

    <axiom component="lesson-plan">
        <title>Differentiation Strategies</title>

        <table>
            <title>Differentiation Framework for Approximation Errors</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        Provide printed number lines with pre-marked tick intervals to reduce the cognitive load of drawing scales. Guide through the tasks and emphasizing that the next digit is ignored during truncation while that value determines the direction of rounding.
                    </cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        Complete groups number line drawing task as mapped out in the main activity block, executing both the truncation and rounding off tasks, and calculating the respective absolute and percentage errors.
                    </cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        Task these learners by giving more challenging questions to discover more on error propagation. 
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

