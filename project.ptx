<!-- This file, the project manifest, provides the overall configuration for your PreTeXt project. To edit the content of your document, open `source/main.ptx`. See https://pretextbook.org/doc/guide/html/processing-CLI.html#cli-project-manifest. -->
<project ptx-version="2">
  <targets>
    <target name="web" format="html" publication="publication-teacher.ptx" deploy-dir="web">
        <stringparams html.js.extra="external/review-button.js" />
    </target>
    <target name="student" format="html" publication="publication-student.ptx" deploy-dir="student">
    </target>
    <target name="print" format="pdf" publication="publication-teacher-print.ptx">
    </target>
    <target name="latex" format="latex" publication="publication-teacher-print.ptx">
    </target>
    <target name="plans-print" format="pdf" publication="publication-plans-print.ptx">
    </target>
    <target name="plans" format="html" publication="publication-plans.ptx" deploy-dir="plans">
      <stringparams html.js.extra="external/print-button.js" />
    </target>
    <!-- For internal purposes, `pretext build ref` will create all the reference / open source materials, in the structure. Re-routes to a different source file to avoid any impact on the normal build -->
    <target name="ref" format="html" source="../reference/main-reference.ptx" publication="publication-reference.ptx"/> 
  </targets>
</project>


